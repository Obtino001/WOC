{% schema %}
{
  "name": "Science Tabs",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "CLEAN MY SOUL'un Arkasındaki Bilim" }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        { "type": "text", "id": "tab_title", "label": "Tab Name", "default": "Ultrasonik" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Ultrasonik Teknoloji" },
        { "type": "textarea", "id": "text", "label": "Text content" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [{ "name": "Science Tabs" }]
}
{% endschema %}

<section class="bg-neutral-50 border-y border-neutral-100 py-16 lg:py-24">
  <div class="container mx-auto px-4 max-w-5xl text-center mb-12">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 mx-auto mb-3 text-amber-500"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path></svg>
    <h2 class="text-3xl md:text-4xl font-light tracking-wider">{{ section.settings.title }}</h2>
  </div>

  <div class="container mx-auto px-4 max-w-5xl">
    <div class="grid grid-cols-{{ section.blocks.size }} bg-white border border-neutral-200 rounded-lg p-1 w-full gap-1">
      {% for block in section.blocks %}
        <button class="tab-button inline-flex items-center justify-center px-3 py-3 text-xs tracking-wider uppercase font-medium rounded-md transition-all {% if forloop.first %}bg-neutral-900 text-white{% else %}text-muted-foreground hover:bg-neutral-100{% endif %}" data-target="tab-{{ section.id }}-{{ forloop.index }}">
          {{ block.settings.tab_title }}
        </button>
      {% endfor %}
    </div>

    <div class="mt-8">
      {% for block in section.blocks %}
        <div id="tab-{{ section.id }}-{{ forloop.index }}" class="tab-content grid md:grid-cols-2 gap-8 items-center {% unless forloop.first %}hidden{% endunless %}">
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: 'rounded-lg w-full object-cover' }}
          {% else %}
             <div class="bg-neutral-200 w-full aspect-square rounded-lg"></div>
          {% endif %}
          <div>
            <h3 class="text-2xl font-light tracking-wider mb-4">{{ block.settings.heading }}</h3>
            <p class="text-sm text-neutral-600 leading-relaxed" style="font-family: system-ui, sans-serif">{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.tab-button').forEach(button => {
    button.addEventListener('click', () => {
      // Remove active states from buttons
      const section = button.closest('section');
      section.querySelectorAll('.tab-button').forEach(b => {
        b.classList.remove('bg-neutral-900', 'text-white');
        b.classList.add('text-muted-foreground');
      });
      // Add active state to clicked
      button.classList.add('bg-neutral-900', 'text-white');
      button.classList.remove('text-muted-foreground');

      // Hide all content
      section.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
      // Show target content
      document.getElementById(button.dataset.target).classList.remove('hidden');
    });
  });
</script>

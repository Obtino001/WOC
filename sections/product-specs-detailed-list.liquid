{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8 max-w-4xl">
    <div class="text-center mb-10">
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl md:text-4xl font-light text-foreground">{{ section.settings.heading }}</h2>
    </div>
    
    <div class="rounded-2xl border border-border/10 overflow-hidden bg-card">
      <div class="flex items-center gap-3 px-6 py-4 bg-gold/5 border-b border-border/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-ruler w-5 h-5 text-gold"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"></path><path d="m14.5 12.5 2-2"></path><path d="m11.5 9.5 2-2"></path><path d="m8.5 6.5 2-2"></path><path d="m17.5 15.5 2-2"></path></svg>
        <h4 class="font-display text-lg font-bold text-foreground">Specifications</h4>
      </div>
      <div class="divide-y divide-border/10">
        {% for block in section.blocks %}
          <div class="flex justify-between px-6 py-3 hover:bg-white/[0.02] transition-colors" {{ block.shopify_attributes }}>
            <span class="font-body text-sm text-muted-foreground font-medium">{{ block.settings.label }}</span>
            <span class="font-body text-sm text-foreground text-right">{{ block.settings.value }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Detailed Specs List",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 64 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Technical Details" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Specifications" }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Specification Row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "value", "label": "Value" }
      ]
    }
  ],
  "presets": [
    { "name": "Detailed Specs List" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    
    <div class="text-center mb-12">
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-foreground/50 mb-3">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl">{{ section.settings.heading }}</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-24">
      {% for block in section.blocks %}
        {% if block.type == 'mini_feature' %}
          <div class="rounded-2xl bg-foreground/5 border border-foreground/10 p-6 hover:bg-foreground/10 transition-colors" {{ block.shopify_attributes }}>
            <div class="w-12 h-12 rounded-xl bg-foreground/10 flex items-center justify-center mb-4 [&>svg]:w-6 [&>svg]:h-6 [&>svg]:text-foreground">
              {{ block.settings.icon_svg }}
            </div>
            <h3 class="font-display text-lg font-bold text-foreground mb-2">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-foreground/60 leading-relaxed">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="space-y-24">
      {% assign row_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'split_row' %}
          {% assign is_even = row_count | modulo: 2 %}
          <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16 {% if is_even == 1 %}lg:[direction:rtl]{% endif %}" {{ block.shopify_attributes }}>
            
            <div class="{% if is_even == 1 %}lg:[direction:ltr]{% endif %}">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-muted px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground mb-4">
                <div class="[&>svg]:w-3 [&>svg]:h-3">{{ block.settings.tag_icon }}</div>
                {{ block.settings.tag_text }}
              </span>
              <h2 class="mb-4 font-display text-2xl font-semibold text-foreground md:text-3xl">
                {{ block.settings.title }}
              </h2>
              <p class="mb-6 font-body text-base leading-relaxed text-foreground/60">
                {{ block.settings.description }}
              </p>
              <div class="inline-flex items-baseline gap-2 rounded-xl bg-foreground/10 border border-foreground/20 px-5 py-3">
                <span class="font-display text-2xl font-bold text-foreground">{{ block.settings.stat_value }}</span>
                <span class="font-body text-xs text-foreground/60">{{ block.settings.stat_label }}</span>
              </div>
            </div>
            
            <div class="overflow-hidden rounded-[2rem] border border-foreground/10 bg-foreground/5 shadow-soft">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'aspect-[4/3] w-full object-cover', loading: 'lazy' }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'aspect-[4/3] w-full object-cover bg-gray-800' }}
              {% endif %}
            </div>
            
          </div>
          {% assign row_count = row_count | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FP Feature Rows",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "FITNESS BENEFITS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Train smarter — not harder" }
  ],
  "blocks": [
    {
      "type": "mini_feature",
      "name": "Top Mini Feature",
      "limit": 3,
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    },
    {
      "type": "split_row",
      "name": "Split Row",
      "settings": [
        { "type": "html", "id": "tag_icon", "label": "Tag Icon SVG" },
        { "type": "text", "id": "tag_text", "label": "Tag Text" },
        { "type": "text", "id": "title", "label": "Heading" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "stat_value", "label": "Stat Value (e.g. 92%)" },
        { "type": "text", "id": "stat_label", "label": "Stat Label" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Feature Rows" }
  ]
}
{% endschema %}

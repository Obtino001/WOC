<section class="py-20 bg-charcoal border-y border-border relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 50% 50%, hsl(var(--gold)), transparent 60%);"></div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="luxury-line mx-auto mb-8"></div>
      {%- if section.settings.label != blank -%}
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">
          {{ section.settings.label }}
        </p>
      {%- endif -%}
      <h2 class="woc-display-font text-3xl md:text-4xl lg:text-5xl font-light text-foreground leading-[1.05]">
        {{ section.settings.title }}
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <div 
            class="relative p-8 rounded-2xl bg-[#0F0F0F] border border-border/10 group hover:border-gold/20 transition-all duration-500 hover:scale-[1.01]" 
            {{ block.shopify_attributes }}
          >
            <!-- Stat Badge (Top Right) -->
            {%- if block.settings.stat != blank -%}
              <div class="absolute top-6 right-6 text-right">
                <p class="woc-display-font text-3xl font-bold text-gold leading-none">{{ block.settings.stat }}</p>
                <p class="font-body text-[9px] uppercase tracking-widest text-muted-foreground mt-1">{{ block.settings.stat_label }}</p>
              </div>
            {%- endif -%}

            <!-- Icon -->
            <div class="w-14 h-14 rounded-xl bg-gold/10 flex items-center justify-center mb-6 group-hover:bg-gold/20 transition-all duration-500">
              <span class="text-gold shrink-0 flex items-center justify-center">
                {%- if block.settings.custom_icon_svg != blank -%}
                  {{ block.settings.custom_icon_svg }}
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'waves' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.5 0 2.5 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2c2.5 0 2.5 2 5 2s2.5-2 5-2c1.3 0 1.9.5 2.5 1M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2c2.5 0 2.5 2 5 2s2.5-2 5-2c1.3 0 1.9.5 2.5 1"/></svg>
                    {%- when 'flame' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                    {%- when 'brain' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3.02 3.02 0 0 1 0-3.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3.02 3.02 0 0 0 0-3.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2Z"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>
            </div>

            <!-- Title & Description -->
            <h3 class="woc-display-font text-xl font-medium text-foreground mb-3">{{ block.settings.title }}</h3>
            <p class="font-body text-xs font-light text-foreground/60 leading-relaxed">{{ block.settings.desc }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC Highlights Cards",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "INTELLIGENT WELLNESS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Massage. Heat. AI Intelligence."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Highlight Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Preset Icon",
          "options": [
            { "value": "waves", "label": "Wave Massage" },
            { "value": "flame", "label": "Soothing Heat" },
            { "value": "brain", "label": "AI microchip/Brain" }
          ],
          "default": "waves"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG XML code here to override the preset icon selection."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "7 Massage Presets"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Card Description",
          "default": "7 massagepreset modes that help your body relax and increase circulation."
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Stat Figure (e.g. 7, 12h, 24/7)",
          "default": "7"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Stat Label",
          "default": "Programs"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Highlights Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "waves",
            "title": "7 Massage Programmes",
            "desc": "4 full-body modes (Auto, Stretch, Wave, Cradle) plus 3 targeted zone modes for shoulders, lumbar, and legs.",
            "stat": "7",
            "stat_label": "Programs"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "flame",
            "title": "3-Level Soothing Heat",
            "desc": "Integrated heating with low, medium, and high settings. Timer up to 12 hours for overnight warmth and muscle relaxation.",
            "stat": "12h",
            "stat_label": "Heat Timer"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "brain",
            "title": "AI Sleep Tracking",
            "desc": "Via the companion app, monitor heart rate, breathing, movement, and sleep stages. Receive personalised sleep recommendations.",
            "stat": "24/7",
            "stat_label": "Monitoring"
          }
        }
      ]
    }
  ]
}
{% endschema %}

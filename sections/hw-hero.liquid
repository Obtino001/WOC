<section class="relative h-[calc(100vh-5rem)] min-h-[600px] flex items-end overflow-hidden">
  {% if section.settings.image != blank %}
    {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'absolute inset-0 w-full h-full object-cover object-center', loading: 'eager' }}
  {% else %}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover bg-gray-800' }}
  {% endif %}
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
  <div class="container mx-auto px-6 lg:px-12 relative z-10 pb-16 lg:pb-24">
    <div>
      <h1 class="font-display text-5xl md:text-6xl lg:text-8xl font-light text-white leading-[0.95]">
        {{ section.settings.heading | newline_to_br }}
      </h1>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HW Hero",
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Home Training &\n<span class=\"italic text-white/90\">Red Light</span>" }
  ],
  "presets": [
    { "name": "HW Hero" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-white section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 {{ section.settings.page_width | default: 'max-w-3xl' }} text-center">
    <div>
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="mx-auto">
        <path d="M24 4L26 20L24 22L22 20L24 4Z" fill="hsl(36 72% 45%)" opacity="0.8"></path>
        <path d="M24 44L22 28L24 26L26 28L24 44Z" fill="hsl(36 72% 45%)" opacity="0.8"></path>
        <path d="M4 24L20 22L22 24L20 26L4 24Z" fill="hsl(36 72% 45%)" opacity="0.8"></path>
        <path d="M44 24L28 26L26 24L28 22L44 24Z" fill="hsl(36 72% 45%)" opacity="0.8"></path>
        <path d="M10 10L21 19L20 21L18 20L10 10Z" fill="hsl(36 72% 45%)" opacity="0.5"></path>
        <path d="M38 38L27 29L28 27L30 28L38 38Z" fill="hsl(36 72% 45%)" opacity="0.5"></path>
        <path d="M38 10L29 21L27 20L28 18L38 10Z" fill="hsl(36 72% 45%)" opacity="0.5"></path>
        <path d="M10 38L19 27L21 28L20 30L10 38Z" fill="hsl(36 72% 45%)" opacity="0.5"></path>
      </svg>
      <p class="font-display text-xl md:text-2xl lg:text-[26px] font-light text-zinc-800 leading-[1.7] mt-10 max-w-2xl mx-auto italic">
        {{ section.settings.text }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SED Brand Intro",
  "settings": [
    { 
      "type": "select", 
      "id": "page_width", 
      "label": "Page Width", 
      "options": [
        { "value": "max-w-3xl", "label": "Small" },
        { "value": "max-w-4xl", "label": "Medium" },
        { "value": "max-w-6xl", "label": "Large" },
        { "value": "max-w-7xl", "label": "Extra Large" },
        { "value": "max-w-full", "label": "Full Width" }
      ],
      "default": "max-w-3xl" 
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 112 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 144 },
    { "type": "textarea", "id": "text", "label": "Text", "default": "For over a decade, Séduisante has redefined luxury skincare through pioneering devices and award-winning formulations, trusted in clinics and loved at home" }
  ],
  "presets": [
    { "name": "SED Brand Intro" }
  ]
}
{% endschema %}

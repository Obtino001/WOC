<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="woc-section-minimal">
    <nav
      aria-label="{{ section.settings.aria_label }}"
      class="container mx-auto px-4 lg:px-8"
      itemscope
      itemtype="https://schema.org/BreadcrumbList"
    >
      <ol class="flex flex-wrap items-center gap-1.5 font-body text-[11px] text-muted-foreground py-1">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="flex items-center gap-1.5">
          <a itemprop="item" class="flex items-center gap-1 hover:text-foreground transition-colors" href="{{ routes.root_url }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3" aria-hidden="true"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
            <span itemprop="name">{{ section.settings.home_label }}</span>
          </a>
          <meta itemprop="position" content="1">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-muted-foreground/50" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
        </li>

        {%- if section.settings.parent_label != blank and section.settings.parent_url != blank -%}
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="flex items-center gap-1.5">
            <a itemprop="item" class="hover:text-foreground transition-colors" href="{{ section.settings.parent_url }}">
              <span itemprop="name">{{ section.settings.parent_label }}</span>
            </a>
            <meta itemprop="position" content="2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-muted-foreground/50" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
          </li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="flex items-center">
            <span itemprop="name" class="text-foreground font-medium">{{ section.settings.current_label | default: page.title }}</span>
            <link itemprop="item" href="{{ request.path }}">
            <meta itemprop="position" content="3">
          </li>
        {%- else -%}
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="flex items-center">
            <span itemprop="name" class="text-foreground font-medium">{{ section.settings.current_label | default: page.title }}</span>
            <link itemprop="item" href="{{ request.path }}">
            <meta itemprop="position" content="2">
          </li>
        {%- endif -%}
      </ol>
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "İçerik Haritası"
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Ana Sayfa"
    },
    {
      "type": "text",
      "id": "parent_label",
      "label": "Parent page label (optional)"
    },
    {
      "type": "url",
      "id": "parent_url",
      "label": "Parent page URL (optional)"
    },
    {
      "type": "text",
      "id": "current_label",
      "label": "Current page label",
      "info": "Leave blank to use page title"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs"
    }
  ]
}
{% endschema %}

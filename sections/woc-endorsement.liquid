{% schema %}
{
  "name": "WOC Endorsement",
  "settings": [
    {
      "type": "text",
      "id": "pre_title",
      "label": "Pre-title",
      "default": "LÆGEFAGLIGT ANBEFALET"
    },
    {
      "type": "text",
      "id": "title_line1",
      "label": "Title Line 1",
      "default": "Din Ryg Fortjener"
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Title Line 2 (Gold Italic)",
      "default": "Ekspertise"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote Text",
      "default": "Som kiropraktor gennem 30 år kan jeg bekræfte, at World of Comfort's massagestole leverer en yderst effektiv, dybdegående og terapeutisk korrekt behandling. Den kunstige intelligens sikrer, at trykket tilpasses individuelt til rygsøjlen – præcis som ved en professionel behandling."
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Author Image"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "Dr. Carsten Rosendahl"
    },
    {
      "type": "text",
      "id": "author_title",
      "label": "Author Title",
      "default": "SPECIALLÆGE & KIROPRAKTOR"
    }
  ],
  "presets": [
    {
      "name": "WOC Endorsement"
    }
  ]
}
{% endschema %}

<section class="py-28 bg-[#151515] relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 30% 50%, #d8b261, transparent 60%)"></div>
  <div class="container max-w-4xl mx-auto px-4 lg:px-8 relative z-10 text-center">
    
    <div class="luxury-line mx-auto mb-8"></div>
    
    {%- if section.settings.pre_title != blank -%}
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.2em] text-gold mb-6">
        {{ section.settings.pre_title }}
      </p>
    {%- endif -%}

    <h2 class="woc-display-font text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-12 leading-[1.05]">
      {{ section.settings.title_line1 }}<br/>
      {%- if section.settings.title_line2 != blank -%}
        <span class="italic text-gold">{{ section.settings.title_line2 }}</span>
      {%- endif -%}
    </h2>

    <blockquote class="relative">
      <div class="woc-display-font text-8xl text-gold/10 absolute -top-8 left-1/2 -translate-x-1/2 select-none">"</div>
      <p class="woc-display-font text-xl md:text-2xl italic text-foreground/80 leading-relaxed max-w-3xl mx-auto pt-8">
        {{ section.settings.quote }}
      </p>
    </blockquote>

    <div class="mt-12 flex flex-col items-center gap-4">
      <div class="w-20 h-20 rounded-full overflow-hidden border-2 border-gold/30 shadow-[0_0_15px_rgba(216,178,97,0.3)]">
        {%- if section.settings.author_image != blank -%}
          <img src="{{ section.settings.author_image | image_url: width: 200 }}" alt="{{ section.settings.author_name }}" class="w-full h-full object-cover">
        {%- else -%}
          <div class="w-full h-full bg-white/10"></div>
        {%- endif -%}
      </div>
      <div>
        <p class="font-body text-sm font-semibold text-foreground">{{ section.settings.author_name }}</p>
        <p class="font-body text-[10px] uppercase tracking-[0.2em] text-foreground/60 mt-1">{{ section.settings.author_title }}</p>
      </div>
    </div>
    
  </div>
</section>

<section class="bg-white py-20">
  <div class="container mx-auto px-4 text-center">
    <p class="font-body text-[10px] font-medium uppercase tracking-[0.3em] text-zinc-500 mb-12">{{ section.settings.kicker }}</p>
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-10 max-w-5xl mx-auto">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 600 | image_tag: class: 'h-auto w-full max-w-[240px] md:max-w-[280px] object-contain', loading: 'lazy' }}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SED Awards",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "AWARD-WINNING PRODUCTS" }
  ],
  "blocks": [
    {
      "type": "award",
      "name": "Award Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Award Logo" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Awards" }
  ]
}
{% endschema %}

<section class="color-{{ section.settings.color_scheme }} gradient py-20">
  <div class="container mx-auto px-4 text-center">
    <p class="font-body text-[10px] font-medium uppercase tracking-[0.3em] text-muted-foreground mb-12">{{ section.settings.kicker }}</p>
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 max-w-4xl mx-auto">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 300 | image_tag: class: 'h-16 md:h-20 object-contain opacity-50 hover:opacity-100 transition-opacity duration-500', loading: 'lazy' }}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SED Awards",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "AWARD-WINNING PRODUCTS" }
  ],
  "blocks": [
    {
      "type": "award",
      "name": "Award Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Award Logo" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Awards" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-card border-b border-border section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">{{ section.settings.heading }}</h2>
    </div>
    <div class="grid md:grid-cols-{{ section.settings.columns }} gap-8">
      {% for block in section.blocks %}
        <div class="text-center" {{ block.shopify_attributes }}>
          <div class="overflow-hidden rounded-2xl border border-border bg-background mb-6 shadow-soft">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: class: 'aspect-[4/3] w-full object-cover', loading: 'lazy' }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'aspect-[4/3] w-full object-cover bg-gray-200' }}
            {% endif %}
          </div>
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-foreground text-background font-display text-lg font-bold">
            {{ forloop.index }}
          </div>
          <h3 class="font-display text-xl font-bold text-foreground mb-2">{{ block.settings.title }}</h3>
          <p class="font-body text-sm text-muted-foreground">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FP Step by Step",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How it works" },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Desktop Columns", "default": 3 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Step by Step" }
  ]
}
{% endschema %}
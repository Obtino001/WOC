{% schema %}
{
  "name": "WOC Trust Bar",
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {"value": "full", "label": "Full Width"},
        {"value": "standard", "label": "Standard Width"},
        {"value": "narrow", "label": "Narrow Width"}
      ],
      "default": "standard"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield Check" },
            { "value": "award", "label": "Award Medal" },
            { "value": "creditcard", "label": "Credit Card" }
          ],
          "default": "truck"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Gratis Levering"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Sub Label",
          "default": "Til alle adresser"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "label": "Gratis Levering", "sub": "I hele Skandinavien" } },
        { "type": "trust_item", "settings": { "icon": "shield", "label": "5 Års Garanti", "sub": "På alle modeller" } },
        { "type": "trust_item", "settings": { "icon": "award", "label": "Prisvindende", "sub": "Skandinavisk Design" } },
        { "type": "trust_item", "settings": { "icon": "creditcard", "label": "0% Rente", "sub": "Finansiering tilbydes" } }
      ]
    }
  ]
}
{% endschema %}

<section
  id="woc-trust-bar-{{ section.id }}"
  class="bg-charcoal border-y border-white/10 overflow-hidden transition-all duration-500"
  style="max-height: 200px; opacity: 1;"
>
  <div class="{% if section.settings.page_width == 'full' %}w-full{% elsif section.settings.page_width == 'narrow' %}max-w-[1000px] mx-auto{% else %}container mx-auto{% endif %} px-4 py-2 flex items-center gap-3">
    <div class="flex-1 min-w-0">
      <ul
        class="grid grid-cols-2 lg:grid-cols-4 gap-2"
        aria-label="Our security guarantees"
      >
        {%- for block in section.blocks -%}
          <li class="flex items-start gap-3 p-3 rounded-lg bg-white/5 border border-white/10" {{ block.shopify_attributes }}>
            <div class="w-9 h-9 rounded-full bg-gold/10 flex items-center justify-center shrink-0">
              {%- if block.settings.custom_icon_svg != blank -%}
                {{ block.settings.custom_icon_svg }}
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg>
                  {%- when 'shield' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
                  {%- when 'award' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                  {%- when 'creditcard' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>
            <div class="min-w-0">
              <p class="font-body text-xs font-semibold text-foreground leading-tight m-0">{{ block.settings.label }}</p>
              <p class="font-body text-[10px] text-foreground/60 mt-0.5 leading-tight m-0">{{ block.settings.sub }}</p>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <button
      type="button"
      aria-label="Hide"
      id="woc-trust-bar-close-{{ section.id }}"
      class="shrink-0 w-7 h-7 rounded-full hover:bg-white/10 flex items-center justify-center text-foreground/50 hover:text-foreground transition-colors duration-200"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>
</section>

<script>
  (function() {
    var STORAGE_KEY = 'woc-trust-bar-dismissed-{{ section.id }}';
    var bar = document.getElementById('woc-trust-bar-{{ section.id }}');
    var btn = document.getElementById('woc-trust-bar-close-{{ section.id }}');

    // Hide immediately if already dismissed this session
    if (sessionStorage.getItem(STORAGE_KEY)) {
      bar.style.maxHeight = '0';
      bar.style.opacity = '0';
      bar.style.paddingTop = '0';
      bar.style.paddingBottom = '0';
      bar.style.borderWidth = '0';
    }

    if (btn) {
      btn.addEventListener('click', function() {
        bar.style.transition = 'max-height 0.4s ease, opacity 0.3s ease, padding 0.4s ease, border-width 0.4s ease';
        bar.style.maxHeight = '0';
        bar.style.opacity = '0';
        bar.style.paddingTop = '0';
        bar.style.paddingBottom = '0';
        bar.style.borderWidth = '0';
        sessionStorage.setItem(STORAGE_KEY, '1');
      });
    }
  })();
</script>

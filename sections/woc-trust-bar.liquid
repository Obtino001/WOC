{% schema %}
{
  "name": "WOC Trust Bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield Check" },
            { "value": "award", "label": "Award Medal" },
            { "value": "creditcard", "label": "Credit Card" }
          ],
          "default": "truck"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Gratis Levering"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Sub Label",
          "default": "Til alle adresser"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "label": "Gratis Levering", "sub": "I hele Skandinavien" } },
        { "type": "trust_item", "settings": { "icon": "shield", "label": "5 Års Garanti", "sub": "På alle modeller" } },
        { "type": "trust_item", "settings": { "icon": "award", "label": "Prisvindende", "sub": "Skandinavisk Design" } },
        { "type": "trust_item", "settings": { "icon": "creditcard", "label": "0% Rente", "sub": "Finansiering tilbydes" } }
      ]
    }
  ]
}
{% endschema %}

<section class="bg-charcoal border-y border-white/10">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-white/10">
      {%- for block in section.blocks -%}
        <div class="flex items-center gap-3 py-5 px-4 justify-center" {{ block.shopify_attributes }}>
          <span class="text-gold shrink-0">
            {%- if block.settings.custom_icon_svg != blank -%}
              {{ block.settings.custom_icon_svg }}
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'truck' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                {%- when 'shield' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 11 2 2 4-4"></path></svg>
                {%- when 'award' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                {%- when 'creditcard' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
              {%- endcase -%}
            {%- endif -%}
          </span>
          <div>
            <p class="font-body text-xs font-semibold text-foreground m-0">{{ block.settings.label }}</p>
            <p class="font-body text-[10px] text-foreground/60 m-0">{{ block.settings.sub }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

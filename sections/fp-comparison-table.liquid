{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.product != blank -%}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    
    <div class="text-center mb-16">
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl lg:text-5xl mb-5">{{ section.settings.heading }}</h2>
      <p class="font-body text-base text-muted-foreground max-w-3xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 mb-20">
      
      <div>
        <div class="rounded-[2rem] border border-destructive/20 bg-destructive/5 p-8 md:p-10 h-full">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-destructive/10 flex items-center justify-center">
              <span class="text-destructive text-lg font-bold">✕</span>
            </div>
            <h3 class="font-display text-xl font-bold text-foreground">{{ section.settings.bad_title }}</h3>
          </div>
          <div class="space-y-4">
            {% for block in section.blocks %}
              {% if block.type == 'bad_point' %}
                <div class="flex gap-3" {{ block.shopify_attributes }}>
                  <span class="text-destructive mt-0.5 shrink-0">✕</span>
                  <div>
                    <p class="font-body text-sm font-bold text-foreground">{{ block.settings.title }}</p>
                    <p class="font-body text-xs text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div>
        <div class="rounded-[2rem] border border-green-500/20 bg-green-500/5 p-8 md:p-10 h-full">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-green-500/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check text-green-500 w-5 h-5"><path d="M20 6 9 17l-5-5"></path></svg>
            </div>
            <h3 class="font-display text-xl font-bold text-foreground">{{ section.settings.good_title }}</h3>
          </div>
          <div class="space-y-4">
            {% for block in section.blocks %}
              {% if block.type == 'good_point' %}
                <div class="flex gap-3" {{ block.shopify_attributes }}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check text-green-500 mt-0.5 w-4 h-4 shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                  <div>
                    <p class="font-body text-sm font-bold text-foreground">{{ block.settings.title }}</p>
                    <p class="font-body text-xs text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      
    </div>

    <div class="rounded-[2rem] border border-border bg-card p-8 md:p-12 text-center shadow-soft">
      <h3 class="font-display text-2xl font-semibold text-foreground md:text-3xl mb-5">{{ section.settings.summary_heading }}</h3>
      <div class="font-body text-base text-muted-foreground leading-relaxed max-w-3xl mx-auto mb-8 space-y-4">
        {{ section.settings.summary_text }}
      </div>
      
      <div class="flex justify-center">
        {%- if section.settings.product != blank -%}
          {%- assign product = section.settings.product -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          {%- assign product_form_id = 'product-form-' | append: section.id -%}
          <product-form>
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}" disabled>
              <button type="submit" name="add" class="inline-flex items-center justify-center gap-2 rounded-full bg-foreground px-10 py-4 font-body text-sm font-semibold uppercase tracking-[0.18em] text-background transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
                {% if current_variant.available == false %}disabled{% endif %}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-bag h-4 w-4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                {%- if current_variant.available -%}
                  {{ section.settings.btn_text | default: 'Invest in your health' }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t | default: 'Udsolgt' }}
                {%- endif -%}
              </button>
            {%- endform -%}
          </product-form>
        {%- else -%}
          <button class="inline-flex items-center justify-center gap-2 rounded-full bg-foreground px-10 py-4 font-body text-sm font-semibold uppercase tracking-[0.18em] text-background transition-opacity hover:opacity-90">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-bag h-4 w-4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            {{ section.settings.btn_text }}
          </button>
        {%- endif -%}
      </div>
    </div>

    <div class="mt-16 overflow-hidden rounded-[1.5rem] border border-border bg-card">
      <div class="grid grid-cols-[1fr_auto_auto] border-b border-border bg-muted px-6 py-4">
        <span class="font-body text-xs font-semibold uppercase tracking-wider text-muted-foreground">Specification</span>
        <span class="w-32 text-center font-body text-xs font-bold uppercase tracking-wider text-foreground">FitnessPlate XD</span>
        <span class="w-32 text-center font-body text-xs font-semibold uppercase tracking-wider text-muted-foreground">Cheap 2D plates</span>
      </div>
      
      {% for block in section.blocks %}
        {% if block.type == 'table_row' %}
          <div class="grid grid-cols-[1fr_auto_auto] items-center px-6 py-3.5 border-b border-border last:border-b-0" {{ block.shopify_attributes }}>
            <span class="font-body text-sm text-foreground">{{ block.settings.spec_name }}</span>
            <span class="w-32 text-center font-body text-xs font-bold text-green-500">{{ block.settings.good_val }}</span>
            <span class="w-32 text-center font-body text-xs text-muted-foreground">{{ block.settings.bad_val }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "FP Comparison Table",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 },
    { "type": "product", "id": "product", "label": "Select Product (Enables Add to Cart)" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "THE IMPORTANT DIFFERENCE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Cheap vibration plates don't deliver results" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "text", "id": "bad_title", "label": "Bad Card Title", "default": "Cheap 2D plates (£50-£200)" },
    { "type": "text", "id": "good_title", "label": "Good Card Title", "default": "FitnessPlate XD (£825)" },
    { "type": "text", "id": "summary_heading", "label": "Summary Box Heading", "default": "The bottom line: technology determines the result" },
    { "type": "richtext", "id": "summary_text", "label": "Summary Box Text" },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Invest in your health — £825" }
  ],
  "blocks": [
    {
      "type": "bad_point",
      "name": "Bad Point",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    },
    {
      "type": "good_point",
      "name": "Good Point",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    },
    {
      "type": "table_row",
      "name": "Table Row",
      "settings": [
        { "type": "text", "id": "spec_name", "label": "Specification Name" },
        { "type": "text", "id": "good_val", "label": "FitnessPlate Value" },
        { "type": "text", "id": "bad_val", "label": "Cheap Plate Value" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Comparison Table" }
  ]
}
{% endschema %}

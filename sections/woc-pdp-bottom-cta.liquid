<section class="color-{{ section.settings.color_scheme }} gradient py-24 bg-charcoal border-t border-border relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 50% 50%, hsl(var(--gold)), transparent 60%);"></div>

  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <div class="max-w-2xl mx-auto">
      <div class="luxury-line mx-auto mb-8"></div>
      
      <!-- Heading -->
      <h2 class="woc-display-font text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-6 leading-[1.05]">
        {{ section.settings.title | replace: '[product]', product.title }}
      </h2>
      
      <!-- Description -->
      {%- if section.settings.description != blank -%}
        <p class="font-body text-sm text-muted-foreground mb-10 max-w-md mx-auto leading-relaxed">
          {{ section.settings.description }}
        </p>
      {%- endif -%}

      <!-- Product Form / CTA Actions -->
      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- form 'product', product, id: 'product-form-bottom-cta', class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          
          <!-- Buy Now Button -->
          <button 
            type="submit" 
            name="add" 
            {% unless current_variant.available %}disabled{% endunless %}
            class="w-full sm:w-auto px-8 py-4 rounded-full bg-gold hover:bg-gold/90 text-background font-body text-sm font-semibold tracking-wide transition-all duration-300 shadow-lg hover:shadow-gold/20 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-gold"
          >
            {%- if section.settings.buy_icon_svg != blank -%}
              {{ section.settings.buy_icon_svg }}
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            {%- endif -%}
            {%- if current_variant.available -%}
              {{ section.settings.buy_now_text }} — {{ product.price | money }}
            {%- else -%}
              Udsolgt
            {%- endif -%}
          </button>

          <!-- Secondary Gösterim rezervasyonu yapın Button -->
          {%- if section.settings.show_demo_button -%}
            <a 
              href="{{ section.settings.demo_link }}" 
              class="w-full sm:w-auto px-8 py-4 rounded-full border border-border hover:border-gold/30 text-foreground font-body text-sm font-semibold tracking-wide transition-all duration-300 hover:bg-white/[0.02] flex items-center justify-center gap-2"
            >
              {%- if section.settings.demo_icon_svg != blank -%}
                {{ section.settings.demo_icon_svg }}
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {%- endif -%}
              {{ section.settings.demo_text }}
            </a>
          {%- endif -%}

        </div>
      {%- endform -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC PDP Bottom CTA",
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {"value": "full", "label": "Full Width"},
        {"value": "standard", "label": "Standard Width"},
        {"value": "narrow", "label": "Narrow Width"}
      ],
      "default": "standard"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "CTA Title",
      "default": "Klar til at opleve [product]?",
      "info": "Use '[product]' to dynamically insert the active product name."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "CTA Description",
      "default": "Besøg et showroom for en personlig demonstration eller bestil online med gratis levering."
    },
    {
      "type": "text",
      "id": "buy_now_text",
      "label": "Buy Now Button Text",
      "default": "Køb nu"
    },
    {
      "type": "checkbox",
      "id": "show_demo_button",
      "label": "Show Demo Button",
      "default": true
    },
    {
      "type": "text",
      "id": "demo_text",
      "label": "Demo Button Text",
      "default": "Gösterim rezervasyonu yapın"
    },
    {
      "type": "url",
      "id": "demo_link",
      "label": "Demo Button Link"
    },
    {
      "type": "html",
      "id": "buy_icon_svg",
      "label": "Buy Now SVG Icon"
    },
    {
      "type": "html",
      "id": "demo_icon_svg",
      "label": "Demo SVG Icon"
    }
  ],
  "presets": [
    {
      "name": "WOC PDP Bottom CTA"
    }
  ]
}
{% endschema %}

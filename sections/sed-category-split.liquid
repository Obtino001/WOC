<section class="color-{{ section.settings.color_scheme }} gradient py-10">
  <div class="grid md:grid-cols-2">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="relative group overflow-hidden aspect-[4/3] bg-[#c8b9a8]" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover object-top transition-transform duration-[2s] group-hover:scale-105', loading: 'lazy' }}
        {% else %}
          {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105' }}
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent group-hover:from-black/60 transition-colors duration-500"></div>
        <div class="absolute bottom-8 left-8">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-white"></span>
            <span class="font-body text-[11px] uppercase tracking-[0.2em] text-white">{{ block.settings.subtitle }}</span>
          </div>
          <p class="font-display text-xl md:text-2xl font-light text-white uppercase tracking-[0.1em]">{{ block.settings.title }}</p>
          <p class="font-body text-[11px] uppercase tracking-[0.2em] text-white/70 mt-2 flex items-center gap-1">
            {{ block.settings.link_text }}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </p>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "SED Category Split",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Banner",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "link_text", "label": "Link Text" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Category Split" }
  ]
}
{% endschema %}

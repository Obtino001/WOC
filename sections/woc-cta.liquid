<section class="woc-section-py" style="background: rgb(248, 245, 238);">
  <div class="container mx-auto px-4 lg:px-8 max-w-4xl text-center">
    <div>
      <h2 class="font-display text-3xl md:text-5xl font-bold leading-tight mb-6" style="color: rgb(15, 31, 46);">{{ section.settings.title }}</h2>
      <p class="font-body text-lg text-neutral-600 max-w-2xl mx-auto mb-10">{{ section.settings.description }}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 bg-primary hover:bg-primary/90 font-body text-sm font-semibold px-8 py-6 h-auto rounded-full uppercase tracking-wider text-white" href="{{ section.settings.btn_1_url }}" style="background: rgb(14, 92, 92);">
          {{ section.settings.btn_1_text }} <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 border border-input bg-background hover:bg-accent hover:text-accent-foreground font-body text-sm font-semibold px-8 py-6 h-auto rounded-full uppercase tracking-wider" href="{{ section.settings.btn_2_url }}" style="border-color: rgb(15, 31, 46); color: rgb(15, 31, 46);">
          {{ section.settings.btn_2_text }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC CTA",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "WOC yöntemini uygulamaya hazır mısınız?" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Bağlayıcı olmayan bir demo ayırtın; yöntemin şirketinizde nasıl uygulanabileceğini..." },
    { "type": "text", "id": "btn_1_text", "label": "Button 1 Text", "default": "Demo ayırtın" },
    { "type": "url", "id": "btn_1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "btn_2_text", "label": "Button 2 Text", "default": "ROI hesapla" },
    { "type": "url", "id": "btn_2_url", "label": "Button 2 URL" }
  ],
  "presets": [{ "name": "WOC CTA" }]
}
{% endschema %}

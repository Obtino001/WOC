<section id="testimonials" class="color-{{ section.settings.color_scheme }} gradient py-24">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border/20">
      {% for block in section.blocks %}
        <div class="bg-card p-8 md:p-10" {{ block.shopify_attributes }}>
          <div class="flex items-center gap-0.5 mb-5">
            {% for i in (1..5) %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-star w-3 h-3 fill-amber-400 text-amber-400"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            {% endfor %}
          </div>
          <p class="font-body text-xs font-light text-foreground/80 leading-[1.8] mb-4 italic line-clamp-4">"{{ block.settings.quote }}"</p>
          <div>
            <p class="font-display text-xs font-medium text-foreground">{{ block.settings.author }}</p>
            <p class="font-body text-[9px] uppercase tracking-luxury text-muted-foreground">{{ block.settings.product }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SED Testimonials Grid",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author" },
        { "type": "text", "id": "product", "label": "Product Reference" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Testimonials Grid" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient overflow-hidden section-{{ section.id }}-padding">
  {% if section.settings.heading != blank %}
    <div class="container mx-auto px-4 lg:px-8 text-center mb-10">
      <h2 class="font-display text-2xl md:text-4xl font-light text-foreground">
        {{ section.settings.heading }}
      </h2>
    </div>
  {% endif %}
  
  <div class="relative">
    <div class="flex animate-marquee gap-8 whitespace-nowrap" style="animation-duration: {{ section.settings.speed }}s;">
      {%- for i in (1..3) -%}
        {%- for block in section.blocks -%}
          <span class="font-display text-lg md:text-xl text-muted-foreground/40 flex items-center gap-4" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
            <span class="text-gold">—</span>
          </span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Text Marquee",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 64 },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Ultimate Comfort,<br><span class=\"italic text-gold\">Beyond Comparison</span>" },
    { "type": "range", "id": "speed", "min": 10, "max": 100, "step": 5, "unit": "sec", "label": "Animation Speed", "default": 30 }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Marquee Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Product Text Marquee" }
  ]
}
{% endschema %}

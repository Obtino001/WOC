{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient gradient-dark section-{{ section.id }}-padding">
  <div class="{% if section.settings.page_width == 'full' %}w-full{% elsif section.settings.page_width == 'narrow' %}max-w-[1000px] mx-auto{% else %}container{% endif %} mx-auto px-4 lg:px-8 max-w-4xl">
    <div class="text-center">
      <div class="luxury-line mx-auto mb-8"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl md:text-4xl font-light text-foreground mb-6 leading-[1.05]">
        {{ section.settings.heading | newline_to_br }}
      </h2>
      <p class="font-body text-sm text-muted-foreground mb-12 max-w-lg mx-auto leading-relaxed">
        {{ section.settings.description }}
      </p>
    </div>
    
    <div class="grid sm:grid-cols-3 gap-6">
      {% for block in section.blocks %}
        <div class="bg-card border border-border p-8 text-center hover:border-gold/30 transition-colors group" {{ block.shopify_attributes }}>
          <p class="font-body text-xs uppercase tracking-luxury text-gold mb-4">{{ block.settings.title }}</p>
          <p class="font-display text-3xl font-bold text-foreground mb-2">
            {{ block.settings.price }}
            {% if block.settings.price_suffix != blank %}
              <span class="font-body text-sm font-normal text-muted-foreground">{{ block.settings.price_suffix }}</span>
            {% endif %}
          </p>
          <p class="font-body text-xs text-muted-foreground">{{ block.settings.subtitle }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Flexible Pricing Plans",
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {"value": "full", "label": "Full Width"},
        {"value": "standard", "label": "Standard Width"},
        {"value": "narrow", "label": "Narrow Width"}
      ],
      "default": "standard"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Flexible Payment" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Invest in Your <span class=\"italic text-gold\">Wellbeing</span>" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Make wellness accessible with our flexible financing options. Start your wellness journey today." }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Pricing Plan",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Title (e.g. 24 Months)" },
        { "type": "text", "id": "price", "label": "Price (e.g. £275)" },
        { "type": "text", "id": "price_suffix", "label": "Price Suffix (e.g. /md.)" },
        { "type": "text", "id": "subtitle", "label": "Subtitle (e.g. 0% down payment)" }
      ]
    }
  ],
  "presets": [
    { "name": "Flexible Pricing Plans" }
  ]
}
{% endschema %}

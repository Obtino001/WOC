{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient border-y border-neutral-100 section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-1 mb-3">
        {% for i in (1..5) %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-star w-5 h-5 fill-amber-400 text-amber-400"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
        {% endfor %}
      </div>
      <p class="text-sm text-muted-foreground mb-2" style="font-family: system-ui, sans-serif;">{{ section.settings.rating_text }}</p>
      <h2 class="text-3xl md:text-4xl font-light tracking-wider">{{ section.settings.heading }}</h2>
    </div>

    <div class="overflow-hidden py-6">
      <div class="flex gap-6 overflow-x-auto scrollbar-hide snap-x px-4 pb-4">
        {% for block in section.blocks %}
          <div class="flex-shrink-0 w-[300px] bg-card rounded-none p-6 border border-border shadow-sm snap-center" {{ block.shopify_attributes }}>
            <div class="flex items-center gap-1 mb-3">
              {% for i in (1..5) %}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-star w-3.5 h-3.5 fill-amber-400 text-amber-400"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              {% endfor %}
            </div>
            <p class="text-sm text-foreground/80 mb-3 italic leading-relaxed" style="font-family: system-ui, sans-serif;">
              "{{ block.settings.quote }}"
            </p>
            <p class="text-xs font-semibold tracking-wider uppercase text-foreground" style="font-family: system-ui, sans-serif;">
              {{ block.settings.author }}
            </p>
          </div>
        {% endfor %}
      </div>
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "SED Reviews Horizontal",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 },
    { "type": "text", "id": "rating_text", "label": "Rating Subtitle", "default": "4.7 out of 5" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We Have Many Happy Customers!" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author Name" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Reviews Horizontal" }
  ]
}
{% endschema %}

<section class="woc-section-py bg-[#0a0a0a] text-[#e5e5e5]" id="woc-product-configurator-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="container mx-auto px-4 lg:px-8">
    
    <!-- Top Header -->
    <div class="text-center mb-12">
      <p class="font-body text-sm uppercase tracking-[0.25em] text-[#d4af37] mb-4">{{ section.settings.subtitle }}</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white">{{ section.settings.title }}</h2>
    </div>
    
    <!-- 3 Bed Type Cards (Tabs) -->
    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto mb-16">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
          {% assign product = block.settings.product_ref %}
          
          <button type="button" 
                  class="woc-card-selector relative group rounded-2xl overflow-hidden border-2 transition-all duration-500 text-left flex flex-col {% if forloop.first %}border-[#d4af37] shadow-[0_0_40px_rgba(212,175,55,0.15)] scale-[1.02] is-active{% else %}border-[#333] hover:border-[#d4af37]/40{% endif %}" 
                  data-target-id="{{ block.id }}"
                  {{ block.shopify_attributes }}>
            
            {% if block.settings.badge != blank %}
              <div class="absolute top-4 left-4 z-10">
                <span class="woc-card-badge font-body text-[10px] font-semibold uppercase tracking-[0.15em] px-3 py-1.5 rounded-full backdrop-blur-md {% if forloop.first %}bg-[#d4af37] text-black{% else %}bg-black/70 text-[#d4af37] border border-[#d4af37]/30{% endif %}">
                  {{ block.settings.badge }}
                </span>
              </div>
            {% endif %}
            
            <div class="woc-card-checkmark absolute top-4 right-4 z-10 w-8 h-8 rounded-full bg-[#d4af37] flex items-center justify-center" style="display: {% if forloop.first %}flex{% else %}none{% endif %};">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-black"><path d="M20 6 9 17l-5-5"></path></svg>
            </div>
            
            <div class="aspect-[4/3] overflow-hidden relative bg-[#111]">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105' }}
              {% elsif product != blank and product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105' }}
              {% else %}
                 <div class="w-full h-full flex items-center justify-center text-[#555]">Görsel Yok</div>
              {% endif %}
              <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-transparent to-transparent opacity-90"></div>
            </div>
            
            <div class="p-6 bg-[#111] flex-1 flex flex-col justify-between">
              <div>
                <h3 class="font-display text-xl font-bold text-white mb-1.5">
                  {% if block.settings.title != blank %}{{ block.settings.title }}{% elsif product != blank %}{{ product.title }}{% else %}Ürün Adı{% endif %}
                </h3>
                <p class="font-body text-sm text-[#888] mb-4 italic">{{ block.settings.description }}</p>
              </div>
              <div class="flex items-end justify-between">
                <div>
                  <p class="font-body text-[10px] uppercase tracking-widest text-[#666] mb-0.5">{{ section.settings.from_text }}</p>
                  <p class="font-display text-2xl font-bold text-[#d4af37]">
                    {% if product != blank %}{{ product.price | money }}{% else %}{{ block.settings.price }}{% endif %}
                  </p>
                </div>
                <div class="woc-card-btn flex items-center gap-1.5 font-body text-xs font-medium transition-colors {% if forloop.first %}text-[#d4af37]{% else %}text-[#888] group-hover:text-[#d4af37]{% endif %}">
                  {{ section.settings.configure_text }} 
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="m9 18 6-6-6-6"></path></svg>
                </div>
              </div>
            </div>
            <div class="woc-card-highlight h-1 w-full bg-gradient-to-r from-[#d4af37]/0 via-[#d4af37] to-[#d4af37]/0" style="display: {% if forloop.first %}block{% else %}none{% endif %};"></div>
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Main Configurator Area (Dynamic Bottom Section) -->
    <div class="max-w-6xl mx-auto">
      
      <div id="woc-configurator-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'product_card' %}
            {% assign product = block.settings.product_ref %}
            
            <div class="woc-configurator-panel {% if forloop.first %}grid{% else %}hidden{% endif %} lg:grid-cols-2 gap-12" data-panel-id="{{ block.id }}">
              
              <!-- Configurator Left (Gallery & Title) -->
              <div>
                <!-- Image Gallery Main -->
                <div class="relative rounded-xl overflow-hidden mb-3 bg-[#111] aspect-[4/3] border border-[#222] flex items-center justify-center">
                  {% if product != blank and product.featured_image %}
                    {{ product.featured_image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover' }}
                  {% elsif block.settings.image != blank %}
                     {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover' }}
                  {% else %}
                    <h2 class="font-display text-2xl text-[#555] font-bold">Görsel Yok</h2>
                  {% endif %}
                </div>
                
                <!-- Gallery Thumbnails (Optional: Loop through real product images) -->
                {% if product != blank and product.images.size > 1 %}
                  <div class="flex gap-2 mb-8 overflow-x-auto pb-2">
                    {% for image in product.images limit: 4 %}
                      <button class="flex-shrink-0 w-20 h-16 rounded-none bg-[#111] border {% if forloop.first %}border-[#d4af37]{% else %}border-[#333] hover:border-[#666]{% endif %} transition-colors overflow-hidden">
                        {{ image | image_url: width: 150 | image_tag: class: 'w-full h-full object-cover' }}
                      </button>
                    {% endfor %}
                  </div>
                {% endif %}

                <div class="mt-8">
                   <h3 class="font-display text-2xl font-bold text-white mb-2">
                     {% if block.settings.title != blank %}{{ block.settings.title }}{% elsif product != blank %}{{ product.title }}{% else %}Ürün Adı{% endif %}
                   </h3>
                   <p class="font-body text-[#888] text-sm leading-relaxed mb-4">
                     {% if product != blank %}{{ product.description | strip_html | truncatewords: 30 }}{% else %}{{ block.settings.description }}{% endif %}
                   </p>
                </div>
              </div>

              <!-- Configurator Right (Form & Price) -->
              <div class="bg-[#0f0f0f] rounded-xl border border-[#222] p-6 lg:p-8">
                
                <!-- Price -->
                <div class="flex items-baseline justify-between mb-6">
                  <div>
                    <p class="font-body text-[10px] uppercase tracking-widest text-[#888] mb-1">DİN PRİS</p>
                    <p class="font-display text-3xl font-bold text-[#d4af37] tracking-tight">
                      {% if product != blank %}{{ product.price | money }}{% else %}{{ block.settings.price }}{% endif %}
                    </p>
                  </div>
                  <p class="font-body text-xs text-[#888]">{{ section.settings.installment_text }}</p>
                </div>
                
                <!-- Promo Line -->
                <div class="border border-[#d4af37]/30 rounded-none h-12 mb-6 flex items-center justify-center">
                   <span class="text-[#d4af37] font-body text-xs font-semibold uppercase tracking-widest">Yatak Başlığı ve Ped Yatak Dahil</span>
                </div>
                
                <div class="shrink-0 bg-[#222] h-[1px] w-full mb-6"></div>
                
                <!-- Dummy Selectors (Size, Hardness, Color) -->
                <div class="mb-6">
                  <p class="font-body text-[10px] uppercase tracking-widest text-[#888] mb-3">STØRRELSE</p>
                  <div class="flex flex-wrap gap-2">
                    <button class="px-5 py-2 rounded-none border border-[#333] bg-transparent text-[#aaa] font-body text-xs hover:border-[#555] transition-colors">80×200</button>
                    <button class="px-5 py-2 rounded-none border border-[#d4af37] bg-[#1a1a1a] text-[#ddd] font-body text-xs">90×200</button>
                    <button class="px-5 py-2 rounded-none border border-[#333] bg-transparent text-[#aaa] font-body text-xs hover:border-[#555] transition-colors">120×200</button>
                  </div>
                </div>
                
                <div class="mb-6">
                  <p class="font-body text-[10px] uppercase tracking-widest text-[#888] mb-3">HÅRDHED</p>
                  <div class="space-y-2">
                    <button class="w-full text-left px-4 py-3 rounded-none border border-[#d4af37] bg-[#1a1a1a] text-[#ddd] font-body text-xs">Medium — anbefales til person u. 75 kg</button>
                    <button class="w-full text-left px-4 py-3 rounded-none border border-[#333] bg-transparent text-[#aaa] font-body text-xs hover:border-[#555] transition-colors">Fast — anbefales til person o. 95 kg</button>
                  </div>
                </div>

                <!-- ADD TO CART FORM -->
                {% if product != blank %}
                  {% form 'product', product %}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <div class="flex flex-col gap-3 mt-8">
                      <button type="submit" class="w-full flex items-center justify-center h-12 rounded-none bg-[#d4af37] hover:bg-[#d4af37]/90 text-black font-body text-sm font-bold uppercase tracking-wider transition-colors">
                        Sepete Ekle
                      </button>
                      <button type="button" class="w-full flex items-center justify-center gap-2 h-12 rounded-none bg-transparent border border-[#d4af37] text-[#d4af37] hover:bg-[#d4af37]/10 font-body text-sm font-bold uppercase tracking-wider transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                        Gösterim Rezervasyonu Yapın
                      </button>
                    </div>
                  {% endform %}
                {% else %}
                  <div class="flex flex-col gap-3 mt-8">
                    <button type="button" class="w-full flex items-center justify-center h-12 rounded-none bg-[#d4af37] hover:bg-[#d4af37]/90 text-black font-body text-sm font-bold uppercase tracking-wider transition-colors">
                      Yapılandır & Satın Al
                    </button>
                    <button type="button" class="w-full flex items-center justify-center gap-2 h-12 rounded-none bg-transparent border border-[#d4af37] text-[#d4af37] hover:bg-[#d4af37]/10 font-body text-sm font-bold uppercase tracking-wider transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                      Gösterim Rezervasyonu Yapın
                    </button>
                  </div>
                {% endif %}

              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

    </div>
  </div>
</section>

<script>
  function initWocConfigurator() {
    const selectors = document.querySelectorAll('#woc-product-configurator-{{ section.id }} .woc-card-selector');
    const panels = document.querySelectorAll('#woc-product-configurator-{{ section.id }} .woc-configurator-panel');

    if (!selectors.length || !panels.length) return;

    selectors.forEach(selector => {
      // Remove old listeners to prevent duplicates in Theme Editor
      const newSelector = selector.cloneNode(true);
      selector.parentNode.replaceChild(newSelector, selector);
      
      newSelector.addEventListener('click', function() {
        // 1. Reset all cards
        document.querySelectorAll('#woc-product-configurator-{{ section.id }} .woc-card-selector').forEach(s => {
          s.classList.remove('border-[#d4af37]', 'shadow-[0_0_40px_rgba(212,175,55,0.15)]', 'scale-[1.02]', 'is-active');
          s.classList.add('border-[#333]');
          
          const badge = s.querySelector('.woc-card-badge');
          if(badge) {
            badge.classList.remove('bg-[#d4af37]', 'text-black');
            badge.classList.add('bg-black/70', 'text-[#d4af37]', 'border', 'border-[#d4af37]/30');
          }
          
          const checkmark = s.querySelector('.woc-card-checkmark');
          if(checkmark) checkmark.style.display = 'none';

          const highlight = s.querySelector('.woc-card-highlight');
          if(highlight) highlight.style.display = 'none';

          const btnText = s.querySelector('.woc-card-btn');
          if(btnText) {
             btnText.classList.remove('text-[#d4af37]');
             btnText.classList.add('text-[#888]');
          }
        });

        // 2. Highlight clicked card
        this.classList.remove('border-[#333]');
        this.classList.add('border-[#d4af37]', 'shadow-[0_0_40px_rgba(212,175,55,0.15)]', 'scale-[1.02]', 'is-active');
        
        const badge = this.querySelector('.woc-card-badge');
        if(badge) {
          badge.classList.remove('bg-black/70', 'text-[#d4af37]', 'border', 'border-[#d4af37]/30');
          badge.classList.add('bg-[#d4af37]', 'text-black');
        }

        const checkmark = this.querySelector('.woc-card-checkmark');
        if(checkmark) checkmark.style.display = 'flex';

        const highlight = this.querySelector('.woc-card-highlight');
        if(highlight) highlight.style.display = 'block';

        const btnText = this.querySelector('.woc-card-btn');
        if(btnText) {
            btnText.classList.remove('text-[#888]');
            btnText.classList.add('text-[#d4af37]');
        }

        // 3. Switch Bottom Panels
        const targetId = this.getAttribute('data-target-id');
        panels.forEach(panel => {
          if (panel.getAttribute('data-panel-id') === targetId) {
            panel.classList.remove('hidden');
            panel.classList.add('grid');
          } else {
            panel.classList.remove('grid');
            panel.classList.add('hidden');
          }
        });
      });
    });
  }

  // Initialize on normal page load
  document.addEventListener('DOMContentLoaded', initWocConfigurator);
  
  // Re-initialize inside Shopify Theme Editor when section updates
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initWocConfigurator();
    }
  });
</script>

{% schema %}
{
  "name": "Configurator Dynamic",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "YATAK TİPİNİZİ SEÇİN"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Üç tip, tek kalite"
    },
    {
      "type": "text",
      "id": "from_text",
      "label": "'From' Text",
      "default": "ŞURADAN"
    },
    {
      "type": "text",
      "id": "configure_text",
      "label": "Configure Text",
      "default": "Yapılandır"
    },
    {
      "type": "text",
      "id": "installment_text",
      "label": "Installment Text",
      "default": "Eller ₺7.530/md. i 10 mdr."
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Bed Card (Dynamic)",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product_ref",
          "label": "Select Backend Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text",
          "default": "AKILLI SEÇİM"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image Override (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title Override (Optional)"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short Description",
          "default": "Özel konfor akıllı depolamayla buluşuyor"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Fallback Price (If no product)",
          "default": "₺27.605"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Configurator Dynamic",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "badge": "ÇOK SATANLAR",
            "title": "AI Smart Topper",
            "description": "Erteleme düğmesini karşı konulmaz yapın",
            "price": "2,499.00TL"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "badge": "PREMIUM",
            "title": "BOSS LADY Facelift",
            "description": "Sizi yedinci cennete taşıyor",
            "price": "3,499.00TL"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "badge": "AKILLI SEÇİM",
            "title": "CardioFlex",
            "description": "Özel konfor akıllı depolamayla buluşuyor",
            "price": "502,000.00TL"
          }
        }
      ]
    }
  ]
}
{% endschema %}
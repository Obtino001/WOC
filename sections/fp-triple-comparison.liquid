{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-background section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    <div class="text-center mb-4">
      <h2 class="font-display text-2xl font-bold text-foreground md:text-3xl">{{ section.settings.heading }}</h2>
      <p class="font-body text-base text-muted-foreground mt-2">{{ section.settings.subtitle }}</p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-6 mt-12">
      
      <div class="flex flex-col">
        <div class="rounded-2xl border border-foreground/30 bg-foreground px-5 py-4 mb-4">
          <h3 class="font-display text-lg font-bold text-background">{{ section.settings.col1_title }}</h3>
        </div>
        <div class="space-y-3">
          {% for block in section.blocks %}
            {% if block.type == 'good' %}
              <div class="flex items-start gap-3 rounded-xl border border-border bg-card px-4 py-3" {{ block.shopify_attributes }}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-check w-5 h-5 text-green-600 flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
                <span class="font-body text-sm text-foreground font-medium">{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="flex flex-col">
        <div class="rounded-2xl border border-border bg-card px-5 py-4 mb-4">
          <h3 class="font-display text-lg font-bold text-foreground">{{ section.settings.col2_title }}</h3>
        </div>
        <div class="space-y-3">
          {% for block in section.blocks %}
            {% if block.type == 'bad_1' %}
              <div class="flex items-start gap-3 rounded-xl border border-border bg-card px-4 py-3" {{ block.shopify_attributes }}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-x w-5 h-5 text-destructive flex-shrink-0 mt-0.5"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                <span class="font-body text-sm text-muted-foreground">{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="flex flex-col">
        <div class="rounded-2xl border border-border bg-card px-5 py-4 mb-4">
          <h3 class="font-display text-lg font-bold text-foreground">{{ section.settings.col3_title }}</h3>
        </div>
        <div class="space-y-3">
          {% for block in section.blocks %}
            {% if block.type == 'bad_2' %}
              <div class="flex items-start gap-3 rounded-xl border border-border bg-card px-4 py-3" {{ block.shopify_attributes }}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-x w-5 h-5 text-destructive flex-shrink-0 mt-0.5"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
                <span class="font-body text-sm text-muted-foreground">{{ block.settings.text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "FP Triple Comparison",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why WOC beats studio machines" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "(and cheap imitations)" },
    { "type": "text", "id": "col1_title", "label": "Col 1 Title", "default": "Home Pilates Reformer" },
    { "type": "text", "id": "col2_title", "label": "Col 2 Title", "default": "Studio Reformer" },
    { "type": "text", "id": "col3_title", "label": "Col 3 Title", "default": "Cheap imitations" }
  ],
  "blocks": [
    { "type": "good", "name": "Column 1 Item", "settings": [ { "type": "text", "id": "text", "label": "Text" } ] },
    { "type": "bad_1", "name": "Column 2 Item", "settings": [ { "type": "text", "id": "text", "label": "Text" } ] },
    { "type": "bad_2", "name": "Column 3 Item", "settings": [ { "type": "text", "id": "text", "label": "Text" } ] }
  ],
  "presets": [
    { "name": "FP Triple Comparison" }
  ]
}
{% endschema %}
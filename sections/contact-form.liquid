<section>
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="rounded-none border bg-card text-card-foreground shadow-sm p-8 border-border">
        
        <div class="mb-6">
          <h2 class="font-display text-2xl font-bold text-foreground mb-2">{{ section.settings.heading }}</h2>
          <p class="font-body text-sm text-muted-foreground">{{ section.settings.subtitle }}</p>
        </div>
        
        {% form 'contact', class: 'space-y-5' %}
          <input type="hidden" name="contact[tags]" value="consultation, contact-page">

          {% render 'form-feedback', success_message: 'Thank you! We have received your request and will contact you shortly.' %}

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="font-body text-sm font-medium text-foreground mb-1.5 block">Name <span class="text-destructive">*</span></label>
              <input type="text" name="contact[name]" class="flex h-10 w-full rounded-none border border-input bg-background px-3 py-2 text-base md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold" required maxlength="100" placeholder="Name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
            </div>
            <div>
              <label class="font-body text-sm font-medium text-foreground mb-1.5 block">Phone <span class="text-destructive">*</span></label>
              <input type="tel" name="contact[phone]" class="flex h-10 w-full rounded-none border border-input bg-background px-3 py-2 text-base md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold" required maxlength="20" placeholder="+45 XX XX XX XX" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="font-body text-sm font-medium text-foreground mb-1.5 block">Email <span class="text-destructive">*</span></label>
              <input type="email" name="contact[email]" class="flex h-10 w-full rounded-none border border-input bg-background px-3 py-2 text-base md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold" required maxlength="255" placeholder="you@email.com" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
            </div>
            <div>
              <label class="font-body text-sm font-medium text-foreground mb-1.5 block">Postcode <span class="text-destructive">*</span></label>
              <input type="text" name="contact[postcode]" class="flex h-10 w-full rounded-none border border-input bg-background px-3 py-2 text-base md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold" required maxlength="10" placeholder="e.g. 1620">
            </div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="font-body text-sm font-medium text-foreground mb-1.5 block">Company Name</label>
              <input type="text" name="contact[company]" class="flex h-10 w-full rounded-none border border-input bg-background px-3 py-2 text-base md:text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold" maxlength="100" placeholder="Optional">
            </div>
            <div>
              <label class="font-body text-sm font-medium text-foreground mb-1.5 block">I am Interested in <span class="text-destructive">*</span></label>
              <div class="relative">
                <select name="contact[interested_in]" required class="flex h-10 w-full appearance-none items-center justify-between rounded-none border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gold">
                  <option value="" disabled selected>Select a product</option>
                  <option value="Massage Chairs">Massage Chairs</option>
                  <option value="SOVESYSTEM® (Bespoke Bed)">SOVESYSTEM® (Bespoke Bed)</option>
                  <option value="SYNTHERA™ AI Mattress">SYNTHERA™ AI Mattress</option>
                  <option value="Sports Recovery">Sports Recovery</option>
                  <option value="Beauty Technology">Beauty Technology</option>
                  <option value="Corporate Wellness / OHS">Corporate Wellness / OHS</option>
                  <option value="Other / General Enquiry">Other / General Enquiry</option>
                </select>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 opacity-50 pointer-events-none"><path d="m6 9 6 6 6-6"></path></svg>
              </div>
            </div>
          </div>
          
          <div>
            <label class="font-body text-sm font-medium text-foreground mb-1.5 block">How Did You Find Us?</label>
            <div class="relative">
              <select name="contact[how_did_you_find_us]" class="flex h-10 w-full appearance-none items-center justify-between rounded-none border border-input bg-background px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gold">
                <option value="" disabled selected>Select an option</option>
                <option value="Google / Search Engine">Google / Search Engine</option>
                <option value="Recommended by a Friend">Recommended by a Friend</option>
                <option value="Social Media (Facebook/Instagram)">Social Media (Facebook/Instagram)</option>
                <option value="Saw Our Showroom">Saw Our Showroom</option>
                <option value="Online Advertisement">Online Advertisement</option>
                <option value="Newspaper / Magazine">Newspaper / Magazine</option>
                <option value="Business Event / Fair">Business Event / Fair</option>
                <option value="Other">Other</option>
              </select>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 opacity-50 pointer-events-none"><path d="m6 9 6 6 6-6"></path></svg>
            </div>
          </div>
          
          <div>
            <label class="font-body text-sm font-medium text-foreground mb-1.5 block">Message</label>
            <textarea name="contact[body]" class="flex min-h-[80px] w-full rounded-none border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold" maxlength="1000" rows="4" placeholder="Tell us what you are looking for — home visit, showroom appointment, product questions..."></textarea>
          </div>
          
          <p class="font-body text-xs text-muted-foreground leading-relaxed">{{ section.settings.disclaimer }}</p>
          
          <button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10 w-full">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path></svg>
            {{ section.settings.button_text }}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </button>
          
        {% endform %}
        
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Book a Free Consultation"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Fields marked with * are required"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "By submitting this form, you consent to being contacted by World of Comfort regarding your enquiry via phone, email, or SMS. You can unsubscribe at any time."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Book Free Consultation"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}

<section class="woc-section-py bg-charcoal border-t border-border">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Testimonials Header -->
    <div class="text-center mb-16">
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">
        {{ section.settings.label }}
      </p>
      <h2 class="woc-display-font text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-4">
        {{ section.settings.heading }}
      </h2>
      <p class="font-body text-sm text-muted-foreground max-w-xl mx-auto leading-relaxed">
        {{ section.settings.description }}
      </p>
    </div>

    <!-- Video Reviews Row (Gridded first) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mb-16">
      {%- for block in section.blocks -%}
        {%- if block.type == 'video_review' -%}
          
          <div class="group relative rounded-none border border-border bg-card overflow-hidden shadow-soft flex flex-col" {{ block.shopify_attributes }}>
            <!-- Video Container -->
            <div class="relative aspect-video bg-black flex items-center justify-center overflow-hidden">
              {%- if block.settings.youtube_id != blank -%}
                <!-- Cover Image & Play Trigger -->
                <div id="woc-video-cover-{{ block.id }}" class="absolute inset-0 z-20 cursor-pointer">
                  {%- if block.settings.cover_image != blank -%}
                    <img
                      src="{{ block.settings.cover_image | image_url: width: 600 }}"
                      alt="{{ block.settings.reviewer_name }}"
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-600">Video Cover</div>
                  {%- endif -%}
                  
                  <!-- Play Button overlay -->
                  <div class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/30 transition-colors">
                    <button
                      type="button"
                      onclick="playWocTestimonialVideo('{{ block.id }}', '{{ block.settings.youtube_id }}')"
                      class="w-14 h-14 rounded-full bg-gold hover:bg-gold-hover text-charcoal flex items-center justify-center shadow-elevated transform group-hover:scale-110 transition-all duration-300"
                      aria-label="Play video testimonial"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 ml-1"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    </button>
                  </div>
                </div>

                <!-- Iframe wrapper (Hidden initially) -->
                <div id="woc-video-player-{{ block.id }}" class="w-full h-full hidden">
                  <!-- Loaded on click dynamically to optimize initial page loading speeds -->
                </div>
              {%- endif -%}
            </div>

            <!-- Details -->
            <div class="p-5 flex-1 flex flex-col justify-between">
              <div>
                <p class="font-body text-xs font-semibold text-gold">
                  {{ block.settings.product }}
                </p>
                <h4 class="woc-display-font text-lg text-foreground mt-1 mb-2">
                  {{ block.settings.title }}
                </h4>
                <p class="font-body text-xs text-muted-foreground leading-relaxed italic">
                  &ldquo;{{ block.settings.quote }}&rdquo;
                </p>
              </div>

              <div class="mt-4 pt-3 border-t border-border/50 flex items-center justify-between">
                <span class="font-body text-xs font-medium text-foreground">{{ block.settings.reviewer_name }}</span>
                <span class="font-body text-[10px] text-forest font-semibold uppercase tracking-widest flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  Verificeret
                </span>
              </div>
            </div>
          </div>

        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Text Reviews Row (Gridded below) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {%- for block in section.blocks -%}
        {%- if block.type == 'text_review' -%}
          
          <div class="p-6 bg-card border border-border rounded flex flex-col justify-between" {{ block.shopify_attributes }}>
            <div>
              <!-- Stars -->
              <div class="flex items-center gap-0.5 mb-4 text-[#FBBC05]">
                {%- for i in (1..block.settings.stars) -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" /></svg>
                {%- endfor -%}
              </div>

              <!-- Quote Body -->
              <p class="font-body text-xs text-foreground/80 leading-relaxed italic mb-6">
                &ldquo;{{ block.settings.text }}&rdquo;
              </p>
            </div>

            <!-- Reviewer Credit info -->
            <div class="pt-4 border-t border-border/50 flex items-center justify-between">
              <div>
                <p class="font-body text-xs font-semibold text-foreground">{{ block.settings.name }}</p>
                <p class="font-body text-[9px] text-muted-foreground mt-0.5">{{ block.settings.purchased_product }}</p>
              </div>
              <span class="font-body text-[8px] text-forest font-semibold uppercase tracking-widest flex items-center gap-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-2.5 h-2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Køber
              </span>
            </div>
          </div>

        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  function playWocTestimonialVideo(blockId, youtubeId) {
    const cover = document.getElementById('woc-video-cover-' + blockId);
    const player = document.getElementById('woc-video-player-' + blockId);
    
    if (cover && player) {
      cover.classList.add('hidden');
      player.classList.remove('hidden');
      
      // Load iframe HTML dynamically
      player.innerHTML = `<iframe 
        class="w-full h-full" 
        src="https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0" 
        title="YouTube video player" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        referrerpolicy="strict-origin-when-cross-origin" 
        allowfullscreen>
      </iframe>`;
    }
  }
</script>

{% schema %}
{
  "name": "WOC Testimonials Grid",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "KUNDERNES ERFARINGER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Elsket af Vores Kunder",
      "default": "Hvad siger vores kunder?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Over 50.000 skandinaver har forbedret deres livskvalitet med vores wellnessprodukter. Her kan du høre og læse nogle af deres historier."
    }
  ],
  "blocks": [
    {
      "type": "video_review",
      "name": "Video Review Card",
      "settings": [
        {
          "type": "text",
          "id": "youtube_id",
          "label": "YouTube Video ID",
          "default": "dQw4w9WgXcQ"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Video Cover Image"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Lars Poulsen"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product Purchased",
          "default": "Biovis Pro Massagestol"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review Short Title",
          "default": "Helt fantastisk lindring"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Short Quote Snippet",
          "default": "Min ryg og mine lægge har aldrig haft det bedre. Efter jeg fik massagestolen har jeg reduceret mine spændinger markant."
        }
      ]
    },
    {
      "type": "text_review",
      "name": "Written Review Card",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Jeg har lidt af kroniske rygproblemer i mange år, og efter jeg købte mit saunatæppe, har jeg mærket en utrolig lettelse. Varmen går virkelig i dybden!"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Charlotte S."
        },
        {
          "type": "text",
          "id": "purchased_product",
          "label": "Product Name",
          "default": "Nordic Sauna Blanket"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Testimonials Grid",
      "blocks": [
        { "type": "video_review", "settings": { "reviewer_name": "Lars Poulsen", "product": "Biovis Pro Massagestol" } },
        { "type": "video_review", "settings": { "reviewer_name": "Mette Rosengren", "product": "Nordic Sauna Blanket" } },
        { "type": "video_review", "settings": { "reviewer_name": "Søren K.", "product": "Synthera AI Madras" } },
        { "type": "text_review", "settings": { "name": "Charlotte S.", "purchased_product": "Nordic Sauna Blanket" } },
        { "type": "text_review", "settings": { "name": "Morten T.", "purchased_product": "Physio Plus Massagestol" } },
        { "type": "text_review", "settings": { "name": "Line B.", "purchased_product": "Pilates Reformer" } },
        { "type": "text_review", "settings": { "name": "Henrik M.", "purchased_product": "Compact Treadmill" } }
      ]
    }
  ]
}
{% endschema %}

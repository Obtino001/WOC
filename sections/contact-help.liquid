<section class="py-12 bg-white border-t border-neutral-100">
  <div class="container mx-auto px-4 lg:px-8">
    <h2 class="font-body text-2xl font-bold text-neutral-900 text-center mb-8">{{ section.settings.heading }}</h2>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
      {% for block in section.blocks %}
        <div class="flex items-center gap-3 text-neutral-700" {{ block.shopify_attributes }}>
          <div class="[&>svg]:w-5 [&>svg]:h-5 [&>svg]:text-copper">
            {{ block.settings.icon_svg }}
          </div>
          <div>
            <p class="font-body text-xs text-neutral-500 uppercase tracking-wide">{{ block.settings.label }}</p>
            <p class="font-body text-sm font-medium">{{ block.settings.value }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Help",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Har du brug for hjælp?"
    }
  ],
  "blocks": [
    {
      "type": "contact_method",
      "name": "Contact Method",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g., E-mail)"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value (e.g., kontakt@...)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Help"
    }
  ]
}
{% endschema %}

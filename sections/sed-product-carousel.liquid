<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<section class="bg-white py-20">
  <div class="container mx-auto px-4 {{ section.settings.page_width | default: 'max-w-full' }}">
    <div class="flex items-center justify-center gap-8 mb-4">
      <button onclick="filterCarousel_{{ section.id | replace: '-', '_' }}('1', this)" class="font-display text-lg md:text-xl font-light uppercase tracking-[0.1em] pb-2 border-b-2 transition-colors duration-300 text-zinc-900 border-zinc-900">{{ section.settings.tab_1 }}</button>
      <button onclick="filterCarousel_{{ section.id | replace: '-', '_' }}('2', this)" class="font-display text-lg md:text-xl font-light uppercase tracking-[0.1em] pb-2 border-b-2 transition-colors duration-300 text-zinc-500 border-transparent hover:text-zinc-800">{{ section.settings.tab_2 }}</button>
    </div>
    <p class="text-center font-body text-sm text-zinc-500 mb-10">{{ section.settings.subtitle }}</p>
    
    <div class="relative">
      <button class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-white/80 backdrop-blur-sm border border-zinc-200 rounded-full flex items-center justify-center hover:bg-white transition-colors -ml-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-zinc-700"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      
      <div id="carousel-{{ section.id }}" class="flex gap-px bg-zinc-100 overflow-x-auto scrollbar-hide scroll-smooth" style="scrollbar-width: none;">
        {%- assign products_to_display = section.blocks -%}
        {%- assign products_to_display = section.blocks -%}
        {%- assign is_collection = false -%}
        
        {%- if section.settings.collection != blank -%}
          {%- assign coll = section.settings.collection -%}
          {%- if coll.products and coll.products.size > 0 -%}
            {%- assign products_to_display = coll.products -%}
            {%- assign is_collection = true -%}
          {%- elsif collections[coll].products.size > 0 -%}
            {%- assign products_to_display = collections[coll].products -%}
            {%- assign is_collection = true -%}
          {%- endif -%}
        {%- endif -%}

        {%- for item in products_to_display limit: section.settings.products_to_show -%}
          {%- assign product = item.settings.product -%}
          {%- assign target_url = product.url | default: item.settings.product_url -%}
          {%- assign image_to_show = item.settings.image | default: product.featured_image -%}
          {%- assign tag_to_show = item.settings.tag -%}
          {%- assign title_to_show = item.settings.title | default: product.title -%}
          {%- assign subtitle_to_show = item.settings.subtitle -%}
          {%- assign compare_price_to_show = item.settings.compare_price -%}
          {%- if compare_price_to_show == blank and product != blank and product.compare_at_price > product.price -%}
            {%- assign compare_price_to_show = product.compare_at_price | money -%}
          {%- endif -%}
          {%- assign price_to_show = item.settings.price -%}
          {%- if price_to_show == blank and product != blank -%}
            {%- assign price_to_show = product.price | money -%}
          {%- endif -%}
          {%- assign item_shopify_attributes = item.shopify_attributes -%}

          <div data-tab="{{ item.settings.tab }}" class="carousel-item min-w-[260px] sm:min-w-[280px] flex-shrink-0 bg-white group h-full flex flex-col relative" {{ item_shopify_attributes }}>
            <div class="relative aspect-square overflow-hidden bg-[#f5f5f3]">
              <a href="{{ target_url }}" class="absolute inset-0 z-0"></a>
              {% if image_to_show != blank %}
                {{ image_to_show | image_url: width: 600 | image_tag: class: 'w-full h-full transition-transform duration-[2s] group-hover:scale-105 object-contain p-8 relative z-0', loading: 'lazy' }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover relative z-0' }}
              {% endif %}
              
              {% if tag_to_show != blank %}
                <span class="absolute top-4 left-4 font-body text-[8px] font-medium uppercase tracking-[0.15em] bg-white/90 text-zinc-900 px-2.5 py-1 backdrop-blur-sm z-10">{{ tag_to_show }}</span>
              {% endif %}
              
              <div class="absolute inset-x-0 bottom-0 p-4 opacity-0 translate-y-3 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 z-10">
                {%- if product != blank -%}
                  {%- assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id -%}
                  {%- assign current_variant = product.selected_or_first_available_variant -%}
                  <product-form>
                    <div class="product-form__error-message-wrapper" role="alert" hidden>
                      <span class="product-form__error-message"></span>
                    </div>
                    {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                      <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" disabled>
                      <button type="submit" name="add" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-all duration-500 px-3 w-full bg-foreground hover:bg-foreground/90 text-background text-[10px] uppercase tracking-[0.15em] rounded-none h-10 disabled:opacity-50 disabled:cursor-not-allowed"
                        {% if current_variant.available == false %}disabled{% endif %}>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 mr-2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                        <span>
                          {%- if current_variant.available -%}
                            Add to Basket
                          {%- else -%}
                            {{ 'products.product.sold_out' | t | default: 'Udsolgt' }}
                          {%- endif -%}
                        </span>
                        {%- render 'loading-spinner' -%}
                      </button>
                    {%- endform -%}
                  </product-form>
                {%- else -%}
                  <a href="{{ target_url }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-all duration-500 px-3 w-full bg-foreground hover:bg-foreground/90 text-background text-[10px] uppercase tracking-[0.15em] rounded-none h-10">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 mr-2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg> Add to Basket
                  </a>
                {%- endif -%}
              </div>
            </div>
            <a class="px-4 py-5 text-center border-t border-zinc-200/10 min-h-[128px] flex flex-col justify-start flex-1" href="{{ target_url }}">
              <h3 class="font-display text-[13px] font-light text-zinc-900 uppercase tracking-[0.12em]">
                {{ title_to_show }}
              </h3>
              {% if subtitle_to_show != blank %}
                <p class="font-display text-[11px] text-zinc-500 uppercase tracking-[0.12em] mt-0.5">{{ subtitle_to_show }}</p>
              {% endif %}
              <div class="flex items-center justify-center gap-2 mt-2.5">
                {% if product.compare_at_price > product.price or compare_price_to_show != blank %}
                  <span class="font-body text-[12px] text-zinc-500 line-through">
                    {{ compare_price_to_show }}
                  </span>
                {% endif %}
                
                <span class="font-body text-[12px] text-zinc-900">
                  {{ price_to_show }}
                </span>
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>

      <button class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-white/80 backdrop-blur-sm border border-zinc-200 rounded-full flex items-center justify-center hover:bg-white transition-colors -mr-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-zinc-700"><path d="m9 18 6-6-6-6"></path></svg>
      </button>
    </div>
  </div>
</section>

<script>
function filterCarousel_{{ section.id | replace: '-', '_' }}(tabId, btn) {
  const container = document.getElementById('carousel-{{ section.id }}');
  if(!container) return;
  const items = container.querySelectorAll('.carousel-item');
  items.forEach(item => {
    if(item.dataset.tab === tabId) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
  if(btn) {
    const parent = btn.parentElement;
    parent.querySelectorAll('button').forEach(b => {
      b.className = 'font-display text-lg md:text-xl font-light uppercase tracking-[0.1em] pb-2 border-b-2 transition-colors duration-300 text-zinc-500 border-transparent hover:text-zinc-800';
    });
    btn.className = 'font-display text-lg md:text-xl font-light uppercase tracking-[0.1em] pb-2 border-b-2 transition-colors duration-300 text-zinc-900 border-zinc-900';
  }
}
document.addEventListener('DOMContentLoaded', () => {
  filterCarousel_{{ section.id | replace: '-', '_' }}('1', null);
});
</script>

{% schema %}
{
  "name": "SED Product Carousel",
  "settings": [
    { 
      "type": "select", 
      "id": "page_width", 
      "label": "Page Width", 
      "options": [
        { "value": "max-w-4xl", "label": "Small" },
        { "value": "max-w-6xl", "label": "Medium" },
        { "value": "max-w-7xl", "label": "Large" },
        { "value": "max-w-full", "label": "Full Width" }
      ],
      "default": "max-w-full" 
    },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 8, "label": "Products to Show" },
    { "type": "text", "id": "tab_1", "label": "Tab 1 Title", "default": "Best Sellers" },
    { "type": "text", "id": "tab_2", "label": "Tab 2 Title", "default": "Trending Now" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Our most awarded products, chosen by experts worldwide." }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Slide",
      "settings": [
        { "type": "select", "id": "tab", "label": "Assign to Tab", "options": [ { "value": "1", "label": "Tab 1" }, { "value": "2", "label": "Tab 2" } ], "default": "1" },
        { "type": "product", "id": "product", "label": "Select Product (Enables Add to Cart)" },
        { "type": "image_picker", "id": "image", "label": "Image Override (Optional)" },
        { "type": "text", "id": "tag", "label": "Badge Tag (e.g. BESTSELLER)" },
        { "type": "text", "id": "title", "label": "Product Title Override (Optional)" },
        { "type": "text", "id": "subtitle", "label": "Product Subtitle" },
        { "type": "text", "id": "compare_price", "label": "Compare Price Override (Optional)" },
        { "type": "text", "id": "price", "label": "Price Override (Optional)" },
        { "type": "url", "id": "product_url", "label": "Link Override (Optional)" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Product Carousel" }
  ]
}
{% endschema %}

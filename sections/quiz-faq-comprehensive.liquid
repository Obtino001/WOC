{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Smooth accordion animation */
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
{%- endstyle -%}

<!-- Dynamic FAQ Schema Generation -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for block in section.blocks %}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ block.settings.answer | strip_html | json }}
        }
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>

<section class="relative overflow-hidden section-{{ section.id }}-padding bg-white" id="{{ section.settings.section_id }}">
  <div class="container relative mx-auto px-4 lg:px-8 z-10">
    
    <!-- Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <div class="w-12 h-[1px] bg-gold mx-auto mb-8"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.2em] text-gold mb-4">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl md:text-5xl font-light text-zinc-900 leading-[1.05] mb-5">
        {{ section.settings.heading }}
      </h2>
      <p class="font-body text-sm md:text-base text-zinc-500 max-w-2xl mx-auto leading-relaxed">
        {{ section.settings.description }}
      </p>
    </div>

    <!-- Search Input -->
    <div class="max-w-3xl mx-auto mb-12">
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-zinc-500"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
        <input type="text" id="faq-search-{{ section.id }}" placeholder="{{ section.settings.search_placeholder }}" class="w-full pl-12 pr-4 py-4 bg-transparent border border-zinc-200 rounded-lg font-body text-sm text-zinc-900 placeholder:text-zinc-500 focus:outline-none focus:border-gold/50 transition-colors">
      </div>
    </div>

    <!-- Get Unique Categories -->
    {% assign categories_str = "" %}
    {% for block in section.blocks %}
      {% if block.settings.category != blank %}
        {% assign categories_str = categories_str | append: block.settings.category | append: "|||" %}
      {% endif %}
    {% endfor %}
    {% assign unique_categories = categories_str | split: "|||" | compact | uniq %}

    <!-- Category Tabs -->
    <div class="flex flex-wrap justify-center gap-3 mb-14" id="faq-tabs-{{ section.id }}">
      
      <!-- 'All' Tab Removed -->

      <!-- Dynamic Tabs -->
      {% for category in unique_categories %}
        {% assign cat_count = 0 %}
        {% for block in section.blocks %}
          {% if block.settings.category == category %}
            {% assign cat_count = cat_count | plus: 1 %}
          {% endif %}
        {% endfor %}
        <button class="faq-tab flex items-center gap-2 px-5 py-2.5 rounded-full font-body text-xs font-medium tracking-wide transition-all duration-300 {% if forloop.first %}bg-gold/10 text-gold border-gold/30{% else %}bg-transparent border-zinc-200 text-zinc-500 hover:text-zinc-900 hover:border-gold/30{% endif %} border" data-category="{{ category | escape }}">
          {{ category }}
          <span class="text-[10px] rounded-full px-1.5 py-0.5 ml-0.5 {% if forloop.first %}bg-gold/20 text-gold{% else %}bg-muted text-zinc-500{% endif %} cat-badge">{{ cat_count }}</span>
        </button>
      {% endfor %}
    </div>

    <!-- FAQ Accordion List -->
    <div class="max-w-4xl mx-auto space-y-2 border border-zinc-200 rounded-xl p-6 bg-white/10" id="faq-list-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="faq-item border-b border-zinc-200/50 last:border-b-0 group" data-category="{{ block.settings.category | escape }}" {{ block.shopify_attributes }}>
          <details class="group/details">
            <summary class="flex items-center justify-between w-full text-left py-5 gap-4 cursor-pointer">
              <h3 class="font-display text-sm md:text-base font-medium transition-colors text-zinc-900 group-hover:text-gold">{{ block.settings.question }}</h3>
              <span class="shrink-0 transition-transform duration-300 group-open/details:rotate-180">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down h-4 w-4 text-zinc-500"><path d="m6 9 6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="pb-6 pt-1 pr-8 font-body text-sm text-zinc-500 leading-relaxed">
              {{ block.settings.answer }}
            </div>
          </details>
        </div>
      {% endfor %}
      
      <!-- Empty State (Hidden by default) -->
      <div id="faq-empty-{{ section.id }}" class="hidden text-center py-10">
        <p class="font-body text-sm text-zinc-500">No questions found matching your search.</p>
      </div>
    </div>

    <!-- Still have questions -->
    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-4 bg-transparent border border-zinc-200 rounded-xl px-8 py-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle h-6 w-6 text-gold"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
        <div class="text-left">
          <p class="font-display text-sm font-medium text-zinc-900 mb-1">{{ section.settings.contact_title }}</p>
          <p class="font-body text-xs text-zinc-500">{{ section.settings.contact_text }}</p>
        </div>
      </div>
    </div>
    
  </div>
</section>

<!-- Scoped JavaScript for Tab Filtering and Search -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const tabs = document.querySelectorAll(`#faq-tabs-${sectionId} .faq-tab`);
    const items = document.querySelectorAll(`#faq-list-${sectionId} .faq-item`);
    const searchInput = document.getElementById(`faq-search-${sectionId}`);
    const emptyState = document.getElementById(`faq-empty-${sectionId}`);

    function filterFaqs() {
      // 1. Get current active category
      const activeTab = document.querySelector(`#faq-tabs-${sectionId} .faq-tab[data-active="true"]`) || tabs[0];
      if (!activeTab) return;
      const targetCategory = activeTab.getAttribute('data-category');
      
      // 2. Get search query
      const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
      
      let visibleCount = 0;

      items.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        const questionText = item.querySelector('summary h3').textContent.toLowerCase();
        
        const matchesCategory = (itemCategory === targetCategory);
        const matchesSearch = questionText.includes(searchTerm);

        if (matchesCategory && matchesSearch) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
          // Optional: close accordions when hidden
          item.querySelector('details').removeAttribute('open');
        }
      });

      // Show/hide empty state message
      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    // Add Click Listeners to Tabs
    tabs.forEach(tab => {
      // Set initial data state on the first tab
      if(tab.classList.contains('bg-gold/10')) {
        tab.setAttribute('data-active', 'true');
      }

      tab.addEventListener('click', () => {
        // Remove active styling from all tabs
        tabs.forEach(t => {
          t.setAttribute('data-active', 'false');
          t.classList.remove('bg-gold/10', 'text-gold', 'border-gold/30');
          t.classList.add('bg-transparent', 'border-zinc-200', 'text-zinc-500');
          
          // Reset badge colors
          const badge = t.querySelector('.cat-badge');
          if(badge) {
            badge.classList.remove('bg-gold/20', 'text-gold');
            badge.classList.add('bg-muted', 'text-zinc-500');
          }
        });

        // Add active styling to clicked tab
        tab.setAttribute('data-active', 'true');
        tab.classList.remove('bg-transparent', 'border-zinc-200', 'text-zinc-500');
        tab.classList.add('bg-gold/10', 'text-gold', 'border-gold/30');
        
        // Highlight badge on active tab
        const activeBadge = tab.querySelector('.cat-badge');
        if(activeBadge) {
          activeBadge.classList.remove('bg-muted', 'text-zinc-500');
          activeBadge.classList.add('bg-gold/20', 'text-gold');
        }

        filterFaqs();
      });
    });

    // Add Input Listener to Search
    if (searchInput) {
      searchInput.addEventListener('input', filterFaqs);
    }
  });
</script>

{% schema %}
{
  "name": "Categorized FAQ",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 },
    { "type": "text", "id": "section_id", "label": "Section Anchor ID", "default": "faq" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Frequently Asked Questions" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "FAQ <span class=\"italic text-gold font-serif\">to know</span>" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "We have answered the most common questions from over 5,000 customers in Scandinavia. Can't find what you're looking for? Our wellness experts are just a call away." },
    { "type": "text", "id": "search_placeholder", "label": "Search Placeholder", "default": "Search questions — e.g. 'warranty', 'delivery', 'zero gravity'..." },
    { "type": "text", "id": "contact_title", "label": "Contact Box Title", "default": "Still have questions?" },
    { "type": "text", "id": "contact_text", "label": "Contact Box Text", "default": "Call us on +45 XX XX XX XX or book a free showroom demo — our experts are ready to help." }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "category", "label": "Category Tab", "info": "E.g., 'Choosing a chair', 'Delivery & Setup'. Questions with the same exact category name will be grouped together." },
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    { "name": "Categorized FAQ" }
  ]
}
{% endschema %}
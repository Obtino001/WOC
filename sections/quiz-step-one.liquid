{
  "name": "Single Page Quiz",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Kişisel sandalye tavsiyesi"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Mükemmel masaj koltuğunuzu bulun"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_step_label",
      "label": "Form Step Label",
      "default": "NEREDEYSE BİTTİ"
    },
    {

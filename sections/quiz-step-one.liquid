        { "type": "text", "id": "opt2_emoji", "label": "Emoji/Icon" },
        { "type": "text", "id": "opt2_title", "label": "Title" },
        { "type": "text", "id": "opt2_subtitle", "label": "Subtitle" },
        { "type": "text", "id": "opt2_val", "label": "Internal Value (optional)" },
        
        { "type": "header", "content": "Option 3" },
        { "type": "text", "id": "opt3_emoji", "label": "Emoji/Icon" },
        { "type": "text", "id": "opt3_title", "label": "Title" },
        { "type": "text", "id": "opt3_subtitle", "label": "Subtitle" },
        { "type": "text", "id": "opt3_val", "label": "Internal Value (optional)" },
        
        { "type": "header", "content": "Option 4" },
        { "type": "text", "id": "opt4_emoji", "label": "Emoji/Icon" },
        { "type": "text", "id": "opt4_title", "label": "Title" },
        { "type": "text", "id": "opt4_subtitle", "label": "Subtitle" },
        { "type": "text", "id": "opt4_val", "label": "Internal Value (optional)" },
        
        { "type": "header", "content": "Option 5" },
        { "type": "text", "id": "opt5_emoji", "label": "Emoji/Icon" },
        { "type": "text", "id": "opt5_title", "label": "Title" },
        { "type": "text", "id": "opt5_subtitle", "label": "Subtitle" },
        { "type": "text", "id": "opt5_val", "label": "Internal Value (optional)" },
        
        { "type": "header", "content": "Option 6" },
        { "type": "text", "id": "opt6_emoji", "label": "Emoji/Icon" },
        { "type": "text", "id": "opt6_title", "label": "Title" },
        { "type": "text", "id": "opt6_subtitle", "label": "Subtitle" },

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="container mx-auto px-4 max-w-3xl section-{{ section.id }}-padding woc-quiz-step-section" id="quiz-container-{{ section.id }}">
  
  <div class="text-center mb-10 mt-4">
    <div class="inline-flex items-center gap-2 px-3.5 py-1 rounded-full mb-4 border" style="border-color: hsl(var(--gold) / 0.3); background: hsl(var(--gold) / 0.08);">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-3 h-3" style="color: hsl(var(--gold));">
        <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path>
        <path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path>
      </svg>
      <span class="text-[11px] font-semibold uppercase tracking-widest" style="color: hsl(var(--gold));">{{ section.settings.badge_text }}</span>
    </div>
    <h1 class="font-display text-2xl md:text-3xl font-bold text-foreground">{{ section.settings.title }}</h1>
  </div>

  <!-- QUESTIONS -->
  <div id="quiz-questions-{{ section.id }}"{% if form.posted_successfully? %} class="hidden"{% endif %}>
    {% for block in section.blocks %}
      {% if block.type == 'question' %}
        <div class="quiz-question-block {% if forloop.index > 1 %}hidden{% endif %}" data-step="{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="mb-10">
            <div class="flex justify-between items-center mb-3">
              <span class="font-body text-xs text-muted-foreground uppercase tracking-wider">{{ block.settings.step_text }}</span>
              <span class="font-body text-xs font-semibold" style="color: hsl(var(--gold));">{{ block.settings.progress }}%</span>
            </div>
            <div class="h-1.5 bg-muted rounded-full overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500" style="background: hsl(var(--gold)); width: {{ block.settings.progress }}%;"></div>
            </div>
          </div>

          <div>
            <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">{{ block.settings.question_title }}</h2>
            <p class="text-muted-foreground mb-8">{{ block.settings.question_subtitle }}</p>
            
            <div class="space-y-3">
              {% for i in (1..6) %}
                {% capture opt_emoji_key %}opt{{ i }}_emoji{% endcapture %}
                {% capture opt_title_key %}opt{{ i }}_title{% endcapture %}
                {% capture opt_sub_key %}opt{{ i }}_subtitle{% endcapture %}
                {% capture opt_val_key %}opt{{ i }}_val{% endcapture %}
                
                {% assign opt_emoji = block.settings[opt_emoji_key] %}
                {% assign opt_title = block.settings[opt_title_key] %}
                {% assign opt_sub = block.settings[opt_sub_key] %}
                {% assign opt_val = block.settings[opt_val_key] %}

                {% if opt_title != blank %}
                  <button type="button" data-question="{{ block.settings.question_title | escape }}" data-value="{{ opt_val | escape | default: opt_title }}" class="quiz-option-btn w-full text-left p-5 rounded-xl border-2 transition-all duration-200 group border-border hover:border-[hsl(var(--gold)/0.5)] hover:bg-muted/30">
                    <div class="flex items-start gap-4">
                      {% if opt_emoji != blank %}
                        <span class="text-2xl flex-shrink-0">{{ opt_emoji }}</span>
                      {% endif %}
                      <div class="flex-1">
                        <div class="font-semibold text-foreground">{{ opt_title }}</div>
                        {% if opt_sub != blank %}
                          <div class="text-sm text-muted-foreground mt-0.5">{{ opt_sub }}</div>
                        {% endif %}
                      </div>
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-5 h-5 mt-1 flex-shrink-0 transition-all text-muted-foreground group-hover:translate-x-1">
                        <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
                      </svg>
                    </div>
                  </button>
                {% endif %}
              {% endfor %}
            </div>
            
            {% if forloop.index > 1 %}
              <button type="button" class="btn-prev-quiz mt-8 inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left w-4 h-4"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
                Önceki soru
              </button>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- FORM -->
  <div id="quiz-form-{{ section.id }}" class="{% unless form.posted_successfully? %}hidden{% endunless %}">
    <div class="mb-10">
      <div class="flex justify-between items-center mb-3">
        <span class="font-body text-xs text-muted-foreground uppercase tracking-wider">{{ section.settings.form_step_label | default: "NEREDEYSE BİTTİ" }}</span>
        <span class="font-body text-xs font-semibold" style="color: hsl(var(--gold));">100%</span>
      </div>
      <div class="h-1.5 bg-muted rounded-full overflow-hidden">
        <div class="h-full rounded-full transition-all duration-500" style="background: hsl(var(--gold)); width: 100%;"></div>
      </div>
    </div>
    
    <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">{{ section.settings.form_heading | default: "Önerinizi Alın" }}</h2>
    <p class="text-muted-foreground mb-8">{{ section.settings.form_subheading | default: "Detaylarınızı girin, size özel eşleşmeyi gönderelim." }}</p>
    
    {% form 'contact', id: 'quiz-contact-form' %}
      <input type="hidden" name="contact[tags]" value="quiz, chair-recommendation">
      <input type="hidden" name="contact[body]" id="quiz-body-field-{{ section.id }}" value="">
      <div id="hidden-quiz-inputs-{{ section.id }}"></div>

      {% render 'form-feedback', success_message: 'Teşekkürler! Öneri talebiniz başarıyla gönderildi.' %}

      {% unless form.posted_successfully? %}
      <div class="space-y-4">
        <div>
          <input type="text" name="contact[name]" placeholder="İsim Soyisim *" required class="w-full p-4 rounded-xl border-2 border-border bg-background focus:border-[hsl(var(--gold)/0.5)] focus:outline-none transition-colors text-foreground">
        </div>
        <div>
          <input type="email" name="contact[email]" placeholder="E-posta Adresi *" required class="w-full p-4 rounded-xl border-2 border-border bg-background focus:border-[hsl(var(--gold)/0.5)] focus:outline-none transition-colors text-foreground">
        </div>
        <div>
          <input type="tel" name="contact[phone]" placeholder="Telefon (İsteğe bağlı)" class="w-full p-4 rounded-xl border-2 border-border bg-background focus:border-[hsl(var(--gold)/0.5)] focus:outline-none transition-colors text-foreground">
        </div>
        <button type="submit" class="w-full p-4 rounded-xl bg-gold text-charcoal font-bold mt-4 hover:opacity-90 transition-opacity">
          {{ section.settings.form_button_text | default: "ÖNERİMİ AL" }}
        </button>
      </div>
      {% endunless %}
    {% endform %}
    
    <button type="button" class="btn-prev-quiz-form mt-8 inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left w-4 h-4"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
      Önceki soru
    </button>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('quiz-container-{{ section.id }}');
    if (!container) return;
    
    const questions = Array.from(container.querySelectorAll('.quiz-question-block'));
    const formBlock = document.getElementById('quiz-form-{{ section.id }}');
    const hiddenInputsContainer = document.getElementById('hidden-quiz-inputs-{{ section.id }}');
    let currentStepIndex = 0;
    let answers = {};
    
    function showStep(index) {
      questions.forEach((q, i) => {
        if(i === index) {
          q.classList.remove('hidden');
        } else {
          q.classList.add('hidden');
        }
      });
      if(index >= questions.length && questions.length > 0) {
        formBlock.classList.remove('hidden');
        // populate hidden inputs
        hiddenInputsContainer.innerHTML = '';
        const bodyParts = [];
        for (const [q, a] of Object.entries(answers)) {
           const input = document.createElement('input');
           input.type = 'hidden';
           input.name = `contact[quiz_${q.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase()}]`;
           input.value = a;
           hiddenInputsContainer.appendChild(input);
           bodyParts.push(`${q}: ${a}`);
        }
        const bodyField = document.getElementById('quiz-body-field-{{ section.id }}');
        if (bodyField) bodyField.value = bodyParts.join('\n');
      } else {
        formBlock.classList.add('hidden');
      }
      window.scrollTo({ top: container.offsetTop - 50, behavior: 'smooth' });
    }
    
    container.querySelectorAll('.quiz-option-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const questionName = this.getAttribute('data-question');
        const val = this.getAttribute('data-value');
        answers[questionName] = val;
        
        currentStepIndex++;
        showStep(currentStepIndex);
      });
    });
    
    container.querySelectorAll('.btn-prev-quiz, .btn-prev-quiz-form').forEach(btn => {
      btn.addEventListener('click', function() {
        if(currentStepIndex > 0) {
          currentStepIndex--;
          showStep(currentStepIndex);
        }
      });
    });
  });
</script>


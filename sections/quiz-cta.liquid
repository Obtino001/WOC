{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-linen section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <div class="luxury-line mx-auto mb-10"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-8">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-light text-foreground mb-6 leading-[1.05]">
        {{ section.settings.heading | newline_to_br }}
      </h2>
      <p class="font-body text-sm font-light text-muted-foreground mb-12 max-w-md mx-auto leading-relaxed">
        {{ section.settings.description }}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        {% if section.settings.button_text != blank %}
          <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-gold text-charcoal font-semibold hover:bg-gold/90 transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10" href="{{ section.settings.button_link }}">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
        
        {% if section.settings.secondary_button_text != blank %}
          <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-gold/50 text-gold hover:bg-gold hover:text-charcoal font-semibold transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10" href="{{ section.settings.secondary_button_link }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-4 h-4"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            {{ section.settings.secondary_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz CTA",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Personal Guidance"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect <span class=\"block italic text-gold\">Massage Chair</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Take our 2-minute quiz and find the chair that matches your body, lifestyle, and wellness goals."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Start the Quiz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Quiz CTA"
    }
  ]
}
{% endschema %}
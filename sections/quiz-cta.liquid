<section class="bg-linen" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <div class="luxury-line mx-auto mb-10"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-8">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-light text-foreground mb-6 leading-[1.05]">
        {{ section.settings.heading | newline_to_br }}
      </h2>
      <p class="font-body text-sm font-light text-muted-foreground mb-12 max-w-md mx-auto leading-relaxed">
        {{ section.settings.description }}
      </p>
      {% if section.settings.button_text != blank %}
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10" href="{{ section.settings.button_link }}">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz CTA",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Top",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 128
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Personal Guidance"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect\n<span class=\"block italic text-gold\">Massage Chair</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Take our 2-minute quiz and find the chair that matches your body, lifestyle, and wellness goals."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Start the Quiz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Quiz CTA"
    }
  ]
}
{% endschema %}

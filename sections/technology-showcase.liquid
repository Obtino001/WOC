<section class="relative py-32 lg:py-44 overflow-hidden bg-[hsl(0,0%,3%)]" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="absolute inset-0 opacity-[0.035]" style="background-image: radial-gradient(circle at 30% 20%, hsl(var(--gold)), transparent 45%), radial-gradient(circle at 70% 80%, hsl(var(--gold)), transparent 45%);"></div>
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(hsl(var(--gold) / 0.2) 1px, transparent 1px), linear-gradient(90deg, hsl(var(--gold) / 0.2) 1px, transparent 1px); background-size: 80px 80px;"></div>
  <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[hsl(0,0%,2%)] to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-[hsl(0,0%,2%)] to-transparent"></div>

  <div class="container mx-auto px-4 lg:px-8 relative z-10">
    <div class="text-center mb-20 lg:mb-28">
      <div class="inline-flex items-center gap-2.5 bg-gold/[0.08] border border-gold/20 rounded-full px-6 py-2.5 mb-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 text-gold"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path></svg>
        <span class="font-body text-[10px] font-bold uppercase tracking-luxury text-gold">{{ section.settings.badge }}</span>
      </div>
      <h2 class="font-display text-5xl md:text-6xl lg:text-8xl font-light text-white leading-[1.02] mb-8">{{ section.settings.heading }}</h2>
      <p class="font-body text-lg md:text-xl text-white/45 max-w-2xl mx-auto leading-relaxed mt-10 tracking-wide">{{ section.settings.description }}</p>
    </div>

    <div class="flex justify-center mb-20 lg:mb-28">
      <div class="relative">
        <div class="absolute inset-0 rounded-full bg-gold/[0.07] blur-[80px] scale-[2]"></div>
        <div class="absolute inset-0 rounded-full border border-gold/10 scale-[1.8] animate-pulse"></div>
        {% if section.settings.center_gif != blank %}
          <img src="{{ section.settings.center_gif | image_url: width: 600 }}" class="relative w-52 h-52 md:w-72 md:h-72 lg:w-80 lg:h-80 object-contain drop-shadow-[0_0_40px_hsl(var(--gold)/0.15)]" loading="lazy">
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'relative w-52 h-52 md:w-72 md:h-72 lg:w-80 lg:h-80 object-contain' }}
        {% endif %}
      </div>
    </div>

    <div class="max-w-3xl mx-auto mb-28 lg:mb-36">
      <div class="relative bg-white/[0.025] backdrop-blur-md border border-white/[0.07] rounded-3xl p-10 md:p-14">
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-gold/[0.03] via-transparent to-gold/[0.02] pointer-events-none"></div>
        <div class="relative">
          <div class="flex items-end justify-between mb-12">
            <div>
              <p class="font-body text-[10px] text-gold/50 uppercase tracking-luxury mb-3">{{ section.settings.bars_kicker }}</p>
              <h3 class="font-display text-3xl md:text-4xl font-light text-white">{{ section.settings.bars_heading }}</h3>
            </div>
            <div class="hidden md:block w-16 h-px bg-gradient-to-l from-gold/30 to-transparent"></div>
          </div>
          <div class="space-y-6">
            <div class="flex items-center gap-5">
              <span class="font-body text-[13px] tracking-[0.15em] w-16 text-right tabular-nums uppercase text-white/25 font-medium">3D</span>
              <div class="flex-1 h-[6px] bg-white/[0.06] rounded-full overflow-hidden"><div class="h-full rounded-full bg-white/[0.08]" style="width: 25%;"></div></div>
              <span class="font-body text-[11px] w-12 text-right tabular-nums text-white/15">25%</span>
            </div>
            <div class="flex items-center gap-5">
              <span class="font-body text-[13px] tracking-[0.15em] w-16 text-right tabular-nums uppercase text-white/25 font-medium">4D</span>
              <div class="flex-1 h-[6px] bg-white/[0.06] rounded-full overflow-hidden"><div class="h-full rounded-full bg-white/[0.08]" style="width: 42%;"></div></div>
              <span class="font-body text-[11px] w-12 text-right tabular-nums text-white/15">42%</span>
            </div>
            <div class="flex items-center gap-5">
              <span class="font-body text-[13px] tracking-[0.15em] w-16 text-right tabular-nums uppercase text-white/25 font-medium">5D</span>
              <div class="flex-1 h-[6px] bg-white/[0.06] rounded-full overflow-hidden"><div class="h-full rounded-full bg-white/[0.08]" style="width: 55%;"></div></div>
              <span class="font-body text-[11px] w-12 text-right tabular-nums text-white/15">55%</span>
            </div>
            <div class="pt-6 border-t border-gold/[0.12]">
              <div class="space-y-6">
                <div class="flex items-center gap-5">
                  <span class="font-body text-[13px] tracking-[0.15em] w-16 text-right tabular-nums uppercase text-gold font-bold text-sm">XD</span>
                  <div class="flex-1 h-[6px] bg-white/[0.06] rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-gold to-[hsl(40,55%,55%)] shadow-[0_0_20px_hsl(var(--gold)/0.35)]" style="width: 92%;"></div></div>
                  <span class="font-body text-[11px] w-12 text-right tabular-nums text-gold/80 font-semibold">92%</span>
                </div>
                <div class="flex items-center gap-5">
                  <span class="font-body text-[13px] tracking-[0.15em] w-16 text-right tabular-nums uppercase text-gold font-bold text-sm">XD+</span>
                  <div class="flex-1 h-[6px] bg-white/[0.06] rounded-full overflow-hidden"><div class="h-full rounded-full bg-gradient-to-r from-gold to-[hsl(40,55%,55%)] shadow-[0_0_20px_hsl(var(--gold)/0.35)]" style="width: 100%;"></div></div>
                  <span class="font-body text-[11px] w-12 text-right tabular-nums text-gold/80 font-semibold">100%</span>
                </div>
              </div>
            </div>
          </div>
          <p class="font-body text-[11px] text-white/30 mt-10 text-center italic tracking-wide">{{ section.settings.comparison_note }}</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 mb-28 lg:mb-36 max-w-5xl mx-auto">
      {% for block in section.blocks %}
        {% if block.type == 'highlight_stat' %}
          <div class="text-center px-6 relative" {{ block.shopify_attributes }}>
            {% if forloop.index > 1 %}<div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2 w-px h-12 bg-white/[0.06]"></div>{% endif %}
            <p class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-gold mb-3 tracking-tight">{{ block.settings.number }}</p>
            <p class="font-body text-[11px] text-white/40 uppercase tracking-[0.2em] leading-relaxed">{{ block.settings.label }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="space-y-0">
      {% assign alt = false %}
      {% for block in section.blocks %}
        {% if block.type == 'feature_row' %}
          {% capture image_order %}{% cycle '', 'lg:order-2' %}{% endcapture %}
          {% capture text_order %}{% cycle '', 'lg:order-1' %}{% endcapture %}
          {% capture gradient_dir %}{% cycle 'bg-gradient-to-r', 'bg-gradient-to-l' %}{% endcapture %}

          <div class="grid lg:grid-cols-2 gap-0 items-center mt-16 lg:mt-0" {{ block.shopify_attributes }}>
            
            <div class="relative overflow-hidden {{ image_order }}">
              <div class="relative aspect-square lg:aspect-auto lg:h-[600px] overflow-hidden">
                {% if block.settings.image != blank %}
                   {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
                {% else %}
                   {{ 'detailed-apparel-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-neutral-800' }}
                {% endif %}
                <div class="absolute inset-0 {{ gradient_dir }} from-transparent via-transparent to-[hsl(0,0%,3%)]/40"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-[hsl(0,0%,3%)]/30 via-transparent to-[hsl(0,0%,3%)]/30"></div>
              </div>
            </div>
            
            <div class="px-6 py-12 lg:px-16 lg:py-20 {{ text_order }}">
              <div class="max-w-lg">
                <p class="font-body text-[10px] text-gold/60 uppercase tracking-luxury mb-4">{{ block.settings.kicker }}</p>
                <h3 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-white leading-[1.1] mb-8">{{ block.settings.heading }}</h3>
                <div class="w-12 h-px bg-gold/30 mb-8"></div>
                <p class="font-body text-[15px] md:text-base text-white/50 leading-[2] mb-10">
                  {{ block.settings.description }}
                </p>
                <div class="flex flex-wrap gap-3">
                  {% if block.settings.tag_1 != blank %}
                    <div class="flex items-center gap-2.5 bg-white/[0.04] border border-white/[0.08] rounded-full px-5 py-2.5 group hover:border-gold/25 transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-gold/60 flex-shrink-0 group-hover:bg-gold transition-colors"></div>
                      <span class="font-body text-[11px] text-white/50 group-hover:text-white/70 transition-colors tracking-wide">{{ block.settings.tag_1 }}</span>
                    </div>
                  {% endif %}
                  {% if block.settings.tag_2 != blank %}
                    <div class="flex items-center gap-2.5 bg-white/[0.04] border border-white/[0.08] rounded-full px-5 py-2.5 group hover:border-gold/25 transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-gold/60 flex-shrink-0 group-hover:bg-gold transition-colors"></div>
                      <span class="font-body text-[11px] text-white/50 group-hover:text-white/70 transition-colors tracking-wide">{{ block.settings.tag_2 }}</span>
                    </div>
                  {% endif %}
                  {% if block.settings.tag_3 != blank %}
                    <div class="flex items-center gap-2.5 bg-white/[0.04] border border-white/[0.08] rounded-full px-5 py-2.5 group hover:border-gold/25 transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-gold/60 flex-shrink-0 group-hover:bg-gold transition-colors"></div>
                      <span class="font-body text-[11px] text-white/50 group-hover:text-white/70 transition-colors tracking-wide">{{ block.settings.tag_3 }}</span>
                    </div>
                  {% endif %}
                </div>
                {% if block.settings.button_link != blank and block.settings.button_label != blank %}
                  <a href="{{ block.settings.button_link }}" class="inline-flex items-center justify-center px-8 py-3 mt-10 text-sm font-medium text-[hsl(0,0%,3%)] bg-gold hover:bg-gold/90 rounded-full transition-colors">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
              </div>
            </div>
            
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.footer_quote != blank %}
      <div class="text-center mt-28 lg:mt-36">
        <div class="inline-flex items-center gap-6">
          <div class="w-16 h-px bg-gradient-to-r from-transparent to-gold/30"></div>
          <p class="font-display text-xl md:text-2xl italic text-gold/60 tracking-wide">{{ section.settings.footer_quote }}</p>
          <div class="w-16 h-px bg-gradient-to-l from-transparent to-gold/30"></div>
        </div>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "XD Technology Showcase",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Top",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 128
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "Proprietary XD Technology"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Forget Everything About<br><span class=\"relative inline-block mt-2\"><span class=\"italic text-gold\">3D, 4D and 5D</span><span class=\"absolute -bottom-3 left-0 h-px bg-gradient-to-r from-transparent via-gold/60 to-transparent\" style=\"width: 100%;\"></span></span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "While competitors struggle to add another dimension, we have reinvented the entire massage experience..."
    },
    {
      "type": "image_picker",
      "id": "center_gif",
      "label": "Center GIF/Image"
    },
    {
      "type": "text",
      "id": "bars_kicker",
      "label": "Bars Kicker",
      "default": "Movement Range"
    },
    {
      "type": "text",
      "id": "bars_heading",
      "label": "Bars Heading",
      "default": "XD vs. Competitors"
    },
    {
      "type": "text",
      "id": "comparison_note",
      "label": "Comparison Note",
      "default": "XD = eXtended Dimension — our patented massage system..."
    },
    {
      "type": "text",
      "id": "footer_quote",
      "label": "Footer Quote",
      "default": "Technology that doesn't just massage — but understands you"
    }
  ],
  "blocks": [
    {
      "type": "highlight_stat",
      "name": "Highlight Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        }
      ]
    },
    {
      "type": "feature_row",
      "name": "Feature Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "Proprietary XD Technology"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "tag_1",
          "label": "Tag 1"
        },
        {
          "type": "text",
          "id": "tag_2",
          "label": "Tag 2"
        },
        {
          "type": "text",
          "id": "tag_3",
          "label": "Tag 3"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "XD Technology Showcase"
    }
  ]
}
{% endschema %}

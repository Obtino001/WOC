{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.product != blank -%}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<section id="{{ section.settings.section_id }}" class="{% if section.settings.bg_color == 'warm' %}section-light-warm{% else %}section-light{% endif %} section-{{ section.id }}-padding">
  {% if section.settings.show_divider_top %}
    <div class="w-full h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent absolute top-0 left-0 right-0"></div>
  {% endif %}
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        {% capture text_content %}
          <div class="{% if section.settings.layout == 'right' %}order-2 lg:order-1{% else %}order-2 lg:order-2{% endif %}">
            <span class="inline-block font-body text-xs uppercase tracking-[0.3em] {% if section.settings.kicker_color == 'gold' %}text-gold bg-gold/10{% else %}text-forest bg-forest/10{% endif %} px-4 py-1.5 rounded-full mb-6">
              {{ section.settings.kicker }}
            </span>
            <h3 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-3">{{ section.settings.title }}</h3>
            <p class="font-display text-lg italic text-muted-foreground mb-4">{{ section.settings.subtitle }}</p>
            
            {% if section.settings.origin_text != blank %}
              <div class="inline-flex items-center gap-2 px-4 py-1.5 border border-gold/30 rounded-full bg-gold/10 shadow-[0_0_10px_rgba(212,175,55,0.15)] mb-6">
                <span class="text-base">{{ section.settings.origin_emoji }}</span>
                <span class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-gold">{{ section.settings.origin_text }}</span>
              </div>
            {% endif %}

            <div class="font-body text-muted-foreground leading-relaxed mb-8 space-y-4">
              {{ section.settings.description }}
            </div>

            {% if section.blocks.size > 0 %}
              <div class="grid grid-cols-2 gap-4 mb-8">
                {% for block in section.blocks %}
                  <div class="flex items-center gap-3" {{ block.shopify_attributes }}>
                    <div class="w-8 h-8 rounded-full bg-forest/10 flex items-center justify-center flex-shrink-0 [&>svg]:w-4 [&>svg]:h-4 [&>svg]:text-forest">
                      {{ block.settings.icon_svg }}
                    </div>
                    <span class="font-body text-sm text-foreground">{{ block.settings.text }}</span>
                  </div>
                {% endfor %}
              </div>
            {% endif %}

            <div class="flex items-center gap-6 mb-8">
              <div>
                {% if section.settings.price_prefix != blank %}
                  <span class="font-body text-xs text-muted-foreground">{{ section.settings.price_prefix }}</span>
                {% endif %}
                <div class="flex items-baseline gap-3">
                  {% if section.settings.compare_price != blank %}
                    <span class="font-body text-sm text-muted-foreground line-through">{{ section.settings.compare_price }}</span>
                  {% endif %}
                  <p class="font-display text-3xl font-bold text-foreground">{{ section.settings.price }}</p>
                </div>
                {% if section.settings.price_suffix != blank %}
                  <p class="font-body text-xs text-gold mt-1">{{ section.settings.price_suffix }}</p>
                {% endif %}
              </div>
              {% if section.settings.badge_text != blank %}
                <span class="bg-sale-red text-white font-body text-xs font-bold px-3 py-1 rounded-full">{{ section.settings.badge_text }}</span>
              {% endif %}
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
              {%- if section.settings.product != blank -%}
                {%- assign product = section.settings.product -%}
                {%- assign current_variant = product.selected_or_first_available_variant -%}
                {%- assign product_form_id = 'product-form-' | append: section.id -%}
                <product-form class="w-full sm:w-auto">
                  {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" value="{{ current_variant.id }}" disabled>
                    <button type="submit" name="add" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10 w-full disabled:opacity-50 disabled:cursor-not-allowed"
                      {% if current_variant.available == false %}disabled{% endif %}>
                      {% if section.settings.btn1_icon != blank %}
                         <span class="[&>svg]:w-4 [&>svg]:h-4 [&>svg]:mr-2">{{ section.settings.btn1_icon }}</span>
                      {% endif %}
                      {%- if current_variant.available -%}
                        {{ section.settings.btn1_text | default: 'Add to basket' }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t | default: 'Udsolgt' }}
                      {%- endif -%}
                    </button>
                  {%- endform -%}
                </product-form>
              {%- else -%}
                {% if section.settings.btn1_text != blank %}
                  <a href="{{ section.settings.btn1_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10">
                    {% if section.settings.btn1_icon != blank %}
                       <span class="[&>svg]:w-4 [&>svg]:h-4 [&>svg]:mr-2">{{ section.settings.btn1_icon }}</span>
                    {% endif %}
                    {{ section.settings.btn1_text }}
                  </a>
                {% endif %}
              {%- endif -%}
              {% if section.settings.btn2_text != blank %}
                <a href="{{ section.settings.btn2_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-12 px-10 transition-all duration-500">
                  {{ section.settings.btn2_text }}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endcapture %}

        {% capture image_content %}
          <div class="{% if section.settings.layout == 'right' %}order-1 lg:order-2{% else %}order-1 lg:order-1{% endif %}">
            <div class="relative rounded-2xl overflow-hidden shadow-elevated {% if section.settings.show_play_button %}group cursor-pointer{% endif %} bg-charcoal">
              {% if section.settings.image != blank %}
                {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'w-full aspect-[4/3] object-cover', loading: 'lazy' }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full aspect-[4/3] object-cover bg-gray-200' }}
              {% endif %}
              
              {% if section.settings.image_badge != blank %}
                <div class="absolute top-4 right-4 {% if section.settings.badge_text != blank %}bg-sale-red{% else %}bg-gold{% endif %} text-white font-body text-xs font-bold px-4 py-1.5 rounded-full">
                  {{ section.settings.image_badge }}
                </div>
              {% endif %}

              {% if section.settings.show_play_button %}
                <div class="absolute inset-0 bg-charcoal/30 flex items-center justify-center group-hover:bg-charcoal/20 transition-colors">
                  <div class="w-16 h-16 rounded-full bg-gold/90 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-background fill-background ml-1"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-charcoal/60 to-transparent p-6">
                  <p class="font-body text-xs uppercase tracking-widest text-secondary/80">{{ section.settings.video_label }}</p>
                </div>
              {% endif %}
            </div>
            
            {% if section.settings.show_process_box %}
              <div class="mt-8 p-6 rounded-2xl border border-border/30 bg-background/50">
                <h4 class="font-display text-lg font-bold text-foreground mb-5 flex items-center gap-2">
                  {{ section.settings.process_heading }}
                  <span class="font-body text-[10px] font-normal uppercase tracking-widest text-gold bg-gold/10 px-3 py-1 rounded-full">{{ section.settings.process_badge }}</span>
                </h4>
                <div class="grid grid-cols-2 gap-4">
                   <div class="flex items-start gap-3">
                     <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path></svg></div>
                     <div><span class="font-body text-[10px] font-semibold uppercase tracking-widest text-gold">1.</span><p class="font-body text-sm text-foreground leading-snug">{{ section.settings.process_step_1 }}</p></div>
                   </div>
                   <div class="flex items-start gap-3">
                     <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg></div>
                     <div><span class="font-body text-[10px] font-semibold uppercase tracking-widest text-gold">2.</span><p class="font-body text-sm text-foreground leading-snug">{{ section.settings.process_step_2 }}</p></div>
                   </div>
                   <div class="flex items-start gap-3">
                     <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"></path><path d="m14.5 12.5 2-2"></path><path d="m11.5 9.5 2-2"></path><path d="m8.5 6.5 2-2"></path><path d="m17.5 15.5 2-2"></path></svg></div>
                     <div><span class="font-body text-[10px] font-semibold uppercase tracking-widest text-gold">3.</span><p class="font-body text-sm text-foreground leading-snug">{{ section.settings.process_step_3 }}</p></div>
                   </div>
                   <div class="flex items-start gap-3">
                     <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-gold"><circle cx="12" cy="8" r="6"></circle><path d="M15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"></path></svg></div>
                     <div><span class="font-body text-[10px] font-semibold uppercase tracking-widest text-gold">4.</span><p class="font-body text-sm text-foreground leading-snug">{{ section.settings.process_step_4 }}</p></div>
                   </div>
                </div>
              </div>
            {% endif %}
          </div>
        {% endcapture %}

        {% if section.settings.layout == 'right' %}
          {{ text_content }}
          {{ image_content }}
        {% else %}
          {{ image_content }}
          {{ text_content }}
        {% endif %}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Smart Bed Showcase",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "HTML ID (for anchoring)"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background Tone",
      "options": [
        {
          "value": "light",
          "label": "Light"
        },
        {
          "value": "warm",
          "label": "Warm Light"
        }
      ],
      "default": "light"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Text Alignment (Desktop)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_divider_top",
      "label": "Show Top Divider Line",
      "default": false
    },
    {
      "type": "product",
      "id": "product",
      "label": "Select Product (Enables Add to Cart)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "text",
      "id": "image_badge",
      "label": "Image Badge (e.g. NEW 2026)"
    },
    {
      "type": "checkbox",
      "id": "show_play_button",
      "label": "Show Video Play Overlay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_process_box",
      "label": "Show 'The Process' Box",
      "default": false
    },
    {
      "type": "select",
      "id": "kicker_color",
      "label": "Kicker Color",
      "options": [
        {
          "value": "gold",
          "label": "Gold"
        },
        {
          "value": "forest",
          "label": "Forest"
        }
      ],
      "default": "gold"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle (Italic)"
    },
    {
      "type": "text",
      "id": "origin_emoji",
      "label": "Origin Emoji (e.g. 🇩🇪)"
    },
    {
      "type": "text",
      "id": "origin_text",
      "label": "Origin Text"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "price_prefix",
      "label": "Price Prefix (e.g. From)"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Main Price"
    },
    {
      "type": "text",
      "id": "compare_price",
      "label": "Compare at Price"
    },
    {
      "type": "text",
      "id": "price_suffix",
      "label": "Price Suffix (e.g. or from £6 / week)"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Discount Badge (e.g. Save 1,000 kr.)"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Primary Button Text"
    },
    {
      "type": "html",
      "id": "btn1_icon",
      "label": "Primary Button Icon (SVG)"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Secondary Button Text"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "video_label",
      "label": "Video Label",
      "default": "Watch Video"
    },
    {
      "type": "text",
      "id": "process_heading",
      "label": "Process Box Heading",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "process_badge",
      "label": "Process Box Badge",
      "default": "4 steps"
    },
    {
      "type": "text",
      "id": "process_step_1",
      "label": "Process Step 1 Text",
      "default": "Book free body analysis"
    },
    {
      "type": "text",
      "id": "process_step_2",
      "label": "Process Step 2 Text",
      "default": "Consultation and needs analysis"
    },
    {
      "type": "text",
      "id": "process_step_3",
      "label": "Process Step 3 Text",
      "default": "Body measurement and scanning"
    },
    {
      "type": "text",
      "id": "process_step_4",
      "label": "Process Step 4 Text",
      "default": "Personal recommendation"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Smart Bed Showcase"
    }
  ]
}
{% endschema %}

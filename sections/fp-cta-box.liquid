{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.product != blank -%}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<section class="color-{{ section.settings.color_scheme }} gradient border-b border-border section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 text-center lg:px-12">
    <div class="mx-auto max-w-2xl rounded-[2rem] border border-border bg-card px-8 py-12 shadow-soft md:px-12">
      <h2 class="mb-4 font-display text-2xl font-semibold text-foreground md:text-3xl">{{ section.settings.heading }}</h2>
      <p class="mb-8 font-body text-base text-muted-foreground">{{ section.settings.description }}</p>
      
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        {%- if section.settings.product != blank -%}
          {%- assign product = section.settings.product -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          {%- assign product_form_id = 'product-form-' | append: section.id -%}
          <product-form>
            <div class="product-form__error-message-wrapper" role="alert" hidden>
              <span class="product-form__error-message"></span>
            </div>
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id" disabled>
              <button type="submit" name="add" class="inline-flex items-center justify-center gap-2 rounded-full bg-foreground px-10 py-4 font-body text-sm font-semibold uppercase tracking-[0.18em] text-background transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
                {% if current_variant.available == false %}disabled{% endif %}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-shopping-bag h-4 w-4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                <span>
                  {%- if current_variant.available -%}
                    {{ section.settings.btn_text | default: 'Buy now' }}
                  {%- else -%}
                    {{ 'products.product.sold_out' | t | default: 'Udsolgt' }}
                  {%- endif -%}
                </span>
                {%- render 'loading-spinner' -%}
              </button>
            {%- endform -%}
          </product-form>
        {%- else -%}
          <button class="inline-flex items-center justify-center gap-2 rounded-full bg-foreground px-10 py-4 font-body text-sm font-semibold uppercase tracking-[0.18em] text-background transition-opacity hover:opacity-90">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-shopping-bag h-4 w-4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            {{ section.settings.btn_text }}
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FP CTA Box",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "product", "id": "product", "label": "Select Product (Enables Add to Cart)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to feel the difference?" },
    { "type": "text", "id": "description", "label": "Description", "default": "Order your FitnessPlate XD today with free delivery and 30-day satisfaction guarantee." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Buy now — £825" }
  ],
  "presets": [
    { "name": "FP CTA Box" }
  ]
}
{% endschema %}

<section class="woc-section-py md:py-36 bg-white">
  <div class="container mx-auto px-4 max-w-3xl text-center">
    <div>
      {% if section.settings.icon_svg != blank %}
        <div class="mx-auto flex justify-center [&>svg]:w-12 [&>svg]:h-12">
          {{ section.settings.icon_svg }}
        </div>
      {% endif %}
      
      {% if section.settings.heading != blank %}
        <h2 class="font-display text-3xl md:text-4xl font-light text-neutral-800 mt-8 mb-6">{{ section.settings.heading }}</h2>
      {% endif %}
      
      <p class="font-display text-xl md:text-2xl lg:text-[26px] font-light text-neutral-500 leading-[1.7] mt-10 max-w-2xl mx-auto {% if section.settings.italic_text %}italic{% endif %}">
        {{ section.settings.text }}
      </p>

      {% if section.settings.button_text != blank %}
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-all duration-500 bg-neutral-900 hover:bg-neutral-800 text-white uppercase tracking-[0.15em] text-[11px] px-10 h-12 mt-10" href="{{ section.settings.button_link }}">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beauty Text Intro",
  "settings": [
    {
      "type": "html",
      "id": "icon_svg",
      "label": "Icon SVG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (Optional)"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Main Text"
    },
    {
      "type": "checkbox",
      "id": "italic_text",
      "label": "Italicize Text",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Beauty Text Intro"
    }
  ]
}
{% endschema %}

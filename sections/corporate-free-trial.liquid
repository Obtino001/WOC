{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-corporate-dark relative overflow-hidden">
  <!-- Decorative Blurs -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-corporate/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-corporate/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/4"></div>
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex-1 flex flex-col justify-end pb-12 lg:pb-16 w-full pt-40">
    <div class="max-w-4xl mx-auto">
      
      <div class="text-center mb-10">
        <span class="inline-flex items-center gap-2 font-body text-sm font-semibold tracking-widest uppercase text-corporate bg-corporate/10 px-4 py-2 rounded-full mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-4 h-4"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
          {{ section.settings.badge }}
        </span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-white leading-tight mb-5">{{ section.settings.heading }}</h2>
        <p class="font-body text-base md:text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
      </div>
      
      <div class="grid sm:grid-cols-2 gap-4 max-w-xl mx-auto mb-10">
        {%- for block in section.blocks -%}
          <div class="flex items-start gap-3" {{ block.shopify_attributes }}>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big w-5 h-5 text-corporate flex-shrink-0 mt-0.5"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg>
            <span class="font-body text-sm text-white/80">{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
      
      <div class="text-center">
        <a href="{{ section.settings.btn_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-corporate hover:bg-corporate/90 text-white font-body font-bold px-10 py-5 h-auto rounded-full text-sm uppercase tracking-wider shadow-[0_0_30px_rgba(91,154,125,0.3)]">
          {{ section.settings.btn_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate Free Trial",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 52 },
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "Free trial period" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Try our recovery solution <br><span class=\"text-corporate\">2 weeks — completely free</span>" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Experience the difference for yourself. We deliver, install, and provide full support — so your employees can feel the effect of professional recovery. No commitment, no risk." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Book a free trial" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit List Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Corporate Free Trial" }
  ]
}
{% endschema %}

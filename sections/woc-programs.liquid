<section class="woc-section-py bg-neutral-50 text-neutral-900 border-t border-neutral-200">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Title -->
    <div class="text-center mb-14">
      <div class="luxury-line mx-auto mb-8"></div>
      {%- if section.settings.label != blank -%}
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">
          {{ section.settings.label }}
        </p>
      {%- endif -%}
      <h2 class="woc-display-font text-3xl md:text-4xl font-light text-foreground leading-[1.05]">
        {{ section.settings.title }}
      </h2>
    </div>

    <!-- Programs Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
      {%- for block in section.blocks -%}
        {%- if block.type == 'program' -%}
          <div 
            class="p-6 rounded-xl bg-white border border-neutral-200 hover:border-gold/30 hover:shadow-soft transition-all duration-300 group"
            {{ block.shopify_attributes }}
          >
            <!-- Icon -->
            <div class="w-10 h-10 rounded-none bg-gold/10 flex items-center justify-center mb-4 group-hover:bg-gold/20 transition-all duration-300">
              <span class="text-gold shrink-0 flex items-center justify-center">
                {%- if block.settings.custom_icon_svg != blank -%}
                  {{ block.settings.custom_icon_svg }}
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'waves' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.5 0 2.5 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2c2.5 0 2.5 2 5 2s2.5-2 5-2c1.3 0 1.9.5 2.5 1M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2c2.5 0 2.5 2 5 2s2.5-2 5-2c1.3 0 1.9.5 2.5 1"/></svg>
                    {%- when 'activity' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                    {%- when 'flame' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                    {%- when 'brain' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3.02 3.02 0 0 1 0-3.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3.02 3.02 0 0 0 0-3.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2Z"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>
            </div>
            
            <p class="font-body text-xs font-semibold text-neutral-800 leading-relaxed">{{ block.settings.label }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

  </div>
</section>

{% schema %}
{
  "name": "WOC Programs Grid",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "INTELLIGENT PROGRAMMES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "7 Ways to Unwind"
    }
  ],
  "blocks": [
    {
      "type": "program",
      "name": "Program Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Preset Icon",
          "options": [
            { "value": "waves", "label": "Wave Massage" },
            { "value": "activity", "label": "Physical Stretch" },
            { "value": "flame", "label": "Soothing Heat" },
            { "value": "brain", "label": "AI Brain" }
          ],
          "default": "waves"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG XML code here to override the preset icon selection."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Program Label",
          "default": "Full body auto massage"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Programs Grid",
      "blocks": [
        { "type": "program", "settings": { "icon": "waves", "label": "Auto full-body programme" } },
        { "type": "program", "settings": { "icon": "activity", "label": "Stretch full-body massage" } },
        { "type": "program", "settings": { "icon": "waves", "label": "Wave full-body soothing" } },
        { "type": "program", "settings": { "icon": "activity", "label": "Cradle full-body rocking" } },
        { "type": "program", "settings": { "icon": "waves", "label": "Targeted shoulder & neck zone" } },
        { "type": "program", "settings": { "icon": "flame", "label": "Targeted lumbar warming relief" } },
        { "type": "program", "settings": { "icon": "activity", "label": "Targeted leg & calf pressure" } }
      ]
    }
  ]
}
{% endschema %}

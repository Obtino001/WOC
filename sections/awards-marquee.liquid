{% schema %}
{
  "name": "Awards Marquee",
  "settings": [],
  "blocks": [
    {
      "type": "award",
      "name": "Award",
      "settings": [
        { "type": "text", "id": "title", "label": "Award Title", "default": "Güzellik Ödülü 2024" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Altın Kazanan" }
      ]
    }
  ],
  "presets": [{ "name": "Awards Marquee" }]
}
{% endschema %}

<section class="bg-neutral-900 py-6 overflow-hidden">
  <div class="flex items-center gap-16 animate-marquee whitespace-nowrap">
    {% for block in section.blocks %}
    <div class="flex items-center gap-3 flex-shrink-0" {{ block.shopify_attributes }}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-amber-400"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"></path><circle cx="12" cy="8" r="6"></circle></svg>
      <div>
        <p class="text-white text-xs font-bold tracking-widest uppercase" style="font-family: system-ui, sans-serif">{{ block.settings.title }}</p>
        <p class="text-neutral-400 text-[10px] tracking-wider uppercase" style="font-family: system-ui, sans-serif">{{ block.settings.subtitle }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<style>
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .animate-marquee { animation: marquee 20s linear infinite; }
</style>

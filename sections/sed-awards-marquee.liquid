{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding overflow-hidden">
  <div class="relative flex overflow-x-hidden">
    <div class="flex items-center gap-16 animate-marquee whitespace-nowrap" style="animation-duration: {{ section.settings.speed }}s;">
      {%- for i in (1..3) -%}
        {% for block in section.blocks %}
          <div class="flex items-center gap-3 flex-shrink-0" {{ block.shopify_attributes }}>
            <div class="[&>svg]:w-8 [&>svg]:h-8 [&>svg]:text-amber-400">
              {{ block.settings.icon_svg }}
            </div>
            <div>
              <p class="text-foreground text-xs font-bold tracking-widest uppercase" style="font-family: system-ui, sans-serif;">
                {{ block.settings.title }}
              </p>
              <p class="text-muted-foreground text-[10px] tracking-wider uppercase" style="font-family: system-ui, sans-serif;">
                {{ block.settings.subtitle }}
              </p>
            </div>
          </div>
        {% endfor %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SED Awards Marquee",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 64, "step": 4, "unit": "px", "label": "Padding Top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 64, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 24 },
    { "type": "range", "id": "speed", "min": 10, "max": 100, "step": 5, "unit": "sec", "label": "Animation Speed", "default": 30 }
  ],
  "blocks": [
    {
      "type": "award",
      "name": "Award",
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon SVG", "default": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"></path><circle cx=\"12\" cy=\"8\" r=\"6\"></circle></svg>" },
        { "type": "text", "id": "title", "label": "Title", "default": "Beauty Award 2024" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Gold Winner" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Awards Marquee" }
  ]
}
{% endschema %}

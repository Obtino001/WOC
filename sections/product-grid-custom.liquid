<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<section class="py-20 {% if section.settings.bg_style == 'warm' %}section-light-warm{% else %}section-light{% endif %}" id="{{ section.settings.section_id }}">
  <div class="mx-auto px-4 lg:px-8 {% if section.settings.page_width == 'full' %}w-full{% elsif section.settings.page_width == 'narrow' %}max-w-[1000px]{% else %}page-width{% endif %}">
    
    <div class="text-center mb-14">
      <p class="font-body text-sm uppercase tracking-[0.25em] {% if section.settings.badge_color == 'forest' %}text-forest{% else %}text-gold{% endif %} mb-4">
        {{ section.settings.badge }}
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">{{ section.settings.title }}</h2>
      <p class="font-body text-muted-foreground mt-4 max-w-2xl mx-auto">{{ section.settings.description }}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {% for block in section.blocks %}
        {% assign product = block.settings.product_ref %}
        
        <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 relative border border-neutral-100 h-full flex flex-col" {{ block.shopify_attributes }}>
          <a class="block flex-1 flex flex-col" href="{% if product != blank %}{{ product.url }}{% else %}{{ block.settings.link }}{% endif %}">
            
            {% if block.settings.card_badge != blank %}
              <div class="absolute top-3 left-3 z-10 flex gap-1.5">
                <span class="bg-neutral-900 text-white font-body text-[10px] font-bold px-2.5 py-1 rounded-sm uppercase tracking-wide">
                  {{ block.settings.card_badge }}
                </span>
              </div>
            {% endif %}

            <div class="relative aspect-square bg-neutral-50 overflow-hidden">
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-contain p-4 transition-transform duration-500 group-hover:scale-105' }}
              {% elsif product != blank %}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-contain p-4 transition-transform duration-500 group-hover:scale-105' }}
              {% endif %}
            </div>

            <div class="p-4 bg-white flex flex-col flex-1">
              
              <!-- Review Stars -->
              <div class="flex items-center gap-1 mb-2">
                {% for i in (1..5) %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 {% if i <= 4 %}fill-copper text-copper{% else %}fill-neutral-200 text-neutral-200{% endif %}"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                {% endfor %}
                <span class="font-body text-[11px] text-neutral-500 ml-1">{{ block.settings.review_text }}</span>
              </div>

              <!-- Title & Price -->
              <h3 class="font-body text-base font-bold text-neutral-900 mb-1 line-clamp-2 leading-tight min-h-[2.5rem]">
                {% if product != blank %}{{ product.title }}{% else %}{{ block.settings.title }}{% endif %}
              </h3>
              <div class="flex items-baseline gap-2 mb-2">
                <span class="font-body text-lg font-bold text-neutral-900">
                  {% if product != blank %}{{ product.price | money }}{% else %}{{ block.settings.price }}{% endif %}
                </span>
              </div>

              <!-- Bullets -->
              <!-- Bullets -->
              <div class="flex flex-wrap gap-1.5 mb-3 flex-1 content-start">
                {% assign has_usps = false %}
                {% if product != blank and product.metafields.custom.products_usps != blank %}
                  {% assign has_usps = true %}
                  {% assign usps_string = product.metafields.custom.products_usps.value | join: ',' | default: product.metafields.custom.products_usps.value %}
                  {% assign usps_array = usps_string | split: ',' %}
                  {% for usp in usps_array limit: 4 %}
                    <div class="flex items-center gap-1.5 bg-neutral-100/50 border border-neutral-200/50 rounded-md px-2 py-1">
                      {% render 'usp-icon', keyword: usp %}
                      <span class="font-body text-[10px] text-neutral-600 leading-tight">{{ usp | strip }}</span>
                    </div>
                  {% endfor %}
                {% endif %}
                
                {% if has_usps == false %}
                  {% for i in (1..4) %}
                    {% capture bullet_var %}bullet_{{ i }}{% endcapture %}
                    {% assign bullet_text = block.settings[bullet_var] %}
                    {% if bullet_text != blank %}
                      <div class="flex items-center gap-1.5 bg-neutral-100/50 border border-neutral-200/50 rounded-md px-2 py-1">
                        {% render 'usp-icon', keyword: bullet_text %}
                        <span class="font-body text-[10px] text-neutral-600 leading-tight">{{ bullet_text }}</span>
                      </div>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
            </a>

            <div class="mt-auto pt-3 flex flex-col gap-3">
              <!-- Stock -->
              <div class="flex items-center gap-1.5">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                <span class="font-body text-[11px] font-semibold text-emerald-600">{{ section.settings.stock_text }}</span>
              </div>
              {%- if product != blank -%}
                {%- assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id -%}
                <product-form>
                  {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" class="product-variant-id">
                    <button type="submit" name="add" class="inline-flex items-center justify-center gap-2 whitespace-nowrap transition-all duration-500 px-4 w-full bg-copper hover:bg-copper-hover text-white font-body text-sm font-bold py-2.5 rounded-lg h-auto uppercase tracking-wider"
                      {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                      <span>
                        {%- if product.selected_or_first_available_variant.available -%}
                          {{ section.settings.btn_text }}
                        {%- else -%}
                          {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
                        {%- endif -%}
                      </span>
                      {%- render 'loading-spinner' -%}
                    </button>
                  {%- endform -%}
                </product-form>
              {%- else -%}
                <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap transition-all duration-500 px-4 w-full bg-copper hover:bg-copper-hover text-white font-body text-sm font-bold py-2.5 rounded-lg h-auto uppercase tracking-wider">
                  {{ section.settings.btn_text }}
                </button>
              {%- endif -%}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section HTML ID (e.g., 'shop')"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background Style",
      "options": [
        {"value": "warm", "label": "Warm Light"},
        {"value": "light", "label": "Standard Light"}
      ],
      "default": "warm"
    },
    {
      "type": "select",
      "id": "badge_color",
      "label": "Top Badge Color",
      "options": [
        {"value": "gold", "label": "Gold"},
        {"value": "forest", "label": "Forest Green"}
      ],
      "default": "gold"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {"value": "full", "label": "Full Width"},
        {"value": "standard", "label": "Standard Width"},
        {"value": "narrow", "label": "Narrow Width"}
      ],
      "default": "standard"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Top Badge",
      "default": "Yorganlar"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Doğal Dolgulu Yorganlar"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "stock_text",
      "label": "Stock Status Text",
      "default": "Stokta · Bugün gönderilir"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "BURADAN SATIN AL"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product_ref",
          "label": "Select Backend Product (Optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Manual Link (If no product selected)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override Image"
        },
        {
          "type": "text",
          "id": "card_badge",
          "label": "Card Badge (e.g., Lüks)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Manual Title"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Manual Price (e.g., ₺10.035)"
        },
        {
          "type": "text",
          "id": "review_text",
          "label": "Review Text",
          "default": "4.7 üzerinden 210 yorumlar"
        },
        {
          "type": "text",
          "id": "bullet_1",
          "label": "Bullet Point 1"
        },
        {
          "type": "text",
          "id": "bullet_2",
          "label": "Bullet Point 2"
        },
        {
          "type": "text",
          "id": "bullet_3",
          "label": "Bullet Point 3"
        },
        {
          "type": "text",
          "id": "bullet_4",
          "label": "Bullet Point 4"
        }
      ]
    }
  ],
  "presets": [{"name": "Custom Product Grid"}]
}
{% endschema %}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient border-b border-border section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    
    <div class="text-center mb-14">
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl lg:text-5xl mb-5">{{ section.settings.heading }}</h2>
      <p class="font-body text-base text-muted-foreground max-w-3xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-14">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          <div class="rounded-2xl border border-border bg-background p-7 shadow-soft" {{ block.shopify_attributes }}>
            <h3 class="font-display text-lg font-bold text-foreground mb-3">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-muted-foreground leading-relaxed mb-5">{{ block.settings.description }}</p>
            <div class="flex items-baseline gap-2 rounded-xl bg-muted px-4 py-3">
              <span class="font-display text-2xl font-bold text-foreground">{{ block.settings.stat_val }}</span>
              <span class="font-body text-[11px] text-muted-foreground">{{ block.settings.stat_label }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="rounded-2xl border border-border bg-background p-8 md:p-10">
      <h3 class="font-display text-xl font-semibold text-foreground mb-4">{{ section.settings.list_heading }}</h3>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
        {% for block in section.blocks %}
          {% if block.type == 'list_item' %}
            <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-green-600 shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
              <span class="font-body text-sm text-foreground">{{ block.settings.text }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "FP Info Cards",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 112 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "LYMPHATIC TRAINING & SWELLING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Eliminate swelling in legs and feet" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "text", "id": "list_heading", "label": "Checklist Heading", "default": "Who benefits from a lymphatic training device?" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Info Card",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "stat_val", "label": "Stat Value" },
        { "type": "text", "id": "stat_label", "label": "Stat Label" }
      ]
    },
    {
      "type": "list_item",
      "name": "Checklist Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Info Cards" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-card border-y border-border section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-2 gap-8 text-center md:grid-cols-4">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          <p class="font-body text-sm font-bold tracking-wide text-foreground">{{ block.settings.title }}</p>
          <p class="mt-1 font-body text-xs text-muted-foreground">{{ block.settings.subtitle }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HW Guarantees Bar",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "guarantee",
      "name": "Guarantee",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" }
      ]
    }
  ],
  "presets": [
    { "name": "HW Guarantees Bar" }
  ]
}
{% endschema %}

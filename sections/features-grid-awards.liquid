<section class="woc-section-py bg-white">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="space-y-0">
      {% for block in section.blocks %}
        {% assign is_rtl = forloop.index | modulo: 2 %}
        <div class="grid lg:grid-cols-2 gap-0 min-h-[50vh] {% if is_rtl == 0 %}lg:[direction:rtl]{% endif %}" {{ block.shopify_attributes }}>
          
          <!-- Image Part -->
          <div class="relative overflow-hidden aspect-[4/3] lg:aspect-auto">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
            {% endif %}
          </div>

          <!-- Content Part -->
          <div class="flex flex-col justify-center p-8 md:p-14 lg:p-16 bg-[#f8f7f4] {% if is_rtl == 0 %}lg:[direction:ltr]{% endif %}">
            <span class="font-display text-5xl font-extralight text-neutral-200 mb-4">{{ block.settings.number }}</span>
            <h3 class="font-display text-2xl md:text-3xl font-light text-neutral-800 mb-5">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-neutral-500 leading-[1.9]">{{ block.settings.description }}</p>
            
            {% if block.settings.btn_text != blank %}
              <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-all duration-500 py-2 mt-8 bg-neutral-900 hover:bg-neutral-800 text-white uppercase tracking-[0.15em] text-[11px] rounded-none px-8 h-11 w-fit" href="{{ block.settings.btn_url }}">
                {{ block.settings.btn_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature Grid awards",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        { "type": "text", "id": "number", "label": "Index Number (e.g. 01)", "default": "01" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "btn_text", "label": "Button Text (Optional)" },
        { "type": "url", "id": "btn_url", "label": "Button Link" }
      ]
    }
  ],
  "presets": [{ "name": "Feature Grid awards" }]
}
{% endschema %}
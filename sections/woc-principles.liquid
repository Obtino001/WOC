<section class="py-24 md:py-32" style="background: rgb(248, 245, 238);">
  <div class="container mx-auto px-4 lg:px-8 max-w-7xl">
    <div class="text-center mb-16">
      <span class="inline-block font-body text-xs font-semibold tracking-widest uppercase mb-4" style="color: rgb(14, 92, 92);">{{ section.settings.badge_text }}</span>
      <h2 class="font-display text-3xl md:text-5xl font-bold leading-tight" style="color: rgb(15, 31, 46);">{{ section.settings.title }}</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          <div class="h-full p-8 md:p-10 rounded-2xl border" style="background: white; border-color: rgba(14, 92, 92, 0.12);">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: rgba(14, 92, 92, 0.08);">
              <div class="lucide-icon w-6 h-6" style="color: rgb(14, 92, 92);">
                {{ block.settings.svg_icon }}
              </div>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold mb-3" style="color: rgb(15, 31, 46);">{{ block.settings.title }}</h3>
            <p class="font-body text-sm md:text-base leading-relaxed text-neutral-600">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC Principles",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "Temelimiz" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Fark yaratan dört ilke" }
  ],
  "blocks": [
    {
      "type": "principle",
      "name": "Principle Box",
      "settings": [
        { "type": "html", "id": "svg_icon", "label": "SVG Icon Code" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "WOC Principles" }]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-card border-b border-border section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-6xl">
    
    <div class="text-center mb-10">
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl">{{ section.settings.heading }}</h2>
      <p class="mt-3 font-body text-base text-muted-foreground max-w-xl mx-auto">{{ section.settings.description }}</p>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-10">
      <button class="rounded-full px-5 py-2 font-body text-xs font-medium uppercase tracking-wider transition-colors bg-foreground text-background">All exercises</button>
      <button class="rounded-full px-5 py-2 font-body text-xs font-medium uppercase tracking-wider transition-colors bg-background border border-border text-muted-foreground hover:text-foreground">Core</button>
      <button class="rounded-full px-5 py-2 font-body text-xs font-medium uppercase tracking-wider transition-colors bg-background border border-border text-muted-foreground hover:text-foreground">Strength</button>
      <button class="rounded-full px-5 py-2 font-body text-xs font-medium uppercase tracking-wider transition-colors bg-background border border-border text-muted-foreground hover:text-foreground">Flexibility</button>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for block in section.blocks %}
        <div class="group rounded-2xl border border-border bg-background overflow-hidden hover:border-foreground/20 transition-colors" {{ block.shopify_attributes }}>
          <div class="overflow-hidden bg-muted aspect-[4/3] flex items-center justify-center">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-500', loading: 'lazy' }}
            {% else %}
               {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 bg-gray-200' }}
            {% endif %}
          </div>
          <div class="p-5">
            <span class="inline-block rounded-full bg-foreground/5 px-3 py-1 font-body text-[10px] font-medium uppercase tracking-wider text-muted-foreground mb-2">{{ block.settings.category }}</span>
            <h3 class="font-display text-lg font-bold text-foreground mb-1">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="flex items-center justify-center gap-4 mt-10">
      <button disabled class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-foreground disabled:opacity-30 hover:bg-muted transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-chevron-left w-4 h-4"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      <span class="font-body text-sm text-muted-foreground">1 / 2</span>
      <button class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-foreground hover:bg-muted transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-chevron-right w-4 h-4"><path d="m9 18 6-6-6-6"></path></svg>
      </button>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FP Exercise Grid",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "OVER 100 EXERCISES POSSIBLE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Exercise Guide" },
    { "type": "textarea", "id": "description", "label": "Description" }
  ],
  "blocks": [
    {
      "type": "exercise",
      "name": "Exercise Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "category", "label": "Category Tag" },
        { "type": "text", "id": "title", "label": "Exercise Name" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Exercise Grid" }
  ]
}
{% endschema %}
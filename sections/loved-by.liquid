<main class="section-{{ section.id }}">
  <!-- Hero Section -->
  <section class="relative min-h-[55vh] md:min-h-[65vh] flex items-center justify-center overflow-hidden">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: class: 'absolute inset-0 w-full h-full object-cover', loading: 'eager' }}
    {% endif %}
    <div class="absolute inset-0 bg-black/30"></div>
    <div class="relative z-10 text-center px-4">
      <div class="flex items-center justify-center gap-4 mb-3">
        <div class="w-16 h-px bg-gold"></div><div class="w-16 h-px bg-gold"></div>
      </div>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-light text-white uppercase tracking-[0.08em]">
        {{ section.settings.hero_title }} 
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart inline w-10 h-10 md:w-14 md:h-14 text-pink-400 fill-pink-400 mx-2 -mt-2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg> 
        {{ section.settings.hero_title_suffix }}
      </h1>
      <div class="flex items-center justify-center gap-4 mt-3">
        <div class="w-16 h-px bg-gold"></div><div class="w-16 h-px bg-gold"></div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 md:py-28 bg-background">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <h2 class="font-display text-2xl md:text-4xl font-light text-foreground leading-relaxed mb-6 uppercase tracking-wide">{{ section.settings.intro_heading }}</h2>
      <p class="font-body text-[11px] uppercase tracking-[0.25em] text-muted-foreground">{{ section.settings.intro_subtext }}</p>
    </div>
  </section>

  <!-- Influencer Grid -->
  <section class="pb-20 md:pb-28 bg-background">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {% for block in section.blocks %}
          {% if block.type == 'influencer' %}
            <div class="text-center" {{ block.shopify_attributes }}>
              <div class="relative p-[3px] bg-gradient-to-br from-gold/60 via-gold/30 to-gold/60">
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full aspect-[4/5] object-cover', loading: 'lazy' }}
              </div>
              <div class="flex items-center justify-center gap-3 mt-5">
                <div class="w-6 h-px bg-gold"></div>
                <p class="font-display text-sm md:text-base tracking-[0.15em] text-foreground">{{ block.settings.name }}</p>
                <div class="w-6 h-px bg-gold"></div>
              </div>
              <p class="font-body text-xs text-muted-foreground italic mt-1">{{ block.settings.role }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-neutral-900">
    <div class="container mx-auto px-4 max-w-2xl text-center">
      <h2 class="font-display text-3xl md:text-4xl font-light text-white mb-8">{{ section.settings.cta_heading }}</h2>
      <a class="inline-block bg-white hover:bg-neutral-100 text-neutral-900 uppercase tracking-[0.15em] text-[11px] px-10 py-4 transition-colors" href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
    </div>
  </section>
</main>

{% schema %}
{
  "name": "Loved By Page",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "hero_title", "label": "Hero Title", "default": "Sevilen" },
    { "type": "text", "id": "hero_title_suffix", "label": "Hero Suffix", "default": "Tarafından" },
    { "type": "text", "id": "intro_heading", "label": "Intro Heading" },
    { "type": "text", "id": "intro_subtext", "label": "Intro Subtext" },
    { "type": "text", "id": "cta_heading", "label": "CTA Heading" },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text" },
    { "type": "url", "id": "cta_url", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "influencer",
      "name": "Influencer",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "role", "label": "Role/Title" }
      ]
    }
  ],
  "presets": [{ "name": "Loved By Section" }]
}
{% endschema %}
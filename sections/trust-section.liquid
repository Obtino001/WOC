{% comment %} ─── Trust Section — 1:1 from TrustSection.tsx ─── {% endcomment %}
<section class="py-8 lg:py-10 bg-background border-y border-white/10" data-animate>
  <div class="container mx-auto px-4 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-0">

      {% comment %} Review Badges {% endcomment %}
      <div class="flex items-center gap-6 lg:gap-8 pr-0 lg:pr-10 lg:border-r border-white/10 shrink-0">
        {% if section.settings.show_google %}
          <a href="{{ section.settings.google_link | default: 'https://www.google.com/search?q=World+of+Comfort+reviews' }}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
            <div class="w-9 h-9 rounded-full bg-card/5 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
            <div class="flex flex-col">
              <div class="flex items-center gap-1">
                {% for i in (1..5) %}
                  <svg class="w-3.5 h-3.5 fill-[#FBBC05] text-[#FBBC05]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endfor %}
              </div>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="font-body text-xs font-semibold text-white">{{ section.settings.google_rating }}</span>
                <span class="font-body text-[10px] text-white/50">• {{ section.settings.google_count }} {{ 'trust.reviews' | t | default: 'Değerlendirme' }}</span>
              </div>
              <span class="font-body text-[10px] text-white/50 group-hover:text-white/60 transition-colors">Google Reviews</span>
            </div>
          </a>
        {% endif %}

        {% if section.settings.show_google and section.settings.show_trustpilot %}
          <div class="w-px h-12 bg-white/10 hidden sm:block mx-2"></div>
        {% endif %}

        {% if section.settings.show_trustpilot %}
          <a href="{{ section.settings.trustpilot_link | default: 'https://www.trustpilot.com' }}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 group">
            <div class="w-9 h-9 rounded-full bg-card/5 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 fill-[#00b67a] text-[#00b67a]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <div class="flex flex-col">
              <div class="flex items-center gap-1">
                {% for i in (1..5) %}
                  <svg class="w-3.5 h-3.5 fill-[#00b67a] text-[#00b67a]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endfor %}
              </div>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="font-body text-xs font-semibold text-white">{{ section.settings.trustpilot_rating }}</span>
                <span class="font-body text-[10px] text-white/50">• {{ section.settings.trustpilot_count }} {{ 'trust.reviews' | t | default: 'Değerlendirme' }}</span>
              </div>
              <span class="font-body text-[10px] text-[#00b67a]/80 group-hover:text-[#00b67a] transition-colors">Trustpilot</span>
            </div>
          </a>
        {% endif %}
      </div>

      {% comment %} Trust Stats {% endcomment %}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 flex-1 lg:pl-10 mt-8 lg:mt-0 w-full">
        {% for block in section.blocks %}
          <div class="text-center flex flex-col items-center gap-1.5" {{ block.shopify_attributes }}>
            {% if block.settings.is_icon %}
              <div class="text-gold mb-1">
                {{ block.settings.icon_svg }}
              </div>
            {% endif %}
            <p class="font-display text-2xl lg:text-3xl font-light text-gold leading-none">{{ block.settings.value }}</p>
            <p class="font-body text-[10px] font-light uppercase tracking-[0.2em] text-white/50">{{ block.settings.label }}</p>
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Section",
  "settings": [
    { "type": "header", "content": "Color scheme" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    {
      "type": "header",
      "content": "Google Reviews"
    },
    { "type": "checkbox", "id": "show_google", "label": "Show Google Badge", "default": true },
    { "type": "text", "id": "google_rating", "label": "Google Rating", "default": "4.9" },
    { "type": "text", "id": "google_count", "label": "Google Review Count", "default": "847" },
    { "type": "url", "id": "google_link", "label": "Google Reviews Link" },
    {
      "type": "header",
      "content": "Trustpilot"
    },
    { "type": "checkbox", "id": "show_trustpilot", "label": "Show Trustpilot Badge", "default": true },
    { "type": "text", "id": "trustpilot_rating", "label": "Trustpilot Rating", "default": "4.6" },
    { "type": "text", "id": "trustpilot_count", "label": "Trustpilot Review Count", "default": "1.243" },
    { "type": "url", "id": "trustpilot_link", "label": "Trustpilot Link" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
    { "type": "header", "content": "Color scheme" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
        { "type": "checkbox", "id": "is_icon", "label": "Show Icon?", "default": true },
        { "type": "text", "id": "value", "label": "Value (e.g. 5)", "default": "5" },
        { "type": "html", "id": "icon_svg", "label": "SVG Icon Code" },
        { "type": "text", "id": "label", "label": "Label", "default": "Year Warranty" }
      ]
    }
  ],
  "presets": [{ 
    "name": "Trust Section",
    "blocks": [
      { "type": "stat", "settings": { "value": "5", "label": "Yıl Garanti", "icon_svg": "<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"/></svg>" } },
      { "type": "stat", "settings": { "value": "20+", "label": "Showroom", "icon_svg": "<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7\"/><path d=\"M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8\"/><path d=\"M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4\"/><path d=\"M2 7h20\"/><path d=\"M22 7v3a2 2 0 0 1-2 2a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12a2 2 0 0 1-2-2V7\"/></svg>" } },
      { "type": "stat", "settings": { "value": "50K+", "label": "Mutlu Müşteri", "icon_svg": "<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>" } },
      { "type": "stat", "settings": { "value": "24/7", "label": "Uzman Desteği", "icon_svg": "<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path d=\"M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3\"/></svg>" } }
    ]
  }]
}
{% endschema %}

<section class="relative woc-section-py bg-charcoal overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-forest/10 to-transparent pointer-events-none"></div>
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex-1 flex flex-col justify-end pb-12 lg:pb-16 w-full pt-10 text-center">
    <div style="opacity: 1; transform: none;">
      {% if section.settings.badge_text != blank %}
        <div class="inline-flex items-center gap-2 px-4 py-1.5 border border-gold/30 rounded-full bg-gold/10 mb-6">
          <span class="text-base">{{ section.settings.badge_emoji }}</span>
          <span class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-gold">{{ section.settings.badge_text }}</span>
        </div>
      {% endif %}
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-secondary leading-tight mb-6">
        {{ section.settings.heading }}
      </h1>
      <p class="font-body text-lg text-secondary/60 max-w-2xl mx-auto">
        {{ section.settings.subheading }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "badge_emoji",
      "label": "Badge Emoji",
      "default": "🇩🇰"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Made in Denmark"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Universale Senge"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "5 bölgeli cep yayları, birinci sınıf döşeme ve 15 yıla kadar garantiye sahip..."
    }
  ],
  "presets": [{"name": "Hero Banner"}]
}
{% endschema %}
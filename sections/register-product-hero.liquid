<section class="bg-neutral-50 border-b border-neutral-100 py-16 md:py-24">
  <div class="container mx-auto px-4 text-center">
    <div>
      {% if section.settings.kicker != blank %}
        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-4" style="font-family: system-ui, sans-serif;">{{ section.settings.kicker }}</p>
      {% endif %}
      
      <h1 class="text-4xl md:text-6xl font-light tracking-wider mb-4">{{ section.settings.heading }}</h1>
      
      {% if section.settings.description != blank %}
        <div class="text-sm text-neutral-500 max-w-xl mx-auto" style="font-family: system-ui, sans-serif;">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Register Hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "● REGISTER MY PRODUCT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LIFETIME WARRANTY"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p><strong>NOTE:</strong> Please submit a separate warranty registration for each product where the receipt number used is different.</p>"
    }
  ],
  "presets": [
    {
      "name": "Register Hero"
    }
  ]
}
{% endschema %}

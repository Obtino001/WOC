        { "type": "image_picker", "id": "feature_4_img", "label": "Image 4" },
        { "type": "text", "id": "feature_4_title", "label": "Title 4", "default": "Premium taşıma çantası" },
        { "type": "text", "id": "feature_4_text", "label": "Text 4", "default": "Botları her yere götürün." }
      ]
    },
    {
      "type": "recovery_benefits",
      "name": "Recovery Benefits",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "Recovery Boots neden kullanılır?" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Sıralı pnömatik kompresyon, dünya çapındaki elit sporcular tarafından klinik olarak tanınır ve kullanılır." },
        { "type": "text", "id": "benefit_1_title", "label": "Title 1", "default": "Daha hızlı iyileşme" },
        { "type": "text", "id": "benefit_1_text", "label": "Text 1", "default": "Yoğun antrenman sonrası laktik asit atılımını ve iyileşmeyi hızlandırır." },
        { "type": "text", "id": "benefit_2_title", "label": "Title 2", "default": "Daha iyi dolaşım" },
        { "type": "text", "id": "benefit_2_text", "label": "Text 2", "default": "Sıralı sıkıştırma, kanı kalbe doğru iter; bu, yorgun bacaklar için idealdir." },
        { "type": "text", "id": "benefit_3_title", "label": "Title 3", "default": "Lenfatik drenaj" },
        { "type": "text", "id": "benefit_3_text", "label": "Text 3", "default": "Özellikle uzun günlerin ardından şişliği ve sıvı tutulumunu azaltır." },
        { "type": "text", "id": "benefit_4_title", "label": "Title 4", "default": "Ağrıyı yatıştırır" },
        { "type": "text", "id": "benefit_4_text", "label": "Text 4", "default": "Zorlu antrenman sonrası DOMS'u (gecikmeli başlangıçlı kas ağrısı) azaltır." },
        { "type": "text", "id": "benefit_5_title", "label": "Title 5", "default": "Kablosuz özgürlük" },
        { "type": "text", "id": "benefit_5_text", "label": "Text 5", "default": "Arabada, kanepede, yatakta kullanın; kablo yok." },
        { "type": "text", "id": "benefit_6_title", "label": "Title 6", "default": "Stresi azaltır" },
        { "type": "text", "id": "benefit_6_text", "label": "Text 6", "default": "Çizmelerle 20-30 dakika profesyonel bir dinlenme spa'sı gibi hissettirir." },
        { "type": "text", "id": "benefit_7_title", "label": "Title 7", "default": "Daha iyi uyku" },
        { "type": "text", "id": "benefit_7_text", "label": "Text 7", "default": "Daha hafif, daha rahat bacaklar ve daha derin uyku için yatmadan önce kullanın." },
        { "type": "text", "id": "benefit_8_title", "label": "Title 8", "default": "4 saate kadar" },
        { "type": "text", "id": "benefit_8_text", "label": "Text 8", "default": "Uzun pil ömrü – tek şarjla 8-12 seans için yeterli." }
      ]
    },
    {
      "type": "therapeutic_benefits",
      "name": "Therapeutic Benefits",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Terapötik faydaları" },
        { "type": "text", "id": "title", "label": "Heading", "default": "Sakatlıkları önler · Ağrıyı giderir · Formu geri kazandırır" },
        { "type": "text", "id": "tb_1_title", "label": "Title 1", "default": "Sakatlıkları önler" },
        { "type": "text", "id": "tb_1_text", "label": "Text 1", "default": "Antrenman öncesi ve sonrası optimum dolaşım sayesinde bacak sağlığını destekler ve sporla ilgili sakatlanma riskini azaltır." },
        { "type": "text", "id": "tb_2_title", "label": "Title 2", "default": "Ağrı ve gerginliği giderir" },
        { "type": "text", "id": "tb_2_text", "label": "Text 2", "default": "Siyatik, kaval kemiği ağrısı, kas zorlanmaları ve kronik bacak gerginliği gibi sorunları hassas kompresyon terapisiyle hedefler." },
        { "type": "text", "id": "tb_3_title", "label": "Title 3", "default": "Kas ağrısını azaltır" },
        { "type": "text", "id": "tb_3_text", "label": "Text 3", "default": "DOMS'u (gecikmeli başlangıçlı kas ağrısı) etkili bir şekilde ortadan kaldırır ve seanslar arasındaki iyileşmeyi önemli ölçüde hızlandırır." }
      ]
    },
    {
      "type": "massage_modes",
      "name": "Massage Modes",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "3 masaj modu" },
        { "type": "text", "id": "title", "label": "Heading", "default": "Kişiye özel iyileşme" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Vücudun doğal kan ve lenfatik akışını taklit eden üç akıllı program." },
        { "type": "text", "id": "mode_1_title", "label": "Mode 1 Title", "default": "Sıralı Mod" },
        { "type": "text", "id": "mode_1_text", "label": "Mode 1 Text", "default": "Ayaktan uyluğa kadar bölmeleri kan ve lenfatik akışı taklit eden dalga hareketleriyle şişirir. Uzun bir gün veya ağır bir antrenmandan sonra nazik, yenileyici iyileşme için idealdir." },
        { "type": "text", "id": "mode_2_title", "label": "Mode 2 Title", "default": "Dolaşım Modu" },
        { "type": "text", "id": "mode_2_text", "label": "Mode 2 Text", "default": "Baldırlar ve uyluklar gibi belirli bölgeler arasında sıkıştırmayı değiştirir. Yerel kan akışını iyileştirir ve şişliği azaltır; kaval kemiği ağrısı ve gergin kaslar için mükemmeldir." },
        { "type": "text", "id": "mode_3_title", "label": "Mode 3 Title", "default": "Kombinasyon Modu" },
        { "type": "text", "id": "mode_3_text", "label": "Mode 3 Text", "default": "Tüm bölmelere aynı anda eş zamanlı sıkıştırma sağlar. Kapsamlı kas rahatlaması ve kronik durumlar için derin, tutarlı terapötik basınç." },
        { "type": "text", "id": "pressure_kicker", "label": "Pressure Kicker", "default": "Ayarlanabilir yoğunluk" },
        { "type": "text", "id": "pressure_val", "label": "Pressure Value", "default": "0 — 260 mmHg" },
        { "type": "text", "id": "pressure_desc", "label": "Pressure Desc", "default": "Her seansı kişiselleştirin; nazik basınçtan derin terapiye kadar. Çizmeler, sizin özel iyileşme ihtiyaçlarınıza uyum sağlar." }
      ]
    },
    {
      "type": "text_content",
      "name": "Rich Text Content",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "Profesyonel iyileşme çözümü" },
        { "type": "richtext", "id": "text", "label": "Content", "default": "<p><strong>WOC Recovery Boots Pro</strong> , antrenman sonrası daha hızlı iyileşme, uzun ve yorucu günler veya ağır, şiş bacakları rahatlatmak için profesyonel çözümdür. Her bir botta <strong>8 hava haznesi</strong>, elit sporcuların müsabakalar arasında daha hızlı dönmek için kullandığı aynı teknoloji olan hassas sıralı kompresyon masajı sunarlar.</p><p>Bu botları benzersiz kılan şey, <strong>%100 kablosuz</strong> olmalarıdır. Batarya, kompakt kontrolöre doğrudan entegre edilmiştir, böylece onları antrenman sonrası arabada, soyunma odasında, kanepede veya yatakta dilediğiniz her yerde özgürce kullanabilirsiniz. Kablo yok, sınır yok.</p><p>Şunlar arasından seçim yapın: <strong>6 önceden programlanmış masaj modu</strong> ve basıncı 0 ila 260 mmHg arasında 8 seviyede hassas bir şekilde ayarlayın. Şeffaf renkli ekran zamanı, basıncı, modu ve pili gösterir – kolay ve sezgisel kontroller.</p><p>İle <strong>4 saate kadar pil ömrüyle</strong> ve sadece 1 kg ağırlığıyla kontrol cihazı her yere sizinle birlikte seyahat etmek için üretilmiştir. Şarj olurken de kullanılabilir. Dahil olan birinci sınıf taşıma çantası, botları antrenman kampına, maça veya tatile götürmeyi kolaylaştırır.</p><p>Hem günlük sporcular hem de elit sporcular için üretilmiştir – triatletlerden ve bisikletçilerden, uzun bir günün ardından rahatlamaya ihtiyaç duyan yoğun ayaklara kadar.</p>" }
      ]
    },
    {
      "type": "how_it_works",
      "name": "How It Works",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "Nasıl çalışır" },
        { "type": "text", "id": "step_1_title", "label": "Step 1", "default": "Giymek" },

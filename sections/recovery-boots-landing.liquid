{% comment %}
  Section: Recovery Boots Landing Page Mega Section
{% endcomment %}

<div class="recovery-boots-landing-wrapper" id="section-{{ section.id }}">
  {% for block in section.blocks %}
    {% case block.type %}
      
      {% comment %} 1. TECH FEATURES {% endcomment %}
      {% when 'tech_features' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-500 text-center mb-10 max-w-xl mx-auto">{{ block.settings.subtitle | escape }}</p>
            <div class="grid md:grid-cols-2 gap-6">
              {% for i in (1..4) %}
                {% assign title_key = 'feature_' | append: i | append: '_title' %}
                {% assign text_key = 'feature_' | append: i | append: '_text' %}
                {% assign img_key = 'feature_' | append: i | append: '_img' %}
                
                {% if block.settings[title_key] != blank %}
                  <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-neutral-100">
                    <div class="aspect-square bg-neutral-50">
                      {% if block.settings[img_key] != blank %}
                        <img src="{{ block.settings[img_key] | image_url: width: 600 }}" alt="{{ block.settings[title_key] | escape }}" loading="lazy" class="w-full h-full object-contain p-6" />
                      {% else %}
                        {% assign default_img = '/assets/recovery-boots-pro-01-BqStoFjR.jpg' %}
                        {% if i == 2 %}{% assign default_img = '/assets/recovery-boots-pro-02-controller-D-1lJBb7.jpg' %}{% endif %}
                        {% if i == 3 %}{% assign default_img = '/assets/recovery-boots-pro-04-controller-detail-BgMDyPLk.jpg' %}{% endif %}
                        {% if i == 4 %}{% assign default_img = '/assets/recovery-boots-pro-05-bag-C_VdqXXZ.jpg' %}{% endif %}
                        <img src="{{ default_img }}" alt="{{ block.settings[title_key] | escape }}" loading="lazy" class="w-full h-full object-contain p-6" />
                      {% endif %}
                    </div>
                    <div class="p-5">
                      <h3 class="font-heading text-lg font-bold text-neutral-900 mb-1 uppercase">{{ block.settings[title_key] | escape }}</h3>
                      <p class="font-body text-sm text-neutral-500">{{ block.settings[text_key] | escape }}</p>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 2. RECOVERY BENEFITS {% endcomment %}
      {% when 'recovery_benefits' %}
        <section class="py-16 bg-white" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-500 text-center mb-12 max-w-2xl mx-auto">{{ block.settings.subtitle | escape }}</p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {% for i in (1..8) %}
                {% assign title_key = 'benefit_' | append: i | append: '_title' %}
                {% assign text_key = 'benefit_' | append: i | append: '_text' %}
                {% if block.settings[title_key] != blank %}
                  <div class="flex flex-col items-center text-center p-5 rounded-xl bg-neutral-50 border border-neutral-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 rounded-full bg-copper/10 flex items-center justify-center mb-3">
                      {% case i %}
                        {% when 1 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg>
                        {% when 2 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
                        {% when 3 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"></path><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"></path></svg>
                        {% when 4 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg>
                        {% when 5 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M12.8 19.6A2 2 0 1 0 14 16H2"></path><path d="M17.5 8a2.5 2.5 0 1 1 2 4H2"></path><path d="M9.8 4.4A2 2 0 1 1 11 8H2"></path></svg>
                        {% when 6 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"></path><path d="M3.477 10.896a4 4 0 0 1 .585-.396"></path><path d="M19.938 10.5a4 4 0 0 1 .585.396"></path><path d="M6 18a4 4 0 0 1-1.967-.516"></path><path d="M19.967 17.484A4 4 0 0 1 18 18"></path></svg>
                        {% when 7 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
                        {% when 8 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><rect width="16" height="10" x="2" y="7" rx="2" ry="2"></rect><line x1="22" x2="22" y1="11" y2="13"></line></svg>
                      {% endcase %}
                    </div>
                    <h3 class="font-body text-sm font-bold text-neutral-800 mb-1.5">{{ block.settings[title_key] | escape }}</h3>
                    <p class="font-body text-xs text-neutral-500 leading-relaxed">{{ block.settings[text_key] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 3. THERAPEUTIC BENEFITS {% endcomment %}
      {% when 'therapeutic_benefits' %}
        <section class="py-16 bg-neutral-900 text-white" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <p class="font-body text-xs uppercase tracking-[0.2em] text-copper text-center mb-3">{{ block.settings.kicker | escape }}</p>
            <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-12 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid md:grid-cols-3 gap-6">
              {% for i in (1..3) %}
                {% assign title_key = 'tb_' | append: i | append: '_title' %}
                {% assign text_key = 'tb_' | append: i | append: '_text' %}
                {% if block.settings[title_key] != blank %}
                  <div class="flex flex-col p-7 rounded-xl bg-neutral-800/60 border border-neutral-700 hover:border-copper/40 transition-colors">
                    <div class="w-12 h-12 rounded-full bg-copper/15 flex items-center justify-center mb-4">
                      {% case i %}
                        {% when 1 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
                        {% when 2 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg>
                        {% when 3 %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg>
                      {% endcase %}
                    </div>
                    <h3 class="font-heading text-lg font-bold mb-2">{{ block.settings[title_key] | escape }}</h3>
                    <p class="font-body text-sm text-neutral-300 leading-relaxed">{{ block.settings[text_key] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 4. MASSAGE MODES {% endcomment %}
      {% when 'massage_modes' %}
        <section class="py-16 bg-white" {{ block.shopify_attributes }}>
          <div class="max-w-6xl mx-auto px-4">
            <p class="font-body text-xs uppercase tracking-[0.2em] text-copper text-center mb-3">{{ block.settings.kicker | escape }}</p>
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-500 text-center mb-12 max-w-2xl mx-auto">{{ block.settings.subtitle | escape }}</p>
            <div class="grid md:grid-cols-3 gap-6">
              {% for i in (1..3) %}
                {% assign title_key = 'mode_' | append: i | append: '_title' %}
                {% assign text_key = 'mode_' | append: i | append: '_text' %}
                {% if block.settings[title_key] != blank %}
                  <div class="flex flex-col p-7 rounded-xl bg-neutral-50 border border-neutral-200 hover:border-copper/50 hover:shadow-lg transition-all">
                    <span class="font-heading text-3xl font-bold text-copper mb-3">0{{ i }}</span>
                    <h3 class="font-heading text-lg font-bold text-neutral-900 mb-2 uppercase">{{ block.settings[title_key] | escape }}</h3>
                    <p class="font-body text-sm text-neutral-600 leading-relaxed">{{ block.settings[text_key] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            <div class="mt-10 rounded-xl border border-copper/30 bg-copper/5 p-6 text-center">
              <p class="font-body text-xs uppercase tracking-widest text-copper font-bold mb-2">{{ block.settings.pressure_kicker | escape }}</p>
              <p class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900">{{ block.settings.pressure_val | escape }}</p>
              <p class="font-body text-sm text-neutral-600 mt-2 max-w-xl mx-auto">{{ block.settings.pressure_desc | escape }}</p>
            </div>
          </div>
        </section>

      {% comment %} 5. TEXT CONTENT {% endcomment %}
      {% when 'text_content' %}
        <section class="py-16" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-6 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="font-body text-neutral-600 text-base leading-relaxed space-y-4">
              {{ block.settings.text }}
            </div>
          </div>
        </section>

      {% comment %} 6. HOW IT WORKS {% endcomment %}
      {% when 'how_it_works' %}
        <section class="bg-neutral-900 text-white py-16" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-12 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid md:grid-cols-3 gap-8">
              {% for i in (1..3) %}
                {% assign step_title = 'step_' | append: i | append: '_title' %}
                {% assign step_text = 'step_' | append: i | append: '_text' %}
                {% if block.settings[step_title] != blank %}
                  <div class="text-center">
                    <div class="w-16 h-16 rounded-full bg-copper/20 flex items-center justify-center mx-auto mb-4">
                      <span class="font-heading text-2xl font-bold text-copper">{{ i }}</span>
                    </div>
                    <h3 class="font-heading text-lg font-bold mb-3 uppercase">{{ block.settings[step_title] | escape }}</h3>
                    <p class="font-body text-sm text-neutral-300 leading-relaxed">{{ block.settings[step_text] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 7. COMPARISON TABLE {% endcomment %}
      {% when 'comparison_table' %}
        <section class="py-16" {{ block.shopify_attributes }}>
          <div class="max-w-3xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-center text-neutral-500 mb-8">{{ block.settings.subtitle | escape }}</p>
            <div class="rounded-xl overflow-hidden border border-neutral-200">
              <div class="grid grid-cols-3 bg-neutral-100">
                <div class="p-4 font-body text-sm font-semibold text-neutral-500"></div>
                <div class="p-4 font-body text-sm font-bold text-center text-copper">WOC</div>
                <div class="p-4 font-body text-sm font-semibold text-center text-neutral-400">Diğer</div>
              </div>
              {% for i in (1..10) %}
                {% assign feature_key = 'comp_' | append: i %}
                {% assign has_it_key = 'has_it_' | append: i %}
                {% if block.settings[feature_key] != blank %}
                  {% assign row_bg = 'bg-white' %}
                  {% assign is_even = i | modulo: 2 %}
                  {% if is_even == 0 %}{% assign row_bg = 'bg-neutral-50' %}{% endif %}
                  <div class="grid grid-cols-3 {{ row_bg }}">
                    <div class="p-4 font-body text-sm text-neutral-700">{{ block.settings[feature_key] | escape }}</div>
                    <div class="p-4 flex justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-emerald-500"><path d="M20 6 9 17l-5-5"></path></svg>
                    </div>
                    <div class="p-4 flex justify-center">
                      {% if block.settings[has_it_key] %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-emerald-500"><path d="M20 6 9 17l-5-5"></path></svg>
                      {% else %}
                        <span class="w-5 h-5 rounded-full border-2 border-neutral-300 flex items-center justify-center text-neutral-300 text-xs">✕</span>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 8. ADVANTAGES {% endcomment %}
      {% when 'advantages' %}
        <section class="py-16 bg-white" {{ block.shopify_attributes }}>
          <div class="max-w-6xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-copper italic mb-10 text-center">{{ block.settings.title | escape }}</h2>
            <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
              
              <div class="rounded-2xl border border-copper/30 bg-copper/5 p-6 lg:p-8 flex flex-col">
                <div class="aspect-square bg-white rounded-xl overflow-hidden mb-6 flex items-center justify-center">
                  {% if block.settings.adv_img_left != blank %}
                    <img src="{{ block.settings.adv_img_left | image_url: width: 600 }}" alt="{{ block.settings.adv_title_left | escape }}" class="w-full h-full object-contain p-4" />
                  {% else %}
                    <img src="/assets/recovery-boots-pro-01-BqStoFjR.jpg" alt="WOC Recovery Boots Pro" class="w-full h-full object-contain p-4" />
                  {% endif %}
                </div>
                <div class="flex items-center gap-3 mb-5">
                  <div class="w-9 h-9 rounded-md border-2 border-copper flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-copper"><path d="M20 6 9 17l-5-5"></path></svg>
                  </div>
                  <h3 class="font-heading text-2xl font-bold text-neutral-900">{{ block.settings.adv_title_left | escape }}</h3>
                </div>
                <ul class="space-y-3 font-body text-sm text-neutral-800">
                  {% for i in (1..6) %}
                    {% assign li_key = 'adv_li_left_' | append: i %}
                    {% if block.settings[li_key] != blank %}
                      <li class="flex items-start justify-between gap-3 border-b border-copper/10 pb-2 last:border-0">
                        <span class="flex-1">› {{ block.settings[li_key] | escape }}</span>
                        {% if i == 1 or i == 3 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-copper flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>

              <div class="rounded-2xl border border-neutral-200 bg-neutral-100 p-6 lg:p-8 flex flex-col">
                <div class="aspect-square bg-neutral-200/60 rounded-xl overflow-hidden mb-6 flex items-center justify-center">
                  <div class="text-neutral-400 font-body text-xs uppercase tracking-widest text-center px-6">
                    {{ block.settings.adv_img_right_text | escape }}
                  </div>
                </div>
                <div class="flex items-center gap-3 mb-5">
                  <div class="w-9 h-9 rounded-md border-2 border-neutral-500 flex items-center justify-center">
                    <span class="font-heading text-xl font-bold text-neutral-700 leading-none">×</span>
                  </div>
                  <h3 class="font-heading text-2xl font-bold text-neutral-700">{{ block.settings.adv_title_right | escape }}</h3>
                </div>
                <ul class="space-y-3 font-body text-sm text-neutral-600">
                  {% for i in (1..6) %}
                    {% assign li_key = 'adv_li_right_' | append: i %}
                    {% if block.settings[li_key] != blank %}
                      <li class="flex items-start justify-between gap-3 border-b border-neutral-300/60 pb-2 last:border-0">
                        <span class="flex-1">› {{ block.settings[li_key] | escape }}</span>
                        {% if i == 1 or i == 3 %}
                          <span class="font-heading text-base font-bold text-neutral-500 leading-none flex-shrink-0">×</span>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>

            </div>
          </div>
        </section>

      {% comment %} 9. TECH SPECS (Using same design style as previous version) {% endcomment %}
      {% when 'tech_specs' %}
        <section class="py-16" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-8 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {% for i in (1..10) %}
                {% assign label_key = 'spec_label_' | append: i %}
                {% assign val_key = 'spec_val_' | append: i %}
                {% if block.settings[label_key] != blank %}
                  <div class="flex justify-between items-center p-4 bg-neutral-50 rounded-lg border border-neutral-100 gap-3">
                    <span class="font-body text-sm font-semibold text-neutral-700">{{ block.settings[label_key] | escape }}</span>
                    <span class="font-body text-sm text-neutral-500 text-right">{{ block.settings[val_key] | escape }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 10. TESTIMONIALS {% endcomment %}
      {% when 'testimonials' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <div class="text-center mb-10">
              <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 uppercase mb-2">{{ block.settings.title | escape }}</h2>
              <div class="flex items-center justify-center gap-2">
                <div class="flex gap-0.5">
                  {% for i in (1..5) %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 fill-copper text-copper"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                  {% endfor %}
                </div>
                <span class="font-body text-sm text-neutral-500">{{ block.settings.rating_text | escape }}</span>
              </div>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
              {% for i in (1..3) %}
                {% assign quote_key = 'quote_' | append: i %}
                {% assign author_key = 'author_' | append: i %}
                {% if block.settings[quote_key] != blank %}
                  <div class="bg-white p-6 rounded-xl shadow-sm border border-neutral-100">
                    <div class="flex gap-0.5 mb-3">
                      {% for j in (1..5) %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 fill-copper text-copper"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                      {% endfor %}
                    </div>
                    <p class="font-body text-sm text-neutral-600 leading-relaxed mb-4 italic">"{{ block.settings[quote_key] | escape }}"</p>
                    <p class="font-body text-sm font-bold text-neutral-800">{{ block.settings[author_key] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 11. FAQ {% endcomment %}
      {% when 'faq' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-3xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-8 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="space-y-2 faq-accordion-container">
              {% for i in (1..8) %}
                {% assign q_key = 'faq_q_' | append: i %}
                {% assign a_key = 'faq_a_' | append: i %}
                {% if block.settings[q_key] != blank %}
                  <div class="border border-neutral-200 rounded-lg px-4 bg-white faq-item">
                    <button class="flex w-full items-center justify-between transition-all font-body text-sm font-semibold text-neutral-800 py-4 hover:no-underline text-left faq-trigger">
                      {{ block.settings[q_key] | escape }}
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 transition-transform duration-200 faq-icon"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    <div class="overflow-hidden text-sm transition-all h-0 faq-content-wrapper">
                      <div class="pb-4 pt-0 font-body text-neutral-600 faq-content">
                        {{ block.settings[a_key] }}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 12. CONTACT {% endcomment %}
      {% when 'contact' %}
        <section class="bg-neutral-100 py-12" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            <h2 class="font-heading text-xl lg:text-2xl font-bold text-neutral-900 mb-8 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid sm:grid-cols-3 gap-6">
              {% if block.settings.email_val != blank %}
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-neutral-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper mb-3"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                  <p class="font-body text-xs font-bold text-neutral-700 mb-1">{{ block.settings.email_label | escape }}</p>
                  <p class="font-body text-xs text-neutral-500">{{ block.settings.email_val | escape }}</p>
                </div>
              {% endif %}
              {% if block.settings.chat_val != blank %}
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-neutral-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper mb-3"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
                  <p class="font-body text-xs font-bold text-neutral-700 mb-1">{{ block.settings.chat_label | escape }}</p>
                  <p class="font-body text-xs text-neutral-500">{{ block.settings.chat_val | escape }}</p>
                </div>
              {% endif %}
              {% if block.settings.phone_val != blank %}
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-neutral-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper mb-3"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  <p class="font-body text-xs font-bold text-neutral-700 mb-1">{{ block.settings.phone_label | escape }}</p>
                  <p class="font-body text-xs text-neutral-500">{{ block.settings.phone_val | escape }}</p>
                </div>
              {% endif %}
            </div>
          </div>
        </section>

      {% comment %} 13. CTA FOOTER {% endcomment %}
      {% when 'cta_footer' %}
        <section class="relative py-20 overflow-hidden" {{ block.shopify_attributes }}>
          <div class="absolute inset-0 bg-neutral-900"></div>
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(184,115,51,0.15),transparent_70%)]"></div>
          <div class="relative max-w-2xl mx-auto px-4 text-center text-white">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-4 uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-300 mb-8 leading-relaxed">{{ block.settings.text | escape }}</p>
            
            <form action="/cart/add" method="post" enctype="multipart/form-data">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 py-2 h-14 px-12 text-base font-bold uppercase tracking-widest bg-copper hover:bg-copper/90 text-white rounded-xl shadow-lg">
                {{ block.settings.btn_text | escape }}
              </button>
            </form>

            <div class="flex flex-wrap items-center justify-center gap-6 mt-6 text-neutral-400 font-body text-xs">
              <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg> {{ block.settings.trust_1 | escape }}</span>
              <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg> {{ block.settings.trust_2 | escape }}</span>
              <span class="flex items-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> {{ block.settings.trust_3 | escape }}</span>
            </div>
          </div>
        </section>

    {% endcase %}
  {% endfor %}
</div>

<style>
  :root { --color-copper: #b87333; }
  .text-copper { color: var(--color-copper); }
  .bg-copper { background-color: var(--color-copper); }
  .fill-copper { fill: var(--color-copper); }
  .faq-icon.open { transform: rotate(180deg); }
  .bg-copper\/5 { background-color: rgba(184,115,51,0.05); }
  .bg-copper\/10 { background-color: rgba(184,115,51,0.10); }
  .bg-copper\/15 { background-color: rgba(184,115,51,0.15); }
  .border-copper\/30 { border-color: rgba(184,115,51,0.30); }
  .border-copper\/10 { border-color: rgba(184,115,51,0.10); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const triggers = document.querySelectorAll('.faq-trigger');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', function() {
        const wrapper = this.nextElementSibling;
        const icon = this.querySelector('.faq-icon');
        const content = wrapper.querySelector('.faq-content');
        const isOpen = wrapper.style.height !== '0px' && wrapper.style.height !== '';
        document.querySelectorAll('.faq-content-wrapper').forEach(w => { w.style.height = '0px'; });
        document.querySelectorAll('.faq-icon').forEach(i => { i.classList.remove('open'); });
        if (!isOpen) {
          wrapper.style.height = content.offsetHeight + 'px';
          icon.classList.add('open');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "WOC Recovery Boots",
  "settings": [],
  "blocks": [
    {

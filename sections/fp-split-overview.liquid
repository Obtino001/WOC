{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-foreground section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-6xl">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      
      <div>
        <h2 class="font-display text-3xl font-bold text-background md:text-4xl mb-4">{{ section.settings.heading }}</h2>
        <p class="font-body text-base text-background/70 leading-relaxed mb-8">{{ section.settings.description }}</p>
        
        <div class="grid grid-cols-2 gap-x-8 gap-y-3">
          {% for block in section.blocks %}
            <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
              <span class="w-2 h-2 rounded-full bg-gold flex-shrink-0"></span>
              <span class="font-body text-sm text-background">{{ block.settings.text }}</span>
            </div>
          {% endfor %}
        </div>
      </div>

      <div>
        <div class="overflow-hidden rounded-2xl">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 800 | image_tag: class: 'w-full aspect-square object-cover', loading: 'lazy' }}
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full aspect-square object-cover bg-gray-600' }}
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "FP Split Overview",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The complete Pilates Reformer experience" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Split Overview" }
  ]
}
{% endschema %}
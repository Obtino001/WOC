{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="relative overflow-hidden section-{{ section.id }}-padding" style="background: linear-gradient(135deg, hsl(var(--background)) 0%, hsl(var(--muted)) 100%);">
  <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 30%, hsl(var(--gold) / 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 70%, hsl(var(--gold) / 0.1) 0%, transparent 50%);"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      
      {% if section.settings.badge_text != blank %}
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 border" style="border-color: hsl(var(--gold) / 0.3); background: hsl(var(--gold) / 0.08);">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-3.5 h-3.5" style="color: hsl(var(--gold))"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path></svg>
          <span class="text-xs font-semibold uppercase tracking-widest" style="color: hsl(var(--gold))">{{ section.settings.badge_text }}</span>
        </div>
      {% endif %}

      <h2 class="font-display text-3xl md:text-5xl font-bold text-foreground mb-5 leading-tight">
        {{ section.settings.heading }}
      </h2>
      
      <p class="text-base md:text-lg text-muted-foreground mb-10 max-w-2xl mx-auto leading-relaxed">
        {{ section.settings.description }}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a class="group inline-flex items-center gap-3 px-8 py-4 rounded-full text-background font-semibold text-base transition-all duration-300 hover:scale-105 shadow-lg" href="{{ section.settings.btn_link }}" style="background: hsl(var(--gold))">
          <span>{{ section.settings.btn_text }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-4 h-4 transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <span class="text-xs text-muted-foreground">{{ section.settings.btn_subtext }}</span>
      </div>

      <div class="mt-10 grid grid-cols-3 gap-6 max-w-xl mx-auto">
        {% for block in section.blocks %}
          <div class="text-center" {{ block.shopify_attributes }}>
            <div class="font-display text-2xl md:text-3xl font-bold mb-1" style="color: hsl(var(--gold))">{{ block.settings.value }}</div>
            <div class="text-xs text-muted-foreground uppercase tracking-wider">{{ block.settings.label }}</div>
          </div>
        {% endfor %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz Hero",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 },
    { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "Personal recommendation" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your perfect massage chair in 60 seconds" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Answer 6 quick questions — we'll match you with the exact chair among our 13 models that suits your needs, your body, and your budget." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Start free quiz" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "text", "id": "btn_subtext", "label": "Button Subtext", "default": "✓ Takes 60 seconds · ✓ No obligations · ✓ 100% free" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "value", "label": "Value" },
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    { "name": "Quiz Hero" }
  ]
}
{% endschema %}
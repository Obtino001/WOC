{% comment %}
  Section: NordicSole Landing Page Mega Section
  Description: A fully modular, block-based mega section for the NordicSole product page.
{% endcomment %}

<div class="nordicsole-landing-wrapper" id="section-{{ section.id }}">
  {% for block in section.blocks %}
    {% case block.type %}
      
      {% comment %} 1. VIDEO SECTION {% endcomment %}
      {% when 'video' %}
        <section class="bg-neutral-50 py-16" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            {% if block.settings.title != blank %}
              <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">
                {{ block.settings.title | escape }}
              </h2>
            {% endif %}
            <div class="relative aspect-video bg-neutral-900 rounded-2xl overflow-hidden shadow-xl">
              {% if block.settings.video_url != blank %}
                <iframe
                  src="https://www.youtube-nocookie.com/embed/{{ block.settings.video_url.id }}?autoplay=1&rel=0&modestbranding=1"
                  title="{{ block.settings.title | escape }}"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  class="w-full h-full border-0 absolute inset-0"
                ></iframe>
              {% endif %}
            </div>
          </div>
        </section>

      {% comment %} 2. BENEFITS SECTION {% endcomment %}
      {% when 'benefits' %}
        <section class="py-16 bg-white" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">
              {{ block.settings.title | escape }}
            </h2>
            <p class="font-body text-neutral-500 text-center mb-12 max-w-2xl mx-auto">
              {{ block.settings.subtitle | escape }}
            </p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {% for i in (1..6) %}
                {% assign title_key = 'benefit_' | append: i | append: '_title' %}
                {% assign text_key = 'benefit_' | append: i | append: '_text' %}
                {% if block.settings[title_key] != blank %}
                  <div class="flex flex-col items-center text-center p-5 rounded-xl bg-neutral-50 border border-neutral-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 rounded-full bg-copper/10 flex items-center justify-center mb-3">
                      {% case i %}
                        {% when 1 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
                        {% when 2 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg>
                        {% when 3 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"></path><path d="M3.477 10.896a4 4 0 0 1 .585-.396"></path><path d="M19.938 10.5a4 4 0 0 1 .585.396"></path><path d="M6 18a4 4 0 0 1-1.967-.516"></path><path d="M19.967 17.484A4 4 0 0 1 18 18"></path></svg>
                        {% when 4 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
                        {% when 5 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg>
                        {% when 6 %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper"><path d="M4 16v-2.38C4 11.5 2.97 10.5 3 8c.03-2.72 1.49-6 4.5-6C9.37 2 10 3.8 10 5.5c0 3.11-2 5.66-2 8.68V16a2 2 0 1 1-4 0Z"></path><path d="M20 20v-2.38c0-2.12 1.03-3.12 1-5.62-.03-2.72-1.49-6-4.5-6C14.63 6 14 7.8 14 9.5c0 3.11 2 5.66 2 8.68V20a2 2 0 1 0 4 0Z"></path><path d="M16 17h4"></path><path d="M4 13h4"></path></svg>
                      {% endcase %}
                    </div>
                    <h3 class="font-body text-sm font-bold text-neutral-800 mb-1.5">{{ block.settings[title_key] }}</h3>
                    <p class="font-body text-xs text-neutral-500 leading-relaxed">{{ block.settings[text_key] }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 3. USAGE SCENARIOS {% endcomment %}
      {% when 'usage' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-6xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-500 text-center mb-10 max-w-xl mx-auto">{{ block.settings.subtitle | escape }}</p>
            <div class="grid sm:grid-cols-2 gap-4">
              {% for i in (1..4) %}
                {% assign img_key = 'image_' | append: i %}
                {% assign label_key = 'label_' | append: i %}
                {% if block.settings[img_key] != blank %}
                  <div class="group relative rounded-xl overflow-hidden aspect-[4/3]">
                    <img src="{{ block.settings[img_key] | image_url: width: 800 }}" alt="{{ block.settings[label_key] | escape }}" loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                    <span class="absolute bottom-4 left-4 font-body text-sm font-semibold text-white">{{ block.settings[label_key] | escape }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 4. TEXT CONTENT {% endcomment %}
      {% when 'text_content' %}
        <section class="py-16" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-6 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="font-body text-neutral-600 text-base leading-relaxed space-y-4">
              {{ block.settings.text }}
            </div>
          </div>
        </section>

      {% comment %} 5. FEATURES GALLERY {% endcomment %}
      {% when 'features_gallery' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-500 text-center mb-10 max-w-xl mx-auto">{{ block.settings.subtitle | escape }}</p>
            <div class="space-y-4">
              {% for i in (1..6) %}
                {% assign img_key = 'image_' | append: i %}
                {% if block.settings[img_key] != blank %}
                  <div class="rounded-xl overflow-hidden shadow-sm">
                    <img src="{{ block.settings[img_key] | image_url: width: 1200 }}" loading="lazy" class="w-full" alt="Feature {{ i }}" />
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 6. PRODUCT DETAILS GALLERY {% endcomment %}
      {% when 'product_details' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-neutral-500 text-center mb-10 max-w-xl mx-auto">{{ block.settings.subtitle | escape }}</p>
            <div class="grid md:grid-cols-2 gap-4">
              {% for i in (1..4) %}
                {% assign img_key = 'image_' | append: i %}
                {% if block.settings[img_key] != blank %}
                  <div class="rounded-xl overflow-hidden bg-white shadow-sm">
                    <img src="{{ block.settings[img_key] | image_url: width: 800 }}" loading="lazy" class="w-full aspect-[4/3] object-cover" alt="Detail {{ i }}" />
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 7. HOW IT WORKS {% endcomment %}
      {% when 'how_it_works' %}
        <section class="bg-neutral-900 text-white py-16" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-12 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid md:grid-cols-3 gap-8">
              {% for i in (1..3) %}
                {% assign step_title = 'step_' | append: i | append: '_title' %}
                {% assign step_text = 'step_' | append: i | append: '_text' %}
                {% if block.settings[step_title] != blank %}
                  <div class="text-center">
                    <div class="w-16 h-16 rounded-full bg-copper/20 flex items-center justify-center mx-auto mb-4">
                      <span class="font-heading text-2xl font-bold text-copper">{{ i }}</span>
                    </div>
                    <h3 class="font-heading text-lg font-bold mb-3 uppercase">{{ block.settings[step_title] | escape }}</h3>
                    <p class="font-body text-sm text-neutral-300 leading-relaxed">{{ block.settings[step_text] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 8. COMPARISON {% endcomment %}
      {% when 'comparison' %}
        <section class="py-16" {{ block.shopify_attributes }}>
          <div class="max-w-3xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-3 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <p class="font-body text-center text-neutral-500 mb-8">{{ block.settings.subtitle | escape }}</p>
            <div class="rounded-xl overflow-hidden border border-neutral-200">
              <div class="grid grid-cols-3 bg-neutral-100">
                <div class="p-4 font-body text-sm font-semibold text-neutral-500"></div>
                <div class="p-4 font-body text-sm font-bold text-center text-copper">WOC</div>
                <div class="p-4 font-body text-sm font-semibold text-center text-neutral-400">Diğer</div>
              </div>
              {% for i in (1..7) %}
                {% assign feature_key = 'feature_' | append: i %}
                {% assign has_it_key = 'has_it_' | append: i %}
                {% if block.settings[feature_key] != blank %}
                  {% assign row_bg = 'bg-white' %}
                  {% assign is_even = i | modulo: 2 %}
                  {% if is_even == 0 %}{% assign row_bg = 'bg-neutral-50' %}{% endif %}
                  
                  <div class="grid grid-cols-3 {{ row_bg }}">
                    <div class="p-4 font-body text-sm text-neutral-700">{{ block.settings[feature_key] }}</div>
                    <div class="p-4 flex justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-emerald-500"><path d="M20 6 9 17l-5-5"></path></svg>
                    </div>
                    <div class="p-4 flex justify-center">
                      {% if block.settings[has_it_key] %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-emerald-500"><path d="M20 6 9 17l-5-5"></path></svg>
                      {% else %}
                        <span class="w-5 h-5 rounded-full border-2 border-neutral-300 flex items-center justify-center text-neutral-300 text-xs">✕</span>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 9. IN THE BOX {% endcomment %}
      {% when 'in_the_box' %}
        <section class="bg-neutral-900 text-white py-16" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-10 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {% for i in (1..4) %}
                {% assign item_title = 'item_' | append: i | append: '_title' %}
                {% assign item_subtitle = 'item_' | append: i | append: '_subtitle' %}
                {% if block.settings[item_title] != blank %}
                  <div class="flex flex-col items-center text-center p-6 bg-white/5 rounded-xl border border-white/10">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-copper mb-3"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"></path><path d="m7.5 4.27 9 5.15"></path></svg>
                    <span class="font-body text-sm font-semibold">{{ block.settings[item_title] | escape }}</span>
                    <span class="font-body text-xs text-neutral-400 mt-1">{{ block.settings[item_subtitle] | escape }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 10. TESTIMONIALS {% endcomment %}
      {% when 'testimonials' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-5xl mx-auto px-4">
            <div class="text-center mb-10">
              <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 uppercase mb-2">{{ block.settings.title | escape }}</h2>
              <div class="flex items-center justify-center gap-2">
                <div class="flex gap-0.5">
                  {% for i in (1..5) %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 fill-copper text-copper"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                  {% endfor %}
                </div>
                <span class="font-body text-sm text-neutral-500">{{ block.settings.rating_text | escape }}</span>
              </div>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
              {% for i in (1..3) %}
                {% assign quote_key = 'quote_' | append: i %}
                {% assign author_key = 'author_' | append: i %}
                {% if block.settings[quote_key] != blank %}
                  <div class="bg-white p-6 rounded-xl shadow-sm border border-neutral-100">
                    <div class="flex gap-0.5 mb-3">
                      {% for j in (1..5) %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 fill-copper text-copper"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                      {% endfor %}
                    </div>
                    <p class="font-body text-sm text-neutral-600 leading-relaxed mb-4 italic">"{{ block.settings[quote_key] | escape }}"</p>
                    <p class="font-body text-sm font-bold text-neutral-800">{{ block.settings[author_key] | escape }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 11. TECH SPECS {% endcomment %}
      {% when 'tech_specs' %}
        <section class="py-16" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-8 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {% for i in (1..10) %}
                {% assign label_key = 'spec_label_' | append: i %}
                {% assign val_key = 'spec_val_' | append: i %}
                {% if block.settings[label_key] != blank %}
                  <div class="flex justify-between items-center p-4 bg-neutral-50 rounded-lg border border-neutral-100">
                    <span class="font-body text-sm font-semibold text-neutral-700">{{ block.settings[label_key] | escape }}</span>
                    <span class="font-body text-sm text-neutral-500">{{ block.settings[val_key] | escape }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 12. FAQ {% endcomment %}
      {% when 'faq' %}
        <section class="py-16 bg-neutral-50" {{ block.shopify_attributes }}>
          <div class="max-w-3xl mx-auto px-4">
            <h2 class="font-heading text-2xl lg:text-3xl font-bold text-neutral-900 mb-8 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="space-y-2 faq-accordion-container">
              {% for i in (1..8) %}
                {% assign q_key = 'faq_q_' | append: i %}
                {% assign a_key = 'faq_a_' | append: i %}
                {% if block.settings[q_key] != blank %}
                  <div class="border border-neutral-200 rounded-lg px-4 bg-white faq-item">
                    <button class="flex w-full items-center justify-between transition-all font-body text-sm font-semibold text-neutral-800 py-4 hover:no-underline text-left faq-trigger">
                      {{ block.settings[q_key] | escape }}
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0 transition-transform duration-200 faq-icon"><path d="m6 9 6 6 6-6"></path></svg>
                    </button>
                    <div class="overflow-hidden text-sm transition-all h-0 faq-content-wrapper">
                      <div class="pb-4 pt-0 font-body text-neutral-600 faq-content">
                        {{ block.settings[a_key] }}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>

      {% comment %} 13. CONTACT {% endcomment %}
      {% when 'contact' %}
        <section class="bg-neutral-100 py-12" {{ block.shopify_attributes }}>
          <div class="max-w-4xl mx-auto px-4">
            <h2 class="font-heading text-xl lg:text-2xl font-bold text-neutral-900 mb-8 text-center uppercase">{{ block.settings.title | escape }}</h2>
            <div class="grid sm:grid-cols-3 gap-6">
              {% if block.settings.email_val != blank %}
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-neutral-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper mb-3"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                  <p class="font-body text-xs font-bold text-neutral-700 mb-1">{{ block.settings.email_label | escape }}</p>
                  <p class="font-body text-xs text-neutral-500">{{ block.settings.email_val | escape }}</p>
                </div>
              {% endif %}
              {% if block.settings.chat_val != blank %}
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-neutral-200">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-copper mb-3"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
                  <p class="font-body text-xs font-bold text-neutral-700 mb-1">{{ block.settings.chat_label | escape }}</p>
                  <p class="font-body text-xs text-neutral-500">{{ block.settings.chat_val | escape }}</p>
                </div>
              {% endif %}
              {% if block.settings.phone_val != blank %}
                <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-neutral-200">

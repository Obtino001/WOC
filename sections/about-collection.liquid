<section class="py-16 bg-neutral-50">
  <div class="container mx-auto px-4 lg:px-8 max-w-3xl">
    <div class="text-center">
      <h2 class="font-body text-2xl md:text-3xl font-bold text-neutral-900 mb-4">{{ section.settings.heading }}</h2>
      <div class="font-body text-sm md:text-base text-neutral-600 leading-relaxed space-y-4">
        {{ section.settings.text }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Om vores massageapparater"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Vores mission er at gøre professionel massage tilgængelig for alle. Vi har cuttet dyre mellemled og leverer direkte til den kvalitetsbevidste forbruger, som ikke ønsker at betale overpris.</p>"
    }
  ],
  "presets": [
    {
      "name": "About Collection"
    }
  ]
}
{% endschema %}

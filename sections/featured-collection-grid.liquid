<section id="{{ section.settings.section_id }}" class="py-16 bg-white">
  <div class="container mx-auto px-4 lg:px-8">
    
    {% if section.settings.show_discount_banner %}
      <div class="bg-gold/10 border border-gold/20 rounded-xl p-4 mb-6">
        <div class="flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-gold flex-shrink-0 mt-0.5"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle></svg>
          <div>
            <p class="font-body text-sm font-semibold text-foreground mb-1">{{ section.settings.discount_title }}</p>
            <div class="flex flex-wrap gap-x-6 gap-y-1">
              {{ section.settings.discount_text }}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    <h2 class="font-body text-2xl md:text-3xl font-bold text-neutral-900 text-center mb-10">{{ section.settings.heading }}</h2>
    
    {% if section.settings.show_filters %}
      <div class="flex items-center justify-between mb-6 max-w-5xl mx-auto">
        <p class="font-body text-sm text-neutral-500">{{ section.settings.collection.products_count | default: '13' }} products</p>
        <select class="font-body text-xs border border-neutral-200 rounded-none px-3 py-2 bg-white text-neutral-700 focus:outline-none focus:ring-2 focus:ring-copper/30">
          <option value="popular">Most Popular</option>
          <option value="price-low">Price: Low to High</option>
          <option value="price-high">Price: High to Low</option>
        </select>
      </div>
    {% endif %}

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
    {% assign target_collection = section.settings.collection %}
{% if target_collection.products == blank %}
  {% assign target_collection = collections[section.settings.collection] %}
{% endif %}
      {% for product in target_collection.products limit: section.settings.limit %}
        
        <a class="block h-full" href="{{ product.url }}">
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 relative border border-neutral-100 h-full flex flex-col">
            
            <div class="absolute top-3 left-3 z-10 flex gap-1.5">
              {% if product.metafields.custom.product_tags != blank %}
                <span class="bg-neutral-900 text-white font-body text-[10px] font-bold px-2.5 py-1 rounded-sm uppercase tracking-wide">{{ product.metafields.custom.product_tags }}</span>
              {% elsif product.tags contains 'Bestseller' %}
                <span class="bg-neutral-900 text-white font-body text-[10px] font-bold px-2.5 py-1 rounded-sm uppercase tracking-wide">BESTSELLER</span>
              {% endif %}
              {% if product.compare_at_price > product.price %}
                <span class="bg-copper text-white font-body text-[10px] font-bold px-2.5 py-1 rounded-sm">Tilbud</span>
              {% endif %}
            </div>

            <div class="relative aspect-square bg-neutral-50 overflow-hidden">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 400 | image_tag: class: 'w-full h-full object-contain p-4 transition-transform duration-500 group-hover:scale-105', loading: 'lazy' }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-contain p-4' }}
              {% endif %}
            </div>

            <div class="p-4 bg-white flex flex-col flex-1">
              <div class="flex items-center gap-1 mb-2">
                {% for i in (1..5) %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 fill-copper text-copper"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                {% endfor %}
                <span class="font-body text-[11px] text-neutral-500 ml-1">
                  {% if product.metafields.custom.reviews != blank %}
                    {{ product.metafields.custom.reviews }}
                  {% else %}
                    {{ product.metafields.reviews.rating.value | default: '4.7' }} ({{ product.metafields.reviews.rating_count.value | default: '102' }} reviews)
                  {% endif %}
                </span>
              </div>
              
              <h3 class="font-body text-base font-bold text-neutral-900 mb-1 line-clamp-2 leading-tight min-h-[2.5rem]">{{ product.title | default: 'Product Title' }}</h3>
              
              <div class="flex items-baseline gap-2 mb-2">
                <span class="font-body text-lg font-bold text-neutral-900">{{ product.price | default: 12100 | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="font-body text-sm text-neutral-400 line-through">{{ product.compare_at_price | money }}</span>
                  {% assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                  <span class="font-body text-xs font-semibold text-copper">Spar {{ savings }}%</span>
                {% endif %}
              </div>
              
              <ul class="space-y-1 mb-3 flex-1 min-h-[5.5rem]">
                {% assign features_string = product.metafields.custom.products_usps.value | join: ',' | default: product.metafields.custom.products_usps.value %}
                {% if features_string != blank %}
                  {% assign features = features_string | split: ',' %}
                  {% for feature in features limit: 4 %}
                    <li class="flex items-start gap-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-copper flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
                      <span class="font-body text-[11px] text-neutral-600 leading-tight line-clamp-1">{{ feature | strip }}</span>
                    </li>
                  {% endfor %}
                {% else %}
                  <li class="flex items-start gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-copper flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg><span class="font-body text-[11px] text-neutral-600 leading-tight line-clamp-1">Smart Pressure Technology</span></li>
                  <li class="flex items-start gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-copper flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg><span class="font-body text-[11px] text-neutral-600 leading-tight line-clamp-1">3200 strokes/min</span></li>
                {% endif %}
              </ul>
              
              {% if product.available != false %}
                <div class="flex items-center gap-1.5 mb-3">
                  <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span></span>
                  <span class="font-body text-xs font-semibold text-emerald-600">På lager · Sendes i dag</span>
                </div>
                <button class="w-full bg-copper hover:bg-copper-hover text-white font-body text-sm font-bold py-2.5 rounded-none h-auto uppercase tracking-wider mt-auto transition-all duration-300">KØB HER</button>
              {% else %}
                <div class="flex items-center gap-1.5 mb-3">
                  <span class="relative flex h-2 w-2"><span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span></span>
                  <span class="font-body text-xs font-semibold text-amber-600">Midlertidigt udsolgt</span>
                </div>
                <button class="w-full border border-neutral-300 text-neutral-600 font-body text-sm font-bold py-2.5 rounded-none h-auto uppercase tracking-wider mt-auto" disabled>UDSOLGT</button>
              {% endif %}
            </div>
          </div>
        </a>
      {% else %}
        {% for i in (1..4) %}
           <div class="group bg-white rounded-xl overflow-hidden border border-neutral-100 h-full flex flex-col p-4 text-center">
             {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full object-contain mb-4' }}
             <h3 class="font-body text-base font-bold text-neutral-900 mb-1">Product Title</h3>
             <span class="font-body text-lg font-bold text-neutral-900">£199</span>
           </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "HTML ID (for anchoring)",
      "default": "products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ALLE PRODUKTER"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 24,
      "step": 4,
      "label": "Product Limit",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show Filter/Sort Bar",
      "default": false
    },
    {
      "type": "header",
      "content": "Discount Banner"
    },
    {
      "type": "checkbox",
      "id": "show_discount_banner",
      "label": "Show Discount Banner",
      "default": false
    },
    {
      "type": "text",
      "id": "discount_title",
      "label": "Discount Title",
      "default": "Mængderabat"
    },
    {
      "type": "html",
      "id": "discount_text",
      "label": "Discount Text (HTML allowed)",
      "default": "<span class=\"font-body text-xs text-gold\">Køb 2+ → <strong>-5%</strong></span><span class=\"font-body text-xs text-gold\">Køb 3+ → <strong>-10%</strong></span>"
    }
  ],
  "presets": [
    {
      "name": "Featured Product Grid"
    }
  ]
}
{% endschema %}

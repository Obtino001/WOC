<section class="relative py-24 bg-charcoal overflow-hidden ">
  <div class="absolute inset-0 bg-gradient-to-br from-forest/10 to-transparent pointer-events-none"> </div>
  <div class="container mx-auto px-4 lg:px-8 relative z-10 text-center">
    <div>
      {% if section.settings.badge != blank %}
        <p class="font-body text-sm uppercase tracking-[0.35em] text-gold mb-6">{{ section.settings.badge }}</p>
      {% endif %}
      
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-secondary leading-tight mb-6">
        {{ section.settings.title }}
      </h1>
      
      <p class="font-body text-lg text-secondary/60 max-w-2xl mx-auto">
        {{ section.settings.description }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner (Duvets)",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "Danimarka Kalitesi"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Dünya Standartlarında Yorganlar ve Yastıklar"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Danimarka'da tasarlanmış doğal dolgulu yorganlar ve kaz tüyü yastıklar. Hipoalerjenik, OEKO-TEX® sertifikalı ve en iyi Avrupa kaz tüyleri ile üretilmiştir."
    }
  ],
  "presets": [{"name": "Hero Banner (Duvets)"}]
}
{% endschema %}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="contact" class="section-{{ section.id }}-padding bg-background">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-start">
      
      <!-- Left Content -->
      <div>
        <span class="font-body text-sm font-semibold tracking-widest uppercase text-corporate">{{ section.settings.kicker }}</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mt-3 mb-4">{{ section.settings.heading }}</h2>
        <p class="font-body text-muted-foreground leading-relaxed mb-8">{{ section.settings.description }}</p>
        
        <div class="space-y-4">
          {%- for block in section.blocks -%}
            <div class="flex items-center gap-3" {{ block.shopify_attributes }}>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big w-5 h-5 text-corporate flex-shrink-0"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg>
              <span class="font-body text-sm text-foreground">{{ block.settings.text }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <!-- Right Form -->
      <div>
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-8 border-border">
          <div class="p-0">
            {%- form 'contact', id: 'CorporateAPVForm', class: 'space-y-4' -%}
              {%- if form.posted_successfully? -%}
                <p class="text-corporate font-medium mb-4 text-center">Thank you! Your request has been received.</p>
              {%- endif -%}
              {%- if form.errors -%}
                <div class="text-red-500 text-sm mb-4">
                  {{ form.errors | default_errors }}
                </div>
              {%- endif -%}

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="ContactForm-name" class="font-body text-sm font-medium text-foreground mb-1.5 block">Full Name</label>
                  <input type="text" id="ContactForm-name" name="contact[name]" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-corporate disabled:opacity-50 md:text-sm" required placeholder="Full Name">
                </div>
                <div>
                  <label for="ContactForm-email" class="font-body text-sm font-medium text-foreground mb-1.5 block">Work email</label>
                  <input type="email" id="ContactForm-email" name="contact[email]" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-corporate disabled:opacity-50 md:text-sm" required placeholder="you@company.com">
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="ContactForm-company" class="font-body text-sm font-medium text-foreground mb-1.5 block">Company</label>
                  <input type="text" id="ContactForm-company" name="contact[company]" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-corporate disabled:opacity-50 md:text-sm" required placeholder="Company">
                </div>
                <div>
                  <label for="ContactForm-employees" class="font-body text-sm font-medium text-foreground mb-1.5 block">Employees</label>
                  <input type="text" id="ContactForm-employees" name="contact[employees]" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-corporate disabled:opacity-50 md:text-sm" placeholder="e.g. 50–200">
                </div>
              </div>

              <div>
                <label for="ContactForm-body" class="font-body text-sm font-medium text-foreground mb-1.5 block">Message</label>
                <textarea id="ContactForm-body" name="contact[body]" class="flex min-h-[80px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-corporate disabled:opacity-50" rows="4" placeholder="Message"></textarea>
              </div>

              <button type="submit" class="inline-flex items-center justify-center gap-2 w-full bg-corporate hover:bg-corporate/90 text-white font-body font-semibold px-8 py-5 h-auto rounded-full text-sm uppercase tracking-wider transition-all duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clipboard-check w-4 h-4 mr-2"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><path d="m9 14 2 2 4-4"></path></svg>
                {{ section.settings.btn_text }}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </button>
              <p class="font-body text-xs text-muted-foreground text-center">{{ section.settings.disclaimer }}</p>
            {%- endform -%}
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate APV Form",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 52 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Free Assessment" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Book Your Free APV Visit" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Our wellness experts visit your workplace, assess stress and ergonomic risks, and provide a full APV report with actionable recommendations — completely free." },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Book Free APV Visit" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "100% free. No obligation. We typically respond within 24 hours." }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Checklist Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Corporate APV Form" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-corporate-dark text-white">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="text-center mb-16">
      <span class="font-body text-sm font-semibold tracking-widest uppercase text-corporate">{{ section.settings.kicker }}</span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mt-3">{{ section.settings.heading }}</h2>
    </div>
    
    <div class="grid md:grid-cols-4 gap-8">
      {%- for block in section.blocks -%}
        <div class="text-center" {{ block.shopify_attributes }}>
          <span class="font-display text-5xl font-bold text-corporate/30">{{ block.settings.number }}</span>
          <h3 class="font-display text-xl font-semibold text-white mt-2 mb-3">{{ block.settings.title }}</h3>
          <p class="font-body text-sm text-white/60 leading-relaxed">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate Steps",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 52 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "How It Works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From Idea to Installation in 4 Steps" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "number", "label": "Number (e.g. 01)" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    { "name": "Corporate Steps" }
  ]
}
{% endschema %}

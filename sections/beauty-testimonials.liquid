<section id="testimonials" class="woc-section-py bg-white">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-100">
      {% for block in section.blocks %}
        <div class="bg-white p-8 md:p-10" {{ block.shopify_attributes }}>
          <div class="flex items-center gap-0.5 mb-5">
            {% for i in (1..5) %}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 fill-amber-400 text-amber-400"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
            {% endfor %}
          </div>
          <p class="font-body text-sm text-neutral-600 leading-[1.8] mb-6">"{{ block.settings.quote }}"</p>
          <p class="font-body text-[10px] uppercase tracking-[0.2em] text-neutral-400">{{ block.settings.author }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beauty Testimonials",
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty Testimonials"
    }
  ]
}
{% endschema %}

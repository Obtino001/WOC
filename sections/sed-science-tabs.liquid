{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="science-tabs-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient border-y border-neutral-100 section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 max-w-5xl">
    
    <div class="text-center mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 mx-auto mb-3 text-amber-500"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path></svg>
      <h2 class="text-3xl md:text-4xl font-light tracking-wider">{{ section.settings.heading }}</h2>
    </div>

    <div dir="ltr" data-orientation="horizontal" class="w-full">
      
      <div role="tablist" aria-orientation="horizontal" class="items-center justify-center text-muted-foreground w-full grid grid-cols-4 bg-white border border-neutral-200 rounded-none h-auto p-1" tabindex="0" data-orientation="horizontal" style="outline: none;">
        {% for block in section.blocks %}
          <button type="button" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" aria-controls="radix-{{ section.id }}-content-{{ forloop.index }}" data-state="{% if forloop.first %}active{% else %}inactive{% endif %}" id="radix-{{ section.id }}-trigger-{{ forloop.index }}" class="inline-flex items-center justify-center whitespace-nowrap px-3 font-medium ring-offset-background transition-all data-[state=active]:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 text-xs tracking-wider uppercase py-3 data-[state=active]:bg-neutral-900 data-[state=active]:text-white data-[state=inactive]:text-neutral-500 rounded-md" tabindex="-1" data-orientation="horizontal" data-radix-collection-item="" style="font-family: system-ui, sans-serif;" {{ block.shopify_attributes }}>
            {{ block.settings.tab_name }}
          </button>
        {% endfor %}
      </div>

      {% for block in section.blocks %}
        <div data-state="{% if forloop.first %}active{% else %}inactive{% endif %}" data-orientation="horizontal" role="tabpanel" aria-labelledby="radix-{{ section.id }}-trigger-{{ forloop.index }}" id="radix-{{ section.id }}-content-{{ forloop.index }}" tabindex="0" class="ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 mt-8 {% unless forloop.first %}hidden{% endunless %}">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'rounded-none w-full', loading: 'lazy' }}
            {% else %}
              {{ 'product-2' | placeholder_svg_tag: 'rounded-none w-full bg-gray-200' }}
            {% endif %}
            
            <div>
              <h3 class="text-2xl font-light tracking-wider mb-4">{{ block.settings.title }}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed mb-4" style="font-family: system-ui, sans-serif;">
                {{ block.settings.description }}
              </p>
              
              {% if block.settings.bullets != blank %}
                <ul class="space-y-2">
                  {% assign bullets = block.settings.bullets | split: ',' %}
                  {% for bullet in bullets %}
                    <li class="flex items-center gap-2 text-sm text-muted-foreground" style="font-family: system-ui, sans-serif;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-500"><path d="M20 6 9 17l-5-5"></path></svg>
                      {{ bullet | strip }}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('science-tabs-{{ section.id }}');
    if (!section) return;
    const triggers = section.querySelectorAll('[role="tab"]');
    const panels = section.querySelectorAll('[role="tabpanel"]');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        triggers.forEach(t => {
          t.setAttribute('aria-selected', 'false');
          t.setAttribute('data-state', 'inactive');
        });
        panels.forEach(p => {
          p.classList.add('hidden');
          p.setAttribute('data-state', 'inactive');
        });
        
        trigger.setAttribute('aria-selected', 'true');
        trigger.setAttribute('data-state', 'active');
        const controls = trigger.getAttribute('aria-controls');
        const targetPanel = section.querySelector('#' + controls);
        if (targetPanel) {
          targetPanel.classList.remove('hidden');
          targetPanel.setAttribute('data-state', 'active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "SED Science Tabs",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Science Behind Boss Lady" }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "tab_name", "label": "Tab Name (e.g. EMS)" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Content Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "textarea", "id": "bullets", "label": "Bullets (comma separated)" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Science Tabs" }
  ]
}
{% endschema %}

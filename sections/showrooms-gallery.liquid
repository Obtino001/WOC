<section class="py-24 bg-background">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="w-2 h-2 rounded-full bg-forest"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-forest">{{ section.settings.subheading }}</p>
      </div>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground">{{ section.settings.heading }}</h2>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {% for block in section.blocks %}
        <div class="group relative aspect-[3/4] overflow-hidden" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-105', loading: 'lazy' }}
          {% else %}
             {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-105' }}
          {% endif %}
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/70 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <p class="font-body text-[10px] uppercase tracking-luxury text-gold mb-1">{{ block.settings.country }}</p>
            <h3 class="font-display text-xl font-light text-secondary">{{ block.settings.city }}</h3>
          </div>
        </div>
      {% endfor %}
    </div>
    
    {% if section.settings.button_text != blank %}
      <div class="text-center mt-10">
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap border border-gold text-gold font-medium hover:bg-gold hover:text-background transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10" href="{{ section.settings.button_link }}">
          {{ section.settings.button_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Showrooms Gallery",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Presence"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Experience It Personally"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Showrooms"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Location Image"
        },
        {
          "type": "text",
          "id": "country",
          "label": "Country (Sublabel)"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City (Heading)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Showrooms Gallery"
    }
  ]
}
{% endschema %}
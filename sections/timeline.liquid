<section class="py-28 bg-background">
  <div class="container mx-auto px-4 lg:px-8 max-w-4xl">
    <div class="text-center mb-20">
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-6">{{ section.settings.subheading }}</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground">{{ section.settings.heading }}</h2>
    </div>
    <div class="relative">
      <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-border"></div>
      
      {% for block in section.blocks %}
        {% assign is_even = forloop.index0 | modulo: 2 %}
        
        <div class="relative flex items-start gap-6 mb-12 {% if is_even == 1 %}md:flex-row-reverse{% else %}md:flex-row{% endif %}" {{ block.shopify_attributes }}>
          
          <div class="hidden md:block md:w-1/2 {% if is_even == 1 %}text-left pl-12{% else %}text-right pr-12{% endif %}">
            <p class="font-display text-2xl font-light text-gold mb-2">{{ block.settings.year }}</p>
            <h3 class="font-display text-xl font-light text-foreground mb-2">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
          </div>
          
          <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-gold border-4 border-background z-10"></div>
          
          <div class="md:hidden pl-12">
            <p class="font-display text-2xl font-light text-gold mb-2">{{ block.settings.year }}</p>
            <h3 class="font-display text-xl font-light text-foreground mb-2">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
          </div>
          
          <div class="hidden md:block md:w-1/2"></div>
        </div>
      {% endfor %}
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Timeline",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Journey"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Vision to Reality"
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Timeline Event",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline"
    }
  ]
}
{% endschema %}
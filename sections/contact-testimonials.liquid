<section class="py-16 bg-card">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="text-center mb-12">
      <p class="font-body text-sm uppercase tracking-[0.25em] text-gold mb-3">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground">{{ section.settings.heading }}</h2>
    </div>
    
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {% for block in section.blocks %}
        <div>
          <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 h-full border-border" {{ block.shopify_attributes }}>
            <div class="p-0 space-y-3">
              <div class="flex gap-0.5">
                {% for i in (1..5) %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                {% endfor %}
              </div>
              <p class="font-body text-sm text-foreground italic leading-relaxed">{{ block.settings.quote }}</p>
              <p class="font-body text-xs font-semibold text-muted-foreground">{{ block.settings.author }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Trustpilot Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Clients Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Testimonials"
    }
  ]
}
{% endschema %}

<section class="woc-section-py bg-white">
  <div class="container mx-auto px-4 max-w-lg text-center">
    <div>
      <h2 class="font-display text-2xl md:text-3xl font-light text-neutral-800 mb-4">{{ section.settings.heading }}</h2>
      <p class="font-body text-sm text-neutral-400 mb-8">{{ section.settings.text }}</p>
      
      {% form 'customer', class: 'space-y-3' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {% render 'form-feedback', success_message: 'Thank you for subscribing!' %}
        {% unless form.posted_successfully? %}
        <div class="flex gap-0 border border-neutral-200">
        <input type="email" name="contact[email]" placeholder="E-mail" class="flex-1 px-4 py-3 font-body text-sm bg-transparent text-neutral-800 placeholder:text-neutral-400 focus:outline-none" required>
        <button type="submit" class="px-6 py-3 bg-neutral-900 text-white font-body text-[11px] uppercase tracking-[0.15em] hover:bg-neutral-800 transition-colors">{{ section.settings.button_text }}</button>
        </div>
        {% endunless %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Beauty Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury in your inbox."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Be the first to know about new collections, innovations, exclusive events and more."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Beauty Newsletter"
    }
  ]
}
{% endschema %}

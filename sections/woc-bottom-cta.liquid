{% schema %}
{
  "name": "WOC Bottom CTA",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image Overlay"
    },
    {
      "type": "text",
      "id": "title_line1",
      "label": "Title Line 1",
      "default": "Tag testen."
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Title Line 2 (Gold Italic)",
      "default": "Find din perfekte stol."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Vores AI-drevne quiz analyserer dine behov, din kropstype og dine præferencer for at matche dig med den ideelle massagestol på under 60 sekunder."
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Tag testen nu"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Book en gratis prøvning"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "WOC Bottom CTA"
    }
  ]
}
{% endschema %}

<section class="woc-section-py relative overflow-hidden">
  <div class="absolute inset-0 bg-charcoal"></div>
  
  {%- if section.settings.bg_image != blank -%}
    <div class="absolute inset-0 bg-cover bg-center opacity-20 mix-blend-overlay" style="background-image: url('{{ section.settings.bg_image | image_url: width: 1920 }}');"></div>
  {%- endif -%}
  
  <div class="absolute inset-0 bg-gradient-to-b from-[#151515] via-[#151515]/90 to-[#151515]/40"></div>

  <div class="container max-w-[1400px] mx-auto px-4 lg:px-8 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      
      <!-- Brain Icon -->
      <div class="w-20 h-20 mx-auto rounded-full bg-gold/10 flex items-center justify-center mb-8 border border-gold/20 shadow-[0_0_15px_rgba(216,178,97,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#d8b261" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-gold">
          <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path>
          <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path>
          <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path>
          <path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path>
          <path d="M6.002 6.5A3 3 0 0 1 5.603 5.125"></path>
          <path d="M11.8 12a1 1 0 0 0-2 0Z"></path>
          <path d="M15.4 15.6a1 1 0 0 0-2 0Z"></path>
          <path d="M10.6 15.6a1 1 0 0 0-2 0Z"></path>
          <path d="M15.4 8.4a1 1 0 0 0-2 0Z"></path>
          <path d="M10.6 8.4a1 1 0 0 0-2 0Z"></path>
        </svg>
      </div>

      <h2 class="woc-display-font text-4xl md:text-5xl lg:text-7xl font-light text-foreground leading-[1.05] mb-6">
        {{ section.settings.title_line1 }}<br/>
        {%- if section.settings.title_line2 != blank -%}
          <span class="italic text-gold">{{ section.settings.title_line2 }}</span>
        {%- endif -%}
      </h2>

      {%- if section.settings.description != blank -%}
        <p class="font-body text-base md:text-lg text-foreground/70 mb-10 max-w-2xl mx-auto leading-relaxed">
          {{ section.settings.description }}
        </p>
      {%- endif -%}

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        {%- if section.settings.btn1_text != blank -%}
          <a href="{{ section.settings.btn1_url }}" class="inline-flex items-center justify-center bg-gold text-charcoal font-body text-sm font-semibold px-10 py-4 rounded gap-2 hover:bg-gold-hover transition-colors shadow-[0_0_15px_rgba(216,178,97,0.3)] group">
            {{ section.settings.btn1_text }}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_text != blank -%}
          <a href="{{ section.settings.btn2_url }}" class="inline-flex items-center justify-center border border-gold/30 text-gold hover:bg-gold/10 font-body text-sm font-semibold px-10 py-4 rounded gap-2 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            {{ section.settings.btn2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

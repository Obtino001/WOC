{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.section_color_scheme }} gradient relative overflow-hidden section-{{ section.id }}-padding section-{{ section.id }}-padding">
  
  {% if section.settings.show_glow %}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 30% 50%, hsl(var(--gold)), transparent 60%);"></div>
  {% endif %}

  <div class="container mx-auto px-4 lg:px-8 relative">
    <div class="text-center mb-16">
      <div class="luxury-line mx-auto mb-8"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light leading-[1.05]">
        {{ section.settings.heading | newline_to_br }}
      </h2>
      <p class="font-body text-sm mt-4 max-w-2xl mx-auto opacity-80">{{ section.settings.description }}</p>
    </div>

    {%- assign cols = section.settings.desktop_columns -%}
    {%- capture grid_class -%}
      {%- if cols == 2 -%}grid-cols-1 sm:grid-cols-2 lg:grid-cols-2
      {%- elsif cols == 3 -%}grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
      {%- elsif cols == 4 -%}grid-cols-1 sm:grid-cols-2 lg:grid-cols-4
      {%- else -%}grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
      {%- endif -%}
    {%- endcapture -%}
    <div class="grid {{ grid_class }} gap-3 lg:gap-6">
      {% assign collection = section.settings.collection %}
      {% for product in collection.products limit: section.settings.limit %}
        
        {% render 'woc-product-card', 
             product: product, 
             card_color_scheme: section.settings.card_color_scheme 
        %}
      {% else %}
        <p>{{ section.settings.empty_collection_text | default: 'No products found in this collection.' }}</p>
      {% endfor %}
    </div>

    {% if section.settings.show_contact_card %}
      <div class="mt-16 color-{{ section.settings.card_color_scheme }} border border-gold/20 rounded-xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="flex-1">
          <h3 class="font-display text-2xl font-light mb-2">{{ section.settings.contact_heading | default: 'Not sure which model?' }}</h3>
          <p class="font-body text-sm opacity-80">{{ section.settings.contact_text | default: 'Take our quiz or book a free trial session in one of our showrooms.' }}</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/pages/quiz" class="inline-flex items-center justify-center whitespace-nowrap bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-10 px-4 py-2 gap-2">
            {{ section.settings.btn_quiz_text | default: 'Take the quiz' }} <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
          <a href="/pages/contact" class="inline-flex items-center justify-center whitespace-nowrap text-sm font-medium border bg-background hover:text-accent-foreground h-10 px-4 py-2 gap-2 border-gold/30 text-gold hover:bg-gold/10 transition-all duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg> {{ section.settings.btn_contact_text | default: 'Contact us' }}
          </a>
        </div>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Advanced Product Grid",
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Show Gold Glow Background",
      "default": false
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Most popular"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Our <span class=\"italic text-gold\">Bestsellers</span>",
      "info": "Use HTML tags for italics."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "The most loved massage chairs among our customers — selected for superior comfort, advanced technology, and unmatched quality."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Display"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Product Limit",
      "default": 3
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Desktop Columns",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_contact_card",
      "label": "Show Contact Card at Bottom",
      "default": true
    },
    {
      "type": "header",
      "content": "Product Card Text"
    },
    {
      "type": "text",
      "id": "badge_new_text",
      "label": "Badge 'New' Text",
      "default": "New"
    },
    {
      "type": "text",
      "id": "badge_award_text",
      "label": "Badge 'Award' Text",
      "default": "Award-Winning"
    },
    {
      "type": "text",
      "id": "badge_flagship_text",
      "label": "Badge 'Flagship' Text",
      "default": "Flagship"
    },
    {
      "type": "text",
      "id": "badge_topseller_text",
      "label": "Badge 'Top Seller' Text",
      "default": "Top Seller"
    },
    {
      "type": "text",
      "id": "free_delivery_text",
      "label": "Free Delivery Text",
      "default": "Free delivery"
    },
    {
      "type": "text",
      "id": "warranty_text",
      "label": "Warranty Text",
      "default": "5-year warranty"
    },
    {
      "type": "text",
      "id": "from_text",
      "label": "'From' Text",
      "default": "From"
    },
    {
      "type": "text",
      "id": "per_week_text",
      "label": "'/ week' Text",
      "default": "/ week"
    },
    {
      "type": "text",
      "id": "in_stock_text",
      "label": "In Stock Text",
      "default": "In stock · 1-2 days free delivery"
    },
    {
      "type": "text",
      "id": "out_of_stock_text",
      "label": "Out of Stock Text",
      "default": "Out of stock"
    },
    {
      "type": "text",
      "id": "btn_see_more_text",
      "label": "See More Button Text",
      "default": "See more"
    },
    {
      "type": "text",
      "id": "btn_try_text",
      "label": "Try Button Text",
      "default": "Try"
    },
    {
      "type": "text",
      "id": "fallback_feature_1",
      "label": "Fallback Feature 1",
      "default": "XD Massage Technology"
    },
    {
      "type": "text",
      "id": "fallback_feature_2",
      "label": "Fallback Feature 2",
      "default": "Zero Gravity"
    },
    {
      "type": "text",
      "id": "empty_collection_text",
      "label": "Empty Collection Text",
      "default": "No products found in this collection."
    },
    {
      "type": "header",
      "content": "Contact Card Text"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact Card Heading",
      "default": "Not sure which model?"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "Contact Card Text",
      "default": "Take our quiz or book a free trial session in one of our showrooms."
    },
    {
      "type": "text",
      "id": "btn_quiz_text",
      "label": "Quiz Button Text",
      "default": "Take the quiz"
    },
    {
      "type": "text",
      "id": "btn_contact_text",
      "label": "Contact Button Text",
      "default": "Contact us"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Advanced Product Grid"
    }
  ]
}
{% endschema %}

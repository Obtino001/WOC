{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="border-y border-neutral-100 bg-white section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 py-8 flex flex-wrap justify-center gap-10 md:gap-16">
    {% for block in section.blocks %}
      {% if block.type == 'trust_badge' %}
        <div class="flex items-center gap-2.5" {{ block.shopify_attributes }}>
          <div class="[&>svg]:w-4 [&>svg]:h-4 [&>svg]:text-neutral-300">
            {{ block.settings.icon_svg }}
          </div>
          <span class="font-body text-[10px] uppercase tracking-[0.2em] text-neutral-400">{{ block.settings.text }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="bg-white" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container mx-auto px-4 text-center max-w-xl">
    <div>
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="mx-auto"><path d="M24 4L26 20L24 22L22 20L24 4Z" fill="hsl(36 72% 45%)" opacity="0.8"></path><path d="M24 44L22 28L24 26L26 28L24 44Z" fill="hsl(36 72% 45%)" opacity="0.8"></path><path d="M4 24L20 22L22 24L20 26L4 24Z" fill="hsl(36 72% 45%)" opacity="0.8"></path><path d="M44 24L28 26L26 24L28 22L44 24Z" fill="hsl(36 72% 45%)" opacity="0.8"></path><path d="M10 10L21 19L20 21L18 20L10 10Z" fill="hsl(36 72% 45%)" opacity="0.5"></path><path d="M38 38L27 29L28 27L30 28L38 38Z" fill="hsl(36 72% 45%)" opacity="0.5"></path><path d="M38 10L29 21L27 20L28 18L38 10Z" fill="hsl(36 72% 45%)" opacity="0.5"></path><path d="M10 38L19 27L21 28L20 30L10 38Z" fill="hsl(36 72% 45%)" opacity="0.5"></path></svg>
      <h2 class="font-display text-3xl md:text-4xl font-light text-neutral-800 mt-8 mb-6">{{ section.settings.heading }}</h2>
      <p class="font-body text-sm text-neutral-500 leading-[1.9] mb-10">{{ section.settings.description }}</p>
      
      {% if section.settings.button_text != blank %}
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-all duration-500 bg-neutral-900 hover:bg-neutral-800 text-white uppercase tracking-[0.15em] text-[11px] px-10 h-12" href="{{ section.settings.button_link }}">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges & Bottom CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Experience in person"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Visit one of our showrooms and experience Séduisante products in real life. Our experts will guide you to the perfect solution."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "FIND YOUR SHOWROOM"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust & Bottom CTA"
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
    
    <div class="text-center mb-14">
      <div class="luxury-line mx-auto mb-6"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-cyan-400 mb-4">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl md:text-4xl font-light text-foreground">{{ section.settings.heading }}</h2>
    </div>
    
    <div class="grid md:grid-cols-2 gap-10">
      
      <div class="relative rounded-2xl border border-border bg-card p-8 text-center">
        <p class="font-body text-[10px] uppercase tracking-luxury text-gold mb-6">Upright Position</p>
        <div class="space-y-4">
          <div class="flex items-center justify-between py-3 border-b border-border/50">
            <span class="font-body text-sm text-muted-foreground">Width</span>
            <span class="font-display text-2xl font-bold text-foreground">{{ section.settings.u_width }}</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-border/50">
            <span class="font-body text-sm text-muted-foreground">Depth</span>
            <span class="font-display text-2xl font-bold text-foreground">{{ section.settings.u_depth }}</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-border/50">
            <span class="font-body text-sm text-muted-foreground">Height</span>
            <span class="font-display text-2xl font-bold text-foreground">{{ section.settings.u_height }}</span>
          </div>
        </div>
      </div>

      <div class="relative rounded-2xl border border-border bg-card p-8 text-center">
        <p class="font-body text-[10px] uppercase tracking-luxury text-gold mb-6">Reclined Position</p>
        <div class="space-y-4">
          <div class="flex items-center justify-between py-3 border-b border-border/50">
            <span class="font-body text-sm text-muted-foreground">Width</span>
            <span class="font-display text-2xl font-bold text-foreground">{{ section.settings.r_width }}</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-border/50">
            <span class="font-body text-sm text-muted-foreground">Depth</span>
            <span class="font-display text-2xl font-bold text-foreground">{{ section.settings.r_depth }}</span>
          </div>
          <div class="flex items-center justify-between py-3 border-b border-border/50">
            <span class="font-body text-sm text-muted-foreground">Height</span>
            <span class="font-display text-2xl font-bold text-foreground">{{ section.settings.r_height }}</span>
          </div>
        </div>
      </div>
      
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-10">
      {% for block in section.blocks %}
        <div class="text-center p-4 rounded-xl border border-border bg-card" {{ block.shopify_attributes }}>
          <p class="font-display text-xl font-bold text-gold mb-1">{{ block.settings.value }}</p>
          <p class="font-body text-[10px] uppercase tracking-luxury text-muted-foreground">{{ block.settings.label }}</p>
        </div>
      {% endfor %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Measurements & Dimensions",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Dimensions" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Measurements & Dimensions" },
    { "type": "header", "content": "Upright Position" },
    { "type": "text", "id": "u_width", "label": "Width", "default": "80 cm" },
    { "type": "text", "id": "u_depth", "label": "Depth", "default": "155 cm" },
    { "type": "text", "id": "u_height", "label": "Height", "default": "122 cm" },
    { "type": "header", "content": "Reclined Position" },
    { "type": "text", "id": "r_width", "label": "Width", "default": "80 cm" },
    { "type": "text", "id": "r_depth", "label": "Depth", "default": "194 cm" },
    { "type": "text", "id": "r_height", "label": "Height", "default": "79 cm" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Bottom Stat Box",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "value", "label": "Value" },
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    { "name": "Measurements & Dimensions" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-background">
  <div class="container mx-auto px-4 lg:px-8">
    
    <div class="text-center mb-16">
      <span class="font-body text-sm font-semibold tracking-widest uppercase text-corporate">{{ section.settings.kicker }}</span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mt-3 mb-4">{{ section.settings.heading }}</h2>
      <p class="font-body text-muted-foreground max-w-2xl mx-auto">{{ section.settings.description }}</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      {%- for block in section.blocks -%}
        <div class="rounded-none border bg-card text-card-foreground shadow-sm p-8 h-full border-border hover:border-corporate/30 transition-colors group" {{ block.shopify_attributes }}>
          <div class="p-0 flex gap-5">
            <div class="w-12 h-12 rounded-none bg-corporate/10 flex items-center justify-center flex-shrink-0 group-hover:bg-corporate/20 transition-colors [&>svg]:w-6 [&>svg]:h-6 [&>svg]:text-corporate">
              {{ block.settings.icon_svg }}
            </div>
            <div>
              <h3 class="font-display text-xl font-semibold text-foreground mb-2">{{ block.settings.title }}</h3>
              <p class="font-body text-muted-foreground leading-relaxed">{{ block.settings.description }}</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Corporate Expertise",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 52 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Our Expertise" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Free APV — We Come to You" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "As certified wellness consultants, we offer a free on-site workplace assessment (APV) to identify exactly how stress and ergonomic issues affect your team." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    { "name": "Corporate Expertise" }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8 max-w-5xl">

    <div class="text-center mb-12">
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">{{ section.settings.kicker }}</p>
    </div>

    <div class="grid sm:grid-cols-3 gap-8 mb-16">
      {% for block in section.blocks %}
        {% if block.type == 'guarantee' %}
          <div class="text-center" {{ block.shopify_attributes }}>
            <div class="w-14 h-14 rounded-full bg-gold/10 flex items-center justify-center mx-auto mb-4 [&>svg]:w-6 [&>svg]:h-6 [&>svg]:text-gold">
              {{ block.settings.icon_svg }}
            </div>
            <h3 class="font-display text-base font-semibold text-foreground mb-2">{{ block.settings.title }}</h3>
            <p class="font-body text-sm text-muted-foreground">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="border border-border rounded-sm overflow-hidden mb-20" id="vip-accordions-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'accordion' %}
          <div class="border-b border-border last:border-b-0 bg-card" {{ block.shopify_attributes }}>
            <h3 class="flex">
              <button
                class="flex flex-1 items-center justify-between px-6 py-5 font-body text-xs font-semibold uppercase tracking-wider text-foreground hover:text-gold transition-colors"
                aria-expanded="false"
              >
                {{ block.settings.title }}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0 transition-transform duration-200"><path d="m6 9 6 6 6-6"></path></svg>
              </button>
            </h3>
            <div class="hidden px-6 pb-5 pt-0 text-sm text-muted-foreground font-body leading-relaxed">
              {{ block.settings.content }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_measurements %}
      <div>
        <h3 class="font-display text-2xl md:text-3xl font-semibold text-foreground text-center mb-10 uppercase tracking-wide">
          Minimum Doorway
        </h3>
        <div class="grid lg:grid-cols-2 gap-10 items-center">

          <div class="flex gap-6 justify-center">
            <div class="text-center">
              <div class="bg-muted/40 border border-border rounded-sm p-6 relative min-w-[140px]">
                <p class="font-display text-xs font-semibold uppercase tracking-wider text-foreground mb-1">Assembled</p>
                <p class="font-display text-xl font-bold text-gold mb-4">{{ section.settings.measure_assembled }}</p>
                <div class="w-full h-px bg-border mb-1"></div>
                <div class="flex justify-between text-[10px] text-muted-foreground"><span>←</span><span>→</span></div>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-16 h-16 text-muted-foreground/30 mx-auto mt-4"><path d="M13 4h3a2 2 0 0 1 2 2v14"></path><path d="M2 20h3"></path><path d="M13 20h9"></path><path d="M10 12v.01"></path><path d="M13 4.562v16.157a1 1 0 0 1-1.242.97L5 20V5.562a2 2 0 0 1 1.515-1.94l4-1A2 2 0 0 1 13 4.561Z"></path></svg>
              </div>
            </div>
            <div class="text-center">
              <div class="bg-muted/40 border border-border rounded-sm p-6 relative min-w-[140px]">
                <p class="font-display text-xs font-semibold uppercase tracking-wider text-foreground mb-1">Disassembled</p>
                <p class="font-display text-xl font-bold text-gold mb-4">{{ section.settings.measure_disassembled }}</p>
                <div class="w-full h-px bg-border mb-1"></div>
                <div class="flex justify-between text-[10px] text-muted-foreground"><span>←</span><span>→</span></div>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-16 h-16 text-muted-foreground/30 mx-auto mt-4"><path d="M13 4h3a2 2 0 0 1 2 2v14"></path><path d="M2 20h3"></path><path d="M13 20h9"></path><path d="M10 12v.01"></path><path d="M13 4.562v16.157a1 1 0 0 1-1.242.97L5 20V5.562a2 2 0 0 1 1.515-1.94l4-1A2 2 0 0 1 13 4.561Z"></path></svg>
              </div>
            </div>
          </div>

          <div>
            <h4 class="font-display text-lg font-semibold text-foreground mb-4">Measuring Guide</h4>
            <div class="space-y-4 font-body text-sm text-muted-foreground leading-relaxed">
              {{ section.settings.measuring_guide | replace: '<li>', '<li class="flex gap-3"><span class="text-gold mt-1">•</span><span>' | replace: '</li>', '</span></li>' }}
            </div>
          </div>

        </div>
      </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  var container = document.getElementById('vip-accordions-{{ section.id }}');
  if (!container) return;
  container.querySelectorAll('button[aria-expanded]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = this.getAttribute('aria-expanded') === 'true';
      var panel = this.closest('div').nextElementSibling;
      this.setAttribute('aria-expanded', !expanded);
      panel.classList.toggle('hidden', expanded);
      this.querySelector('svg').style.transform = expanded ? '' : 'rotate(180deg)';
    });
  });
})();
</script>

{% schema %}
{
  "name": "VIP Delivery Info",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 112 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "VIP GUARANTEED" },
    { "type": "header", "content": "Measuring Guide" },
    { "type": "checkbox", "id": "show_measurements", "label": "Show Measuring Guide", "default": true },
    { "type": "text", "id": "measure_assembled", "label": "Assembled Width", "default": "84 cm" },
    { "type": "text", "id": "measure_disassembled", "label": "Disassembled Width", "default": "76 cm" },
    { "type": "richtext", "id": "measuring_guide", "label": "Measuring Instructions (List format)" }
  ],
  "blocks": [
    {
      "type": "guarantee",
      "name": "Guarantee Card",
      "limit": 3,
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "description", "label": "Description" }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ],
  "presets": [
    { "name": "VIP Delivery Info" }
  ]
}
{% endschema %}

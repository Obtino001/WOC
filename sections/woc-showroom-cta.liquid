<section class="relative h-[600px] flex items-center bg-zinc-950 overflow-hidden border-t border-border">
  
  <!-- Image Background -->
  <div class="absolute inset-0 z-1">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1900 }}"
        alt="{{ section.settings.title }}"
        class="w-full h-full object-cover opacity-40"
        style="width: 100%; height: 100%; object-fit: cover;"
        loading="lazy"
      >
    {%- else -%}
      <div class="w-full h-full bg-zinc-900 flex items-center justify-center opacity-30">Showroom Visual</div>
    {%- endif -%}
    
    <!-- Gradients overlay to bleed with background -->
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/80 to-transparent hidden lg:block"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/60 to-transparent lg:hidden"></div>
  </div>

  <!-- Content Container -->
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="max-w-2xl">
      
      <div class="flex items-center gap-2.5 text-gold mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span class="font-body text-[10px] font-medium uppercase tracking-luxury">
          {{ section.settings.subtitle }}
        </span>
      </div>

      <h2 class="woc-display-font text-4xl md:text-5xl font-light text-foreground mb-6 leading-tight">
        {{ section.settings.title }}
      </h2>

      <p class="font-body text-sm font-light text-muted-foreground mb-10 leading-relaxed max-w-xl">
        {{ section.settings.description }}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        {%- if section.settings.btn1_text != blank -%}
          <a
            href="{{ section.settings.btn1_url | default: '/pages/showrooms' }}"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-gold hover:bg-gold-hover text-charcoal font-body text-xs font-semibold uppercase tracking-wider transition-all duration-300 rounded shadow-elevated"
          >
            {{ section.settings.btn1_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_text != blank -%}
          <a
            href="{{ section.settings.btn2_url | default: '/pages/contact' }}"
            class="inline-flex items-center justify-center px-8 py-3.5 border border-white hover:bg-white hover:text-charcoal text-white font-body text-xs font-semibold uppercase tracking-wider transition-all duration-300 rounded"
          >
            {{ section.settings.btn2_text }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC Showroom CTA",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Showroom Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "20+ SHOWROOMS I EUROPA"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Oplev produkterne selv i vores showrooms"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Kom ind og få en personlig, uforpligtende fremvisning af en af vores rådgivere. Prøv massagestolene, mærk saunatæppets dybe varme og oplev komforten ved vores smarte sovesystem."
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Find showroom"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Kontakt os"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button 2 Link"
    }
  ],
  "presets": [
    {
      "name": "WOC Showroom CTA"
    }
  ]
}
{% endschema %}

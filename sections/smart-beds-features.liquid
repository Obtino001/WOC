{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-light-warm relative overflow-hidden section-{{ section.id }}-padding">
  <div class="absolute inset-0 bg-gradient-to-br from-gold/[0.03] to-transparent pointer-events-none"></div>
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex-1 flex flex-col justify-end pb-12 lg:pb-16 w-full pt-10">
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="w-2 h-2 rounded-full bg-gold"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold">{{ section.settings.kicker }}</p>
      </div>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-4">{{ section.settings.heading }}</h2>
      <p class="font-body text-sm text-muted-foreground max-w-2xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[1px]">
      {% for block in section.blocks %}
        <div class="p-10 group hover:bg-gold/[0.04] transition-colors duration-700" {{ block.shopify_attributes }}>
          <div class="[&>svg]:w-5 [&>svg]:h-5 [&>svg]:text-gold mb-6">
            {{ block.settings.icon_svg }}
          </div>
          <h3 class="font-display text-lg font-light text-foreground mb-3">{{ block.settings.title }}</h3>
          <p class="font-body text-xs font-light text-muted-foreground leading-[1.8]">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features Grid",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Why World of Comfort Sleep"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Our Sleep Systems Unique"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Grid"
    }
  ]
}
{% endschema %}

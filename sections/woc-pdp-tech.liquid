<section class="color-{{ section.settings.color_scheme }} gradient py-20 bg-charcoal border-y border-border relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 50% 50%, hsl(var(--gold)), transparent 60%);"></div>

  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Heading -->
    <div class="text-center mb-16">
      <div class="luxury-line mx-auto mb-8"></div>
      {%- if section.settings.label != blank -%}
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">
          {{ section.settings.label }}
        </p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="woc-display-font text-3xl md:text-4xl lg:text-5xl font-light text-foreground leading-[1.05]">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
    </div>

    <!-- Tech Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div 
            class="bg-[#0F0F0F] border border-border/10 p-8 group hover:border-gold/20 transition-all duration-500"
            {{ block.shopify_attributes }}
          >
            <!-- Icon {% if section.settings.page_width == 'full' %}w-full{% elsif section.settings.page_width == 'narrow' %}max-w-[1000px] mx-auto{% else %}page-width{% endif %} -->
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center mb-6 group-hover:bg-gold/20 transition-colors">
              <span class="text-gold shrink-0 flex items-center justify-center">
                {%- if block.settings.custom_icon_svg != blank -%}
                  {{ block.settings.custom_icon_svg }}
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'brain' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3.02 3.02 0 0 1 0-3.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3.02 3.02 0 0 0 0-3.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2Z"/></svg>
                    {%- when 'activity' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    {%- when 'heart' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    {%- when 'zap' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    {%- when 'waves' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.5 0 2.5 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2c2.5 0 2.5 2 5 2s2.5-2 5-2c1.3 0 1.9.5 2.5 1M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2c2.5 0 2.5 2 5 2s2.5-2 5-2c1.3 0 1.9.5 2.5 1"/></svg>
                    {%- when 'moon' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
                    {%- when 'sparkles' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="m5 3 1 2.5L8.5 6 6 7 5 9.5 4 7 1.5 6 4 5.5 5 3Z"/><path d="m19 17 1 2.5 2.5.5-2.5 1-1 2.5-1-2.5-2.5-1 2.5-1 1-2.5Z"/></svg>
                    {%- when 'flame' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                    {%- when 'eye' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    {%- when 'leaf' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.58 0 8-2 3.7-6.9 8-8 10Z"/><path d="M19 2c-2.26 2.33-5.26 4-8 5"/></svg>
                    {%- when 'droplets' -%}
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.3 1.45-1.14 2.84-2.29 3.76S3 11.09 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M17 18.5c1.37 0 2.5-1.14 2.5-2.53 0-.72-.35-1.41-1.07-2-.71-.58-1.57-1.44-1.76-2.35-.2.9-.71 1.77-1.43 2.35-.71.58-1.07 1.28-1.07 2 0 1.39 1.13 2.53 2.53 2.53z"/></svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>
            </div>
            <h3 class="woc-display-font text-lg font-semibold text-foreground mb-3">{{ block.settings.title }}</h3>
            <p class="font-body text-xs font-light text-foreground/60 leading-relaxed">{{ block.settings.desc }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "WOC PDP Technology",
  "max_blocks": 4,
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {"value": "full", "label": "Full Width"},
        {"value": "standard", "label": "Standard Width"},
        {"value": "narrow", "label": "Narrow Width"}
      ],
      "default": "standard"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "AVANCERET TEKNOLOGI"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Udviklet til perfektion"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Tech Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Preset Icon",
          "options": [
            { "value": "brain", "label": "Brain/AI chip" },
            { "value": "activity", "label": "Activity ECG" },
            { "value": "heart", "label": "Heart Rate" },
            { "value": "zap", "label": "Energy Zap" },
            { "value": "waves", "label": "Waves/Massage" },
            { "value": "moon", "label": "Moon/Sleep" },
            { "value": "sparkles", "label": "Sparkles/Beauty" },
            { "value": "flame", "label": "Flame/Heat" },
            { "value": "eye", "label": "Eye Care" },
            { "value": "leaf", "label": "Leaf/Organic" },
            { "value": "droplets", "label": "Droplets/Moisture" }
          ],
          "default": "brain"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG XML code here to override the preset icon dropdown."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "AI Body Scanning"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Feature Description",
          "default": "Intelligente sensorer kortlægger din kropskontur for en personlig massageoplevelse."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC PDP Technology",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "brain",
            "title": "AI Kropsscanning",
            "desc": "Intelligente sensorer kortlægger din kropskontur for en personlig oplevelse."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "activity",
            "title": "Zero Gravity position",
            "desc": "NASA-inspireret liggestilling fordeler vægten jævnt for at mindske tryk på rygsøjlen."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "flame",
            "title": "Infrarød varmeterapi",
            "desc": "Målrettet dybdegående varme trænger dybt ind i musklerne og fremmer hurtig restitution."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "waves",
            "title": "Dual-Core Mekanisme",
            "desc": "Avanceret dobbelt-motor teknologi til synkroniseret ryg- og lændebehandling."
          }
        }
      ]
    }
  ]
}
{% endschema %}

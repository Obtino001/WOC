<section class="py-24 section-light overflow-hidden">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-6xl mx-auto">
      
      <div class="text-center mb-16">
        <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 font-semibold transition-colors bg-gold/10 text-gold border-gold/20 mb-4 text-xs uppercase tracking-widest">{{ section.settings.badge }}</div>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-4">{{ section.settings.title }}</h2>
        <p class="font-body text-muted-foreground max-w-2xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
      </div>

      <div class="overflow-x-auto -mx-4 px-4">
        <table class="w-full border-collapse min-w-[700px]">
          <thead>
            <tr>
              <th class="text-left font-body text-xs uppercase tracking-widest text-muted-foreground py-4 px-4 border-b border-border">Özellik</th>
              <th class="text-center font-display text-sm font-bold text-gold py-4 px-4 border-b border-gold/30 bg-gold/5 rounded-t-lg">WOC Supreme</th>
              <th class="text-center font-body text-xs uppercase tracking-widest text-muted-foreground py-4 px-4 border-b border-border">Tipik Rakip</th>
            </tr>
          </thead>
          <tbody class="font-body text-sm">
            {% for block in section.blocks %}
              <tr class="{% cycle 'bg-muted/20', '' %}" {{ block.shopify_attributes }}>
                <td class="py-3.5 px-4 font-medium text-foreground">{{ block.settings.feature }}</td>
                <td class="py-3.5 px-4 text-center bg-gold/5 font-semibold text-foreground">{{ block.settings.woc_val }}</td>
                <td class="py-3.5 px-4 text-center text-muted-foreground">{{ block.settings.comp_val }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="mt-12 text-center">
        <p class="font-body text-muted-foreground text-sm mb-6">{{ section.settings.footer_text }}</p>
        <a href="{{ section.settings.btn_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10">
          {{ section.settings.btn_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-1"><path d="m9 18 6-6-6-6"></path></svg>
        </a>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Text"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Table Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature Name"
        },
        {
          "type": "text",
          "id": "woc_val",
          "label": "WOC Value"
        },
        {
          "type": "text",
          "id": "comp_val",
          "label": "Competitor Value"
        }
      ]
    }
  ],
  "presets": [{"name": "Comparison Table"}]
}
{% endschema %}
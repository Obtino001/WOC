      "default": "Fatura Numaranız*"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Ömür Boyu Garanti’yi Etkinleştir"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Option",
      "settings": [
        {
          "type": "text",

{% schema %}
{
  "name": "WOC Product Showcase",
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "pre_title",
      "label": "Pre-title (Small Gold)",
      "default": "MEST POPULÆRE"
    },
    {
      "type": "text",
      "id": "title_line1",
      "label": "Title Line 1",
      "default": "Vores"
    },
    {
      "type": "text",
      "id": "title_line2",
      "label": "Title Line 2 (Gold Italic)",
      "default": "Bestsellere"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "De mest elskede massagestole blandt vores kunder — udvalgt for overlegen komfort, avanceret teknologi og uovertruffen kvalitet."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "header",
      "content": "Product Card Text"
    },
    {
      "type": "text",
      "id": "badge_save_text",
      "label": "Save Text (Sale Badge)",
      "default": "Spar"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Delivery Text",
      "default": "Gratis levering"
    },
    {
      "type": "text",
      "id": "warranty_text",
      "label": "Warranty Text",
      "default": "5 års garanti"
    },
    {
      "type": "text",
      "id": "price_from_text",
      "label": "'From' Price Text",
      "default": "Eller fra"
    },
    {
      "type": "text",
      "id": "price_per_month_text",
      "label": "Price Per Month Text",
      "default": "/ md"
    },
    {
      "type": "text",
      "id": "stock_text",
      "label": "In Stock Text",
      "default": "På lager"
    },
    {
      "type": "text",
      "id": "btn_see_more_text",
      "label": "See More Button Text",
      "default": "Se mere"
    },
    {
      "type": "text",
      "id": "btn_try_text",
      "label": "Try Button Text",
      "default": "Prøv stol"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Custom Badge (Top Left)"
        },
        {
          "type": "text",
          "id": "status_label",
          "label": "Status Label (Red Bar under image)",
          "info": "e.g. Få demomodeller tilbage"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline Override",
          "info": "Leave blank to use product vendor or default text"
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Comma separated features",
          "default": "3D Massage, Zero Gravity, Varmeterapi",
          "info": "e.g. 3D Massage, Zero Gravity, Varmeterapi"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Product Showcase",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}

{%- assign cols = section.settings.columns_desktop -%}
{%- capture grid_class -%}
  {%- if cols == 2 -%}md:grid-cols-2 lg:grid-cols-2
  {%- elsif cols == 3 -%}md:grid-cols-3 lg:grid-cols-3
  {%- elsif cols == 4 -%}grid-cols-2 sm:grid-cols-3 lg:grid-cols-4
  {%- else -%}md:grid-cols-3
  {%- endif -%}
{%- endcapture -%}

<section class="color-{{ section.settings.section_color_scheme }} gradient py-20 lg:py-28 relative overflow-hidden">
  <div class="container max-w-[1400px] mx-auto px-4 lg:px-8 relative">
    
    <!-- Header -->
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <div class="luxury-line mx-auto mb-8"></div>
      {%- if section.settings.pre_title != blank -%}
        <p class="font-body text-[10px] font-medium uppercase tracking-[0.2em] text-gold mb-4">
          {{ section.settings.pre_title }}
        </p>
      {%- endif -%}
      <h2 class="woc-display-font text-4xl md:text-5xl lg:text-6xl font-light leading-[1.05]">
        {{ section.settings.title_line1 }}
        {%- if section.settings.title_line2 != blank -%}
          <span class="italic text-gold">{{ section.settings.title_line2 }}</span>
        {%- endif -%}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="font-body text-sm mt-4 max-w-2xl mx-auto opacity-70">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </div>

    <!-- Products Grid -->
    <div class="grid {{ grid_class }} gap-4 lg:gap-6">
      {%- for block in section.blocks -%}
        {%- assign prod = block.settings.product -%}
        <div class="h-full" {{ block.shopify_attributes }}>
          {%- if prod != blank -%}
            {% render 'woc-product-card', 
                 product: prod, 
                 card_color_scheme: section.settings.card_color_scheme,
                 badge_override: block.settings.badge,
                 status_label_override: block.settings.status_label,
                 tagline_override: block.settings.tagline,
                 features_override: block.settings.features
            %}
          {%- else -%}
            <div class="color-{{ section.settings.card_color_scheme }} border rounded-xl overflow-hidden flex flex-col items-center justify-center h-full p-10 text-center opacity-50">
              Select a product to preview layout.
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% paginate blog.articles by section.settings.articles_per_page %}

<section class="container mx-auto px-4 lg:px-8 mb-12">
  <div class="flex flex-wrap gap-2">
    <a href="{{ blog.url }}" class="px-4 py-2 rounded-full text-xs font-body uppercase tracking-wider transition-all {% if current_tags == blank %}bg-gold text-background{% else %}bg-muted/40 text-foreground/70 hover:bg-muted/60{% endif %}">
      All articles
    </a>
    {% for tag in blog.all_tags %}
      <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="px-4 py-2 rounded-full text-xs font-body uppercase tracking-wider transition-all {% if current_tags contains tag %}bg-gold text-background{% else %}bg-muted/40 text-foreground/70 hover:bg-muted/60{% endif %}">
        {{ tag }}
      </a>
    {% endfor %}
  </div>
</section>

<section class="container mx-auto px-4 lg:px-8">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {% for article in blog.articles %}
      <article class="group relative">
        <a class="block" href="{{ article.url }}">
          <div class="aspect-[4/3] overflow-hidden rounded-lg bg-muted/40 mb-5 relative">
            {% if article.image %}
              {{ article.image | image_url: width: 800 | image_tag: class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105', loading: 'lazy' }}
            {% else %}
              <div class="w-full h-full bg-gradient-to-br from-gold/10 to-muted/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-gold/40"><path d="M12 7v14"></path><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"></path></svg>
              </div>
            {% endif %}
          </div>
          
          {% if article.tags.size > 0 %}
            <p class="font-body text-[10px] uppercase tracking-luxury text-gold mb-3">{{ article.tags.first }}</p>
          {% endif %}
          
          <h2 class="font-display text-xl font-light text-foreground mb-3 leading-snug group-hover:text-gold transition-colors">
            {{ article.title }}
          </h2>
          
          <p class="font-body text-sm text-muted-foreground leading-relaxed line-clamp-3 mb-4">
            {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
          </p>
          
          <div class="flex items-center gap-3 text-[11px] font-body text-muted-foreground/70">
            <span>{{ article.author }}</span>
            <span>·</span>
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {% assign words = article.content | strip_html | split: ' ' | size %}
              {% assign read_time = words | divided_by: 200 | at_least: 1 %}
              {{ read_time }} min
            </span>
          </div>
        </a>
      </article>
    {% else %}
      <p class="font-body text-muted-foreground col-span-full py-10">No articles found in this category.</p>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="mt-16 flex justify-center">
      {{ paginate | default_pagination }}
    </div>
  {% endif %}
</section>

{% endpaginate %}

{% schema %}
{
  "name": "Main Blog Grid",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "label": "Articles Per Page",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Main Blog Grid"
    }
  ]
}
{% endschema %}

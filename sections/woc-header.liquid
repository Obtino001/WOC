{% comment %} ─── Header Section ─── {% endcomment %}

<header id="woc-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-700 bg-transparent">
  <div class="container mx-auto px-3 lg:px-8 max-w-full">
    <div class="flex items-center justify-between h-20 lg:h-24 gap-2 min-w-0">

 {% comment %} ─── Logo ─── {% endcomment %}
      <a href="{{ routes.root_url }}" class="flex items-center shrink-0">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_style = 'max-width: ' | append: section.settings.logo_width | append: 'px;' -%}
          {{ section.settings.logo | image_url: width: 1600 | image_tag:
            class: 'h-14 lg:h-16 w-auto brightness-125 contrast-125 drop-shadow-[0_0_8px_rgba(255,255,255,0.3)]',
            style: logo_style,
            alt: logo_alt
          }}
        {%- else -%}
          <span class="font-display text-2xl font-bold text-white tracking-wide">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {% comment %} ─── Desktop Company Badge ─── {% endcomment %}
      {%- if section.settings.show_badge -%}
        <div class="[@media(min-width:1500px)]:flex items-center gap-2 mr-3 px-3 py-1.5 rounded-full border border-gold/30 bg-gold/10 shadow-[0_0_12px_rgba(212,175,55,0.15)]">
          <span class="text-base">{{ section.settings.badge_icon }}</span>
          <span class="font-body text-[10px] font-semibold uppercase tracking-[0.12em] whitespace-nowrap text-gold">
            {{ section.settings.badge_text | escape }}
          </span>
        </div>
      {%- endif -%}

      {% comment %} ─── Desktop Navigation ─── {% endcomment %}
      <nav class="[@media(min-width:1024px)]:flex items-center gap-1">
        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            {%- if link.links != blank -%}
              <div class="relative group">
                <a href="{{ link.url }}" class="flex items-center gap-1 px-2 py-2 font-body text-[11px] font-normal uppercase tracking-[0.12em] transition-colors duration-300 whitespace-nowrap text-foreground/70 hover:text-gold">
                  {{ link.title | escape }}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-3 h-3 transition-transform duration-200"><path d="m6 9 6 6 6-6"></path></svg>
                </a>
                <div class="hidden group-hover:block absolute left-0 top-full mt-0 pt-2 min-w-[200px] z-50">
                  <div class="border border-white/10 bg-card py-2 shadow-soft">
                    {%- for childlink in link.links -%}
                      <a href="{{ childlink.url }}" class="block px-5 py-2.5 font-body text-sm text-popover-foreground transition-colors hover:bg-muted hover:text-foreground">
                        {{ childlink.title | escape }}
                      </a>
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="flex items-center gap-1 px-2 py-2 font-body text-[11px] font-normal uppercase tracking-[0.12em] transition-colors duration-300 whitespace-nowrap text-foreground/70 hover:text-gold">
                {{ link.title | escape }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {% comment %} ─── Language Selector ─── {% endcomment %}
        {%- if section.settings.show_language_selector and shop.published_locales.size > 1 -%}
          <div class="relative ml-3">
            <button id="lang-dropdown-btn" class="flex items-center gap-1.5 px-2 py-2 font-body text-xs text-white/60 hover:text-gold transition-colors duration-300">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-width="1.5" d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z"/></svg>
              <span>{{ request.locale.iso_code | upcase }}</span>
            </button>
            <div id="lang-dropdown-panel" class="hidden absolute right-0 top-full mt-2 min-w-[180px] border border-white/10 bg-card py-2 shadow-soft z-50">
              {%- for locale in shop.published_locales -%}
                <a href="{{ locale.root_url }}" class="flex w-full items-center gap-3 px-4 py-2.5 text-left font-body text-sm text-white/70 hover:bg-white/5 hover:text-white transition-colors{% if request.locale.iso_code == locale.iso_code %} bg-white/5 text-white{% endif %}">
                  <span>{{ locale.endonym_name }}</span>
                </a>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {% comment %} ─── Action Button (Book Demo) ─── {% endcomment %}
        {%- if section.settings.show_action_button and section.settings.action_button_label != blank -%}
          <a href="{{ section.settings.action_button_link | default: '#' }}" class="ml-2 hidden 2xl:flex items-center gap-1.5 px-4 py-2.5 font-body text-xs font-semibold uppercase tracking-[0.1em] rounded-full border border-gold/50 text-gold hover:bg-gold hover:text-charcoal transition-all duration-300">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/><path stroke-width="1.5" d="M16 2v4M8 2v4M3 10h18"/></svg>
            <span>{{ section.settings.action_button_label | escape }}</span>
          </a>
        {%- endif -%}

        {% comment %} ─── Call Us ─── {% endcomment %}
        {%- if section.settings.show_phone and section.settings.phone_number != blank -%}
          <a href="tel:{{ section.settings.phone_number | remove: ' ' }}" class="ml-2 flex items-center gap-2 px-5 py-2.5 font-body text-xs font-semibold uppercase tracking-[0.1em] rounded-full gradient-gold text-charcoal hover:opacity-90 transition-opacity duration-300">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span>{{ section.settings.phone_label | escape }}</span>
          </a>
        {%- endif -%}

        {% comment %} ─── Cart ─── {% endcomment %}
        <a href="{{ routes.cart_url }}" class="ml-3 relative p-2 text-white/70 hover:text-gold transition-colors" aria-label="Cart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="absolute -top-1 -right-1 w-4 h-4 bg-gold text-charcoal text-[9px] font-bold rounded-full flex items-center justify-center">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </nav>

      {% comment %} ─── Mobile Controls ─── {% endcomment %}
      <div class="xl:hidden flex items-center gap-1">
        {%- if section.settings.show_badge -%}
          <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full mr-1 border border-gold/30 bg-gold/10 shadow-[0_0_10px_rgba(212,175,55,0.15)]">
            <span class="text-sm">{{ section.settings.badge_icon }}</span>
            <span class="font-body text-[9px] font-semibold uppercase tracking-[0.1em] text-gold">{{ section.settings.badge_text | escape }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.show_phone and section.settings.phone_number != blank -%}
          <a href="tel:{{ section.settings.phone_number | remove: ' ' }}" class="p-2 text-white" aria-label="{{ section.settings.phone_label | escape }}">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </a>
        {%- endif -%}

        <a href="{{ routes.cart_url }}" class="p-2 text-white relative" aria-label="Cart">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-gold text-charcoal text-[8px] font-bold rounded-full flex items-center justify-center">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
        <button id="mobile-menu-toggle" class="p-2 text-white" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7"/></svg>
        </button>
      </div>
    </div>
  </div>


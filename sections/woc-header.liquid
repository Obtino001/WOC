        <!-- Dynamic Book Demo CTA -->
        <button
          type="button"
          id="woc-hdr-demo-btn"
          class="ml-3 hidden xl:flex items-center gap-1.5 px-3.5 py-2 font-body text-[10px] font-semibold uppercase tracking-[0.1em] rounded-full border border-gold/50 text-gold hover:bg-gold hover:text-charcoal transition-all duration-300 whitespace-nowrap"
        >
          {%- if section.settings.demo_icon_svg != blank -%}
            {{ section.settings.demo_icon_svg }}
          {%- else -%}

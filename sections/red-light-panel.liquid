{% for block in section.blocks %}
  {% case block.type %}
    
    {% when 'feature_intro' %}
    <section class="border-b border-border bg-card py-8" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12">
        <p class="text-center font-display text-2xl font-semibold text-foreground md:text-3xl" style="opacity: 1">
          {{ block.settings.main_heading }}
        </p>
        <div class="mt-6 grid grid-cols-2 gap-6 md:grid-cols-4">
          {% if block.settings.feature_1_svg != blank and block.settings.feature_1_title != blank %}
          <div class="text-center">
            <div class="mx-auto mb-2 text-foreground">{{ block.settings.feature_1_svg }}</div>
            <p class="font-body text-sm font-bold text-foreground">{{ block.settings.feature_1_title }}</p>
            <p class="font-body text-xs text-muted-foreground">{{ block.settings.feature_1_desc }}</p>
          </div>
          {% endif %}
          {% if block.settings.feature_2_svg != blank and block.settings.feature_2_title != blank %}
          <div class="text-center">
            <div class="mx-auto mb-2 text-foreground">{{ block.settings.feature_2_svg }}</div>
            <p class="font-body text-sm font-bold text-foreground">{{ block.settings.feature_2_title }}</p>
            <p class="font-body text-xs text-muted-foreground">{{ block.settings.feature_2_desc }}</p>
          </div>
          {% endif %}
          {% if block.settings.feature_3_svg != blank and block.settings.feature_3_title != blank %}
          <div class="text-center">
            <div class="mx-auto mb-2 text-foreground">{{ block.settings.feature_3_svg }}</div>
            <p class="font-body text-sm font-bold text-foreground">{{ block.settings.feature_3_title }}</p>
            <p class="font-body text-xs text-muted-foreground">{{ block.settings.feature_3_desc }}</p>
          </div>
          {% endif %}
          {% if block.settings.feature_4_svg != blank and block.settings.feature_4_title != blank %}
          <div class="text-center">
            <div class="mx-auto mb-2 text-foreground">{{ block.settings.feature_4_svg }}</div>
            <p class="font-body text-sm font-bold text-foreground">{{ block.settings.feature_4_title }}</p>
            <p class="font-body text-xs text-muted-foreground">{{ block.settings.feature_4_desc }}</p>
          </div>
          {% endif %}
        </div>
      </div>
    </section>

    {% when 'what_is_rlt' %}
    <section class="bg-background py-16 md:py-24 border-b border-border" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
        <div class="text-center mb-12" style="opacity: 1; transform: none">
          <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ block.settings.subtitle }}</p>
          <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl mb-6">{{ block.settings.heading }}</h2>
        </div>
        <div class="space-y-8">
          <div class="rounded-2xl border border-border bg-card p-8 md:p-10" style="opacity: 1; transform: none">
            {{ block.settings.main_content }}
          </div>
          <div class="grid md:grid-cols-3 gap-5">
            {% for i in (1..3) %}
              {% assign step_num = 'step_' | append: i | append: '_num' %}
              {% assign step_title = 'step_' | append: i | append: '_title' %}
              {% assign step_text = 'step_' | append: i | append: '_text' %}
              {% if block.settings[step_title] != blank %}
              <div class="rounded-2xl border border-border bg-card p-6 text-center" style="opacity: 1; transform: none">
                <div class="w-10 h-10 rounded-full bg-destructive/10 flex items-center justify-center mx-auto mb-4">
                  <span class="font-display text-lg font-bold text-destructive">{{ block.settings[step_num] }}</span>
                </div>
                <h3 class="font-display text-lg font-bold text-foreground mb-2">{{ block.settings[step_title] }}</h3>
                <p class="font-body text-sm text-muted-foreground leading-relaxed">{{ block.settings[step_text] }}</p>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    {% when 'irradiance_table' %}
    <section class="bg-background py-16 md:py-20 border-b border-border" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
        <div class="text-center mb-10" style="opacity: 1; transform: none">
          <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ block.settings.subtitle }}</p>
          <h2 class="font-display text-2xl font-semibold text-foreground md:text-3xl">{{ block.settings.heading }}</h2>
          <p class="font-body text-sm text-muted-foreground mt-3 max-w-xl mx-auto">{{ block.settings.description }}</p>
        </div>
        <div class="overflow-hidden rounded-[1.5rem] border border-border bg-card">
          {{ block.settings.table_html }}
        </div>
      </div>
    </section>

    {% when 'smart_programs' %}
    <section class="bg-card py-16 md:py-20 border-b border-border" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
        <div class="text-center mb-12" style="opacity: 1; transform: none">
          <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ block.settings.subtitle }}</p>
          <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl mb-4">{{ block.settings.heading }}</h2>
          <p class="font-body text-sm text-muted-foreground max-w-2xl mx-auto">{{ block.settings.description }}</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {{ block.settings.programs_html }}
        </div>
        {% if block.settings.footer_text != blank %}
        <p class="text-center mt-8 font-body text-xs text-muted-foreground" style="opacity: 1">{{ block.settings.footer_text }}</p>
        {% endif %}
      </div>
    </section>

    {% when 'comparison_table' %}
    <section class="border-y border-border bg-card py-16 md:py-20" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
        <div class="text-center mb-10" style="opacity: 1">
          <h2 class="font-display text-2xl font-semibold text-foreground md:text-3xl">{{ block.settings.heading }}</h2>
        </div>
        <div class="overflow-hidden rounded-[1.5rem] border border-border bg-background">
          {{ block.settings.table_html }}
        </div>
      </div>
    </section>

    {% when 'package_contents' %}
    <section class="border-y border-border bg-card py-16 md:py-20" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
        <div class="rounded-[2rem] border border-border bg-background p-8 shadow-soft md:p-12" style="opacity: 1; transform: none">
          <div class="flex items-center gap-3 mb-6">
            {% if block.settings.icon_svg != blank %}{{ block.settings.icon_svg }}{% endif %}
            <h2 class="font-display text-xl font-semibold text-foreground">{{ block.settings.heading }}</h2>
          </div>
          <div class="space-y-3">
            {{ block.settings.list_html }}
          </div>
        </div>
      </div>
    </section>

    {% when 'tech_specs' %}
    <section class="bg-background py-16 md:py-20" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
        <div class="text-center mb-10" style="opacity: 1">
          <h2 class="font-display text-2xl font-semibold text-foreground md:text-3xl">{{ block.settings.heading }}</h2>
        </div>
        <div class="overflow-hidden rounded-[1.5rem] border border-border bg-card">
          {{ block.settings.table_html }}
        </div>
      </div>
    </section>

    {% when 'video_section' %}
    <section class="bg-card py-16 md:py-20 border-t border-border" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
        <div class="text-center mb-10" style="opacity: 1; transform: none">
          <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-3">{{ block.settings.subtitle }}</p>
          <h2 class="font-display text-2xl md:text-4xl font-light text-foreground">{{ block.settings.heading }}</h2>
        </div>
        <div class="rounded-2xl overflow-hidden border border-border shadow-lg" style="opacity: 1; transform: none">
          {% if block.settings.video_url != blank %}
            <video src="{{ block.settings.video_url }}" autoplay loop playsinline class="w-full aspect-video object-cover"></video>
          {% else %}
            <div class="w-full aspect-video bg-muted flex items-center justify-center text-muted-foreground">Video Yüklenmedi</div>
          {% endif %}
        </div>
      </div>
    </section>

    {% when 'cta_section' %}
    <section class="bg-background py-20" {{ block.shopify_attributes }}>
      <div class="container mx-auto px-6 text-center lg:px-12">
        <div class="mx-auto max-w-2xl rounded-[2rem] border border-border bg-card px-8 py-12 shadow-soft md:px-12" style="opacity: 1; transform: none">
          <h2 class="mb-4 font-display text-2xl font-semibold text-foreground md:text-3xl">{{ block.settings.heading }}</h2>
          <p class="mb-8 font-body text-base text-muted-foreground">{{ block.settings.description }}</p>
          <div class="flex flex-col justify-center gap-4 sm:flex-row">
            {% if block.settings.button_text != blank %}
            <a href="{{ block.settings.button_link | default: '#' }}" class="inline-flex items-center justify-center gap-2 rounded-full bg-foreground px-10 py-4 font-body text-sm font-semibold uppercase tracking-[0.18em] text-background transition-opacity hover:opacity-90">
              {{ block.settings.button_text }}
            </a>
            {% endif %}
          </div>
        </div>
      </div>
    </section>

  {% endcase %}
{% endfor %}

{% schema %}
{
  "name": "Red Light Panel Sections",
  "tag": "section",
  "class": "red-light-panel-sections",
  "blocks": [
    {
      "type": "feature_intro",
      "name": "Feature Intro (4 Icons)",
      "settings": [
        { "type": "text", "id": "main_heading", "label": "Main Heading", "default": "Vücudunuzun doğuştan gelen iyileşme gücünü yeniden keşfedin." },
        { "type": "header", "content": "Feature 1" },
        { "type": "html", "id": "feature_1_svg", "label": "Feature 1 SVG" },
        { "type": "text", "id": "feature_1_title", "label": "Title", "default": "Kas iyileşmesi" },
        { "type": "text", "id": "feature_1_desc", "label": "Description", "default": "Daha hızlı iyileşme." },
        { "type": "header", "content": "Feature 2" },
        { "type": "html", "id": "feature_2_svg", "label": "Feature 2 SVG" },
        { "type": "text", "id": "feature_2_title", "label": "Title", "default": "İltihap" },
        { "type": "text", "id": "feature_2_desc", "label": "Description", "default": "Doğal ağrı kesici." },
        { "type": "header", "content": "Feature 3" },
        { "type": "html", "id": "feature_3_svg", "label": "Feature 3 SVG" },
        { "type": "text", "id": "feature_3_title", "label": "Title", "default": "Cilt sağlığı" },
        { "type": "text", "id": "feature_3_desc", "label": "Description", "default": "Artan kolajen." },
        { "type": "header", "content": "Feature 4" },
        { "type": "html", "id": "feature_4_svg", "label": "Feature 4 SVG" },
        { "type": "text", "id": "feature_4_title", "label": "Title", "default": "Uyku kalitesi" },
        { "type": "text", "id": "feature_4_desc", "label": "Description", "default": "Daha iyi, daha derin uyku." }
      ]
    },
    {
      "type": "what_is_rlt",
      "name": "What is RLT",
      "settings": [
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "BİLİMSEL OLARAK KANITLANMIŞTIR" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Kırmızı ışık terapisi nedir?" },
        { "type": "richtext", "id": "main_content", "label": "Main Content" },
        { "type": "header", "content": "Step 1" },
        { "type": "text", "id": "step_1_num", "label": "Number", "default": "1" },
        { "type": "text", "id": "step_1_title", "label": "Title", "default": "Işık emilir" },
        { "type": "textarea", "id": "step_1_text", "label": "Text", "default": "660nm ve 850nm dalga boyları cilde, kaslara ve eklemlere tamamen ısı ve rahatsızlık olmadan nüfuz eder." },
        { "type": "header", "content": "Step 2" },
        { "type": "text", "id": "step_2_num", "label": "Number", "default": "2" },
        { "type": "text", "id": "step_2_title", "label": "Title", "default": "Hücreler aktive olur" },
        { "type": "textarea", "id": "step_2_text", "label": "Text", "default": "Işık, mitokondriyi uyarır ve ATP üretimini artırır; bu da hücrelerin onarım ve yenilenme yakıtıdır." },
        { "type": "header", "content": "Step 3" },
        { "type": "text", "id": "step_3_num", "label": "Number", "default": "3" },
        { "type": "text", "id": "step_3_title", "label": "Title", "default": "Vücut iyileşir" },
        { "type": "textarea", "id": "step_3_text", "label": "Text", "default": "Sonuç: daha hızlı iyileşme, azalmış iltihaplanma, daha sağlıklı cilt, daha iyi uyku ve daha fazla enerji." }
      ]
    },
    {
      "type": "irradiance_table",
      "name": "Irradiance Table",
      "settings": [
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "IŞINIM" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Tüm mesafelerde etkili terapi" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Panele ne kadar yakın olursanız, ışık yoğunluğu o kadar yüksek olur. Önerilen tedavi mesafesi: 15-30 cm." },
        { "type": "html", "id": "table_html", "label": "Table HTML", "default": "<div class='grid grid-cols-6 border-b border-border bg-muted px-4 py-3'><span class='col-span-1 font-body text-xs font-bold uppercase tracking-wider text-foreground'>Mesafe</span><span class='text-center font-body text-xs font-semibold text-muted-foreground'>15 cm</span><span class='text-center font-body text-xs font-semibold text-muted-foreground'>30 cm</span><span class='text-center font-body text-xs font-semibold text-muted-foreground'>45 cm</span><span class='text-center font-body text-xs font-semibold text-muted-foreground'>60 cm</span><span class='text-center font-body text-xs font-semibold text-muted-foreground'>90 cm</span></div><div class='grid grid-cols-6 border-b border-border px-4 py-3'><span class='col-span-1 font-body text-xs font-semibold text-foreground'>Kapsama</span><span class='text-center font-body text-xs text-muted-foreground'>25×20 cm</span><span class='text-center font-body text-xs text-muted-foreground'>35×30 cm</span><span class='text-center font-body text-xs text-muted-foreground'>40×40 cm</span><span class='text-center font-body text-xs text-muted-foreground'>50×50 cm</span><span class='text-center font-body text-xs text-muted-foreground'>71×61 cm</span></div><div class='grid grid-cols-6 px-4 py-3'><span class='col-span-1 font-body text-xs font-semibold text-foreground'>mW/cm²</span><span class='text-center font-body text-xs font-bold text-green-600'>118</span><span class='text-center font-body text-xs font-bold text-green-600'>70</span><span class='text-center font-body text-xs font-bold text-muted-foreground'>58</span><span class='text-center font-body text-xs font-bold text-muted-foreground'>46</span><span class='text-center font-body text-xs font-bold text-muted-foreground'>22</span></div>" }
      ]
    },
    {
      "type": "smart_programs",
      "name": "Smart Programs Grid",
      "settings": [
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "DOKUNMATİK EKRAN PROGRAMLARI" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "11 akıllı tedavi programı" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Dokunmatik ekranda tedavi hedefinizi seçmeniz yeterli; panel otomatik olarak optimal dalga boylarını, yoğunluğu ve darbe frekansını ayarlar. Manuel bir kuruluma gerek yoktur." },
        { "type": "html", "id": "programs_html", "label": "Programs Grid HTML (Paste all inner items)" },
        { "type": "text", "id": "footer_text", "label": "Footer Text", "default": "Hafızalı 3 özel ön ayar daha — tercih ettiğiniz ayarları bir sonraki kullanım için kaydedin." }
      ]
    },
    {
      "type": "comparison_table",
      "name": "Comparison Table",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Neden kırmızı ışık terapisini seçmelisiniz?" },
        { "type": "html", "id": "table_html", "label": "Table HTML", "default": "<div class='grid grid-cols-[1fr_auto_auto] border-b border-border bg-muted px-6 py-4'><span class='font-body text-xs font-semibold uppercase tracking-wider text-muted-foreground'></span><span class='w-28 text-center font-body text-xs font-bold uppercase tracking-wider text-foreground'>Panel 300</span><span class='w-28 text-center font-body text-xs font-semibold uppercase tracking-wider text-muted-foreground'>Takviyeler</span></div><div class='grid grid-cols-[1fr_auto_auto] items-center px-6 py-3.5 border-b border-border'><span class='font-body text-sm text-foreground'>Kas iyileşmesini destekler</span><span class='w-28 text-center text-green-600'>✓</span><span class='w-28 text-center text-destructive font-body text-lg'>✕</span></div>" }
      ]
    },
    {
      "type": "package_contents",
      "name": "Package Contents",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Paket içeriği" },
        { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
        { "type": "html", "id": "list_html", "label": "List Items HTML", "default": "<div class='flex items-center gap-3'><svg class='w-4 h-4 text-green-600 flex-shrink-0' fill='none' stroke='currentColor' stroke-width='2' viewBox='0 0 24 24'><path d='M20 6 9 17l-5-5'></path></svg><span class='font-body text-sm text-foreground'>LED Terapi Işığı</span></div>" }
      ]
    },
    {
      "type": "tech_specs",
      "name": "Tech Specs Table",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Teknik Özellikler" },
        { "type": "html", "id": "table_html", "label": "Table HTML", "default": "<div class='grid grid-cols-2 px-6 py-3.5 border-b border-border'><span class='font-body text-sm font-semibold text-foreground'>Model</span><span class='font-body text-sm text-muted-foreground'>Kırmızı Işık Paneli 300</span></div>" }
      ]
    },
    {
      "type": "video_section",
      "name": "Video Section",
      "settings": [
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Paneli çalışırken görün" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "7 dalga boyu — bireysel kontrol" },
        { "type": "video", "id": "video_url", "label": "Video URL" }
      ]
    },
    {
      "type": "cta_section",
      "name": "Call To Action (CTA)",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Kırmızı ışık terapisini deneyimlemeye hazır mısınız?" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Red Light Panel 300'ünüzü bugün ücretsiz kargo ve 30 günlük memnuniyet garantisiyle sipariş edin." },
        { "type": "text", "id": "button_text", "label": "Button Text", "default": "Şimdi satın al — ₺13.248" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Red Light Panel Layout",
      "blocks": [
        { "type": "feature_intro" },
        { "type": "what_is_rlt" },
        { "type": "irradiance_table" },
        { "type": "smart_programs" },
        { "type": "comparison_table" },
        { "type": "package_contents" },
        { "type": "tech_specs" },
        { "type": "video_section" },
        { "type": "cta_section" }
      ]
    }
  ]
}
{% endschema %}
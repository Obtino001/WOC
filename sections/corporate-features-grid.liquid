{% assign bg_color = section.settings.background_color %}
{% assign is_dark = false %}
{% if bg_color == 'bg-corporate-dark' or bg_color == 'bg-card' %}
  {% assign is_dark = true %}
{% endif %}

<section class="woc-section-py {{ bg_color }} relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex-1 flex flex-col justify-end pb-12 lg:pb-16 w-full pt-10">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      {% if section.settings.subheading != blank %}
        <span class="inline-block font-body text-sm font-semibold tracking-widest uppercase {% if is_dark %}text-corporate{% else %}text-corporate{% endif %} mb-3">{{ section.settings.subheading }}</span>
      {% endif %}
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold {% if is_dark %}text-white{% else %}text-neutral-900{% endif %} mt-2 mb-4">{{ section.settings.heading }}</h2>
      {% if section.settings.description != blank %}
        <p class="font-body text-base md:text-lg {% if is_dark %}text-white/60{% else %}text-neutral-600{% endif %} max-w-2xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="grid md:grid-cols-{{ section.settings.columns_md }} lg:grid-cols-{{ section.settings.columns_lg }} gap-6 lg:gap-8 max-w-6xl mx-auto">
      {% for block in section.blocks %}
        <div class="{{ section.settings.card_style }} h-full" {{ block.shopify_attributes }}>
          <div class="p-8 flex flex-col h-full {% if section.settings.center_content %}text-center items-center{% else %}items-start{% endif %}">
            
            {% if block.settings.icon_svg != blank or block.settings.step_number != blank %}
              <div class="mb-5 flex {% if section.settings.center_content %}justify-center{% else %}justify-start{% endif %} w-full">
                {% if block.settings.step_number != blank %}
                  <span class="font-display text-5xl font-bold text-corporate/30">{{ block.settings.step_number }}</span>
                {% elsif block.settings.icon_svg != blank %}
                  <div class="w-16 h-16 rounded-2xl bg-corporate/10 text-corporate flex items-center justify-center transition-transform duration-500 hover:scale-110 [&>svg]:w-8 [&>svg]:h-8">
                    {{ block.settings.icon_svg }}
                  </div>
                {% endif %}
              </div>
            {% endif %}

            <h3 class="font-display text-xl font-semibold {% if is_dark %}text-white{% else %}text-neutral-900{% endif %} mb-3">{{ block.settings.title }}</h3>
            <div class="font-body text-sm {% if is_dark %}text-white/60{% else %}text-neutral-600{% endif %} leading-relaxed flex-1">
              {{ block.settings.text }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank %}
      <div class="text-center mt-12">
        <a href="{{ section.settings.button_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-corporate hover:bg-corporate-dark text-white font-body font-semibold px-8 py-5 h-auto rounded-full text-sm uppercase tracking-wider transition-all duration-500">
          {{ section.settings.button_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Features Grid",
  "settings": [
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-neutral-50", "label": "Light Gray" },
        { "value": "bg-card", "label": "Dark Card" },
        { "value": "bg-corporate-dark", "label": "Corporate Dark" }
      ],
      "default": "bg-white"
    },
{
  "type": "select",
  "id": "card_style",
  "label": "Card Style",
  "options": [
    { "value": "transparent", "label": "Transparent (No Border)" },
    { "value": "white", "label": "White Card w/ Border" },
    { "value": "dark", "label": "Dark Card w/ Border" }
  ],
  "default": "transparent"
},
    {
      "type": "range",
      "id": "columns_md",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columns (Tablet)",
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_lg",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Columns (Desktop)",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "center_content",
      "label": "Center Align Content",
      "default": false
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number (Optional)",
          "info": "e.g., 01 (Overrides Icon)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Card Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Grid"
    }
  ]
}
{% endschema %}
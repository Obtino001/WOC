<section class="relative overflow-hidden pt-32 pb-24 md:pt-44 md:pb-32" style="background: rgb(15, 31, 46);">
  <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full blur-3xl opacity-20" style="background: radial-gradient(circle, rgb(14, 92, 92) 0%, transparent 70%);"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full blur-3xl opacity-15" style="background: radial-gradient(circle, rgb(194, 139, 36) 0%, transparent 70%);"></div>
  <div class="relative container mx-auto px-4 lg:px-8 max-w-6xl">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-8 border" style="border-color: rgba(194, 139, 36, 0.4); background: rgba(194, 139, 36, 0.08);">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-3.5 h-3.5" style="color: rgb(194, 139, 36);"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path></svg>
        <span class="font-body text-xs font-semibold tracking-widest uppercase" style="color: rgb(194, 139, 36);">{{ section.settings.badge_text }}</span>
      </div>
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight text-white mb-6">{{ section.settings.title }}</h1>
      <p class="font-body text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed mb-10">{{ section.settings.subtitle }}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 bg-primary hover:bg-primary/90 font-body text-sm font-semibold px-8 py-6 h-auto rounded-full uppercase tracking-wider text-white" href="{{ section.settings.btn_1_url }}" style="background: rgb(194, 139, 36);">
          {{ section.settings.btn_1_text }} <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 border bg-background font-body text-sm font-semibold px-8 py-6 h-auto rounded-full uppercase tracking-wider border-white/30 text-white hover:bg-white/10 hover:text-white" href="{{ section.settings.btn_2_url }}">
          {{ section.settings.btn_2_text }}
        </a>
      </div>
    </div>
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-4">
      {% for block in section.blocks %}
        <div class="text-center p-6 rounded-2xl border border-white/10 backdrop-blur-sm" style="background: rgba(255, 255, 255, 0.03);" {{ block.shopify_attributes }}>
          <div class="lucide-icon mx-auto mb-3" style="color: rgb(194, 139, 36); width: 20px; height: 20px;">
            {{ block.settings.svg_icon }}
          </div>
          <div class="font-display text-3xl md:text-4xl font-bold text-white mb-1">{{ block.settings.value }}</div>
          <div class="font-body text-xs text-white/60 uppercase tracking-wider">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC Hero meta",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge Text", "default": "WOC Yöntemi®" },
    { "type": "textarea", "id": "title", "label": "Heading", "default": "Sürdürülebilir performans<br>ile <span class=\"italic\" style=\"color: rgb(194, 139, 36);\">akıllı dinlenme</span>" },
    { "type": "textarea", "id": "subtitle", "label": "Subheading", "default": "2015'ten beri geliştirilen bilimsel bir yöntem..." },
    { "type": "text", "id": "btn_1_text", "label": "Button 1 Text", "default": "Demo ayırtın" },
    { "type": "url", "id": "btn_1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "btn_2_text", "label": "Button 2 Text", "default": "Tasarrufu hesapla" },
    { "type": "url", "id": "btn_2_url", "label": "Button 2 URL" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Item",
      "settings": [
        { "type": "html", "id": "svg_icon", "label": "SVG Icon Code" },
        { "type": "text", "id": "value", "label": "Value (e.g. -27%)" },
        { "type": "text", "id": "label", "label": "Label (e.g. Azalan kortizol)" }
      ]
    }
  ],
  "presets": [{ "name": "WOC Hero meta" }]
}
{% endschema %}

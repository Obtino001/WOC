<div class="bg-copper text-white text-center py-2.5">
  <p class="font-body text-xs md:text-sm font-semibold uppercase tracking-[0.15em]">{{ section.settings.top_bar_text }}</p>
</div>

<div class="bg-white border-b border-neutral-100 py-1.5">
  <div class="container mx-auto px-4 flex items-center justify-center gap-2 text-xs text-neutral-600 font-body">
    <span>{{ section.settings.middle_bar_text }}</span>
    {% if section.settings.middle_bar_flag != blank %}
      <span class="ml-4 text-neutral-400">{{ section.settings.middle_bar_flag }}</span>
      <span class="text-neutral-500">{{ section.settings.middle_bar_suffix }}</span>
    {% endif %}
  </div>
</div>

<div class="bg-white border-b border-neutral-100 py-6">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-center gap-10 md:gap-20">
      {% for block in section.blocks %}
        <div class="flex flex-col items-center text-center" {{ block.shopify_attributes }}>
          <div class="mb-1.5 [&>svg]:w-7 [&>svg]:h-7 [&>svg]:text-copper [&>svg]:stroke-[1.5]">
            {{ block.settings.icon_svg }}
          </div>
          <span class="font-body text-sm font-semibold text-copper">{{ block.settings.title }}</span>
          <span class="font-body text-xs text-neutral-500">{{ block.settings.subtitle }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "settings": [
    {
      "type": "text",
      "id": "top_bar_text",
      "label": "Top Bar Text",
      "default": "UDVALGTE TILBUD PÅ MASSAGEAPPARATER 👉"
    },
    {
      "type": "text",
      "id": "middle_bar_text",
      "label": "Middle Bar Text",
      "default": "Gratis levering | 30 dages tilfredshedsgaranti"
    },
    {
      "type": "text",
      "id": "middle_bar_flag",
      "label": "Middle Bar Emoji",
      "default": "🇩🇰"
    },
    {
      "type": "text",
      "id": "middle_bar_suffix",
      "label": "Middle Bar Suffix",
      "default": "Dansk nethandel"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner"
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-card border-y border-border">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {%- for block in section.blocks -%}
        <div class="rounded-none border bg-card text-card-foreground shadow-sm p-8 border-border" {{ block.shopify_attributes }}>
          <div class="p-0 space-y-4">
            <div class="flex gap-1">
              {% for i in (1..5) %}
                 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-4 h-4 fill-corporate text-corporate"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              {% endfor %}
            </div>
            <p class="font-body text-foreground italic leading-relaxed">"{{ block.settings.quote }}"</p>
            <div>
              <p class="font-body text-sm font-semibold text-foreground">{{ block.settings.author }}</p>
              <p class="font-body text-xs text-muted-foreground">{{ block.settings.title }}</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Corporate Testimonials",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 52 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 2,
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author Name" },
        { "type": "text", "id": "title", "label": "Job Title & Company" }
      ]
    }
  ],
  "presets": [
    { "name": "Corporate Testimonials" }
  ]
}
{% endschema %}

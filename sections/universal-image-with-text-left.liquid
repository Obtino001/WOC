<section class="woc-section-py bg-[#0a0a0a] overflow-hidden">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-6xl mx-auto">
      
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        <!-- Image Side -->
        <div class="rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.5)] {% if section.settings.image_position == 'right' %}order-2{% else %}order-1{% endif %}">
          {% if section.settings.image %}
            {{ section.settings.image | image_url: width: 800 | image_tag: class: 'w-full aspect-[4/3] object-cover' }}
          {% else %}
            <!-- Placeholder if no image is selected -->
            <div class="w-full aspect-[4/3] bg-[#111] border border-[#222] flex items-center justify-center text-[#555]">
              Görsel Alanı
            </div>
          {% endif %}
        </div>

        <!-- Content Side -->
        <div class="{% if section.settings.image_position == 'right' %}order-1{% else %}order-2{% endif %}">
          
          {% if section.settings.badge != blank %}
            <div class="inline-flex items-center rounded-full border px-3 py-1 font-semibold transition-colors bg-green-900/30 text-green-400 border-green-800 mb-6 text-[10px] uppercase tracking-widest">
              {{ section.settings.badge }}
            </div>
          {% endif %}
          
          {% if section.settings.title != blank %}
            <h2 class="font-display text-3xl md:text-4xl lg:text-4xl font-light text-white mb-6">
              {{ section.settings.title }}
            </h2>
          {% endif %}
          
          {% if section.settings.description != blank %}
            <div class="font-body text-[#888] leading-relaxed mb-8 text-sm md:text-base [&_p]:mb-4 last:[&_p]:mb-0">
              {{ section.settings.description }}
            </div>
          {% endif %}

          <!-- Icon List (1 Column with Shield Icons) -->
          {% if section.blocks.size > 0 %}
            <div class="space-y-4">
              {% for block in section.blocks %}
                <div class="flex items-start gap-3" {{ block.shopify_attributes }}>
                  <div class="w-6 h-6 rounded-full bg-green-900/30 border border-green-800/50 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3 text-green-400">
                      <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                    </svg>
                  </div>
                  <span class="font-body text-xs sm:text-sm text-[#ddd] leading-relaxed">{{ block.settings.text }}</span>
                </div>
              {% endfor %}
            </div>
          {% endif %}

        </div>
        
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature Dark (Eco/Health)",
  "settings": [
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {"value": "left", "label": "Left"},
        {"value": "right", "label": "Right"}
      ],
      "default": "right"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "DOĞAL OLARAK ANTİBAKTERİYEL"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Daha sağlıklı uyuyun — her gece"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text"
    }
  ],
  "blocks": [
    {
      "type": "check_item",
      "name": "List Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Dark (Eco/Health)",
      "settings": {
        "image_position": "right",
        "badge": "DOĞAL OLARAK ANTİBAKTERİYEL",
        "title": "Daha sağlıklı uyuyun — her gece",
        "description": "<p>Yataklarımız sağlığınız düşünülerek tasarlanmıştır. Lateks doğal olarak antibakteriyel ve hipoalerjeniktir — toz akarları, bakteriler ve küflerin yaşayamadığı bir ortam yaratır.</p><p>Ayrıca, tüm yatak örtülerimiz GREENFIRST® — sitronella, lavanta ve okaliptüsten elde edilen bitkisel bazlı bir anti-akar tedavisidir. Kimyasal yok, taviz yok — sadece daha sağlıklı bir uyku ortamı.</p>"
      },
      "blocks": [
        {
          "type": "check_item",
          "settings": {
            "text": "Doğal lateks, toz akarlarına ve küfe karşı doğal olarak dirençlidir"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "GREENFIRST® bitkisel bazlı anti-akar tedavisi"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "OEKO-TEX® Standard 100 sertifikalı — zararlı maddeler için test edilmiştir"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "Nefes alabilen hücre yapısı nem birikimini önler"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "Alerjisi ve astımı olanlar için idealdir"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "Kılıf çıkarılabilir ve yıkanabilir"
          }
        }
      ]
    }
  ]
}
{% endschema %}
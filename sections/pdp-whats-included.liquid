<section class="py-12 bg-neutral-50 text-neutral-900 border-t border-neutral-200">
  <div class="max-w-[1200px] mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
      
      <!-- Left Column: What's Included & Free Gifts -->
      <div class="flex flex-col">
        <!-- Checklist of Package items -->
        <div class="mb-8">
          <h3 class="font-body text-sm font-bold text-neutral-800 uppercase tracking-widest mb-4">
            {{ section.settings.included_title }}
          </h3>
          <div class="space-y-2.5">
            {%- for block in section.blocks -%}
              {%- if block.type == 'item' -%}
                <div class="flex items-center gap-2 py-1.5 border-b border-neutral-100 last:border-0" {{ block.shopify_attributes }}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d2542a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-copper flex-shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  <div>
                    <span class="font-body text-xs font-semibold text-neutral-800">{{ block.settings.name }}</span>
                    <span class="font-body text-xs text-neutral-400 ml-2">{{ block.settings.detail }}</span>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <!-- Included Free Gifts Promo panel -->
        <div>
          <h3 class="font-body text-xs font-bold text-neutral-700 mb-3">
            {{ section.settings.gifts_title }}
          </h3>
          <div class="grid grid-cols-2 gap-4">
            {%- for block in section.blocks -%}
              {%- if block.type == 'gift' -%}
                
                <div class="p-4 bg-white rounded border border-neutral-200 text-center flex flex-col justify-between items-center" {{ block.shopify_attributes }}>
                  <!-- Icon -->
                  <div class="text-copper mb-2 shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="3" x2="12" y2="21"></line><line x1="3" y1="12" x2="21" y2="12"></line></svg>
                  </div>
                  <div>
                    <p class="font-body text-xs font-bold text-neutral-700 mb-1 leading-snug">{{ block.settings.name }}</p>
                    <p class="font-body text-[10px] text-neutral-400 mb-2 leading-relaxed">{{ block.settings.desc }}</p>
                  </div>
                  <p class="font-body text-[10px] text-copper font-semibold uppercase tracking-wider mt-auto">
                    {{ block.settings.value }}
                  </p>
                </div>

              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- Right Column: Technical Specifications -->
      <div>
        <h3 class="font-body text-sm font-bold text-neutral-800 uppercase tracking-widest mb-4">
          {{ section.settings.specs_title }}
        </h3>
        
        <div class="border border-neutral-200 rounded-lg bg-white overflow-hidden shadow-sm">
          <div class="p-4 space-y-0.5">
            {%- for block in section.blocks -%}
              {%- if block.type == 'spec' -%}
                
                <div class="flex justify-between items-center py-2.5 border-b border-neutral-100 last:border-0" {{ block.shopify_attributes }}>
                  <span class="font-body text-xs font-semibold text-neutral-600 pr-4">{{ block.settings.key }}</span>
                  <span class="font-body text-xs text-neutral-500 text-right">{{ block.settings.value }}</span>
                </div>

              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP Package & Specs",
  "settings": [
    {
      "type": "text",
      "id": "included_title",
      "label": "Package Title",
      "default": "Hvad følger med i kassen?"
    },
    {
      "type": "text",
      "id": "gifts_title",
      "label": "Gifts Section Title",
      "default": "INKLUDEREDE GRATIS GAVER:"
    },
    {
      "type": "text",
      "id": "specs_title",
      "label": "Specs Title",
      "default": "Tekniske Specifikationer"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Package Item",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Item Name",
          "default": "Saunatæppe"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Item Details",
          "default": "3-zone infrarød opvarmning"
        }
      ]
    },
    {
      "type": "gift",
      "name": "Free Gift Card",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Gift Title",
          "default": "Bæretaske"
        },
        {
          "type": "text",
          "id": "desc",
          "label": "Gift description",
          "default": "Holdbar taske til nem transport."
        },
        {
          "type": "text",
          "id": "value",
          "label": "Gift Value Text",
          "default": "Gratis (Værdi 499,-)"
        }
      ]
    },
    {
      "type": "spec",
      "name": "Specification Row",
      "settings": [
        {
          "type": "text",
          "id": "key",
          "label": "Specification Attribute",
          "default": "Temperatur"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Specification Value",
          "default": "30–75°C"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Package & Specs",
      "blocks": [
        { "type": "item", "settings": { "name": "Nordic Sauna Blanket", "detail": "3-zone infrarødt saunatæppe" } },
        { "type": "item", "settings": { "name": "Kontrolboks", "detail": "Med indbygget timer & zone-vælger" } },
        { "type": "item", "settings": { "name": "Bæretaske", "detail": "Til praktisk opbevaring" } },
        { "type": "gift", "settings": { "name": "E-bog & Videokursus", "desc": "Guide til infrarød terapi.", "value": "Gratis (Værdi 299,-)" } },
        { "type": "gift", "settings": { "name": "Opbevaringstaske", "desc": "Kvalitetsbæretaske.", "value": "Gratis (Værdi 499,-)" } },
        { "type": "spec", "settings": { "key": "Varmezoner", "value": "3 uafhængige zoner" } },
        { "type": "spec", "settings": { "key": "Temperaturområde", "value": "30–75°C" } },
        { "type": "spec", "settings": { "key": "Timer", "value": "20–60 minutter" } },
        { "type": "spec", "settings": { "key": "Strømforbrug", "value": "400W–650W" } },
        { "type": "spec", "settings": { "key": "Certificeringer", "value": "ISO9001, CE, FCC, ROHS" } }
      ]
    }
  ]
}
{% endschema %}

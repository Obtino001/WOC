{%- style -%}
  #shopify-section-{{ section.id }} {
    --hero-accent: {{ section.settings.accent_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .hero-video-wrapper video,
  .hero-video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0, var(--overlay-opacity)) 0%, rgba(0,0,0, calc(var(--overlay-opacity) * 0.4)) 50%, transparent 100%);
    z-index: 1;
  }
  
  .hero-overlay-side {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0, calc(var(--overlay-opacity) * 0.6)) 0%, transparent 50%);
    z-index: 1;
  }

  .hero-btn-primary {
    background-color: var(--hero-accent);
    color: #111111;
    transition: transform 0.3s ease, filter 0.3s ease;
  }
  .hero-btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
  }

  .hero-btn-secondary {
    border-color: rgba(255,255,255,0.3);
    transition: all 0.3s ease;
  }
  .hero-btn-secondary:hover {
    background-color: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.6);
  }

  .usp-bar {
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid color-mix(in srgb, var(--hero-accent) 20%, transparent);
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} relative h-[100vh] min-h-[600px] flex flex-col justify-end overflow-hidden">
  
  {% comment %} --- BACKGROUND MEDIA (FORCED HIGH QUALITY) --- {% endcomment %}
  <div class="hero-video-wrapper absolute inset-0 w-full h-full bg-black overflow-hidden pointer-events-none">
    {%- if section.settings.shopify_video != blank -%}
      {%- comment -%} Find the highest resolution MP4 to bypass Shopify's blurry adaptive streaming {%- endcomment -%}
      {%- assign high_res_video = section.settings.shopify_video.sources | where: "format", "mp4" | sort: "height" | last -%}
      
      <video autoplay muted loop playsinline class="w-full h-full object-cover" poster="{{ section.settings.shopify_video.preview_image | image_url: width: 3840 }}">
        <source src="{{ high_res_video.url }}" type="{{ high_res_video.mime_type }}">
      </video>

    {%- elsif section.settings.external_video_url != blank -%}
      {%- if section.settings.external_video_url.type == 'youtube' -%}
        <iframe src="https://www.youtube.com/embed/{{ section.settings.external_video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.external_video_url.id }}&controls=0&showinfo=0&rel=0&playsinline=1&vq=hd1080" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
      {%- elsif section.settings.external_video_url.type == 'vimeo' -%}
        <iframe src="https://player.vimeo.com/video/{{ section.settings.external_video_url.id }}?autoplay=1&muted=1&loop=1&background=1&playsinline=1&quality=1080p" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
      {%- endif -%}

    {%- elsif section.settings.video_source_url != blank -%}
      <video autoplay muted loop playsinline class="w-full h-full object-cover" poster="{{ section.settings.poster_image | image_url: width: 3840 }}">
        <source src="{{ section.settings.video_source_url }}" type="video/mp4">
      </video>

    {%- elsif section.settings.poster_image != blank -%}
      {{ section.settings.poster_image | image_url: width: 3840 | image_tag: class: 'w-full h-full object-cover', loading: 'eager', fetchpriority: 'high' }}
      
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
    {%- endif -%}
    
    <div class="hero-overlay"></div>
    <div class="hero-overlay-side"></div>
  </div>

  {% comment %} --- HERO CONTENT --- {% endcomment %}
  <div class="container mx-auto px-4 lg:px-8 relative z-10 pb-20 lg:pb-28">
    <div class="max-w-3xl">
      
      <div class="w-16 h-[2px] mb-8" style="background-color: var(--hero-accent);"></div>
      
      <h1 class="font-display text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-light text-white leading-[1.05] mb-6 drop-shadow-sm">
        {{ section.settings.title1 }}
        {%- if section.settings.title2 != blank -%}
          <span class="block italic font-light mt-1 md:mt-2" style="color: var(--hero-accent);">
            {{ section.settings.title2 }}
          </span>
        {%- endif -%}
      </h1>
      
      {%- if section.settings.subtitle != blank -%}
        <p class="font-body text-base md:text-lg font-light text-white/90 mb-10 max-w-lg leading-relaxed tracking-wide drop-shadow-sm">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

      <div class="flex flex-col sm:flex-row gap-4">
        {%- if section.settings.btn1_text != blank -%}
          <a href="{{ section.settings.btn1_link | default: '#' }}" class="hero-btn-primary inline-flex items-center justify-center px-8 py-4 font-body text-sm font-semibold uppercase tracking-widest text-center">
            {{ section.settings.btn1_text }}
          </a>
        {%- endif -%}
        
        {%- if section.settings.btn2_text != blank -%}
          <a href="{{ section.settings.btn2_link | default: '#' }}" class="hero-btn-secondary inline-flex items-center justify-center px-8 py-4 border text-white font-body text-sm font-medium uppercase tracking-widest text-center backdrop-blur-sm">
            {{ section.settings.btn2_text }}
          </a>
        {%- endif -%}
      </div>
      
    </div>
  </div>

  {% comment %} --- USP BAR (Dynamic Blocks) --- {% endcomment %}
  {%- assign usp_blocks = section.blocks | where: 'type', 'usp' -%}
  {%- if usp_blocks.size > 0 -%}
    <div class="relative z-10 usp-bar mt-auto">
      <div class="container mx-auto px-4 lg:px-8">
        
        <div class="hidden md:flex items-center justify-between py-4 lg:py-5 overflow-x-auto no-scrollbar gap-6">
          {%- for block in usp_blocks -%}
            <div class="flex items-center gap-3 shrink-0" {{ block.shopify_attributes }}>
              
              <div class="w-5 h-5 flex items-center justify-center shrink-0" style="color: var(--hero-accent);">
                {%- if block.settings.svg_icon != blank -%}
                  {{ block.settings.svg_icon }}
                {%- else -%}
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {%- endif -%}
              </div>
              
              <span class="font-body text-xs font-semibold uppercase tracking-widest text-white/80 whitespace-nowrap">
                {{ block.settings.title }}
              </span>
            </div>
            
            {%- unless forloop.last -%}
              <div class="w-px h-5 hidden lg:block opacity-30" style="background-color: var(--hero-accent);"></div>
            {%- endunless -%}
          {%- endfor -%}
        </div>

        <div class="md:hidden flex overflow-x-auto snap-x snap-mandatory py-4 gap-6 no-scrollbar">
          {%- for block in usp_blocks -%}
            <div class="flex items-center gap-2 shrink-0 snap-start" {{ block.shopify_attributes }}>
              <div class="w-4 h-4 flex items-center justify-center shrink-0" style="color: var(--hero-accent);">
                {%- if block.settings.svg_icon != blank -%}
                  {{ block.settings.svg_icon }}
                {%- else -%}
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {%- endif -%}
              </div>
              <span class="font-body text-[10px] font-semibold uppercase tracking-widest text-white/80 whitespace-nowrap">
                {{ block.settings.title }}
              </span>
            </div>
          {%- endfor -%}
        </div>

      </div>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Hero Section",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Theme & Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Base Color Scheme",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D4AF37",
      "info": "Used for the primary button, highlights, and icons."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Video Darkening Overlay",
      "default": 60,
      "info": "Increase this if your white text is hard to read against a bright video."
    },
    {
      "type": "header",
      "content": "Media (Video / Image)"
    },
    {
      "type": "video",
      "id": "shopify_video",
      "label": "Shopify Video (Recommended)",
      "info": "Upload a 1080p or 4K video directly to Shopify for the highest quality playback."
    },
    {
      "type": "video_url",
      "id": "external_video_url",
      "label": "YouTube / Vimeo URL",
      "accept": ["youtube", "vimeo"],
      "info": "Fallback if no Shopify Video is uploaded."
    },
    {
      "type": "text",
      "id": "video_source_url",
      "label": "Direct MP4 URL",
      "info": "Secondary fallback. Paste a direct .mp4 link."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Fallback / Poster Image",
      "info": "Shown while the video loads, or as a static hero if no video is provided. Use a high-res image (min 2000px wide)."
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "title1",
      "label": "Heading (Line 1)",
      "default": "Discover the Art of"
    },
    {
      "type": "text",
      "id": "title2",
      "label": "Heading (Line 2 - Italic Accent)",
      "default": "True Relaxation"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Experience the life-changing impact of Scandinavian wellness technology, engineered to elevate your daily routine."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button Text",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button Text",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Bar Item",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Wellness Feature"
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "SVG Icon Code",
          "info": "Paste raw SVG code here. Leave blank to use a default checkmark.",
          "default": "<svg fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z\"/></svg>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Section",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "title": "Nordic's Leading Brand"
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Advanced AI Technology"
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "Healthcare Recommended"
          }
        },
        {
          "type": "usp",
          "settings": {
            "title": "White-Glove Delivery"
          }
        }
      ]
    }
  ]
}
{% endschema %}
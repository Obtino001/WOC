{%- comment -%} Determine grid column class dynamically based on schema settings {%- endcomment -%}
{%- assign col_class = 'md:grid-cols-2' -%}
{%- case section.settings.columns_desktop -%}
  {%- when 1 -%}{%- assign col_class = 'md:grid-cols-1' -%}
  {%- when 2 -%}{%- assign col_class = 'md:grid-cols-2' -%}
  {%- when 3 -%}{%- assign col_class = 'md:grid-cols-3' -%}
  {%- when 4 -%}{%- assign col_class = 'md:grid-cols-4' -%}
{%- endcase -%}

{%- assign container_class = 'page-width' -%}
{%- if section.settings.page_width == 'full' -%}
  {%- assign container_class = 'w-full px-4 md:px-8 lg:px-12 max-w-none' -%}
{%- endif -%}

<section class="py-20 lg:py-28 bg-background relative overflow-hidden">
  <div class="{{ container_class }}">
    <div class="text-center mb-16">
      <div class="luxury-line mx-auto mb-8" style="opacity: 1; transform: none;"></div>
      
      {% if section.settings.subtitle != blank %}
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4" style="opacity: 1; transform: none;">
          {{ section.settings.subtitle }}
        </p>
      {% endif %}

      {% if section.settings.partner_logo %}
        <div class="flex justify-center mb-4" style="opacity: 1; transform: none;">
          <img src="{{ section.settings.partner_logo | img_url: 'master' }}" alt="{{ section.settings.partner_logo.alt | default: 'Partner Logo' }}" class="h-20 lg:h-28 w-auto">
        </div>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="font-body text-sm text-muted-foreground mt-4 max-w-2xl mx-auto" style="opacity: 1; transform: none;">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>

    <div class="grid {{ col_class }} gap-8">
      {% for product in section.settings.product_list limit: section.settings.products_to_show %}
        <div class="group relative bg-card border border-border rounded-xl overflow-hidden hover:border-gold/30 transition-all duration-500 hover:shadow-gold flex flex-col" style="opacity: 1; transform: none;">
          
          <div class="absolute top-4 left-4 z-10 flex items-center gap-1.5 bg-charcoal/90 text-white px-3 py-1.5 rounded-sm shadow-lg backdrop-blur-sm">
            <span class="font-body text-[9px] font-bold uppercase tracking-widest">{{ product.vendor | default: "Body Friend" }}</span>
          </div>
          
          {% comment %} Tag placeholder (Requires metafields for dynamic usage, kept static for layout preservation) {% endcomment %}
          <span class="absolute top-4 right-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">
            Flagship
          </span>

          <a class="block" href="{{ product.url }}">
            <div class="aspect-[4/3] bg-white overflow-hidden relative">
              <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" class="w-full h-full object-contain p-8 transition-transform duration-700 group-hover:scale-105">
            </div>
          </a>

          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center gap-1 mb-3">
              <!-- 5 Stars SVG -->
              {% for i in (1..5) %}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              {% endfor %}
              <span class="font-body text-[10px] text-muted-foreground ml-1">4.7 (142)</span>
            </div>

            <a href="{{ product.url }}">
              <h3 class="font-display text-2xl font-bold text-foreground mb-1 hover:text-gold transition-colors">{{ product.title }}</h3>
            </a>
            
            <p class="font-body text-sm text-muted-foreground mb-4 leading-relaxed">
              {{ product.description | strip_html | truncate: 100 }}
            </p>
               {% if product.metafields.custom.product_tags != blank %}
                 <span class="absolute top-4 left-4 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ product.metafields.custom.product_tags }}</span>
              {% elsif product.tags contains 'New' %}
                 <span class="absolute top-4 left-4 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ section.settings.badge_new_text | default: 'New' }}</span>
              {% elsif product.tags contains 'Award' %}
                 <span class="absolute top-4 left-4 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ section.settings.badge_award_text | default: 'Award-Winning' }}</span>
              {% elsif product.tags contains 'Flagship' %}
                 <span class="absolute top-4 left-4 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ section.settings.badge_flagship_text | default: 'Flagship' }}</span>
              {% elsif product.tags contains 'Top Seller' %}
                 <span class="absolute top-4 left-4 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ section.settings.badge_topseller_text | default: 'Top Seller' }}</span>
              {% endif %}
            <div class="mt-auto pt-4 border-t border-border/50">
              <p class="font-display text-2xl font-bold text-foreground mb-3">{{ product.price | money }}</p>
              
              <div class="flex gap-2">
                <a class="inline-flex items-center justify-center whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase h-9 px-3 flex-1 gap-1.5 text-xs" href="{{ product.url }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-3.5 h-3.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg> See more
                </a>
                <a class="inline-flex items-center justify-center whitespace-nowrap font-medium ring-offset-background transition-all duration-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 border bg-background h-9 px-3 gap-1.5 text-xs border-gold/30 text-gold hover:bg-gold/10 hover:text-gold" href="/pages/showrooms">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar w-3.5 h-3.5"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg> Try it
                </a>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Luxury Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {
          "value": "full",
          "label": "Full Width"
        },
        {
          "value": "standard",
          "label": "Standard Width"
        }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Header Configuration"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Official Distributor"
    },
    {
      "type": "image_picker",
      "id": "partner_logo",
      "label": "Partner Logo Image"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We are proudly the official distributor of Body Friend, the world's leading manufacturer of ultra-premium massage chairs."
    },
    {
      "type": "header",
      "content": "Product Grid Configuration"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "info": "Select the products you want to display in this grid."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Number of columns on desktop"
    }
  ],
  "presets": [
    {
      "name": "Featured Product Grid",
      "category": "Products"
    }
  ]
}
{% endschema %}
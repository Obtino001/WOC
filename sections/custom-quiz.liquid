{% schema %}
{
  "name": "6-Step Quiz",
  "settings": [
    {
      "type": "header",
      "content": "Final Form Settings"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Get Your Recommendation"
    },
    {
      "type": "textarea",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Enter your details and we will send your personal match."
    },
    {
      "type": "text",
      "id": "form_button_text",
      "label": "Button Text",
      "default": "GET MY RECOMMENDATION"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question Step",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Step Label (e.g., Question 1 of 6)",
          "default": "Question x of 6"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "What is your primary goal?"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Choose what is most important to you"
        },
        {
          "type": "text",
          "id": "option_1",
          "label": "Option 1"
        },
        {
          "type": "text",
          "id": "option_2",
          "label": "Option 2"
        },
        {
          "type": "text",
          "id": "option_3",
          "label": "Option 3"
        },
        {
          "type": "text",
          "id": "option_4",
          "label": "Option 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "6-Step Quiz",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "step_label": "Question 1 of 6",
            "heading": "What is your primary goal?",
            "subheading": "Choose what is most important to you",
            "option_1": "Stress Reduction",
            "option_2": "Back Pain Relief",
            "option_3": "Recovery & Performance",
            "option_4": "General Wellbeing"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 2 of 6",
            "heading": "Where do you experience the most discomfort?",
            "subheading": "Select the area that bothers you most",
            "option_1": "Lower Back",
            "option_2": "Neck & Shoulders",
            "option_3": "Legs & Feet",
            "option_4": "Full Body Fatigue"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 3 of 6",
            "heading": "How tall are you?",
            "subheading": "This helps us find the right chair size",
            "option_1": "Under 5'5\"",
            "option_2": "5'5\" - 5'10\"",
            "option_3": "5'11\" - 6'2\"",
            "option_4": "Over 6'2\""
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 4 of 6",
            "heading": "How much time do you spend sitting daily?",
            "subheading": "Estimate your average sitting hours",
            "option_1": "Less than 2 hours",
            "option_2": "2 - 4 hours",
            "option_3": "4 - 6 hours",
            "option_4": "6+ hours"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 5 of 6",
            "heading": "What is your preferred massage intensity?",
            "subheading": "Choose your comfort level",
            "option_1": "Gentle & Relaxing",
            "option_2": "Medium Pressure",
            "option_3": "Deep Tissue / Intense",
            "option_4": "Variable Intensity"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 6 of 6",
            "heading": "Would you like to visit a showroom?",
            "subheading": "Experience it before you decide",
            "option_1": "Yes, definitely",
            "option_2": "Maybe later",
            "option_3": "No, I will decide online",
            "option_4": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}

<main class="pt-20 min-h-screen flex items-center justify-center" id="quiz-container-{{ section.id }}">
  <div class="container mx-auto px-4 py-12 max-w-2xl">
    
    {% form 'contact', id: 'custom-quiz-form' %}
      
      <!-- Hidden Inputs to Store Answers -->
      <div id="hidden-quiz-answers">
        {% for block in section.blocks %}
          <input type="hidden" name="contact[{{ block.settings.heading | escape }}]" id="answer-{{ forloop.index }}" value="">
        {% endfor %}
      </div>

      <!-- Progress Header -->
      <div class="mb-12">
        <div class="flex justify-between items-center mb-3">
          <span id="quiz-step-text" class="font-body text-xs text-muted-foreground uppercase tracking-wider">
            <!-- Populated via JS -->
          </span>
          <span id="quiz-progress-text" class="font-body text-xs text-gold font-semibold">
            <!-- Populated via JS -->
          </span>
        </div>
        <div class="h-1 bg-muted rounded-full overflow-hidden">
          <div id="quiz-progress-bar" class="h-full bg-gold rounded-full transition-all duration-300" style="width: 0%;"></div>
        </div>
      </div>

      <!-- The 6 Question Steps -->
      {% for block in section.blocks %}
        <div class="quiz-step hidden" data-step="{{ forloop.index }}" data-label="{{ block.settings.step_label }}" {{ block.shopify_attributes }}>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
            {{ block.settings.heading }}
          </h2>
          <p class="font-body text-muted-foreground mb-10">
            {{ block.settings.subheading }}
          </p>

          <div class="space-y-3">
            {% if block.settings.option_1 != blank %}
              <button type="button" class="quiz-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step="{{ forloop.index }}" data-val="{{ block.settings.option_1 | escape }}">
                {{ block.settings.option_1 }}
              </button>
            {% endif %}
            {% if block.settings.option_2 != blank %}
              <button type="button" class="quiz-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step="{{ forloop.index }}" data-val="{{ block.settings.option_2 | escape }}">
                {{ block.settings.option_2 }}
              </button>
            {% endif %}
            {% if block.settings.option_3 != blank %}
              <button type="button" class="quiz-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step="{{ forloop.index }}" data-val="{{ block.settings.option_3 | escape }}">
                {{ block.settings.option_3 }}
              </button>
            {% endif %}
            {% if block.settings.option_4 != blank %}
              <button type="button" class="quiz-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step="{{ forloop.index }}" data-val="{{ block.settings.option_4 | escape }}">
                {{ block.settings.option_4 }}
              </button>
            {% endif %}
          </div>

          {% if forloop.index > 1 %}
            <button type="button" class="btn-back mt-8 text-sm text-muted-foreground hover:text-foreground transition-colors flex items-center">
              &larr; Previous question
            </button>
          {% endif %}
        </div>
      {% endfor %}

      <!-- Step 7: Final Lead Capture Form -->
      {% assign final_step = section.blocks.size | plus: 1 %}
      <div class="quiz-step hidden" data-step="{{ final_step }}" data-label="ALMOST DONE">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
          {{ section.settings.form_heading }}
        </h2>
        <p class="font-body text-muted-foreground mb-10">
          {{ section.settings.form_subheading }}
        </p>

        <div class="space-y-4">
          <input type="text" name="contact[name]" placeholder="Full Name" required class="w-full px-6 py-4 bg-transparent border-2 border-border rounded-lg text-foreground placeholder-muted-foreground focus:outline-none focus:border-gold transition-colors font-body">
          
          <input type="email" name="contact[email]" placeholder="Email Address" required class="w-full px-6 py-4 bg-transparent border-2 border-border rounded-lg text-foreground placeholder-muted-foreground focus:outline-none focus:border-gold transition-colors font-body">
          
          <input type="tel" name="contact[phone]" placeholder="Phone (Optional)" class="w-full px-6 py-4 bg-transparent border-2 border-border rounded-lg text-foreground placeholder-muted-foreground focus:outline-none focus:border-gold transition-colors font-body">
          
          <button type="submit" class="w-full mt-4 bg-gold hover:bg-gold/90 text-background font-bold py-4 px-6 rounded-lg transition-colors font-body tracking-wider uppercase">
            {{ section.settings.form_button_text }}
          </button>
        </div>

        <button type="button" class="btn-back mt-8 text-sm text-muted-foreground hover:text-foreground transition-colors flex items-center">
          &larr; Back to questions
        </button>
      </div>

      <!-- Success Message -->
      {% if form.posted_successfully? %}
        <div class="absolute inset-0 bg-background flex flex-col items-center justify-center z-50 text-center px-4">
          <h2 class="font-display text-4xl font-bold text-foreground mb-4">Thank You!</h2>
          <p class="font-body text-muted-foreground">Your details have been received.</p>
        </div>
      {% endif %}

    {% endform %}
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const totalQuestions = {{ section.blocks.size }};
    const totalSteps = totalQuestions + 1; // Includes the final form
    let currentStep = 1;

    const steps = document.querySelectorAll('.quiz-step');
    const stepText = document.getElementById('quiz-step-text');
    const progressText = document.getElementById('quiz-progress-text');
    const progressBar = document.getElementById('quiz-progress-bar');

    function renderStep() {
      // Hide all steps completely
      steps.forEach(step => {
        step.classList.add('hidden');
        step.style.opacity = '0';
      });

      // Show the active step
      const activeStep = document.querySelector(`.quiz-step[data-step="${currentStep}"]`);
      if (activeStep) {
        activeStep.classList.remove('hidden');
        // Simple fade effect
        setTimeout(() => {
          activeStep.style.opacity = '1';
          activeStep.style.transition = 'opacity 0.3s ease';
        }, 10);

        // Update progress UI
        const label = activeStep.getAttribute('data-label');
        stepText.textContent = label;

        let percentage = Math.round((currentStep / totalSteps) * 100);
        if (currentStep === totalSteps) percentage = 100;

        progressText.textContent = `${percentage}%`;
        progressBar.style.width = `${percentage}%`;
      }
    }

    // Handle selecting an option
    document.querySelectorAll('.quiz-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const stepNum = this.getAttribute('data-step');
        const val = this.getAttribute('data-val');

        // Populate hidden input for Shopify Form
        document.getElementById(`answer-${stepNum}`).value = val;

        // Visual selection styling
        const siblings = this.parentElement.querySelectorAll('.quiz-btn');
        siblings.forEach(sibling => {
          sibling.classList.remove('border-gold', 'bg-gold/10');
          sibling.classList.add('border-border');
        });
        
        this.classList.remove('border-border');
        this.classList.add('border-gold', 'bg-gold/10');

        // Automatically move to next step after 300ms
        setTimeout(() => {
          if (currentStep < totalSteps) {
            currentStep++;
            renderStep();
          }
        }, 300);
      });
    });

    // Handle 'Previous' or 'Back' buttons
    document.querySelectorAll('.btn-back').forEach(btn => {
      btn.addEventListener('click', () => {
        if (currentStep > 1) {
          currentStep--;
          renderStep();
        }
      });
    });

    // Initialize the first step on load
    renderStep();
  });
</script>
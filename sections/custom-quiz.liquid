{% schema %}
{
  "name": "Multi-Step Quiz",
  "settings": [
    {
      "type": "header",
      "content": "Final Form Settings"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Get Your Recommendation"
    },
    {
      "type": "textarea",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Enter your details and we will send your personal match."
    },
    {
      "type": "text",
      "id": "form_button_text",
      "label": "Button Text",
      "default": "GET MY RECOMMENDATION"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question Step",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Step Label (e.g., Question 1 of 6)",
          "default": "Question x of 6"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "What is your primary goal?"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Choose what is most important to you"
        },
        {
          "type": "text",
          "id": "option_1",
          "label": "Option 1"
        },
        {
          "type": "text",
          "id": "option_2",
          "label": "Option 2"
        },
        {
          "type": "text",
          "id": "option_3",
          "label": "Option 3"
        },
        {
          "type": "text",
          "id": "option_4",
          "label": "Option 4"
        },
        {
          "type": "text",
          "id": "option_5",
          "label": "Option 5"
        },
        {
          "type": "text",
          "id": "option_6",
          "label": "Option 6"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "6-Step Quiz",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "step_label": "Question 1 of 6",
            "heading": "What is your primary goal?",
            "subheading": "Choose what is most important to you",
            "option_1": "Stress Reduction",
            "option_2": "Back Pain Relief",
            "option_3": "Recovery & Performance",
            "option_4": "General Wellbeing"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 2 of 6",
            "heading": "Where do you experience the most discomfort?",
            "subheading": "Select the area that bothers you most",
            "option_1": "Lower Back",
            "option_2": "Neck & Shoulders",
            "option_3": "Legs & Feet",
            "option_4": "Full Body Fatigue"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 3 of 6",
            "heading": "How tall are you?",
            "subheading": "This helps us find the right chair size",
            "option_1": "Under 5'5\"",
            "option_2": "5'5\" - 5'10\"",
            "option_3": "5'11\" - 6'2\"",
            "option_4": "Over 6'2\""
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 4 of 6",
            "heading": "How much time do you spend sitting daily?",
            "subheading": "Estimate your average sitting hours",
            "option_1": "Less than 2 hours",
            "option_2": "2 - 4 hours",
            "option_3": "4 - 6 hours",
            "option_4": "6+ hours"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 5 of 6",
            "heading": "What is your preferred massage intensity?",
            "subheading": "Choose your comfort level",
            "option_1": "Gentle & Relaxing",
            "option_2": "Medium Pressure",
            "option_3": "Deep Tissue / Intense",
            "option_4": "Variable Intensity"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 6 of 6",
            "heading": "Would you like to visit a showroom?",
            "subheading": "Experience your chair before you decide",
            "option_1": "Yes, definitely",
            "option_2": "Maybe later",
            "option_3": "No, I will decide online",
            "option_4": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}

<main class="pt-20 min-h-screen flex items-center justify-center">
  <div class="container mx-auto px-4 py-12 max-w-2xl">
    
    {% form 'contact', id: 'quiz-form' %}
      
      <!-- Hidden inputs to store quiz answers -->
      <div id="quiz-hidden-inputs">
        {% for block in section.blocks %}
          <input type="hidden" name="contact[{{ block.settings.heading | escape }}]" id="hidden-answer-{{ forloop.index }}" value="">
        {% endfor %}
      </div>

      <!-- Progress Bar (Kept exactly as your original code) -->
      <div class="mb-12">
        <div class="flex justify-between items-center mb-3">
          <span id="progress-label" class="font-body text-xs text-muted-foreground uppercase tracking-wider">
            <!-- Updated by JS -->
          </span>
          <span id="progress-percentage" class="font-body text-xs text-gold font-semibold">
            <!-- Updated by JS -->
          </span>
        </div>
        <div class="h-1 bg-muted rounded-full overflow-hidden">
          <div id="progress-bar-fill" class="h-full bg-gold rounded-full transition-all duration-500" style="width: 0%;"></div>
        </div>
      </div>

      <!-- Quiz Questions Blocks -->
      {% for block in section.blocks %}
        <div class="quiz-step hidden opacity-0 transition-opacity duration-300" data-step="{{ forloop.index }}" data-label="{{ block.settings.step_label }}" {{ block.shopify_attributes }}>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
            {{ block.settings.heading }}
          </h2>
          <p class="font-body text-muted-foreground mb-10">
            {{ block.settings.subheading }}
          </p>

          <div class="space-y-3">
            {% if block.settings.option_1 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_1 | escape }}">
                {{ block.settings.option_1 }}
              </button>
            {% endif %}
            {% if block.settings.option_2 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_2 | escape }}">
                {{ block.settings.option_2 }}
              </button>
            {% endif %}
            {% if block.settings.option_3 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_3 | escape }}">
                {{ block.settings.option_3 }}
              </button>
            {% endif %}
            {% if block.settings.option_4 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_4 | escape }}">
                {{ block.settings.option_4 }}
              </button>
            {% endif %}
            {% if block.settings.option_5 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_5 | escape }}">
                {{ block.settings.option_5 }}
              </button>
            {% endif %}
            {% if block.settings.option_6 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border-2 font-body text-base font-medium transition-all duration-200 border-border hover:border-gold/50 text-foreground" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_6 | escape }}">
                {{ block.settings.option_6 }}
              </button>
            {% endif %}
          </div>

          {% if forloop.index > 1 %}
            <button type="button" class="mt-8 font-body text-sm text-muted-foreground hover:text-foreground flex items-center transition-colors btn-prev">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
              Previous question
            </button>
          {% endif %}
        </div>
      {% endfor %}

      <!-- Final Form Step (Using exact classes from your screenshot) -->
      {% assign total_questions = section.blocks.size %}
      {% assign final_step = total_questions | plus: 1 %}
      
      <div class="quiz-step hidden opacity-0 transition-opacity duration-300" data-step="{{ final_step }}" data-label="{{ section.settings.form_step_label | escape | default: 'ALMOST DONE' }}">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
          {{ section.settings.form_heading }}
        </h2>
        <p class="font-body text-muted-foreground mb-10">
          {{ section.settings.form_subheading }}
        </p>

        <div class="space-y-4">
          <div>
            <input type="text" name="contact[name]" placeholder="Full Name" required class="w-full px-4 py-4 bg-transparent border border-border rounded text-foreground placeholder-muted-foreground focus:outline-none focus:border-gold/50 transition-colors font-body text-sm">
          </div>
          <div>
            <input type="email" name="contact[email]" placeholder="Email Address" required class="w-full px-4 py-4 bg-transparent border border-border rounded text-foreground placeholder-muted-foreground focus:outline-none focus:border-gold/50 transition-colors font-body text-sm">
          </div>
          <div>
            <input type="tel" name="contact[phone]" placeholder="Phone (Optional)" class="w-full px-4 py-4 bg-transparent border border-border rounded text-foreground placeholder-muted-foreground focus:outline-none focus:border-gold/50 transition-colors font-body text-sm">
          </div>
          
          <button type="submit" class="w-full mt-2 bg-gold hover:opacity-90 text-background font-body text-sm font-semibold py-4 px-6 rounded transition-all tracking-wider uppercase">
            {{ section.settings.form_button_text }}
          </button>
        </div>

        <button type="button" class="mt-8 font-body text-sm text-muted-foreground hover:text-foreground flex items-center transition-colors btn-prev">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to questions
        </button>
      </div>

      {% if form.posted_successfully? %}
        <div class="absolute inset-0 bg-background flex flex-col items-center justify-center z-50 text-center px-4">
          <h2 class="font-display text-4xl font-bold text-foreground mb-4">Thank You!</h2>
          <p class="font-body text-muted-foreground">Your recommendation request has been sent successfully.</p>
        </div>
      {% endif %}

    {% endform %}
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const totalSteps = {{ section.blocks.size | plus: 1 }};
    let currentStep = 1;

    const steps = document.querySelectorAll('.quiz-step');
    const progressLabel = document.getElementById('progress-label');
    const progressPercentage = document.getElementById('progress-percentage');
    const progressBarFill = document.getElementById('progress-bar-fill');
    
    function updateUI() {
      steps.forEach(step => {
        step.classList.add('hidden');
        step.classList.remove('opacity-100');
        step.classList.add('opacity-0');
      });

      const activeStep = document.querySelector(`.quiz-step[data-step="${currentStep}"]`);
      if(activeStep) {
        activeStep.classList.remove('hidden');
        setTimeout(() => {
          activeStep.classList.remove('opacity-0');
          activeStep.classList.add('opacity-100');
        }, 50);
        
        const stepLabel = activeStep.getAttribute('data-label');
        progressLabel.textContent = stepLabel;
        
        let percentage = Math.round((currentStep / totalSteps) * 100);
        if (currentStep === totalSteps) percentage = 100;
        
        progressPercentage.textContent = `${percentage}%`;
        progressBarFill.style.width = `${percentage}%`;
      }
    }

    const optionButtons = document.querySelectorAll('.quiz-option-btn');
    optionButtons.forEach(button => {
      button.addEventListener('click', function() {
        const stepIndex = this.getAttribute('data-step-index');
        const value = this.getAttribute('data-value');
        
        const hiddenInput = document.getElementById(`hidden-answer-${stepIndex}`);
        if(hiddenInput) hiddenInput.value = value;

        const siblings = this.closest('.space-y-3').querySelectorAll('.quiz-option-btn');
        siblings.forEach(btn => {
          btn.classList.remove('border-gold', 'bg-gold/5');
          btn.classList.add('border-border');
        });
        this.classList.remove('border-border');
        this.classList.add('border-gold', 'bg-gold/5');

        setTimeout(() => {
          if (currentStep < totalSteps) {
            currentStep++;
            updateUI();
          }
        }, 250);
      });
    });

    const prevButtons = document.querySelectorAll('.btn-prev');
    prevButtons.forEach(button => {
      button.addEventListener('click', function() {
        if (currentStep > 1) {
          currentStep--;
          updateUI();
        }
      });
    });

    updateUI();
  });
</script>
{% schema %}
{
  "name": "Multi-Step Quiz",
  "settings": [
    {
      "type": "header",
      "content": "Final Form Step Settings"
    },
    {
      "type": "text",
      "id": "form_step_label",
      "label": "Form Step Label",
      "default": "ALMOST DONE"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Get Your Recommendation"
    },
    {
      "type": "textarea",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Enter your details and we will send your personal match."
    },
    {
      "type": "text",
      "id": "form_button_text",
      "label": "Form Button Text",
      "default": "GET MY RECOMMENDATION"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Quiz Question",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Step Label",
          "default": "Question 1 of 6"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "What is your primary goal?"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Choose what is most important to you"
        },
        {
          "type": "text",
          "id": "option_1",
          "label": "Option 1"
        },
        {
          "type": "text",
          "id": "option_2",
          "label": "Option 2"
        },
        {
          "type": "text",
          "id": "option_3",
          "label": "Option 3"
        },
        {
          "type": "text",
          "id": "option_4",
          "label": "Option 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi-Step Quiz",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "step_label": "Question 1 of 6",
            "heading": "What is your primary goal?",
            "subheading": "Choose what is most important to you",
            "option_1": "Stress Reduction",
            "option_2": "Back Pain Relief",
            "option_3": "Recovery & Performance",
            "option_4": "General Wellbeing"
          }
        },
        {
          "type": "question",
          "settings": {
            "step_label": "Question 6 of 6",
            "heading": "Would you like to visit a showroom?",
            "subheading": "Experience your chair before you decide",
            "option_1": "Yes, definitely",
            "option_2": "Maybe later",
            "option_3": "No, I will decide online",
            "option_4": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}

<main class="pt-20 min-h-screen flex items-center justify-center bg-[#0a0a0a] text-white" id="quiz-section-{{ section.id }}">
  <div class="container mx-auto px-4 py-12 max-w-2xl">
    
    {% form 'contact', id: 'quiz-form' %}
      
      <div id="quiz-hidden-inputs">
        {% for block in section.blocks %}
          <input type="hidden" name="contact[{{ block.settings.heading | escape }}]" id="hidden-answer-{{ forloop.index }}" value="">
        {% endfor %}
      </div>

      <div class="mb-12">
        <div class="flex justify-between items-center mb-3">
          <span id="progress-label" class="font-body text-xs text-gray-400 uppercase tracking-wider">
            </span>
          <span id="progress-percentage" class="font-body text-xs text-[#d4af37] font-semibold">
            </span>
        </div>
        <div class="h-1 bg-gray-800 rounded-full overflow-hidden">
          <div id="progress-bar-fill" class="h-full bg-[#d4af37] rounded-full transition-all duration-500" style="width: 0%;"></div>
        </div>
      </div>

      {% for block in section.blocks %}
        <div class="quiz-step hidden opacity-0 transition-opacity duration-300" data-step="{{ forloop.index }}" data-label="{{ block.settings.step_label }}" {{ block.shopify_attributes }}>
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-2 font-serif">
            {{ block.settings.heading }}
          </h2>
          <p class="font-body text-gray-400 mb-10">
            {{ block.settings.subheading }}
          </p>

          <div class="space-y-3">
            {% if block.settings.option_1 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border border-gray-800 font-body text-base font-medium transition-all duration-200 hover:border-[#d4af37] focus:border-[#d4af37] text-white bg-transparent" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_1 | escape }}">
                {{ block.settings.option_1 }}
              </button>
            {% endif %}
            {% if block.settings.option_2 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border border-gray-800 font-body text-base font-medium transition-all duration-200 hover:border-[#d4af37] focus:border-[#d4af37] text-white bg-transparent" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_2 | escape }}">
                {{ block.settings.option_2 }}
              </button>
            {% endif %}
            {% if block.settings.option_3 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border border-gray-800 font-body text-base font-medium transition-all duration-200 hover:border-[#d4af37] focus:border-[#d4af37] text-white bg-transparent" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_3 | escape }}">
                {{ block.settings.option_3 }}
              </button>
            {% endif %}
            {% if block.settings.option_4 != blank %}
              <button type="button" class="quiz-option-btn w-full text-left px-6 py-5 rounded-lg border border-gray-800 font-body text-base font-medium transition-all duration-200 hover:border-[#d4af37] focus:border-[#d4af37] text-white bg-transparent" data-step-index="{{ forloop.index }}" data-value="{{ block.settings.option_4 | escape }}">
                {{ block.settings.option_4 }}
              </button>
            {% endif %}
          </div>

          {% if forloop.index > 1 %}
            <button type="button" class="mt-8 text-sm text-gray-400 hover:text-white flex items-center transition-colors btn-prev">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
              Previous question
            </button>
          {% endif %}
        </div>
      {% endfor %}

      {% assign total_questions = section.blocks.size %}
      {% assign final_step = total_questions | plus: 1 %}
      
      <div class="quiz-step hidden opacity-0 transition-opacity duration-300" data-step="{{ final_step }}" data-label="{{ section.settings.form_step_label }}">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-2 font-serif">
          {{ section.settings.form_heading }}
        </h2>
        <p class="font-body text-gray-400 mb-10">
          {{ section.settings.form_subheading }}
        </p>

        <div class="space-y-4">
          <div>
            <input type="text" name="contact[name]" placeholder="Full Name" required class="w-full px-6 py-4 bg-transparent border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-[#d4af37] transition-colors">
          </div>
          <div>
            <input type="email" name="contact[email]" placeholder="Email Address" required class="w-full px-6 py-4 bg-transparent border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-[#d4af37] transition-colors">
          </div>
          <div>
            <input type="tel" name="contact[phone]" placeholder="Phone (Optional)" class="w-full px-6 py-4 bg-transparent border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-[#d4af37] transition-colors">
          </div>
          
          <button type="submit" class="w-full mt-4 bg-[#c89b3c] hover:bg-[#b88c36] text-black font-semibold py-4 px-6 rounded-lg transition-colors tracking-wide">
            {{ section.settings.form_button_text }}
          </button>
        </div>

        <button type="button" class="mt-8 text-sm text-gray-400 hover:text-white flex items-center transition-colors btn-prev">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to questions
        </button>
      </div>

      {% if form.posted_successfully? %}
        <div class="absolute inset-0 bg-[#0a0a0a] flex flex-col items-center justify-center z-50 text-center px-4">
          <h2 class="text-4xl font-serif font-bold text-white mb-4">Thank You!</h2>
          <p class="text-gray-400">Your recommendation request has been sent successfully. We will be in touch shortly.</p>
        </div>
      {% endif %}

    {% endform %}
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const totalSteps = {{ section.blocks.size | plus: 1 }};
    const totalQuestions = {{ section.blocks.size }};
    let currentStep = 1;

    const steps = document.querySelectorAll('.quiz-step');
    const progressLabel = document.getElementById('progress-label');
    const progressPercentage = document.getElementById('progress-percentage');
    const progressBarFill = document.getElementById('progress-bar-fill');
    
    function updateUI() {
      // Hide all steps
      steps.forEach(step => {
        step.classList.add('hidden');
        step.classList.remove('opacity-100');
        step.classList.add('opacity-0');
      });

      // Show current step
      const activeStep = document.querySelector(`.quiz-step[data-step="${currentStep}"]`);
      if(activeStep) {
        activeStep.classList.remove('hidden');
        // Slight delay for fade-in effect
        setTimeout(() => {
          activeStep.classList.remove('opacity-0');
          activeStep.classList.add('opacity-100');
        }, 50);
        
        // Update Progress Bar
        const stepLabel = activeStep.getAttribute('data-label');
        progressLabel.textContent = stepLabel;
        
        let percentage = Math.round((currentStep / totalSteps) * 100);
        if (currentStep === totalSteps) percentage = 100; // Force 100% on final form step
        
        progressPercentage.textContent = `${percentage}%`;
        progressBarFill.style.width = `${percentage}%`;
      }
    }

    // Handle Option Selection
    const optionButtons = document.querySelectorAll('.quiz-option-btn');
    optionButtons.forEach(button => {
      button.addEventListener('click', function() {
        const stepIndex = this.getAttribute('data-step-index');
        const value = this.getAttribute('data-value');
        
        // Save to hidden input
        const hiddenInput = document.getElementById(`hidden-answer-${stepIndex}`);
        if(hiddenInput) hiddenInput.value = value;

        // Visual feedback on the button before moving on
        const siblings = this.closest('.space-y-3').querySelectorAll('.quiz-option-btn');
        siblings.forEach(btn => {
          btn.classList.remove('border-[#d4af37]');
          btn.classList.add('border-gray-800');
        });
        this.classList.remove('border-gray-800');
        this.classList.add('border-[#d4af37]');

        // Proceed to next step automatically
        setTimeout(() => {
          if (currentStep < totalSteps) {
            currentStep++;
            updateUI();
          }
        }, 250); // Small delay to let user see their selection
      });
    });

    // Handle Previous Buttons
    const prevButtons = document.querySelectorAll('.btn-prev');
    prevButtons.forEach(button => {
      button.addEventListener('click', function() {
        if (currentStep > 1) {
          currentStep--;
          updateUI();
        }
      });
    });

    // Initialize first step
    updateUI();
  });
</script>
{%- liquid
  # Using CSS grid with auto-fit and minmax instead of Tailwind classes
-%}

<style>
  /* Light Theme Variables */
  .section-light {
    --background: 40 30% 97%;
    --foreground: 0 0% 12%;
    --card: 40 25% 95%;
    --card-foreground: 0 0% 12%;
    --muted: 40 15% 92%;
    --muted-foreground: 0 0% 40%;
    --border: 40 15% 88%;
    background-color: hsl(var(--background));
    color: hsl(var(--foreground));
  }

  /* Custom class to override the theme's hardcoded dark bg-card */
  .custom-light-card {
    background-color: hsl(var(--card)) !important;
    border-color: hsl(var(--border)) !important;
  }
</style>

{%- assign container_class = 'page-width' -%}
{%- if section.settings.page_width == 'full' -%}
  {%- assign container_class = 'w-full px-4 md:px-8 lg:px-12 max-w-none' -%}
{%- endif -%}

<section id="collection" class="section-light woc-section-py">
  <div class="{{ container_class }}">
    
    <div class="flex flex-col {% if section.settings.center_heading %}items-center text-center{% else %}md:flex-row md:items-end md:justify-between{% endif %} gap-6 mb-12">
      <div class="{% if section.settings.center_heading %}flex flex-col items-center{% endif %}">
        <div class="luxury-line mb-6"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-3">{{ section.settings.subtitle }}</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground leading-[1.05]">{{ section.settings.title }}</h2>
        <p class="font-body text-sm text-muted-foreground mt-3 max-w-lg">{{ section.settings.description }}</p>
      </div>
      
      {% if section.settings.show_filter %}
      <div class="flex flex-wrap items-center justify-center gap-2 collection-filters">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-filter w-4 h-4 text-muted-foreground"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
        <button class="filter-btn active font-body text-xs px-3 py-1.5 rounded-full border transition-all border-gold bg-gold/10 text-gold" data-filter="all">{{ section.settings.filter_all_label | default: 'Tümü' }}</button>
        <button class="filter-btn font-body text-xs px-3 py-1.5 rounded-full border transition-all border-border text-muted-foreground hover:border-gold/30" data-filter="high">{{ section.settings.filter_high_label | default: '90.000+' }}</button>
        <button class="filter-btn font-body text-xs px-3 py-1.5 rounded-full border transition-all border-border text-muted-foreground hover:border-gold/30" data-filter="mid">{{ section.settings.filter_mid_label | default: '60–90.000' }}</button>
        <button class="filter-btn font-body text-xs px-3 py-1.5 rounded-full border transition-all border-border text-muted-foreground hover:border-gold/30" data-filter="low">{{ section.settings.filter_low_label | default: "60.000'den az" }}</button>
      </div>
      {% endif %}
    </div>

    <div class="grid gap-6" style="grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr)); opacity: 1;">
      
      {%- assign collection = collections[section.settings.collection] -%}
      
      {% for product in collection.products limit: section.settings.products_to_show %}
        <div class="product-card-wrapper h-full" data-price="{{ product.price }}">
          {% render 'woc-product-card', product: product %}
        </div>
      {% else %}
        <p class="col-span-full text-center text-muted-foreground py-10">Lütfen ayarlardan bir koleksiyon seçin.</p>
      {% endfor %}
      
    </div>
  </div>
</section>

{% if section.settings.show_filter %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('collection');
    const buttons = section.querySelectorAll('.filter-btn');
    const cards = section.querySelectorAll('.product-card-wrapper');
    
    // We will dynamically calculate the price ranges based on the highest price in the collection.
    // This makes the filter perfectly compatible with ALL currencies!
    let maxPrice = 0;
    cards.forEach(card => {
      const price = parseInt(card.getAttribute('data-price') || '0', 10);
      if (price > maxPrice) maxPrice = price;
    });

    // Determine thresholds based on max price (e.g. 150,000 TRY)
    // High: > 60% of max price (approx 90,000)
    // Low: < 40% of max price (approx 60,000)
    const highThreshold = maxPrice * 0.6;
    const lowThreshold = maxPrice * 0.4;

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        // Update active states
        buttons.forEach(btn => {
          btn.classList.remove('border-gold', 'bg-gold/10', 'text-gold', 'active');
          btn.classList.add('border-border', 'text-muted-foreground');
        });
        button.classList.remove('border-border', 'text-muted-foreground');
        button.classList.add('border-gold', 'bg-gold/10', 'text-gold', 'active');

        const filterValue = button.getAttribute('data-filter');

        cards.forEach(card => {
          const price = parseInt(card.getAttribute('data-price') || '0', 10);
          let show = false;

          if (filterValue === 'all') {
            show = true;
          } else if (filterValue === 'high' && price >= highThreshold) {
            show = true;
          } else if (filterValue === 'mid' && price < highThreshold && price >= lowThreshold) {
            show = true;
          } else if (filterValue === 'low' && price < lowThreshold) {
            show = true;
          }

          if (show) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>
{% endif %}

{% schema %}
{
  "name": "Featured Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Koleksiyonumuz"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {
          "value": "full",
          "label": "Full Width"
        },
        {
          "value": "standard",
          "label": "Standard Width"
        }
      ],
      "default": "full"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Sandalyenizi Seçin"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "13 model mevcut · Hepsi ücretsiz teslimat ve 5 yıl garanti ile"
    },
    {
      "type": "checkbox",
      "id": "center_heading",
      "label": "Center align heading",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_filter",
      "label": "Show Price Filter",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_all_label",
      "label": "Filter 'All' Label",
      "default": "Tümü"
    },
    {
      "type": "text",
      "id": "filter_high_label",
      "label": "Filter 'High Price' Label",
      "default": "90.000+"
    },
    {
      "type": "text",
      "id": "filter_mid_label",
      "label": "Filter 'Mid Price' Label",
      "default": "60–90.000"
    },
    {
      "type": "text",
      "id": "filter_low_label",
      "label": "Filter 'Low Price' Label",
      "default": "60.000'den az"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Maximum products to show"
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row (Desktop)",
      "options": [
        {
          "value": "2",
          "label": "2 per row"
        },
        {
          "value": "3",
          "label": "3 per row"
        },
        {
          "value": "4",
          "label": "4 per row"
        }
      ],
      "default": "3"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid"
    }
  ]
}
{% endschema %}
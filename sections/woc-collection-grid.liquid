{%- liquid
  # Determine the Tailwind grid class based on schema setting
  assign grid_class = 'lg:grid-cols-3'
  case section.settings.products_per_row
    when 2
      assign grid_class = 'lg:grid-cols-2'
    when 3
      assign grid_class = 'lg:grid-cols-3'
    when 4
      assign grid_class = 'lg:grid-cols-4'
  endcase
-%}

<style>
  /* Dark Theme Variable Overrides */
  .section-dark {
    --background: 0 0% 8%; /* Very dark grey/black */
    --foreground: 0 0% 98%; /* White text */
    --card: 0 0% 12%; /* Slightly lighter dark for cards */
    --card-foreground: 0 0% 98%;
    --muted: 0 0% 18%;
    --muted-foreground: 0 0% 60%;
    --border: 0 0% 20%; /* Dark border */
    --linen: 0 0% 12%; /* Matching card bg or transparent */
    background-color: hsl(var(--background));
    color: hsl(var(--foreground));
  }
</style>

<section id="collection" class="section-dark py-20 lg:py-28">
  <div class="container mx-auto px-4 lg:px-8">
    
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <div class="luxury-line mb-6"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-3">{{ section.settings.subtitle }}</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground leading-[1.05]">{{ section.settings.title }}</h2>
        <p class="font-body text-sm text-muted-foreground mt-3 max-w-lg">{{ section.settings.description }}</p>
      </div>
      
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-filter w-4 h-4 text-muted-foreground"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
        <button class="font-body text-xs px-3 py-1.5 rounded-full border transition-all border-gold bg-gold/10 text-gold">Tümü</button>
        <button class="font-body text-xs px-3 py-1.5 rounded-full border transition-all border-border text-muted-foreground hover:border-gold/30">90.000+</button>
        <button class="font-body text-xs px-3 py-1.5 rounded-full border transition-all border-border text-muted-foreground hover:border-gold/30">60–90.000</button>
        <button class="font-body text-xs px-3 py-1.5 rounded-full border transition-all border-border text-muted-foreground hover:border-gold/30">60.000'den az</button>
      </div>
    </div>

    <div class="grid md:grid-cols-2 {{ grid_class }} gap-6" style="opacity: 1;">
      
      {%- assign collection = collections[section.settings.collection] -%}
      
      {% for product in collection.products limit: section.settings.products_to_show %}
        <div class="group relative bg-card border border-border overflow-hidden hover:border-gold/30 transition-all duration-500 hover:shadow-gold flex flex-col rounded-xl">
          
          <a class="block" href="{{ product.url }}">
            <div class="relative aspect-square bg-transparent overflow-hidden">
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="w-full h-full object-contain p-6 transition-transform duration-700 group-hover:scale-105" loading="lazy">
              {% if product.tags.size > 0 %}
                <span class="absolute top-4 left-4 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ product.tags.first }}</span>
              {% endif %}
            </div>
          </a>
          
          <div class="p-8 flex flex-col flex-1">
            <div class="flex items-center gap-1 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 fill-gold/50 text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              <span class="font-body text-[10px] text-muted-foreground ml-1">4.8 (100+)</span>
            </div>
            
            <a href="{{ product.url }}"><h3 class="font-display text-2xl font-bold text-foreground mb-1 hover:text-gold transition-colors">{{ product.title }}</h3></a>
            <p class="font-body text-sm text-muted-foreground mb-3 line-clamp-2 leading-relaxed">
              {% if product.description != blank %}
                {{ product.description | strip_html | truncatewords: 8 }}
              {% else %}
                Bang & Olufsen Sesi ile En Üst Düzey Amiral Gemisi
              {% endif %}
            </p>
            
            <div class="flex flex-wrap gap-1.5 mb-3">
              <div class="flex items-center gap-1.5 bg-muted/50 border border-border/50 rounded-md px-2 py-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ear w-3 h-3 text-gold flex-shrink-0"><path d="M6 8.5a6.5 6.5 0 1 1 13 0c0 6-6 6-6 10a3.5 3.5 0 1 1-7 0"></path><path d="M15 8.5a2.5 2.5 0 0 0-5 0v1a2 2 0 1 1 0 4"></path></svg>
                <span class="font-body text-[10px] text-foreground/70 whitespace-nowrap">Bang & Olufsen Surround Ses</span>
              </div>
              <div class="flex items-center gap-1.5 bg-muted/50 border border-border/50 rounded-md px-2 py-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-waves w-3 h-3 text-gold flex-shrink-0"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path></svg>
                <span class="font-body text-[10px] text-foreground/70 whitespace-nowrap">4D Silikon Masaj Silindirleri</span>
              </div>
              <div class="flex items-center gap-1.5 bg-muted/50 border border-border/50 rounded-md px-2 py-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-scan w-3 h-3 text-gold flex-shrink-0"><path d="M3 7V5a2 2 0 0 1 2-2h2"></path><path d="M17 3h2a2 2 0 0 1 2 2v2"></path><path d="M21 17v2a2 2 0 0 1-2 2h-2"></path><path d="M7 21H5a2 2 0 0 1-2-2v-2"></path></svg>
                <span class="font-body text-[10px] text-foreground/70 whitespace-nowrap">81 Hücreli Hava Kompresyonu</span>
              </div>
            </div>
            
            <div class="flex flex-wrap gap-1.5 mb-4">
              <div class="flex items-center gap-1.5 bg-forest/10 border border-forest/20 rounded-md px-2 py-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck w-3 h-3 text-forest flex-shrink-0"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg>
                <span class="font-body text-[10px] text-forest font-medium whitespace-nowrap">Ücretsiz kargo</span>
              </div>
              <div class="flex items-center gap-1.5 bg-gold/10 border border-gold/20 rounded-md px-2 py-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check w-3 h-3 text-gold flex-shrink-0"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
                <span class="font-body text-[10px] text-gold font-medium whitespace-nowrap">5 yıl garanti</span>
              </div>
            </div>
            
            <div class="mt-auto pt-3 border-t border-border/50">
              <div class="flex items-baseline gap-2 mb-1">
                <span class="font-display text-2xl font-bold text-foreground">{{ product.price | money }}</span>
              </div>
              <div class="flex items-center gap-1.5 mb-4">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-forest opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-forest"></span>
                </span>
                <span class="font-body text-[10px] text-forest font-medium">Stokta · 1-2 gün ücretsiz teslimat</span>
              </div>
              <div class="flex gap-2">
                <a class="inline-flex items-center justify-center whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:size-4 [&_svg]:shrink-0 bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase h-9 px-3 flex-1 gap-1.5 text-xs" href="{{ product.url }}">
                  Daha fazlasını gör 
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-3.5 h-3.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <p class="col-span-full text-center text-muted-foreground py-10">Lütfen ayarlardan bir koleksiyon seçin.</p>
      {% endfor %}
      
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Koleksiyonumuz"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Sandalyenizi Seçin"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "13 model mevcut · Hepsi ücretsiz teslimat ve 5 yıl garanti ile"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Maximum products to show"
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row (Desktop)",
      "options": [
        {
          "value": "2",
          "label": "2 per row"
        },
        {
          "value": "3",
          "label": "3 per row"
        },
        {
          "value": "4",
          "label": "4 per row"
        }
      ],
      "default": "3"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid"
    }
  ]
}
{% endschema %}
<product-info
  id="MainProduct-{{ section.id }}"
  class="mpm-section section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'section-main-product-message.css' | asset_url | stylesheet_tag }}
  {{ 'section-main-product-foot.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    #MainProduct-{{ section.id }} {
      --mpm-bg: {{ section.settings.background_color.red }} {{ section.settings.background_color.green }} {{ section.settings.background_color.blue }};
      --mpm-text: {{ section.settings.text_color.red }} {{ section.settings.text_color.green }} {{ section.settings.text_color.blue }};
      --mpm-gallery-bg: {{ section.settings.gallery_background.red }} {{ section.settings.gallery_background.green }} {{ section.settings.gallery_background.blue }};
      --mpm-sale-badge-bg: {{ section.settings.sale_badge_background.red }} {{ section.settings.sale_badge_background.green }} {{ section.settings.sale_badge_background.blue }};
      --mpm-sale-badge-text: {{ section.settings.sale_badge_text_color.red }} {{ section.settings.sale_badge_text_color.green }} {{ section.settings.sale_badge_text_color.blue }};
      --mpm-save-bg: {{ section.settings.save_badge_background.red }} {{ section.settings.save_badge_background.green }} {{ section.settings.save_badge_background.blue }};
      --mpm-save-text: {{ section.settings.save_badge_text_color.red }} {{ section.settings.save_badge_text_color.green }} {{ section.settings.save_badge_text_color.blue }};
      --mpm-atc-bg: {{ section.settings.atc_background.red }} {{ section.settings.atc_background.green }} {{ section.settings.atc_background.blue }};
      --mpm-atc-hover: {{ section.settings.atc_hover_background.red }} {{ section.settings.atc_hover_background.green }} {{ section.settings.atc_hover_background.blue }};
      --mpm-atc-text: {{ section.settings.atc_text_color.red }} {{ section.settings.atc_text_color.green }} {{ section.settings.atc_text_color.blue }};
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'main-product-foot.js' | asset_url }}" defer="defer"></script>
  <main-product-foot data-section-id="{{ section.id }}"></main-product-foot>

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
    <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- endif -%}

  {%- liquid
    assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
    assign selected_variant = product.selected_or_first_available_variant
    assign show_sale_badge = false
    assign sale_badge_pct = 0
    assign sale_badge_display = ''

    if section.settings.gallery_badge_text != blank
      assign show_sale_badge = true
      assign sale_badge_display = section.settings.gallery_badge_text
    elsif section.settings.show_sale_badge and selected_variant.compare_at_price > selected_variant.price
      assign show_sale_badge = true
      assign discount_amount = selected_variant.compare_at_price | minus: selected_variant.price
      assign sale_badge_pct = discount_amount | times: 100.0 | divided_by: selected_variant.compare_at_price | round
      if section.settings.sale_badge_prefix != blank
        assign sale_badge_display = section.settings.sale_badge_prefix | append: sale_badge_pct | append: '%'
      else
        assign sale_badge_display = '-' | append: sale_badge_pct | append: '%'
      endif
    endif
  -%}

  <div class="page-width">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="mpm-breadcrumbs" role="navigation" aria-label="{{ 'general.breadcrumbs' | t | default: 'Breadcrumbs' }}">
        <ol class="flex items-center gap-2 list-none p-0 m-0">
          <li><a href="{{ routes.root_url }}">{{ section.settings.breadcrumb_home_label }}</a></li>
          <li class="mpm-breadcrumbs__sep" aria-hidden="true">/</li>
          {%- if collection -%}
            <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>
            <li class="mpm-breadcrumbs__sep" aria-hidden="true">/</li>
          {%- elsif product.collections.size > 0 -%}
            <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
            <li class="mpm-breadcrumbs__sep" aria-hidden="true">/</li>
          {%- endif -%}
          <li><span aria-current="page">{{ product.title }}</span></li>
        </ol>
      </nav>
    {%- endif -%}

    <div class="mpm-grid product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }}{% if product.media.size == 0 %} product--no-media{% endif %}">
      <div class="mpm-media product__media-wrapper">
        {%- if section.settings.show_sale_badge or section.settings.gallery_badge_text != blank -%}
          <span id="SaleBadge-{{ section.id }}" class="mpm-sale-badge" data-sale-badge{% if section.settings.gallery_badge_text != blank %} data-static-badge="true"{% endif %}{% unless show_sale_badge %} style="display:none"{% endunless %}>
            {%- if show_sale_badge -%}
              {{ sale_badge_display }}
            {%- endif -%}
          </span>
        {%- endif -%}
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <div class="mpm-info product__info-wrapper{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}">
        <section id="ProductInfo-{{ section.id }}" class="product__info-container">
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}

              {%- when 'kicker' -%}
                {%- if block.settings.text != blank -%}
                  <p class="mpf-kicker" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
                {%- endif -%}

              {%- when 'subtitle' -%}
                {%- assign subtitle_text = block.settings.text -%}
                {%- if subtitle_text == blank -%}
                  {%- assign subtitle_text = product.metafields.descriptors.subtitle.value | default: product.metafields.custom.subtitle.value -%}
                {%- endif -%}
                {%- if subtitle_text != blank -%}
                  <p class="mpm-subtitle" {{ block.shopify_attributes }}>{{ subtitle_text }}</p>
                {%- endif -%}

              {%- when 'tagline' -%}
                {%- assign tagline_text = block.settings.text -%}
                {%- if tagline_text == blank -%}
                  {%- assign tagline_text = product.metafields.custom.short_description.value -%}
                {%- endif -%}
                {%- if tagline_text != blank -%}
                  <p class="mpm-tagline" {{ block.shopify_attributes }}>{{ tagline_text }}</p>
                {%- endif -%}

              {%- when 'title' -%}
                <div {{ block.shopify_attributes }}>
                  <h1 class="mpm-title">{{ product.title | escape }}</h1>
                </div>

              {%- when 'rating' -%}
                <div class="mpm-rating" {{ block.shopify_attributes }}>
                  {%- if product.metafields.reviews.rating.value != blank -%}
                    {% liquid
                      assign rating_decimal = 0
                      assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                      if decimal >= 0.3 and decimal <= 0.7
                        assign rating_decimal = 0.5
                      elsif decimal > 0.7
                        assign rating_decimal = 1
                      endif
                      assign rating_value = product.metafields.reviews.rating.value.rating
                      assign rating_count = product.metafields.reviews.rating_count
                    %}
                    <div class="rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: product.metafields.reviews.rating.value.scale_max }}">
                      <span aria-hidden="true" class="rating-star" style="--rating: {{ rating_value | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
                    </div>
                    <span class="mpm-rating__text">
                      {{ rating_value }} {{ block.settings.rating_connector }} {{ rating_count }} {{ block.settings.reviews_label }}
                    </span>
                  {%- else -%}
                    <div class="mpm-rating__stars" aria-hidden="true">
                      {%- for i in (1..5) -%}
                        <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.26l-4.94 2.45.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
                      {%- endfor -%}
                    </div>
                    <span class="mpm-rating__text">
                      {{ block.settings.fallback_rating }} {{ block.settings.rating_connector }} {{ block.settings.fallback_review_count }} {{ block.settings.reviews_label }}
                    </span>
                  {%- endif -%}
                </div>

              {%- when 'status_badges' -%}
                <div class="mpm-status-badges" {{ block.shopify_attributes }}>
                  {%- if block.settings.show_warranty_badge and block.settings.warranty_text != blank -%}
                    <span class="mpm-warranty-badge">
                      {%- if block.settings.warranty_icon != 'none' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- endif -%}
                      {{ block.settings.warranty_text }}
                    </span>
                  {%- endif -%}

                  {%- if block.settings.show_stock_badge -%}
                    {%- if product.selected_or_first_available_variant.available -%}
                      <span class="mpm-stock-badge mpm-stock-badge--in" id="Inventory-{{ section.id }}" role="status">
                        <span class="mpm-stock-badge__dot" aria-hidden="true"></span>
                        {{ block.settings.in_stock_text }}
                      </span>
                    {%- else -%}
                      <span class="mpm-stock-badge mpm-stock-badge--out" id="Inventory-{{ section.id }}" role="status">
                        <span class="mpm-stock-badge__dot" aria-hidden="true"></span>
                        {{ block.settings.out_of_stock_text }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- when 'description' -%}
                {%- assign description_html = block.settings.text -%}
                {%- if description_html == blank -%}
                  {%- assign description_html = product.description -%}
                {%- endif -%}
                {%- if description_html != blank -%}
                  <div class="mpm-description rte" {{ block.shopify_attributes }}>
                    {{ description_html }}
                  </div>
                {%- endif -%}

              {%- when 'feature_list' -%}
                {%- liquid
                  assign features_str = ''
                  if product.metafields.custom.products_usps != blank
                    assign features_str = product.metafields.custom.products_usps.value | join: ','
                  elsif block.settings.features != blank
                    assign features_str = block.settings.features
                  endif
                -%}
                {%- if features_str != blank -%}
                  {%- assign features = features_str | split: ',' -%}
                  <ul class="mpm-features" {{ block.shopify_attributes }}>
                    {%- for feature in features limit: block.settings.max_items -%}
                      <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                        <span>{{ feature | strip }}</span>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'variant_picker' -%}
                <div class="mpf-hidden-variant-picker" aria-hidden="true">
                  {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
                </div>

              {%- when 'bundle_selector' -%}
                {% render 'bundle-selector-foot', block: block, product: product, product_form_id: product_form_id, section_id: section.id %}

              {%- when 'back_in_stock' -%}
                {%- unless product.selected_or_first_available_variant.available -%}
                  <div class="mpf-bis" {{ block.shopify_attributes }}>
                    <div class="mpf-bis__header">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                      <p class="mpf-bis__title">{{ block.settings.heading }}</p>
                    </div>
                    {%- if block.settings.description != blank -%}
                      <p class="mpf-bis__desc">{{ block.settings.description }}</p>
                    {%- endif -%}
                    {%- form 'contact', id: 'BisForm-' | append: section.id, class: 'mpf-bis__form' -%}
                      <input type="hidden" name="contact[tags]" value="prospect, stock-notification">
                      <input type="hidden" name="contact[note]" value="Notify when {{ product.title }} is back in stock.">
                      {% render 'form-feedback', success_message: 'Teşekkürler! Ürün stoğa girdiğinde sizi bilgilendireceğiz.' %}
                      {% unless form.posted_successfully? %}
                      <input
                        type="email"
                        name="contact[email]"
                        class="mpf-bis__input"
                        placeholder="{{ block.settings.placeholder }}"
                        required
                        autocomplete="email"
                      >
                      <button type="submit" class="mpf-bis__button">{{ block.settings.button_label }}</button>
                      {% endunless %}
                    {%- endform -%}
                  </div>
                {%- endunless -%}

              {%- when 'free_gifts' -%}
                <div class="mpf-gifts" {{ block.shopify_attributes }}>
                  {%- if block.settings.heading != blank -%}
                    <h3 class="mpf-gifts__heading">{{ block.settings.heading }}</h3>
                  {%- endif -%}
                  <div class="mpf-gifts__grid">
                    {%- for i in (1..2) -%}
                      {%- liquid
                        case i
                          when 1
                            assign gift_name = block.settings.gift_1_name
                            assign gift_value = block.settings.gift_1_value
                            assign gift_icon = block.settings.gift_1_icon
                          when 2
                            assign gift_name = block.settings.gift_2_name
                            assign gift_value = block.settings.gift_2_value
                            assign gift_icon = block.settings.gift_2_icon
                        endcase
                      -%}
                      {%- if gift_name != blank -%}
                        <div class="mpf-gift">
                          <div class="mpf-gift__icon" aria-hidden="true">
                            {%- case gift_icon -%}
                              {%- when 'remote' -%}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2"/><path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/></svg>
                              {%- when 'book' -%}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                              {%- when 'gift' -%}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/></svg>
                            {%- endcase -%}
                          </div>
                          <div class="mpf-gift__body">
                            <p class="mpf-gift__name">{{ gift_name }}</p>
                            {%- if gift_value != blank -%}
                              <p class="mpf-gift__value">{{ gift_value }}</p>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>

              {%- when 'price' -%}
                {% render 'price-foot', product: product, block: block, section_id: section.id %}

              {%- when 'promotion_banner' -%}
                {%- if block.settings.text != blank -%}
                  <div
                    class="mpm-promo"
                    style="background-color: {{ block.settings.background_color }}; color: {{ block.settings.text_color }}; border: 1px solid {{ block.settings.border_color }};"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.show_icon -%}
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.9 5.8H4l4.9 3.6-1.9 5.8L12 14.6l4.9 3.6-1.9-5.8L20 8.8h-6.1L12 3z"/></svg>
                    {%- endif -%}
                    <span>{{ block.settings.text }}</span>
                  </div>
                {%- endif -%}

              {%- when 'purchase_row' -%}
                {%- if product.selected_or_first_available_variant.available -%}
                  {% render 'buy-buttons-message', block: block, product: product, product_form_id: product_form_id, section_id: section.id %}
                {%- endif -%}

              {%- when 'review_strip' -%}
                <div class="mpm-review-strip" {{ block.shopify_attributes }}>
                  <div class="mpm-review-strip__left">
                    {%- if block.settings.label != blank -%}
                      <span class="mpm-review-strip__label">{{ block.settings.label }}</span>
                    {%- endif -%}
                    <div class="mpm-review-strip__stars" aria-hidden="true">
                      {%- for i in (1..5) -%}
                        <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.26l-4.94 2.45.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
                      {%- endfor -%}
                    </div>
                  </div>
                  {%- if block.settings.payment_image != blank -%}
                    <div class="mpm-review-strip__payments">
                      {{ block.settings.payment_image | image_url: width: 280 | image_tag: class: 'mpm-review-strip__payment-img', alt: block.settings.payment_image_alt, loading: 'lazy' }}
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'trust_grid' -%}
                <ul class="mpm-trust-grid" aria-label="{{ block.settings.aria_label }}" {{ block.shopify_attributes }}>
                  {%- for i in (1..3) -%}
                    {%- liquid
                      case i
                        when 1
                          assign item_label = block.settings.label_1
                          assign item_sub = block.settings.sub_1
                          assign item_icon = block.settings.icon_1
                        when 2
                          assign item_label = block.settings.label_2
                          assign item_sub = block.settings.sub_2
                          assign item_icon = block.settings.icon_2
                        when 3
                          assign item_label = block.settings.label_3
                          assign item_sub = block.settings.sub_3
                          assign item_icon = block.settings.icon_3
                      endcase
                    -%}
                    {%- if item_label != blank -%}
                      <li class="mpm-trust-grid__item">
                        <div class="mpm-trust-grid__icon" aria-hidden="true">
                          {%- case item_icon -%}
                            {%- when 'truck' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                            {%- when 'return' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                            {%- when 'shield' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {%- when 'target' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                            {%- when 'clock' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            {%- when 'custom' -%}
                              {{ block.settings.custom_icon_svg }}
                          {%- endcase -%}
                        </div>
                        <p class="mpm-trust-grid__label">{{ item_label }}</p>
                        {%- if item_sub != blank -%}
                          <p class="mpm-trust-grid__sub">{{ item_sub }}</p>
                        {%- endif -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>

              {%- when 'trust_rail' -%}
                <ul class="mpm-trust-rail" aria-label="{{ block.settings.aria_label }}" {{ block.shopify_attributes }}>
                  {%- for i in (1..4) -%}
                    {%- liquid
                      case i
                        when 1
                          assign item_label = block.settings.label_1
                          assign item_sub = block.settings.sub_1
                          assign item_icon = block.settings.icon_1
                        when 2
                          assign item_label = block.settings.label_2
                          assign item_sub = block.settings.sub_2
                          assign item_icon = block.settings.icon_2
                        when 3
                          assign item_label = block.settings.label_3
                          assign item_sub = block.settings.sub_3
                          assign item_icon = block.settings.icon_3
                        when 4
                          assign item_label = block.settings.label_4
                          assign item_sub = block.settings.sub_4
                          assign item_icon = block.settings.icon_4
                      endcase
                    -%}
                    {%- if item_label != blank -%}
                      <li class="mpm-trust-rail__item">
                        <div class="mpm-trust-rail__icon" aria-hidden="true">
                          {%- case item_icon -%}
                            {%- when 'truck' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                            {%- when 'return' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                            {%- when 'card' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                            {%- when 'shield' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {%- when 'custom' -%}
                              {{ block.settings.custom_icon_svg }}
                          {%- endcase -%}
                        </div>
                        <div>
                          <p class="mpm-trust-rail__label">{{ item_label }}</p>
                          {%- if item_sub != blank -%}
                            <p class="mpm-trust-rail__sub">{{ item_sub }}</p>
                          {%- endif -%}
                        </div>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>

              {%- when 'collapsible_tab' -%}
                <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                  <details id="Details-{{ block.id }}-{{ section.id }}"{% if block.settings.open_by_default %} open{% endif %}>
                    <summary>
                      <div class="summary__title">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                        <h2 class="h4 accordion__title inline-richtext">{{ block.settings.heading | escape }}</h2>
                      </div>
                      <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                    </summary>
                    <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                      {%- if block.settings.content_style == 'steps' -%}
                        {%- assign steps = block.settings.steps | newline_to_br | split: '<br />' -%}
                        <ol class="mpm-accordion-steps">
                          {%- for step in steps -%}
                            {%- assign step_clean = step | strip -%}
                            {%- if step_clean != blank -%}
                              <li>
                                <span class="mpm-accordion-steps__num">{{ forloop.index }}</span>
                                <span>{{ step_clean }}</span>
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ol>
                      {%- elsif block.settings.content_style == 'checklist' -%}
                        {%- assign items = block.settings.steps | newline_to_br | split: '<br />' -%}
                        <ul class="mpm-accordion-checklist">
                          {%- for item in items -%}
                            {%- assign item_clean = item | strip -%}
                            {%- if item_clean != blank -%}
                              <li>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                                <span>{{ item_clean }}</span>
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      {%- else -%}
                        {{ block.settings.content }}
                        {{ block.settings.page.content }}
                      {%- endif -%}
                    </div>
                  </details>
                </div>

              {%- when 'info_boxes' -%}
                <div class="mpm-info-boxes" {{ block.shopify_attributes }}>
                  {%- if block.settings.box_1_title != blank -%}
                    <div class="mpm-info-box" style="background-color: {{ block.settings.box_background }}; border: 1px solid {{ block.settings.box_border }}; color: {{ block.settings.box_icon_color }};">
                      {%- case block.settings.box_1_icon -%}
                        {%- when 'truck' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'shield' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- endcase -%}
                      <div>
                        <p class="mpm-info-box__title">{{ block.settings.box_1_title }}</p>
                        {%- if block.settings.box_1_subtitle != blank -%}
                          <p class="mpm-info-box__sub">{{ block.settings.box_1_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.box_2_title != blank -%}
                    <div class="mpm-info-box" style="background-color: {{ block.settings.box_background }}; border: 1px solid {{ block.settings.box_border }}; color: {{ block.settings.box_icon_color }};">
                      {%- case block.settings.box_2_icon -%}
                        {%- when 'truck' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'shield' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- endcase -%}
                      <div>
                        <p class="mpm-info-box__title">{{ block.settings.box_2_title }}</p>
                        {%- if block.settings.box_2_subtitle != blank -%}
                          <p class="mpm-info-box__sub">{{ block.settings.box_2_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'custom_liquid' -%}
                <div {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
            {%- endcase -%}
          {%- endfor -%}
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if first_3d_model -%}
      <script type="application/json" id="ProductJSON-{{ product.id }}">{{ product.media | where: 'media_type', 'model' | json }}</script>
      <script src="{{ 'product-model.js' | asset_url }}" defer></script>
    {%- endif -%}

    <script type="application/ld+json">{{ product | structured_data }}</script>
  </div>
</product-info>


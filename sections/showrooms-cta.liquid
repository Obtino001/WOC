<section class="py-16 bg-linen">
  <div class="container mx-auto px-4 lg:px-8 text-center">
    <div>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-4">{{ section.settings.title }}</h2>
      <p class="font-body text-muted-foreground mb-8 max-w-xl mx-auto">{{ section.settings.description }}</p>
      <a href="{{ section.settings.button_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-gold text-background font-medium hover:bg-gold-hover transition-all duration-500 tracking-widest uppercase text-xs h-12 px-10">
        {{ section.settings.button_text }} 
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Showrooms CTA",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Can't visit a showroom?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We also offer home visits and virtual consultations. Our experts come to you — throughout Denmark, Sweden, and beyond."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Request Home Visit"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Showrooms CTA"
    }
  ]
}
{% endschema %}

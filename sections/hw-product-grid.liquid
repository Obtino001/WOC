<section id="{{ section.settings.section_id }}" class="border-t border-border bg-background py-16 md:py-20">
  <div class="container mx-auto px-6 lg:px-12">
    <h2 class="mb-10 font-display text-3xl font-semibold text-foreground md:text-4xl">{{ section.settings.heading }}</h2>
    
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {% assign target_collection = section.settings.collection %}
      {% for product in target_collection.products limit: section.settings.limit %}
        
        <div class="group relative flex flex-col rounded-[1.5rem] border border-border bg-card p-3 shadow-soft h-full">
          <div class="absolute left-5 top-5 z-10 flex flex-col gap-1.5">
            {% if product.compare_at_price > product.price %}
              {% assign savings = product.compare_at_price | minus: product.price %}
              {% assign savings_percent = savings | times: 100.0 | divided_by: product.compare_at_price | round %}
              <span class="rounded-full bg-destructive px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.18em] text-destructive-foreground">
                -{{ savings_percent }}% Save {{ savings | money_without_trailing_zeros }}
              </span>
            {% endif %}
            
            {% if product.tags contains 'Bestseller' %}
              <span class="rounded-full bg-foreground px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.18em] text-background">Bestseller</span>
            {% elsif product.tags contains 'Compact' %}
              <span class="rounded-full bg-foreground px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.18em] text-background">Compact</span>
            {% elsif product.tags contains 'Exclusive' %}
               <span class="rounded-full bg-foreground px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.18em] text-background">Exclusive</span>
            {% endif %}
          </div>
          
          <div class="absolute right-5 top-5 z-10 flex items-center gap-1.5">
            {% if product.available %}
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
              </span>
              <span class="font-body text-[10px] font-semibold text-green-700">In stock</span>
            {% else %}
              <span class="relative flex h-2 w-2">
                <span class="relative inline-flex h-2 w-2 rounded-full bg-amber-500"></span>
              </span>
              <span class="font-body text-[10px] font-semibold text-amber-700">Sold out</span>
            {% endif %}
          </div>

          <a href="{{ product.url }}" class="block">
            <div class="relative mb-4 aspect-square overflow-hidden rounded-[1.25rem] bg-muted">
              {% if product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'h-full w-full object-contain p-6 transition-transform duration-500 group-hover:scale-105', loading: 'lazy' }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'h-full w-full object-contain p-6 bg-gray-100' }}
              {% endif %}
            </div>
          </a>

          <div class="flex flex-1 flex-col">
            <h3 class="mb-1 font-body text-sm font-semibold leading-snug text-foreground">{{ product.title }}</h3>
            <p class="mb-3 font-body text-xs leading-relaxed text-muted-foreground line-clamp-2">{{ product.metafields.custom.short_description | default: product.description | strip_html | truncatewords: 10 }}</p>
            
            <ul class="mb-4 space-y-1">
              {% if product.metafields.custom.features != blank %}
                {% assign features = product.metafields.custom.features.value %}
                {% for feature in features limit: 4 %}
                  <li class="flex items-start gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-3 w-3 shrink-0 text-green-600"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span class="font-body text-[11px] leading-snug text-muted-foreground">{{ feature }}</span>
                  </li>
                {% endfor %}
              {% else %}
                <li class="flex items-start gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-3 w-3 shrink-0 text-green-600"><path d="M20 6 9 17l-5-5"></path></svg>
                  <span class="font-body text-[11px] leading-snug text-muted-foreground">Premium quality materials</span>
                </li>
                <li class="flex items-start gap-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-3 w-3 shrink-0 text-green-600"><path d="M20 6 9 17l-5-5"></path></svg>
                  <span class="font-body text-[11px] leading-snug text-muted-foreground">Clinically documented</span>
                </li>
              {% endif %}
            </ul>

            <div class="mb-3 mt-auto flex flex-wrap items-baseline gap-2">
              <span class="font-body text-lg font-bold text-foreground">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="font-body text-sm text-muted-foreground line-through">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>

            <div class="mb-4 flex flex-wrap gap-x-3 gap-y-1">
              <span class="flex items-center gap-1 font-body text-[10px] text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg> Free delivery
              </span>
              <span class="flex items-center gap-1 font-body text-[10px] text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg> Up to 2-year warranty
              </span>
              <span class="flex items-center gap-1 font-body text-[10px] text-muted-foreground">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg> 30-day guarantee
              </span>
            </div>

            <div class="flex gap-2">
              <form method="post" action="/cart/add" class="flex-1 flex">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                <button type="submit" {% unless product.available %}disabled{% endunless %} class="flex flex-1 items-center justify-center gap-2 rounded-full bg-foreground px-4 py-3 font-body text-xs font-semibold uppercase tracking-[0.15em] text-background transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                  Buy now
                </button>
              </form>
              <a href="{{ product.url }}" class="flex flex-1 items-center justify-center gap-2 rounded-full border border-border bg-background px-4 py-3 font-body text-xs font-semibold uppercase tracking-[0.15em] text-foreground transition-colors hover:bg-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path><circle cx="12" cy="12" r="3"></circle></svg>
                See more
              </a>
            </div>
          </div>
        </div>
      {% else %}
        <p>Assign a collection to see products.</p>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HW Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "HTML ID (for anchoring)",
      "default": "shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop all products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Product Limit",
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "HW Product Grid"
    }
  ]
}
{% endschema %}

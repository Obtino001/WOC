{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<section id="shop" class="bg-white border-t border-zinc-200 section-{{ section.id }}-padding">
  <div id="products" class="container mx-auto px-6 lg:px-12">
    <h2 class="mb-10 font-display text-3xl font-semibold text-zinc-900 md:text-4xl">{{ section.settings.heading }}</h2>
    
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-{{ section.settings.columns }} lg:gap-8">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}
        
        <div class="group relative flex flex-col rounded-[1.5rem] border border-zinc-200 bg-white p-3 shadow-soft" {{ block.shopify_attributes }}>
          
          <div class="absolute left-5 top-5 z-10 flex flex-col gap-1.5">
            {% if block.settings.badge_1 != blank %}
              <span class="rounded-full bg-red-600 px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.18em] text-white">{{ block.settings.badge_1 }}</span>
            {% endif %}
            {% if block.settings.badge_2 != blank %}
              <span class="rounded-full bg-zinc-900 px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.18em] text-white">{{ block.settings.badge_2 }}</span>
            {% endif %}
          </div>
          
          <div class="absolute right-5 top-5 z-10 flex items-center gap-1.5">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
            </span>
            <span class="font-body text-[10px] font-semibold text-green-700">In stock</span>
          </div>

          <a href="{{ product.url | default: '#' }}">
            <div class="relative mb-4 aspect-square overflow-hidden rounded-t-[1.5rem]">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'h-full w-full object-contain p-4 transition-transform duration-500 group-hover:scale-105', loading: 'lazy' }}
              {% elsif product != blank and product.featured_image != blank %}
                {{ product.featured_image | image_url: width: 600 | image_tag: class: 'h-full w-full object-contain p-4 transition-transform duration-500 group-hover:scale-105', loading: 'lazy' }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'h-full w-full object-cover p-4 transition-transform duration-500 group-hover:scale-105' }}
              {% endif %}
            </div>
          </a>

          <div class="flex flex-1 flex-col px-2">
            <h3 class="mb-1 font-body text-sm font-semibold leading-snug text-zinc-900">{{ product.title | default: block.settings.title }}</h3>
            <p class="mb-3 font-body text-xs leading-relaxed text-zinc-500">{{ block.settings.subtitle }}</p>
            
            {% if block.settings.features != blank %}
              <ul class="mb-4 space-y-1">
                {% assign features = block.settings.features | split: ',' %}
                {% for feature in features %}
                  <li class="flex items-start gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-check mt-0.5 h-3 w-3 shrink-0 text-green-600"><path d="M20 6 9 17l-5-5"></path></svg>
                    <span class="font-body text-[11px] leading-snug text-zinc-500">{{ feature | strip }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
            
            <div class="mb-3 mt-auto flex flex-wrap items-baseline gap-2">
              <span class="font-body text-lg font-bold text-zinc-900">
                {% if block.settings.price != blank %}{{ block.settings.price }}{% elsif product != blank %}{{ product.price | money }}{% endif %}
              </span>
              {% if block.settings.compare_price != blank %}
                <span class="font-body text-sm text-zinc-500 line-through">{{ block.settings.compare_price }}</span>
              {% elsif product != blank and product.compare_at_price > product.price %}
                <span class="font-body text-sm text-zinc-500 line-through">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>

            <div class="mb-4 flex flex-wrap gap-x-3 gap-y-1">
              <span class="flex items-center gap-1 font-body text-[10px] text-zinc-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-truck h-3 w-3"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg> Free delivery</span>
              <span class="flex items-center gap-1 font-body text-[10px] text-zinc-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-shield h-3 w-3"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg> Up to 2-year warranty</span>
              <span class="flex items-center gap-1 font-body text-[10px] text-zinc-500"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-star h-3 w-3"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg> 30-day satisfaction guarantee</span>
            </div>

            <div class="flex gap-2">
              {%- if product != blank -%}
                {%- assign product_form_id = 'product-form-' | append: section.id | append: '-' | append: product.id -%}
                {%- assign current_variant = product.selected_or_first_available_variant -%}
                <product-form class="flex-1">
                  {%- form 'product', product, id: product_form_id, class: 'form h-full', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" value="{{ current_variant.id }}" disabled>
                    <button type="submit" name="add" class="flex w-full items-center justify-center gap-2 rounded-full bg-zinc-900 px-4 py-3 font-body text-xs font-semibold uppercase tracking-[0.15em] text-white transition-opacity hover:opacity-90 disabled:opacity-50" {% if current_variant.available == false %}disabled{% endif %}>
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-shopping-bag h-3.5 w-3.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                      {%- if current_variant.available -%}
                        Buy now
                      {%- else -%}
                        {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                      {%- endif -%}
                    </button>
                  {%- endform -%}
                </product-form>
              {%- else -%}
                <button class="flex flex-1 items-center justify-center gap-2 rounded-full bg-zinc-900 px-4 py-3 font-body text-xs font-semibold uppercase tracking-[0.15em] text-white transition-opacity hover:opacity-90"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-shopping-bag h-3.5 w-3.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>Buy now</button>
              {%- endif -%}
              
              <a class="flex flex-1 items-center justify-center gap-2 rounded-full border border-zinc-200 bg-white px-4 py-3 font-body text-xs font-semibold uppercase tracking-[0.15em] text-zinc-900 transition-colors hover:bg-zinc-50" href="{{ product.url | default: '#' }}"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-eye h-3.5 w-3.5"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path><circle cx="12" cy="12" r="3"></circle></svg>See more</a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HW Product Grid",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop all products" },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Desktop Columns", "default": 3 }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "product", "id": "product", "label": "Link Product" },
        { "type": "image_picker", "id": "image", "label": "Custom Image (Optional)" },
        { "type": "text", "id": "badge_1", "label": "Red Badge" },
        { "type": "text", "id": "badge_2", "label": "Black Badge" },
        { "type": "text", "id": "title", "label": "Custom Title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "textarea", "id": "features", "label": "Features (comma separated)" },
        { "type": "text", "id": "price", "label": "Custom Price" },
        { "type": "text", "id": "compare_price", "label": "Custom Compare Price" }
      ]
    }
  ],
  "presets": [
    { "name": "HW Product Grid" }
  ]
}
{% endschema %}

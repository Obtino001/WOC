<section class="py-24 bg-[#0a0a0a] overflow-hidden">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-6xl mx-auto">
      
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        
        <!-- Image Side -->
        <div class="rounded-2xl overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.5)] {% if section.settings.image_position == 'right' %}order-2{% else %}order-1{% endif %}">
          {% if section.settings.image %}
            {{ section.settings.image | image_url: width: 800 | image_tag: class: 'w-full aspect-[4/3] object-cover' }}
          {% else %}
            <!-- Placeholder if no image is selected -->
            <div class="w-full aspect-[4/3] bg-[#111] border border-[#222] flex items-center justify-center text-[#555]">
              Görsel Alanı
            </div>
          {% endif %}
        </div>

        <!-- Content Side -->
        <div class="{% if section.settings.image_position == 'right' %}order-1{% else %}order-2{% endif %}">
          
          {% if section.settings.badge != blank %}
            <div class="inline-flex items-center rounded-full border px-3 py-1 font-semibold transition-colors bg-[#d4af37]/10 text-[#d4af37] border-[#d4af37]/30 mb-6 text-[10px] uppercase tracking-widest">
              {{ section.settings.badge }}
            </div>
          {% endif %}
          
          {% if section.settings.title != blank %}
            <h2 class="font-display text-3xl md:text-4xl lg:text-4xl font-light text-white mb-6">
              {{ section.settings.title }}
            </h2>
          {% endif %}
          
          {% if section.settings.description != blank %}
            <!-- Added specific classes to handle spacing between paragraphs in the rich text -->
            <div class="font-body text-[#888] leading-relaxed mb-8 text-sm md:text-base [&_p]:mb-4 last:[&_p]:mb-0">
              {{ section.settings.description }}
            </div>
          {% endif %}

          <!-- Checkmark List (2 Columns) -->
          {% if section.blocks.size > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-4">
              {% for block in section.blocks %}
                <div class="flex items-center gap-3" {{ block.shopify_attributes }}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#d4af37] flex-shrink-0">
                    <path d="M20 6 9 17l-5-5"></path>
                  </svg>
                  <span class="font-body text-xs sm:text-sm text-[#ddd]">{{ block.settings.text }}</span>
                </div>
              {% endfor %}
            </div>
          {% endif %}

        </div>
        
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature Split Dark",
  "settings": [
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        {"value": "left", "label": "Left"},
        {"value": "right", "label": "Right"}
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "TÜM 3 MODELDE STANDARTTIR"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Bireysel olarak kaplanmış torba yaylar"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text"
    }
  ],
  "blocks": [
    {
      "type": "check_item",
      "name": "List Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Split Dark",
      "settings": {
        "image_position": "left",
        "badge": "TÜM 3 MODELDE STANDARTTIR",
        "title": "Bireysel olarak kaplanmış torba yaylar",
        "description": "<p>Yataklarımızdaki her yay, kendi kumaş torbasında ayrı ayrı kapsüllenmiştir. Bu, aşağıdaki anlama gelir: her yay bağımsız çalışır — böylece yatak, geleneksel bonel yaylardaki gibi \"bir bütün\" olmak yerine vücudunuzun benzersiz hatlarına nokta nokta uyum sağlar.</p><p>Şu kadar ile m² başına 220 torba yay olağanüstü nokta esnekliğine sahip bir yatak elde edersiniz. Bu, hareket transferini ortadan kaldırır — eşiniz döndüğünde, siz <i>hiçbir şey</i>.</p><p>Torba yaylar, bir katman <b>doğal lateks</b> ile birleştirilmiştir ve sürekli nefes alabilirlik ve sıcaklık düzenlemesi sağlar. Sonuç olarak, gece boyunca, yıl boyunca destekleyen, havalandıran ve esnekliğini koruyan bir yatak elde edilir — şuna kadar: 15 yıl garanti.</p>"
      },
      "blocks": [
        {
          "type": "check_item",
          "settings": {
            "text": "Sıfır hareket transferi"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "M² başına 220 yaya kadar"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "Doğal lateks ile birleştirilmiş"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "15 yıla kadar garanti"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "Optimal nokta esnekliği"
          }
        },
        {
          "type": "check_item",
          "settings": {
            "text": "Bonnell yaylardan daha iyi"
          }
        }
      ]
    }
  ]
}
{% endschema %}
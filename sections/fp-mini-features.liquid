{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-foreground section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    
    {% if section.settings.kicker != blank or section.settings.heading != blank %}
      <div class="text-center mb-12">
        {% if section.settings.kicker != blank %}
          <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-background/50 mb-3">
            {{ section.settings.kicker }}
          </p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="font-display text-3xl font-semibold text-background md:text-4xl">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {% for block in section.blocks %}
        <div class="rounded-2xl bg-background/5 border border-background/10 p-6 hover:bg-background/10 transition-colors" {{ block.shopify_attributes }}>
          <div class="w-12 h-12 rounded-xl bg-background/10 flex items-center justify-center mb-4 [&>svg]:w-6 [&>svg]:h-6 [&>svg]:text-background">
            {{ block.settings.icon_svg }}
          </div>
          <h3 class="font-display text-lg font-bold text-background mb-2">{{ block.settings.title }}</h3>
          <p class="font-body text-sm text-background/60 leading-relaxed">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FP Mini Features",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "FITNESS BENEFITS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Train smarter — not harder" }
  ],
  "blocks": [
    {
      "type": "mini_feature",
      "name": "Mini Feature",
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature Title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Describe the feature here." }
      ]
    }
  ],
  "presets": [
    { "name": "FP Mini Features" }
  ]
}
{% endschema %}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-background section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
    
    <div class="text-center mb-10">
      <h2 class="font-display text-2xl font-semibold text-foreground md:text-3xl">
        {{ section.settings.heading }}
      </h2>
    </div>
    
    <div class="space-y-3">
      {% for block in section.blocks %}
        <div class="rounded-xl border border-border bg-card px-6 transition-colors hover:border-foreground/20 group" {{ block.shopify_attributes }}>
          <details class="group/details marker:hidden">
            <summary class="flex flex-1 items-center justify-between transition-all font-body text-sm font-semibold text-foreground hover:no-underline py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              {{ block.settings.question }}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down h-4 w-4 shrink-0 transition-transform duration-200 group-open/details:rotate-180">
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </summary>
            <div class="pb-5 pt-0 text-sm text-muted-foreground font-body leading-relaxed animate-accordion-down">
              {{ block.settings.answer }}
            </div>
          </details>
        </div>
      {% endfor %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "FP Simple FAQ",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question goes here?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Answer goes here.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Simple FAQ" }
  ]
}
{% endschema %}
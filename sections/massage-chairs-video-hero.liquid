{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="relative min-h-[90vh] flex items-end overflow-hidden section-{{ section.id }}-padding">
  <div class="absolute inset-0">
    {% if section.settings.video_url != blank %}
      <video autoplay loop muted playsinline poster="{{ section.settings.fallback_image | image_url: width: 2000 }}" class="w-full h-full object-cover">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.fallback_image != blank %}
       {{ section.settings.fallback_image | image_url: width: 2000 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
    {% else %}
       {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover bg-charcoal' }}
    {% endif %}
    
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-charcoal/70 to-charcoal/30"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 to-transparent"></div>
  </div>
  
  <div class="container mx-auto px-4 lg:px-8 relative z-10 pb-16 pt-40">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10">
      
      <div class="max-w-3xl">
        <div class="luxury-line mb-8"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-6">{{ section.settings.kicker }}</p>
        <h1 class="font-display text-4xl md:text-5xl lg:text-7xl font-light text-white leading-[1.05] mb-6">
          {{ section.settings.heading | newline_to_br }}
        </h1>
        <p class="font-body text-base md:text-lg text-white/70 leading-relaxed mb-8 max-w-xl">
          {{ section.settings.description }}
        </p>
        
        <div class="flex items-center gap-6 mb-10">
          <div class="flex items-center gap-2">
            <div class="flex">
              {% for i in (1..5) %}
                 <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              {% endfor %}
            </div>
            <span class="font-display text-2xl font-bold text-white">{{ section.settings.rating_score }}</span>
            <span class="font-body text-xs text-white/50">/5</span>
          </div>
          <div class="h-6 w-px bg-white/20"></div>
          <div class="flex items-center gap-3">
            <span class="font-body text-[10px] text-white/60 uppercase tracking-wider">Google Reviews</span>
            <span class="font-body text-[10px] text-white/60">·</span>
            <span class="font-body text-[10px] text-white/60 uppercase tracking-wider">Trustpilot</span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 flex-wrap">
          {% if section.settings.btn1_text != blank %}
            <a class="inline-flex items-center justify-center whitespace-nowrap text-sm bg-gold hover:bg-gold/90 text-background font-semibold shadow-gold animate-pulse-subtle h-12 px-8 gap-2 transition-all duration-500" href="{{ section.settings.btn1_link }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path><path d="M20 3v4"></path><path d="M22 5h-4"></path><path d="M4 17v2"></path><path d="M5 18H3"></path></svg> 
              {{ section.settings.btn1_text }}
            </a>
          {% endif %}
          {% if section.settings.btn2_text != blank %}
            <a class="inline-flex items-center justify-center gap-2 whitespace-nowrap gradient-gold text-charcoal font-semibold hover:opacity-90 transition-all duration-500 tracking-[0.25em] uppercase text-xs shadow-gold h-12 px-10" href="{{ section.settings.btn2_link }}">
              {{ section.settings.btn2_text }}
            </a>
          {% endif %}
          {% if section.settings.btn3_text != blank %}
            <a class="inline-flex items-center justify-center whitespace-nowrap border-2 border-gold/60 text-gold font-semibold hover:border-gold hover:bg-gold/10 transition-all duration-500 tracking-[0.25em] uppercase text-xs h-12 px-10 gap-2" href="{{ section.settings.btn3_link }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg> 
              {{ section.settings.btn3_text }}
            </a>
          {% endif %}
        </div>
      </div>
      
      <div class="hidden lg:block max-w-xs">
        <div class="bg-charcoal/60 backdrop-blur-md border border-white/10 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full overflow-hidden border border-gold/30">
              {% if section.settings.expert_image != blank %}
                {{ section.settings.expert_image | image_url: width: 100 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
              {% endif %}
            </div>
            <div>
              <p class="font-body text-xs font-semibold text-white">{{ section.settings.expert_name }}</p>
              <p class="font-body text-[10px] text-white/50">{{ section.settings.expert_title }}</p>
            </div>
          </div>
          <p class="font-display text-sm italic text-white/80 leading-relaxed">{{ section.settings.expert_quote }}</p>
          <div class="flex items-center gap-1 mt-3">
             {% for i in (1..5) %}
               <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-2.5 h-2.5 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
             {% endfor %}
            <span class="font-body text-[9px] text-white/40 ml-1">Professionally recommended</span>
          </div>
        </div>
      </div>
      
    </div>

    <div class="mt-12 flex flex-wrap items-center gap-8">
      {% for block in section.blocks %}
        {% if block.type == 'stat' %}
          <div class="text-center" {{ block.shopify_attributes }}>
            <p class="font-display text-xl font-bold text-gold">{{ block.settings.number }}</p>
            <p class="font-body text-[9px] text-white/50 uppercase tracking-wider">{{ block.settings.label }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Video Hero",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (.mp4)"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback Image / Poster"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Flagship Collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Massage Chairs\n<span class=\"italic text-gold\">For the Body</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Experience world-class massage chairs that combine Scandinavian design with ground-breaking wellness technology."
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating Score",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "Find your perfect chair — 60 sec"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "View all models"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "text",
      "id": "btn3_text",
      "label": "Button 3 Text",
      "default": "Book a Demo"
    },
    {
      "type": "url",
      "id": "btn3_link",
      "label": "Button 3 Link"
    },
    {
      "type": "header",
      "content": "Expert Box"
    },
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Expert Image"
    },
    {
      "type": "text",
      "id": "expert_name",
      "label": "Expert Name",
      "default": "Dr. Carsten Rosendahl"
    },
    {
      "type": "text",
      "id": "expert_title",
      "label": "Expert Title",
      "default": "Chiropractor · Nordic Spine & Wellness"
    },
    {
      "type": "textarea",
      "id": "expert_quote",
      "label": "Expert Quote",
      "default": "\"Daily use of a therapeutic massage chair can reduce chronic back pain by up to 60% in 8 weeks.\""
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number (e.g. 50.000+)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. Satisfied customers)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Hero"
    }
  ]
}
{% endschema %}

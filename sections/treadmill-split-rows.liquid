{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-background section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
    <div class="space-y-8">
      {% for block in section.blocks %}
        {% assign is_even = forloop.index0 | modulo: 2 %}
        <div class="grid md:grid-cols-2 gap-6 items-center" {{ block.shopify_attributes }}>
          
          <div class="overflow-hidden rounded-2xl border border-border {% if is_even == 1 %}md:order-2{% endif %}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'w-full aspect-[4/3] object-cover', loading: 'lazy' }}
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full aspect-[4/3] object-cover bg-gray-200' }}
            {% endif %}
          </div>
          
          <div class="p-2 md:p-6 {% if is_even == 1 %}md:order-1{% endif %}">
            <h3 class="font-display text-2xl font-bold text-foreground mb-3">{{ block.settings.title }}</h3>
            <p class="font-body text-base text-muted-foreground leading-relaxed">{{ block.settings.text }}</p>
          </div>
          
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Treadmill Split Rows",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "Treadmill Split Rows" }
  ]
}
{% endschema %}
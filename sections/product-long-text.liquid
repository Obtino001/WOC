{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8 text-center max-w-4xl">
    <div>
      <div class="luxury-line mx-auto mb-8"></div>
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-6">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl md:text-5xl lg:text-6xl font-light text-foreground leading-[1.05] mb-6">
        {{ section.settings.heading }}
      </h2>
      <div class="font-body text-base text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        {{ section.settings.text }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Long Text",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 112 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "LATEST TECHNOLOGY 2026" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "You Have <span class=\"font-bold italic\">Never</span> Seen A Massage Chair Like This" },
    { "type": "richtext", "id": "text", "label": "Text" }
  ],
  "presets": [
    { "name": "Product Long Text" }
  ]
}
{% endschema %}

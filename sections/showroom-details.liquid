{% style %}
  .gradient-gold { background: linear-gradient(135deg, #d4af37 0%, #aa8c2c 100%); }
{% endstyle %}

<section class="relative min-h-[60vh] flex items-end overflow-hidden">
  <div class="absolute inset-0">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: class: 'w-full h-full object-cover', alt: section.settings.hero_title }}
    {% else %}
      <img src="https://via.placeholder.com/1920x1080" alt="{{ section.settings.hero_title }}" class="w-full h-full object-cover">
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/30 to-transparent"></div>
  </div>
  
  <div class="container mx-auto px-4 lg:px-8 relative z-10 pb-16 pt-32">
    <a class="inline-flex items-center gap-1 font-body text-sm text-white/60 hover:text-[#d4af37] transition-colors mb-6" href="{{ section.settings.back_link }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"></path></svg> 
      {{ section.settings.back_label }}
    </a>
    
    <div>
      <span class="font-body text-sm uppercase tracking-[0.3em] text-[#d4af37] mb-3 block">{{ section.settings.hero_subtitle }}</span>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4">{{ section.settings.hero_title }}</h1>
      <p class="font-body text-lg text-white/60 max-w-2xl">{{ section.settings.hero_description }}</p>
    </div>
  </div>
</section>

<section class="py-20">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-12 items-start">
      
      <div class="lg:col-span-2 space-y-6">
        
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 border-gray-200">
          <div class="flex gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[#d4af37] flex-shrink-0 mt-0.5"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <div>
              <h3 class="font-body text-sm font-semibold mb-1">{{ section.settings.address_title }}</h3>
              <p class="font-body text-sm text-gray-500">{{ section.settings.address_line_1 }}</p>
              <p class="font-body text-sm text-gray-500">{{ section.settings.address_line_2 }}</p>
              <p class="font-body text-sm text-gray-500">{{ section.settings.address_line_3 }}</p>
            </div>
          </div>
        </div>

        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 border-gray-200">
          <div class="flex gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[#d4af37] flex-shrink-0 mt-0.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <div>
              <h3 class="font-body text-sm font-semibold mb-1">{{ section.settings.phone_title }}</h3>
              <a href="tel:{{ section.settings.phone_number | replace: ' ', '' }}" class="font-body text-sm text-[#d4af37] hover:underline">{{ section.settings.phone_number }}</a>
            </div>
          </div>
        </div>

        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 border-gray-200">
          <div class="flex gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[#d4af37] flex-shrink-0 mt-0.5"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            <div>
              <h3 class="font-body text-sm font-semibold mb-1">{{ section.settings.email_title }}</h3>
              <a href="mailto:{{ section.settings.email_address }}" class="font-body text-sm text-[#d4af37] hover:underline">{{ section.settings.email_address }}</a>
            </div>
          </div>
        </div>

        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 border-gray-200">
          <div class="flex gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-[#d4af37] flex-shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            <div class="w-full">
              <h3 class="font-body text-sm font-semibold mb-2">{{ section.settings.hours_title }}</h3>
              {% for block in section.blocks %}
                {% if block.type == 'working_hour' %}
                  <div class="flex justify-between gap-4 font-body text-sm mb-1" {{ block.shopify_attributes }}>
                    <span class="text-gray-500">{{ block.settings.day }}</span>
                    <span class="font-medium">{{ block.settings.time }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="rounded-lg border shadow-sm p-6 border-[#d4af37]/20 bg-[#d4af37]/5">
          <h3 class="font-body text-sm font-semibold mb-3">{{ section.settings.features_title }}</h3>
          <div class="space-y-2">
            {% for block in section.blocks %}
              {% if block.type == 'feature' %}
                <div class="flex items-center gap-2" {{ block.shopify_attributes }}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#d4af37] flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
                  <span class="font-body text-sm">{{ block.settings.feature_text }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="lg:col-span-3 space-y-8">
        
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-8 border-gray-200">
          <h2 class="font-display text-2xl font-bold mb-2">{{ section.settings.form_title }}</h2>
          <p class="font-body text-sm text-gray-500 mb-6">{{ section.settings.form_subtitle }}</p>
          
          {% form 'contact', class: 'space-y-4' %}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="font-body text-sm font-medium mb-1.5 block">Ad <span class="text-red-500">*</span></label>
                <input type="text" name="contact[name]" required class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#d4af37]" placeholder="Adınız Soyadınız">
              </div>
              <div>
                <label class="font-body text-sm font-medium mb-1.5 block">Telefon <span class="text-red-500">*</span></label>
                <input type="tel" name="contact[phone]" required class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#d4af37]" placeholder="+45 ...">
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="font-body text-sm font-medium mb-1.5 block">E-posta</label>
                <input type="email" name="contact[email]" class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#d4af37]" placeholder="you@email.com">
              </div>
              <div>
                <label class="font-body text-sm font-medium mb-1.5 block">Tercih Edilen Tarih</label>
                <input type="date" name="contact[date]" class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#d4af37]">
              </div>
            </div>
            
            <div>
              <label class="font-body text-sm font-medium mb-1.5 block">Denemek İstiyorum <span class="text-red-500">*</span></label>
              <select name="contact[product]" required class="flex h-10 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#d4af37]">
                <option value="massage-chairs">Masaj Koltukları</option>
                <option value="sovesystem">SOVESYSTEM® (Özel Yatak)</option>
                <option value="synthera-ai-bed">SYNTHERA™ AI Yatak</option>
                <option value="sports-recovery">Spor İyileşmesi</option>
                <option value="beauty-technology">Güzellik Teknolojisi</option>
                <option value="full-tour">Tam Showroom Turu</option>
              </select>
            </div>
            
            <div>
              <label class="font-body text-sm font-medium mb-1.5 block">Mesaj</label>
              <textarea name="contact[body]" rows="3" class="flex min-h-[80px] w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#d4af37]" placeholder="Özel istekleriniz veya sorularınız var mı?"></textarea>
            </div>
            
            <button type="submit" class="inline-flex items-center justify-center gap-2 bg-[#d4af37] text-white font-medium hover:opacity-90 transition-all duration-300 tracking-widest uppercase text-xs h-12 px-10 w-full rounded-md">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path></svg>
              Ücretsiz Demo Rezervasyonu Yap
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
            <p class="font-body text-xs text-gray-500 text-center">Ücretsiz ve yükümlülüksüz. 1 iş günü içinde onaylayacağız.</p>
          {% endform %}
        </div>

        <div>
          <div class="rounded-lg border bg-card overflow-hidden border-gray-200">
            <div class="aspect-[16/9]">
              <iframe src="{{ section.settings.map_url }}" width="100%" height="100%" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map" style="border: 0px;"></iframe>
            </div>
          </div>
          <p class="font-body text-xs text-gray-500 text-center mt-3">
            <a href="{{ section.settings.map_link }}" target="_blank" rel="noopener noreferrer" class="hover:text-[#d4af37] transition-colors">Google Haritalar'da Aç →</a>
          </p>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Showroom Details",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "🇩🇰 Danimarka"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "Fredericia Genel Merkez ve Showroom"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Description",
      "default": "Fredericia'daki küresel genel merkezimiz ve Jutland showroom'umuz. En popüler masaj koltuklarımızı deneyebileceğiniz ve SOVESYSTEM® vücut analizini rahat, kişisel bir ortamda deneyimleyebileceğiniz kapsamlı bir alan. Burası aynı zamanda tüm organizasyonumuzun da evidir."
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Back Link Label",
      "default": "Tüm Showroomlar"
    },
    {
      "type": "url",
      "id": "back_link",
      "label": "Back Link URL"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "text",
      "id": "address_title",
      "label": "Address Title",
      "default": "Adres"
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address Line 1",
      "default": "Kringsvej 4"
    },
    {
      "type": "text",
      "id": "address_line_2",
      "label": "Address Line 2",
      "default": "7000 Fredericia"
    },
    {
      "type": "text",
      "id": "address_line_3",
      "label": "Address Line 3",
      "default": "Danimarka"
    },
    {
      "type": "text",
      "id": "phone_title",
      "label": "Phone Title",
      "default": "Telefon"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "+45 70 20 30 41"
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Email Title",
      "default": "E-posta"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "fredericia@worldofcomfort.dk"
    },
    {
      "type": "text",
      "id": "hours_title",
      "label": "Hours Title",
      "default": "Çalışma Saatleri"
    },
    {
      "type": "text",
      "id": "features_title",
      "label": "Features Title",
      "default": "Burada Neler Bulacaksınız"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Ücretsiz Demo Rezervasyonu Yapın"
    },
    {
      "type": "text",
      "id": "form_subtitle",
      "label": "Form Subtitle",
      "default": "Satın almadan önce deneyin. Tercih ettiğiniz ürünleri kişisel bir tanıtım için hazırlayacağız."
    },
    {
      "type": "header",
      "content": "Map Settings"
    },
    {
      "type": "url",
      "id": "map_url",
      "label": "Google Maps Iframe Embed URL",
      "info": "Paste the embed URL here"
    },
    {
      "type": "url",
      "id": "map_link",
      "label": "External Google Maps Link"
    }
  ],
  "blocks": [
    {
      "type": "working_hour",
      "name": "Working Hour",
      "settings": [
        {
          "type": "text",
          "id": "day",
          "label": "Day(s)",
          "default": "Pazartesi – Cuma"
        },
        {
          "type": "text",
          "id": "time",
          "label": "Time",
          "default": "10:00 – 17:30"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Feature Point",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Text",
          "default": "World of Comfort Global Headquarters"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Showroom Details",
      "blocks": [
        {
          "type": "working_hour",
          "settings": {
            "day": "Pazartesi – Cuma",
            "time": "10:00 – 17:30"
          }
        },
        {
          "type": "working_hour",
          "settings": {
            "day": "Cumartesi",
            "time": "10:00 – 14:00"
          }
        },
        {
          "type": "working_hour",
          "settings": {
            "day": "Pazar",
            "time": "Kapalı"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "World of Comfort Global Headquarters"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Özenle seçilmiş masaj koltuğu seçenekleri (6+ model)"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "SOVESYSTEM® vücut tarama istasyonu"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Kişisel 1'e 1 danışmanlık"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "E20/E45 otoyolundan kolay erişim"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Kapıda ücretsiz otopark"
          }
        }
      ]
    }
  ]
}
{% endschema %}
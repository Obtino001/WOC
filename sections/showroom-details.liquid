
  <section class="relative min-h-[60vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1920 | image_tag: class: 'w-full h-full object-cover' }}
      {% else %}
        <img src="/assets/showroom-fredericia-Nd0e262J.jpg" alt="Fredericia HQ" class="w-full h-full object-cover">
      {% endif %}
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-charcoal/30 to-transparent"></div>
    </div>
    <div class="container mx-auto px-4 lg:px-8 relative z-10 pb-16 pt-32">
      <a class="inline-flex items-center gap-1 font-body text-sm text-secondary/60 hover:text-gold transition-colors mb-6" href="/showrooms">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"></path></svg> 
        Tüm Showroomlar
      </a>
      <span class="font-body text-sm uppercase tracking-[0.3em] text-gold mb-3 block">{{ section.settings.country }}</span>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-secondary mb-4">{{ section.settings.title }}</h1>
      <p class="font-body text-lg text-secondary/60 max-w-2xl">{{ section.settings.description }}</p>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="py-20">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-12 items-start">
        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6">
          {% for block in section.blocks %}
            {% if block.type == 'info_card' %}
              <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 border-border">
                <div class="flex gap-4">
                  <div class="text-gold">{{ block.settings.icon_svg }}</div>
                  <div>
                    <h3 class="font-body text-sm font-semibold text-foreground mb-1">{{ block.settings.heading }}</h3>
                    <div class="font-body text-sm text-muted-foreground">{{ block.settings.content }}</div>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <!-- Form and Map -->
        <div class="lg:col-span-3 space-y-8">
          <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-8 border-border">
             {% form 'contact' %}
                <h2 class="font-display text-2xl font-bold text-foreground mb-2">Ücretsiz Demo Rezervasyonu Yapın</h2>
                <p class="font-body text-sm text-muted-foreground mb-6">Satın almadan önce deneyimleyin.</p>
                <!-- Form fields would go here -->
                <button type="submit" class="bg-gold w-full py-4 text-background uppercase tracking-widest text-xs font-medium">Ücretsiz Demo Rezervasyonu Yap</button>
             {% endform %}
          </div>
          <div class="rounded-lg border shadow-sm overflow-hidden border-border">
            <div class="aspect-[16/9]">
              <iframe src="{{ section.settings.map_url }}" width="100%" height="100%" frameborder="0" allowfullscreen></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


{% schema %}
{
  "name": "Showroom Details",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "country", "label": "Country", "default": "🇩🇰 Danimarka" },
    { "type": "text", "id": "title", "label": "Title", "default": "Fredericia Genel Merkez ve Showroom" },
    { "type": "textarea", "id": "description", "label": "Description" },
    { "type": "text", "id": "map_url", "label": "Google Maps Embed URL" }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Info Card",
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "SVG Icon" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    }
  ]
}
{% endschema %}
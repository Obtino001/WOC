<section class="container mx-auto px-4 lg:px-8 mt-24">
  <div class="text-center max-w-2xl mx-auto mb-12">
    <p class="font-body text-[10px] uppercase tracking-luxury text-gold mb-4">{{ section.settings.subheading }}</p>
    <h2 class="font-display text-3xl md:text-4xl font-light text-foreground mb-4">{{ section.settings.heading }}</h2>
    <p class="font-body text-sm text-muted-foreground">{{ section.settings.description }}</p>
  </div>
  
  <div class="grid md:grid-cols-3 gap-6">
    {% for block in section.blocks %}
      <div class="relative rounded-xl border {{ block.settings.color_scheme }} p-8 backdrop-blur-sm" {{ block.shopify_attributes }}>
        <div class="w-6 h-6 text-gold mb-4 [&>svg]:w-full [&>svg]:h-full">
           {{ block.settings.icon_svg }}
        </div>
        <p class="font-body text-[10px] uppercase tracking-luxury text-gold mb-2">{{ block.settings.kicker }}</p>
        <h3 class="font-display text-2xl font-light text-foreground mb-3">{{ block.settings.title }}</h3>
        <p class="font-body text-sm text-muted-foreground leading-relaxed mb-6">{{ block.settings.description }}</p>
        
        {% assign form_id = 'ebook_form_' | append: block.id %}
        {% form 'customer', id: form_id, class: 'space-y-3' %}
          {% if form.posted_successfully? %}
            <p class="font-body text-sm text-emerald-600 bg-emerald-50 p-3 rounded-md">Check your email for the download link!</p>
          {% else %}
            <input type="hidden" name="contact[tags]" value="newsletter, ebook-request, {{ block.settings.title | handleize }}">
            <input type="text" name="contact[first_name]" class="flex h-10 w-full rounded-md border border-input px-3 py-2 text-base md:text-sm bg-background/60 focus-visible:ring-gold" placeholder="First name (optional)">
            <input type="email" name="contact[email]" required class="flex h-10 w-full rounded-md border border-input px-3 py-2 text-base md:text-sm bg-background/60 focus-visible:ring-gold" placeholder="Your email">
            <button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium transition-all duration-500 bg-foreground text-background hover:bg-foreground/90 h-10 px-4 py-2 w-full rounded-md">
              {{ section.settings.button_text }}
            </button>
            {{ form.errors | default_errors }}
          {% endif %}
          <p class="text-[10px] text-muted-foreground/70 leading-relaxed">{{ section.settings.disclaimer }}</p>
        {% endform %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Blog E-Books",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Free e-books"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Download our expert guides"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Practical, evidence-based guides written by our experts. Completely free — receive your PDF by email."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get free e-book"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "By downloading, you agree that we may contact you via email. You can always unsubscribe."
    }
  ],
  "blocks": [
    {
      "type": "ebook",
      "name": "E-Book",
      "settings": [
       {
  "type": "select",
  "id": "color_scheme",
  "label": "Card Color Theme",
  "options": [
    { "value": "gold", "label": "Gold" },
    { "value": "forest", "label": "Forest" },
    { "value": "copper", "label": "Copper" }
  ],
  "default": "gold"
},
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "default": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg>"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker/Tagline"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Book Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Book Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog E-Books"
    }
  ]
}
{% endschema %}
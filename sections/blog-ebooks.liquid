<section class="bg-[#0a0a0a] py-24 md:py-32">
  <div class="container mx-auto px-4 lg:px-8">
    
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="font-body text-[10px] uppercase tracking-[0.2em] text-[#c28b24] mb-4">{{ section.settings.subheading }}</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-[#f5f5f0] mb-5">{{ section.settings.heading }}</h2>
      <p class="font-body text-sm text-[#999]">{{ section.settings.description }}</p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {% for block in section.blocks %}
        
        {% assign theme_class = '' %}
        {% assign accent_color = '' %}
        
        {% if block.settings.color_scheme == 'gold' %}
          {% assign theme_class = 'bg-gradient-to-b from-[#c28b24]/10 to-[#151515] border-[#c28b24]/20' %}
          {% assign accent_color = 'text-[#c28b24]' %}
        {% elsif block.settings.color_scheme == 'silver' %}
          {% assign theme_class = 'bg-gradient-to-b from-[#a0a0a0]/15 to-[#151515] border-[#a0a0a0]/20' %}
          {% assign accent_color = 'text-[#a0a0a0]' %}
        {% endif %}

        <div class="rounded-xl border {{ theme_class }} p-8 flex flex-col h-full" {{ block.shopify_attributes }}>
          
          <!-- Icon -->
          <div class="w-6 h-6 {{ accent_color }} mb-5 [&>svg]:w-full [&>svg]:h-full [&>svg]:stroke-[1.5]">
            {{ block.settings.icon_svg }}
          </div>
          
          <!-- Kicker -->
          <p class="font-body text-[10px] uppercase tracking-[0.15em] {{ accent_color }} mb-3">{{ block.settings.kicker }}</p>
          
          <!-- Title -->
          <h3 class="font-display text-2xl font-light text-[#f5f5f0] mb-4">{{ block.settings.title }}</h3>
          
          <!-- Description -->
          <p class="font-body text-sm text-[#999] leading-relaxed mb-8 flex-1">{{ block.settings.description }}</p>
          
          <!-- Form -->
          {% assign form_id = 'ebook_form_' | append: block.id %}
          {% form 'customer', id: form_id, class: 'mt-auto' %}
            
            {% if form.posted_successfully? %}
              <!-- Success State / Download Link -->
              <div class="bg-[#111] border border-emerald-900/50 p-6 rounded-md text-center">
                <p class="font-body text-sm text-emerald-500 mb-4">Teşekkürler! E-kitabınız hazır.</p>
                {% if block.settings.pdf_url != blank %}
                  <a href="{{ block.settings.pdf_url }}" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#d9d9d9] hover:bg-white text-[#111] font-medium text-sm py-3 px-6 rounded-sm transition-colors">
                    PDF'yi İndir
                  </a>
                {% else %}
                  <p class="font-body text-xs text-[#999]">Dosya şu anda kullanılamıyor.</p>
                {% endif %}
              </div>
            {% else %}
              <div class="space-y-3">
                <input type="hidden" name="contact[tags]" value="newsletter, ebook-request, {{ block.settings.title | handleize }}">
                
                <input type="text" name="contact[first_name]" class="w-full h-12 bg-[#111] border border-[#2a2a2a] rounded-sm px-4 py-2 font-body text-sm text-[#f5f5f0] placeholder:text-[#666] focus:outline-none focus:border-[#666] transition-colors" placeholder="First name (optional)">
                
                <input type="email" name="contact[email]" required class="w-full h-12 bg-[#111] border border-[#2a2a2a] rounded-sm px-4 py-2 font-body text-sm text-[#f5f5f0] placeholder:text-[#666] focus:outline-none focus:border-[#666] transition-colors" placeholder="Your email">
                
                <button type="submit" class="w-full h-12 mt-1 bg-[#d9d9d9] hover:bg-white text-[#111] font-body font-medium text-sm px-4 rounded-sm transition-colors flex items-center justify-center">
                  {{ section.settings.button_text }}
                </button>
                
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
            
            <!-- Disclaimer -->
            <p class="font-body text-[9px] text-[#666] leading-relaxed mt-5">{{ section.settings.disclaimer }}</p>
            
          {% endform %}
        </div>
      {% endfor %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Blog E-Books (Dark)",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "FREE E-BOOKS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Download our expert guides"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Practical, evidence-based guides written by our experts. Completely free — receive your PDF by email."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get free e-book"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "By downloading, you agree that we may contact you via email. You can always unsubscribe."
    }
  ],
  "blocks": [
    {
      "type": "ebook",
      "name": "E-Book",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "color_scheme",
          "label": "Card Theme",
          "options": [
            { "value": "gold", "label": "Gold/Bronze" },
            { "value": "silver", "label": "Silver/Grey" }
          ],
          "default": "gold"
        },
        {
          "type": "url",
          "id": "pdf_url",
          "label": "PDF File URL",
          "info": "Upload your PDF to Settings > Files in Shopify, then paste the link here. This link appears after the user submits their email."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "default": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20\"></path></svg>"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker/Tagline",
          "default": "HOW TO CHOOSE THE RIGHT MASSAGE CHAIR"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Book Title",
          "default": "The Massage Chair Guide"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Book Description",
          "default": "50+ page guide on XD technology, health effects, financing, and what to look for."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog E-Books (Dark)",
      "blocks": [
        {
          "type": "ebook",
          "settings": {
            "color_scheme": "gold",
            "kicker": "HOW TO CHOOSE THE RIGHT MASSAGE CHAIR",
            "title": "The Massage Chair Guide",
            "description": "50+ page guide on XD technology, health effects, financing, and what to look for."
          }
        },
        {
          "type": "ebook",
          "settings": {
            "color_scheme": "silver",
            "kicker": "AI SLEEP TECHNOLOGY EXPLAINED",
            "title": "Smart Sleep Guide",
            "description": "Complete introduction to SOVESYSTEM, SYNTHERA AI, and how to design the perfect sleep environment."
          }
        },
        {
          "type": "ebook",
          "settings": {
            "color_scheme": "gold",
            "kicker": "ANTI-AGING AT HOME",
            "title": "LED Beauty Guide",
            "description": "The science behind red, yellow, and infrared LED light — and how to achieve clinic-level results."
          }
        }
      ]
    }
  ]
}
{% endschema %}
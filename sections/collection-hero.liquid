<section class="relative min-h-[70vh] flex items-center overflow-hidden">
  <div class="absolute inset-0">
    {% if section.settings.background_image != blank %}
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: class: 'w-full h-full object-cover', loading: 'eager', preload: true }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover' }}
    {% endif %}
    <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/70 via-neutral-900/40 to-transparent"></div>
  </div>
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex-1 flex flex-col justify-end pb-12 lg:pb-16 w-full pt-10">
    <div class="max-w-xl">
      <div class="flex items-center gap-2 mb-4">
        <div class="flex">
          {% for i in (1..5) %}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 fill-copper text-copper"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
          {% endfor %}
        </div>
        <span class="font-body text-sm text-white/80">{{ section.settings.rating_text }}</span>
      </div>
      
      <h1 class="font-body text-3xl md:text-5xl lg:text-6xl font-bold text-white mb-3 leading-[1.1] uppercase">{{ section.settings.heading | default: collection.title }}</h1>
      <p class="font-body text-base md:text-lg text-white/70 mb-3 uppercase tracking-[0.2em]">{{ section.settings.subheading }}</p>
      
      <div class="flex flex-col sm:flex-row gap-3 mb-6">
        {% if section.settings.button_1_text != blank %}
          <a href="{{ section.settings.button_1_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-copper hover:bg-copper-hover text-white font-body font-bold text-sm px-8 py-4 h-auto uppercase tracking-[0.15em] rounded-lg transition-all duration-500">
            {{ section.settings.button_1_text }}
          </a>
        {% endif %}
        {% if section.settings.button_2_text != blank %}
          <a href="{{ section.settings.button_2_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap bg-white/10 backdrop-blur-sm border border-white/30 text-white hover:bg-white/20 font-body font-bold text-sm px-8 py-4 h-auto uppercase tracking-[0.15em] rounded-lg transition-all duration-500">
            {{ section.settings.button_2_text }}
          </a>
        {% endif %}
      </div>
      
      <div class="flex items-center gap-6 text-white/60 font-body text-xs">
        <span>{{ section.settings.guarantee_1 }}</span>
        <span>{{ section.settings.guarantee_2 }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4,9/5 baseret på +1.100 anmeldelser"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "+30.000 glade kunder"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Primary Button Text",
      "default": "SE ALLE PRODUKTER 👉"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary Button Text",
      "default": "BESTSELLERS 👉"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "guarantee_1",
      "label": "Guarantee 1",
      "default": "🛡️ Prøv risikofrit"
    },
    {
      "type": "text",
      "id": "guarantee_2",
      "label": "Guarantee 2",
      "default": "🚀 Lynhurtig levering"
    }
  ],
  "presets": [
    {
      "name": "Collection Hero"
    }
  ]
}
{% endschema %}

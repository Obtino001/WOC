<section class="relative overflow-hidden">
  <!-- Top Block: Editorial Doctor Quote -->
  <div class="bg-card border-t border-border">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 items-stretch">
        
        <!-- Doctor Image -->
        <div class="lg:col-span-2 relative min-h-[400px] lg:min-h-[500px]">
          {%- if section.settings.doctor_image != blank -%}
            <img
              src="{{ section.settings.doctor_image | image_url: width: 800 }}"
              alt="{{ section.settings.doctor_name }}"
              class="absolute inset-0 w-full h-full object-cover object-top"
              style="width: 100%; height: 100%; object-fit: cover; object-position: top;"
              loading="lazy"
            >
          {%- else -%}
            <div class="absolute inset-0 bg-zinc-800 flex items-center justify-center text-gold/30">Læge Profilbillede</div>
          {%- endif -%}
          <!-- Gradients overlay to bleed with background -->
          <div class="absolute inset-0 bg-gradient-to-r from-transparent to-card/85 hidden lg:block"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-card via-transparent to-transparent lg:hidden"></div>
        </div>

        <!-- Quote Content -->
        <div class="lg:col-span-3 flex flex-col justify-center py-16 lg:py-24 lg:pl-16">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-8 h-[1px] bg-forest"></div>
            <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-forest">
              {{ section.settings.label }}
            </p>
          </div>

          <h2 class="woc-display-font text-3xl md:text-4xl lg:text-5xl font-light text-foreground leading-[1.15] mb-10">
            {{ section.settings.heading }}
            <span class="text-forest italic block mt-1">{{ section.settings.heading_accent }}</span>
          </h2>

          <blockquote class="mb-10">
            <p class="woc-display-font text-lg md:text-xl italic text-foreground/60 leading-relaxed">
              &ldquo;{{ section.settings.quote }}&rdquo;
            </p>
          </blockquote>

          <div class="flex items-center gap-4">
            <div class="w-[3px] h-10 bg-forest/40"></div>
            <div>
              <p class="font-body text-sm font-medium text-foreground">
                {{ section.settings.doctor_name }}
              </p>
              <p class="font-body text-xs text-muted-foreground">
                {{ section.settings.doctor_title }}
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom Block: Benefits Grid -->
  <div class="bg-background border-t border-border">
    <div class="px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      
      <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold text-center mb-12">
        {{ section.settings.benefits_label }}
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-5">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            
            {%- assign is_gold = block.settings.accent -%}
            <div
              class="group relative border rounded-none p-6 lg:p-7 text-center transition-all duration-500 hover:scale-[1.02] cursor-default overflow-hidden
                {% if is_gold == 'gold' %}bg-gradient-to-br from-gold/20 to-gold/5 border-gold/30 hover:border-gold/50{% else %}bg-gradient-to-br from-forest/20 to-forest/5 border-forest/30 hover:border-forest/50{% endif %}"
              {{ block.shopify_attributes }}
            >
              <!-- Glow line top effect -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-0 group-hover:w-full h-[2px] bg-gradient-to-r from-transparent {% if is_gold == 'gold' %}via-gold/60{% else %}via-forest/60{% endif %} to-transparent transition-all duration-700"></div>

              <!-- Number watermark -->
              <span class="absolute top-3 right-4 woc-display-font text-[40px] font-light leading-none select-none transition-colors duration-500
                {% if is_gold == 'gold' %}text-gold/15 group-hover:text-gold/30{% else %}text-forest/15 group-hover:text-forest/30{% endif %}">
                {{ forloop.index | prepend: '0' | slice: -2, 2 }}
              </span>

              <!-- Icon -->
              <div class="mx-auto mb-4 w-11 h-11 flex items-center justify-center rounded-full transition-all duration-500
                {% if is_gold == 'gold' %}bg-gold/15 group-hover:bg-gold/25{% else %}bg-forest/15 group-hover:bg-forest/25{% endif %}">
                
                <span class="{% if is_gold == 'gold' %}text-gold{% else %}text-forest{% endif %} shrink-0 flex items-center justify-center">
                  {%- if block.settings.custom_icon_svg != blank -%}
                    {{ block.settings.custom_icon_svg }}
                  {%- else -%}
                    {%- case block.settings.icon -%}
                      {%- when 'pulse' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
                      {%- when 'bone' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M5 5h14M5 19h14"></path></svg>
                      {%- when 'droplet' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-11-7-11S5 10.7 5 15a7 7 0 0 0 7 7z"></path></svg>
                      {%- when 'stretch' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 3-5 5 5 5M9 21l5-5-5-5"></path></svg>
                      {%- when 'moon' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
                      {%- when 'brain' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-3.12 3.02 3.02 0 0 1 0-3.88 2.5 2.5 0 0 1 0-3.12A2.5 2.5 0 0 1 9.5 2Z"></path><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-3.12 3.02 3.02 0 0 0 0-3.88 2.5 2.5 0 0 0 0-3.12A2.5 2.5 0 0 0 14.5 2Z"></path></svg>
                      {%- when 'shield' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                      {%- when 'alignment' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" y1="6" x2="3" y2="6"></line><line x1="21" y1="12" x2="3" y2="12"></line><line x1="21" y1="18" x2="3" y2="18"></line></svg>
                      {%- when 'circle' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="1"></circle></svg>
                      {%- else -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
                    {%- endcase -%}
                  {%- endif -%}
                </span>

              </div>

              <!-- Text -->
              <p class="font-body text-[13px] font-semibold leading-snug
                {% if is_gold == 'gold' %}text-gold{% else %}text-forest{% endif %}">
                {{ block.settings.text }}
              </p>
            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC Doctor Endorsement",
  "settings": [
    {
      "type": "image_picker",
      "id": "doctor_image",
      "label": "Doctor Profile Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "SUNDHEDSFAGLIG ANBEFALING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Medicinsk Godkendt Teknologi",
      "default": "Wellness understøttet af"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading Accent (Italic Forest)",
      "default": "Sundhedsfaglig Ekspertise"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Doctor Quote Statement",
      "default": "Regelmæssig brug af dybdegående massage og infrarød varmeterapi kan bidrage markant til øget blodcirkulation, muskelrestitution og lindring af kroniske spændinger. Teknologien understøtter kroppens naturlige helingsprocesser og fremmer dyb mental afslapning."
    },
    {
      "type": "text",
      "id": "doctor_name",
      "label": "Doctor Name",
      "default": "Dr. Carsten Rosendahl"
    },
    {
      "type": "text",
      "id": "doctor_title",
      "label": "Doctor Title / Credentials",
      "default": "Læge & Ekspert i Wellness-Teknologi"
    },
    {
      "type": "text",
      "id": "benefits_label",
      "label": "Benefits Subtitle",
      "default": "10 DOKUMENTEREDE FORDELE VED VORES VELVÆRETEKNOLOGI"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit text",
          "default": "Lindring af muskel- og ledsmerter"
        },
        {
          "type": "select",
          "id": "accent",
          "label": "Card Accent Style",
          "options": [
            { "value": "gold", "label": "Gold Theme" },
            { "value": "forest", "label": "Forest Green Theme" }
          ],
          "default": "gold"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon Graphic",
          "options": [
            { "value": "pulse", "label": "Heart Pulse" },
            { "value": "bone", "label": "Led / Gigt Bones" },
            { "value": "droplet", "label": "Sweat Droplet" },
            { "value": "stretch", "label": "Stretch / Flex" },
            { "value": "moon", "label": "Sleep Moon" },
            { "value": "brain", "label": "Stress Brain" },
            { "value": "shield", "label": "Immune Shield" },
            { "value": "alignment", "label": "Posture Alignment" },
            { "value": "circle", "label": "Cells / Circle" }
          ],
          "default": "pulse"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG XML code here to override the dropdown icon selection."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Doctor Endorsement",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Dybdegående muskelrestitution", "accent": "gold", "icon": "pulse" } },
        { "type": "benefit", "settings": { "text": "Forbedret blodcirkulation", "accent": "forest", "icon": "alignment" } },
        { "type": "benefit", "settings": { "text": "Lindring af gigt- & ledsmerter", "accent": "gold", "icon": "bone" } },
        { "type": "benefit", "settings": { "text": "Effektiv afgiftning (Sved)", "accent": "forest", "icon": "droplet" } },
        { "type": "benefit", "settings": { "text": "Øget smidighed & fleksibilitet", "accent": "gold", "icon": "stretch" } },
        { "type": "benefit", "settings": { "text": "Dybere søvn & bedre ro", "accent": "forest", "icon": "moon" } },
        { "type": "benefit", "settings": { "text": "Stress- og spændingsreduktion", "accent": "gold", "icon": "brain" } },
        { "type": "benefit", "settings": { "text": "Styrket immunforsvar", "accent": "forest", "icon": "shield" } },
        { "type": "benefit", "settings": { "text": "Forbedret kropsholdning", "accent": "gold", "icon": "alignment" } },
        { "type": "benefit", "settings": { "text": "Cellefornyelse & smuk hud", "accent": "forest", "icon": "circle" } }
      ]
    }
  ]
}
{% endschema %}

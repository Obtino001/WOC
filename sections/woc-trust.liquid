<section class="py-10 bg-charcoal border-y border-border">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-0">

      <!-- Review Badges (Left Side) -->
      <div class="flex flex-wrap sm:flex-nowrap items-center gap-6 lg:gap-8 pr-0 lg:pr-10 lg:border-r border-border shrink-0 justify-center w-full lg:w-auto">
        
        <!-- Google Reviews -->
        <a
          href="{{ section.settings.google_url }}"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 group transition-transform duration-300 hover:scale-[1.02]"
        >
          <div class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center shrink-0">
            <svg viewBox="0 0 24 24" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
          <div class="flex flex-col">
            <div class="flex items-center gap-0.5">
              {%- for i in (1..5) -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-[#FBBC05]"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" /></svg>
              {%- endfor -%}
            </div>
            <div class="flex items-center gap-1 mt-0.5">
              <span class="font-body text-xs font-semibold text-foreground">{{ section.settings.google_score }}</span>
              <span class="font-body text-[10px] text-muted-foreground">• {{ section.settings.google_count }} reviews</span>
            </div>
            <span class="font-body text-[9px] text-muted-foreground/60 group-hover:text-foreground/60 transition-colors">Google Reviews</span>
          </div>
        </a>

        <!-- Divider -->
        <div class="hidden sm:block w-px h-12 bg-border"></div>

        <!-- Trustpilot -->
        <a
          href="{{ section.settings.trustpilot_url }}"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 group transition-transform duration-300 hover:scale-[1.02]"
        >
          <div class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#00b67a]"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" /></svg>
          </div>
          <div class="flex flex-col">
            <div class="flex items-center gap-0.5">
              {%- for i in (1..5) -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-[#00b67a]"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" /></svg>
              {%- endfor -%}
            </div>
            <div class="flex items-center gap-1 mt-0.5">
              <span class="font-body text-xs font-semibold text-foreground">{{ section.settings.trustpilot_score }}</span>
              <span class="font-body text-[10px] text-muted-foreground">• {{ section.settings.trustpilot_count }} reviews</span>
            </div>
            <span class="font-body text-[9px] text-[#00b67a]/80 group-hover:text-[#00b67a] transition-colors">Trustpilot Reviews</span>
          </div>
        </a>
      </div>

      <!-- Trust Stats (Right Side Grid) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8 flex-1 w-full lg:pl-10">
        {%- for block in section.blocks -%}
          <div class="text-center flex flex-col items-center gap-1.5" {{ block.shopify_attributes }}>
            
            <!-- Icon Render -->
            <span class="text-gold shrink-0">
              {%- if block.settings.custom_icon_svg != blank -%}
                {{ block.settings.custom_icon_svg }}
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'shield' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 11 2 2 4-4"></path></svg>
                  {%- when 'store' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"></path><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"></path><path d="M2 7h20"></path><path d="M3 12h18"></path></svg>
                  {%- when 'users' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                  {%- when 'support' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
                {%- endcase -%}
              {%- endif -%}
            </span>

            <p class="woc-display-font text-2xl lg:text-3xl font-light text-gold">{{ block.settings.value }}</p>
            <p class="font-body text-[9px] font-light uppercase tracking-luxury text-muted-foreground">{{ block.settings.label }}</p>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "WOC Trust Stats",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "google_score",
      "label": "Google Rating Score",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "google_count",
      "label": "Google Review Count",
      "default": "847"
    },
    {
      "type": "text",
      "id": "google_url",
      "label": "Google Reviews Link",
      "default": "https://google.com"
    },
    {
      "type": "text",
      "id": "trustpilot_score",
      "label": "Trustpilot Rating Score",
      "default": "4.6"
    },
    {
      "type": "text",
      "id": "trustpilot_count",
      "label": "Trustpilot Review Count",
      "default": "1.243"
    },
    {
      "type": "text",
      "id": "trustpilot_url",
      "label": "Trustpilot Link",
      "default": "https://trustpilot.com"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Trust Metric",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield Check" },
            { "value": "store", "label": "Showroom Store" },
            { "value": "users", "label": "Clients / Users" },
            { "value": "support", "label": "Support Headset" }
          ],
          "default": "shield"
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG XML code here to override the dropdown icon selection."
        },
        {
          "type": "text",
          "id": "value",
          "label": "Highlight Value",
          "default": "5"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Description Label",
          "default": "Års Garanti"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WOC Trust Stats",
      "blocks": [
        { "type": "stat", "settings": { "icon": "shield", "value": "5", "label": "Års Garanti" } },
        { "type": "stat", "settings": { "icon": "store", "value": "20+", "label": "Europæiske Showrooms" } },
        { "type": "stat", "settings": { "icon": "users", "value": "50.000+", "label": "Glade Kunder" } },
        { "type": "stat", "settings": { "icon": "support", "value": "24/7", "label": "Personlig Support" } }
      ]
    }
  ]
}
{% endschema %}

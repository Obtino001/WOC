<section class="color-{{ section.settings.color_scheme }} gradient border-y border-border">
  <div class="container mx-auto px-4 py-8 flex flex-wrap justify-center gap-10 md:gap-16">
    {% for block in section.blocks %}
      <div class="flex items-center gap-2.5" {{ block.shopify_attributes }}>
        <div class="[&>svg]:w-4 [&>svg]:h-4 [&>svg]:text-muted-foreground/60">
          {{ block.settings.icon_svg }}
        </div>
        <span class="font-body text-[10px] uppercase tracking-[0.2em] text-muted-foreground">{{ block.settings.text }}</span>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "SED Guarantees Bar",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "guarantee",
      "name": "Guarantee",
      "limit": 4,
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "SED Guarantees Bar" }
  ]
}
{% endschema %}

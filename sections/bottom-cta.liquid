{% schema %}
{
  "name": "Bottom CTA",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Dönüşümünüze Hazır mısınız?" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "HEMEN AL — ₺13.052" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Bottom CTA" }]
}
{% endschema %}

<section class="bg-neutral-900 text-white">
  <div class="container mx-auto px-4 py-16 lg:py-20 text-center">
    <h2 class="text-3xl md:text-4xl font-light tracking-wider mb-4">{{ section.settings.title }}</h2>
    <p class="text-neutral-400 text-sm mb-8 max-w-lg mx-auto" style="font-family: system-ui, sans-serif">
      {{ section.settings.text }}
    </p>
    <a href="{{ section.settings.button_link }}" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium transition-all bg-white text-neutral-900 hover:bg-neutral-100 rounded-sm tracking-[0.2em] uppercase h-12 px-10" style="font-family: system-ui, sans-serif">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
      {{ section.settings.button_text }}
    </a>
  </div>
</section>

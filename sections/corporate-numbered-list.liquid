<section class="relative overflow-hidden" style="background-color: #f7f4ed; color: #261d17;">
  <div class="pointer-events-none absolute -top-40 -left-40 w-[500px] h-[500px] rounded-full blur-3xl" style="background-color: rgba(198, 76, 57, 0.06);"></div>
  <div class="pointer-events-none absolute top-1/3 -right-40 w-[600px] h-[600px] rounded-full blur-3xl" style="background-color: rgba(209, 154, 71, 0.07);"></div>

  {%- comment -%} ── HERO HEADER ── {%- endcomment -%}
  <div class="container mx-auto px-4 lg:px-8 pt-24 pb-16 lg:pt-32 lg:pb-20 relative">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      {%- comment -%} Left column — text {%- endcomment -%}
      <div class="lg:col-span-7 order-2 lg:order-1">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px w-12" style="background-color: #a64030;"></div>
          <span class="font-body text-xs font-semibold tracking-[0.25em] uppercase" style="color: #a64030;">{{ section.settings.subheading }}</span>
        </div>

        <h2 class="font-display text-[clamp(2.5rem,6vw,5rem)] font-bold leading-[1.02] tracking-tight" style="color: #261d17;">
          {{ section.settings.heading | newline_to_br }}
        </h2>

        <div class="mt-10 flex items-center gap-6">
          <div class="flex -space-x-2">
            {% for block in section.blocks %}
              {% if block.type == 'avatar' %}
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 100 | image_tag: class: 'w-9 h-9 rounded-full border-2 object-cover', style: 'border-color: #f7f4ed;' }}
                {% else %}
                  <div class="w-9 h-9 rounded-full border-2" style="border-color: #f7f4ed; background-color: #d4cbc4;"></div>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>
          <p class="font-body text-sm max-w-xs" style="color: #52463d;">{{ section.settings.avatar_text }}</p>
        </div>
      </div>

      {%- comment -%} Right column — image + floating stat {%- endcomment -%}
      <div class="lg:col-span-5 order-1 lg:order-2 relative">
        <div class="relative aspect-[4/5] overflow-hidden rounded-sm shadow-[0_30px_80px_-20px_rgba(0,0,0,0.25)]">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 1024 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy' }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-200' }}
          {% endif %}
          <div class="absolute inset-0 bg-gradient-to-t from-black/25 via-transparent to-transparent"></div>
        </div>

        <div class="absolute -bottom-6 -left-6 lg:-left-12 backdrop-blur-sm px-6 py-5 shadow-xl rounded-sm max-w-[220px]" style="background-color: rgba(255,255,255,0.97); border: 1px solid #d4cbc4;">
          <p class="font-display text-3xl font-bold leading-none" style="color: #a64030;">{{ section.settings.stat_number }}</p>
          <p class="font-body text-xs mt-2 leading-relaxed" style="color: #52463d;">{{ section.settings.stat_text }}</p>
        </div>
      </div>

    </div>
  </div>

  {%- comment -%} ── NUMBERED ROWS ── {%- endcomment -%}
  <div class="container mx-auto px-4 lg:px-8 pb-24">
    <div class="max-w-6xl mx-auto">
      {% for block in section.blocks %}
        {% if block.type == 'insight' %}
          <div class="relative group" style="border-top: 1px solid #d4cbc4; {% if forloop.last %}border-bottom: 1px solid #d4cbc4;{% endif %}" {{ block.shopify_attributes }}>

            <div class="absolute left-0 top-0 bottom-0 w-[2px] origin-top transition-transform duration-700 ease-out {% if block.settings.highlight %}scale-y-100{% else %}scale-y-0 group-hover:scale-y-100{% endif %}" style="background-color: #a64030;"></div>

            <div class="grid grid-cols-12 gap-4 md:gap-8 items-center px-2 md:px-6 py-10 md:py-14">
              <div class="col-span-2 md:col-span-1">
                <span class="font-display text-4xl md:text-6xl font-light leading-none tracking-tight transition-colors duration-500{% if block.settings.highlight %}" style="color: #a64030; font-feature-settings: 'lnum';"{% else %}" style="font-feature-settings: 'lnum';"{% endif %}>{{ forloop.index | prepend: '0' }}</span>
              </div>

              <div class="col-span-10 {% if block.settings.large_stat != blank %}md:col-span-7{% else %}md:col-span-11{% endif %} min-w-0">
                <h3 class="font-display text-2xl md:text-3xl lg:text-[34px] font-semibold leading-[1.15] tracking-tight whitespace-pre-line" style="color: {% if block.settings.highlight %}#a64030{% else %}#261d17{% endif %};">{{ block.settings.title }}</h3>
                {% if block.settings.subtitle != blank %}
                  <p class="font-body text-sm md:text-base mt-4 max-w-2xl leading-relaxed" style="color: #52463d;">{{ block.settings.subtitle }}</p>
                {% endif %}
              </div>

              {% if block.settings.large_stat != blank %}
                <div class="col-span-12 md:col-span-4 flex items-center justify-start md:justify-end mt-4 md:mt-0">
                  <div class="hidden md:block w-px h-20 mr-8" style="background-color: #d4cbc4;"></div>
                  <div class="text-left md:text-right">
                    <span class="font-display text-6xl md:text-7xl lg:text-8xl font-light tabular-nums leading-none tracking-tight" style="color: #a64030;">
                      {{ block.settings.large_stat }}{% if block.settings.stat_suffix != blank %}<span class="text-3xl md:text-4xl lg:text-5xl font-light ml-0.5" style="color: #a64030; opacity: 0.6;">{{ block.settings.stat_suffix }}</span>{% endif %}
                    </span>
                    <p class="font-body text-[10px] tracking-[0.28em] uppercase mt-3 font-semibold" style="color: #7e7167;">{{ block.settings.stat_label }}</p>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} ── LOGO GRID ── {%- endcomment -%}
  <div class="container mx-auto px-4 lg:px-8 pb-24 pt-16" style="border-top: 1px solid #d4cbc4;">
    <p class="font-body text-[11px] font-semibold tracking-[0.3em] uppercase text-center mb-10" style="color: #7e7167;">{{ section.settings.logos_label }}</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-8 gap-y-10 items-center justify-items-center">

      {%- comment -%} Loop through logo blocks {%- endcomment -%}
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]" {{ block.shopify_attributes }}>
            {% if block.settings.logo_image != blank %}
              {{ block.settings.logo_image | image_url: width: 300 | image_tag: class: 'max-h-full max-w-full object-contain', loading: 'lazy', alt: block.settings.logo_alt }}
            {% elsif block.settings.logo_url != blank %}
              <img src="{{ block.settings.logo_url }}" alt="{{ block.settings.logo_alt }}" loading="lazy" class="max-h-full max-w-full object-contain">
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {%- comment -%} Hardcoded fallback logos — always shown if no logo blocks are added {%- endcomment -%}
      {% assign has_logo_blocks = false %}
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}{% assign has_logo_blocks = true %}{% endif %}
      {% endfor %}

      {% unless has_logo_blocks %}
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'nordea.png' | asset_url }}" alt="Nordea" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'novo-nordisk.png' | asset_url }}" alt="Novo Nordisk" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'carlsberg.png' | asset_url }}" alt="Carlsberg" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'lego.png' | asset_url }}" alt="LEGO" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'danfoss.png' | asset_url }}" alt="Danfoss" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'ikea.png' | asset_url }}" alt="IKEA" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'seb.png' | asset_url }}" alt="SEB" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'telenor.png' | asset_url }}" alt="Telenor" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'hedin-bil.jpg' | asset_url }}" alt="Hedin Bil" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'rams.png' | asset_url }}" alt="RAMS" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'galatasaray.jpg' | asset_url }}" alt="Galatasaray" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="{{ 'man.jpg' | asset_url }}" alt="MAN" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="data:image/png;base64," alt="Maersk" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
        <div class="flex h-20 w-40 items-center justify-center transition-all duration-300 hover:scale-[1.05]">
          <img src="data:image/png;base64," alt="Volvo" loading="lazy" class="max-h-full max-w-full object-contain">
        </div>
      {% endunless %}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Numbered Insights",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The problem is real"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Use a newline to split into two lines. Wrap italic text in <i> tags.",
      "default": "From fatigue\n<i>to loss</i>"
    },
    {
      "type": "text",
      "id": "avatar_text",
      "label": "Avatar Caption",
      "default": "They trust prevention"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "stat_number",
      "label": "Floating Stat Number",
      "default": "76%"
    },
    {
      "type": "textarea",
      "id": "stat_text",
      "label": "Floating Stat Text",
      "default": "of Danish employees experience physical discomfort at the workplace"
    },
    {
      "type": "text",
      "id": "logos_label",
      "label": "Logos Section Label",
      "default": "They trust prevention"
    }
  ],
  "blocks": [
    {
      "type": "avatar",
      "name": "Avatar Image",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Avatar Image"
        }
      ]
    },
    {
      "type": "insight",
      "name": "Insight Row",
      "settings": [
        {
          "type": "textarea",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "large_stat",
          "label": "Large Statistic (Optional)",
          "info": "e.g. 26"
        },
        {
          "type": "text",
          "id": "stat_suffix",
          "label": "Statistic Suffix (Optional)",
          "info": "e.g. M or +"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Statistic Label"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight Row (Red Text & Line)",
          "default": false
        }
      ]
    },
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "logo_url",
          "label": "Logo URL (External, if not using image picker)"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Logo Alt Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Numbered Insights",
      "blocks": [
        { "type": "avatar" },
        { "type": "avatar" },
        { "type": "avatar" },
        { "type": "avatar" },
        { "type": "insight", "settings": { "title": "Your employees are tired", "subtitle": "You notice it too late" } },
        { "type": "insight", "settings": { "title": "Fatigue turns into absence", "subtitle": "Actually 26 million sick days a year", "large_stat": "26", "stat_suffix": "M", "stat_label": "sick days / year" } },
        { "type": "insight", "settings": { "title": "Absence is expensive.\nReplacement is more expensive.", "subtitle": "850,000 resignations a year", "large_stat": "850", "stat_suffix": "k", "stat_label": "resignations / year" } },
        { "type": "insight", "settings": { "title": "Absence is not inevitable.\nReplacement is not random.", "subtitle": "But it can be prevented" } },
        { "type": "insight", "settings": { "title": "Over 250 companies have chosen systematic prevention.", "large_stat": "250", "stat_suffix": "+", "stat_label": "companies", "highlight": true } },
        { "type": "logo", "settings": { "logo_alt": "Nordea" } },
        { "type": "logo", "settings": { "logo_alt": "Novo Nordisk" } },
        { "type": "logo", "settings": { "logo_alt": "Carlsberg" } },
        { "type": "logo", "settings": { "logo_alt": "LEGO" } },
        { "type": "logo", "settings": { "logo_alt": "Danfoss" } },
        { "type": "logo", "settings": { "logo_alt": "Maersk" } },
        { "type": "logo", "settings": { "logo_alt": "IKEA" } },
        { "type": "logo", "settings": { "logo_alt": "Volvo" } },
        { "type": "logo", "settings": { "logo_alt": "SEB" } },
        { "type": "logo", "settings": { "logo_alt": "Telenor" } },
        { "type": "logo", "settings": { "logo_alt": "Hedin Bil" } },
        { "type": "logo", "settings": { "logo_alt": "RAMS" } },
        { "type": "logo", "settings": { "logo_alt": "Renkli" } },
        { "type": "logo", "settings": { "logo_alt": "Galatasaray" } },
        { "type": "logo", "settings": { "logo_alt": "MAN" } }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-background relative overflow-hidden">
  <!-- Background glow effect -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-gold/[0.03] rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex-1 flex flex-col justify-end pb-12 lg:pb-16 w-full pt-40">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="w-8 h-px bg-gold/40"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold">{{ section.settings.kicker }}</p>
        <div class="w-8 h-px bg-gold/40"></div>
      </div>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-5">{{ section.settings.heading }}</h2>
      <p class="font-body text-sm text-muted-foreground max-w-2xl mx-auto leading-relaxed">{{ section.settings.description }}</p>
    </div>

    <!-- Video Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6 mb-20">
      {%- for block in section.blocks -%}
        {%- if block.type == 'video_testimonial' -%}
          {%- assign shopify_video_url = "" -%}
          {%- if block.settings.video != blank -%}
            {%- for source in block.settings.video.sources -%}
              {%- if source.format == 'mp4' -%}
                {%- assign shopify_video_url = source.url -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if shopify_video_url == "" -%}
              {%- assign shopify_video_url = block.settings.video.sources[0].url -%}
            {%- endif -%}
          {%- endif -%}

          <div class="group relative cursor-pointer js-video-testimonial-trigger" 
            {{ block.shopify_attributes }}
            data-video-type="{% if block.settings.video != blank %}shopify{% elsif block.settings.video_url != blank %}{{ block.settings.video_url.type }}{% endif %}"
            data-video-id="{% if block.settings.video_url != blank %}{{ block.settings.video_url.id }}{% endif %}"
            data-video-url="{{ shopify_video_url }}"
          >
            <div class="relative rounded-xl overflow-hidden border border-border/50 hover:border-gold/30 transition-all duration-700 shadow-soft hover:shadow-gold h-full flex flex-col">
              
              <div class="relative aspect-[3/4] overflow-hidden">
                {%- assign cover_image_url = "" -%}
                {%- if block.settings.image != blank -%}
                  {%- assign cover_image_url = block.settings.image | image_url: width: 600 -%}
                {%- elsif block.settings.video_url.type == 'youtube' -%}
                  {%- assign cover_image_url = 'https://i.ytimg.com/vi/' | append: block.settings.video_url.id | append: '/hqdefault.jpg' -%}
                {%- elsif block.settings.video != blank and block.settings.video.preview_image != blank -%}
                  {%- assign cover_image_url = block.settings.video.preview_image | image_url: width: 600 -%}
                {%- endif -%}

                {%- if cover_image_url != "" -%}
                  <img src="{{ cover_image_url }}" alt="{{ block.settings.author | escape }}" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy">
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 bg-muted' }}
                {%- endif -%}
                
                <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-700"></div>
                <div class="absolute inset-0 opacity-[0.03] mix-blend-overlay bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20viewBox%3D%220%200%20256%20256%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cfilter%20id%3D%22noise%22%3E%3CfeTurbulence%20baseFrequency%3D%220.9%22%2F%3E%3C%2Ffilter%3E%3Crect%20width%3D%22100%25%22%20height%3D%22100%25%22%20filter%3D%22url(%23noise)%22%2F%3E%3C%2Fsvg%3E')]"></div>
                
                <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                  <div class="relative">
                    <div class="w-16 h-16 rounded-full bg-gold/10 backdrop-blur-md border border-gold/40 flex items-center justify-center group-hover:bg-gold/20 transition-all duration-500">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play w-6 h-6 text-gold fill-gold/60 ml-0.5"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                    </div>
                    <div class="absolute inset-0 rounded-full border border-gold/20 animate-ping opacity-0 group-hover:opacity-30" style="animation-duration: 2s;"></div>
                  </div>
                </div>

                <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-quote w-5 h-5 text-gold/40"><path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path><path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path></svg>
                </div>
              </div>

              <div class="relative bg-card/80 backdrop-blur-sm p-5 border-t border-border/30 flex-1 flex flex-col justify-end pointer-events-none">
                <div class="flex gap-0.5 mb-2">
                  {% for i in (1..5) %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star w-3 h-3 text-gold fill-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                  {% endfor %}
                </div>
                <p class="font-body text-[13px] text-foreground/60 italic mb-3 leading-relaxed line-clamp-2">"{{ block.settings.quote }}"</p>
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-body text-xs font-semibold text-foreground tracking-wide">{{ block.settings.author }}</p>
                    <p class="font-body text-[10px] text-gold/70 uppercase tracking-widest mt-0.5">{{ block.settings.location_product }}</p>
                  </div>
                  <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play w-3.5 h-3.5 text-gold fill-gold/50 ml-px"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                  </div>
                </div>
              </div>
              
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Text Testimonials Marquees -->
  {% assign text_reviews = section.blocks | where: 'type', 'text_testimonial' %}
  
  {% if text_reviews.size > 0 %}
    <div class="space-y-4 overflow-hidden w-full max-w-[100vw]">
      
      <!-- Row 1 (Left to Right) -->
      <div class="flex w-max animate-marquee hover:[animation-play-state:paused]" style="--marquee-duration: 70s; direction: ltr;">
        {% for i in (1..2) %}
          {% for block in text_reviews %}
            {% assign mod = forloop.index0 | modulo: 3 %}
            {% if mod == 0 %}
              {% render 'testimonial-text-card', block: block %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>

      <!-- Row 2 (Right to Left) -->
      <div class="flex w-max animate-marquee hover:[animation-play-state:paused]" style="--marquee-duration: 65s; direction: rtl;">
        {% for i in (1..2) %}
          {% for block in text_reviews %}
            {% assign mod = forloop.index0 | modulo: 3 %}
            {% if mod == 1 %}
              {% render 'testimonial-text-card', block: block %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>

      <!-- Row 3 (Left to Right) -->
      <div class="flex w-max animate-marquee hover:[animation-play-state:paused]" style="--marquee-duration: 75s; direction: ltr;">
        {% for i in (1..2) %}
          {% for block in text_reviews %}
            {% assign mod = forloop.index0 | modulo: 3 %}
            {% if mod == 2 %}
              {% render 'testimonial-text-card', block: block %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
      
    </div>
  {% endif %}
</section>

<!-- Premium Video Modal Popup -->
<div id="woc-video-modal" class="fixed inset-0 z-[1000] hidden items-center justify-center bg-black/85 backdrop-blur-md p-4 transition-opacity duration-300 opacity-0" aria-hidden="true" role="dialog">
  <div class="relative w-full max-w-4xl bg-card/65 backdrop-blur-xl rounded-2xl border border-gold/15 overflow-hidden shadow-2xl flex flex-col transform scale-95 transition-transform duration-300">
    <button
      id="woc-video-modal-close"
      type="button"
      class="absolute top-4 right-4 text-gold/60 hover:text-gold hover:scale-110 bg-black/40 backdrop-blur-md rounded-full p-2 border border-gold/15 transition-all z-[1010]"
      aria-label="Close modal"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <div class="relative aspect-video w-full bg-black flex items-center justify-center overflow-hidden">
      <div id="woc-modal-video-container" class="w-full h-full"></div>
    </div>
  </div>
</div>

<style>
  #woc-video-modal.is-active {
    opacity: 1;
  }
  #woc-video-modal.is-active > div {
    transform: scale(1);
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const triggers = document.querySelectorAll('.js-video-testimonial-trigger');
  const modal = document.getElementById('woc-video-modal');
  const closeBtn = document.getElementById('woc-video-modal-close');
  const container = document.getElementById('woc-modal-video-container');

  if (!modal || !closeBtn || !container) return;

  function openModal(trigger) {
    const videoType = trigger.getAttribute('data-video-type');
    const videoId = trigger.getAttribute('data-video-id');
    const videoUrl = trigger.getAttribute('data-video-url');

    container.innerHTML = '';

    if (videoType === 'youtube' && videoId) {
      container.innerHTML = `
        <iframe 
          class="w-full h-full border-0 absolute inset-0"
          src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&enablejsapi=1" 
          allow="autoplay; encrypted-media; picture-in-picture" 
          allowfullscreen>
        </iframe>`;
    } else if (videoType === 'vimeo' && videoId) {
      container.innerHTML = `
        <iframe 
          class="w-full h-full border-0 absolute inset-0"
          src="https://player.vimeo.com/video/${videoId}?autoplay=1" 
          allow="autoplay; fullscreen; picture-in-picture" 
          allowfullscreen>
        </iframe>`;
    } else if (videoType === 'shopify' && videoUrl) {
      container.innerHTML = `
        <video 
          class="w-full h-full object-contain absolute inset-0" 
          src="${videoUrl}" 
          controls 
          autoplay 
          playsinline>
        </video>`;
    } else {
      container.innerHTML = `<div class="text-gold font-body text-sm text-center p-8">Video content is unavailable</div>`;
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.offsetHeight; // Force reflow
    modal.classList.add('is-active');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-active');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    
    setTimeout(() => {
      if (!modal.classList.contains('is-active')) {
        modal.classList.remove('flex');
        modal.classList.add('hidden');
        container.innerHTML = '';
      }
    }, 300);
  }

  triggers.forEach(trigger => {
    trigger.addEventListener('click', function() {
      openModal(trigger);
    });
  });

  closeBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
});
</script>
</section>

{% schema %}
{
  "name": "Testimonials Showcase",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 52
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Real Stories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hear From Our Customers"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Real people share their experience with World of Comfort products"
    }
  ],
  "blocks": [
    {
      "type": "video_testimonial",
      "name": "Video Testimonial",
      "limit": 4,
      "settings": [
        {
          "type": "video_url",
          "id": "video_url",
          "label": "External Video URL (YouTube or Vimeo)",
          "accept": [
            "youtube",
            "vimeo"
          ]
        },
        {
          "type": "video",
          "id": "video",
          "label": "Shopify Hosted Video Upload"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Cover Image (Fallback)"
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Short Quote"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        },
        {
          "type": "text",
          "id": "location_product",
          "label": "Location & Product"
        }
      ]
    },
    {
      "type": "text_testimonial",
      "name": "Text Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name"
        },
        {
          "type": "text",
          "id": "location_product",
          "label": "Location & Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Showcase"
    }
  ]
}
{% endschema %}
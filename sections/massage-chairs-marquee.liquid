<div class="woc-section-bar bg-gold text-background overflow-hidden whitespace-nowrap relative z-10">
  <div class="animate-marquee inline-flex gap-0 hover:[animation-play-state:paused]" style="--marquee-duration: 35s;">
    {% for i in (1..3) %}
      <span class="inline-flex items-center gap-8 px-8 font-body text-[11px] font-semibold uppercase tracking-wider">
        {% for block in section.blocks %}
          <span class="contents" {{ block.shopify_attributes }}>
            <span>{{ block.settings.text }}</span>
            <span class="text-background/40">✦</span>
          </span>
        {% endfor %}
      </span>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Banner"
    }
  ]
}
{% endschema %}

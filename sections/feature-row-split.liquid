{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8">

    {% if section.settings.show_header %}
      <div class="text-center mb-16">
        <div class="luxury-line mx-auto mb-8"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold mb-4">{{ section.settings.main_kicker }}</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground leading-[1.05]">{{ section.settings.main_heading | newline_to_br }}</h2>
      </div>
    {% endif %}

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div class="relative overflow-hidden rounded-sm {% if section.settings.image_position == 'right' %}lg:order-2{% endif %}">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'w-full h-auto aspect-[3/2] object-cover', loading: 'lazy', widths: '600,900,1200', sizes: '(min-width: 1024px) 50vw, 100vw' }}
        {% else %}
          {{ 'product-2' | placeholder_svg_tag: 'w-full h-auto aspect-[3/2] object-cover bg-charcoal' }}
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>

        {% if section.settings.image_label != blank %}
          <div class="absolute bottom-6 left-6 right-6">
            <span class="font-display text-lg text-white font-semibold">{{ section.settings.image_label }}</span>
          </div>
        {% endif %}
      </div>

      <div class="{% if section.settings.image_position == 'right' %}lg:order-1{% endif %}">
        {% if section.settings.icon_svg != blank %}
          <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center mb-6 [&>svg]:w-5 [&>svg]:h-5 [&>svg]:text-gold">
            {{ section.settings.icon_svg }}
          </div>
        {% endif %}

        <h3 class="font-display text-2xl md:text-3xl font-semibold text-foreground mb-4 leading-tight">
          {{ section.settings.heading }}
        </h3>
        <p class="font-body text-sm md:text-base text-muted-foreground leading-relaxed max-w-lg">
          {{ section.settings.description }}
        </p>

        {% if section.blocks.size > 0 %}
          <div class="flex items-center gap-6 mt-8">
            {% for block in section.blocks %}
              <div class="flex items-center gap-3" {{ block.shopify_attributes }}>
                <span class="w-8 h-8 rounded-full border-2 border-border" style="background-color: {{ block.settings.color }}"></span>
                <span class="font-body text-sm text-foreground font-medium">{{ block.settings.color_name }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature Row Split",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "info": "t:sections.all.colors.has_cards_info", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 112 },
    { "type": "select", "id": "image_position", "label": "Desktop Image Position", "options": [ {"value": "left", "label": "Left"}, {"value": "right", "label": "Right"} ], "default": "left" },
    { "type": "checkbox", "id": "show_header", "label": "Show Top Header", "default": false },
    { "type": "text", "id": "main_kicker", "label": "Top Header Kicker" },
    { "type": "textarea", "id": "main_heading", "label": "Top Header Heading" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_label", "label": "Image Overlay Label" },
    { "type": "html", "id": "icon_svg", "label": "Icon SVG" },
    { "type": "text", "id": "heading", "label": "Feature Heading" },
    { "type": "textarea", "id": "description", "label": "Feature Description" }
  ],
  "blocks": [
    {
      "type": "color_swatch",
      "name": "Color Swatch",
      "limit": 2,
      "settings": [
        { "type": "color", "id": "color", "label": "Color Hex" },
        { "type": "text", "id": "color_name", "label": "Color Name" }
      ]
    }
  ],
  "presets": [
    { "name": "Feature Row Split" }
  ]
}
{% endschema %}

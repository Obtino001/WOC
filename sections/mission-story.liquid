<article class="py-28 bg-background">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center max-w-6xl mx-auto">
      
      {% capture text_content %}
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-2 h-2 rounded-full bg-gold"></div>
            <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold">{{ section.settings.subheading }}</p>
          </div>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-light text-foreground mb-8 leading-[1.1]">{{ section.settings.heading }}</h2>
          <div class="space-y-5 font-body text-muted-foreground leading-relaxed">
            {{ section.settings.content }}
          </div>
        </div>
      {% endcapture %}

      {% capture image_content %}
        <div>
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: 800 | image_tag: class: 'w-full rounded-xl shadow-elevated', loading: 'lazy' }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'w-full rounded-xl shadow-elevated bg-gray-100 text-gray-300' }}
          {% endif %}
        </div>
      {% endcapture %}

      {% if section.settings.layout == 'left' %}
        {{ image_content }}
        {{ text_content }}
      {% else %}
        {{ text_content }}
        {{ image_content }}
      {% endif %}
      
    </div>
  </div>
</article>
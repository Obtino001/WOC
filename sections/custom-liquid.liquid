{%- liquid
  assign minimal = section.settings.minimal_padding
  if section.settings.custom_liquid contains 'BreadcrumbList'
    assign minimal = true
  endif

  if minimal
    assign pad_top = 12
    assign pad_bottom = 12
  else
    assign pad_top = section.settings.padding_top
    assign pad_bottom = section.settings.padding_bottom
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ pad_top }}px * 0.75);
    padding-bottom: calc({{ pad_bottom }}px * 0.75);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding{% if minimal %} woc-section-minimal{% endif %}">
    {{ section.settings.custom_liquid }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.custom-liquid.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:sections.custom-liquid.settings.custom_liquid.label",
      "info": "t:sections.custom-liquid.settings.custom_liquid.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "minimal_padding",
      "label": "Minimal padding (breadcrumbs, thin strips)",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-liquid.presets.name"
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="section-light overflow-hidden section-{{ section.id }}-padding">
  <div class="container mx-auto px-4 lg:px-8 mb-10">
    <div class="text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="w-2 h-2 rounded-full bg-gold"></div>
        <p class="font-body text-[10px] font-medium uppercase tracking-luxury text-gold">{{ section.settings.kicker }}</p>
      </div>
      <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-light text-foreground">{{ section.settings.heading }}</h2>
    </div>
  </div>
  
  <div class="overflow-hidden">
    <div class="flex animate-marquee" style="animation-duration: {{ section.settings.speed }}s; direction: ltr;">
      {%- for i in (1..3) -%}
        {% for block in section.blocks %}
          <div class="flex-shrink-0 w-[320px] md:w-[360px] bg-card border border-border hover:border-gold/20 transition-colors duration-500 p-6 mx-2" {{ block.shopify_attributes }}>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="lucide lucide-quote w-5 h-5 text-gold/20 mb-3"><path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path><path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path></svg>
            <div class="flex gap-0.5 mb-3">
              {% for star in (1..5) %}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-star w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
              {% endfor %}
            </div>
            <p class="font-body text-xs font-light text-foreground/80 leading-[1.8] mb-4 italic line-clamp-4">"{{ block.settings.quote }}"</p>
            <div>
              <p class="font-display text-xs font-medium text-foreground">{{ block.settings.author }}</p>
              <p class="font-body text-[9px] uppercase tracking-luxury text-muted-foreground">{{ block.settings.product }}</p>
            </div>
          </div>
        {% endfor %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quiz Reviews Marquee",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Customer Experiences" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our customers are saying" },
    { "type": "range", "id": "speed", "min": 10, "max": 100, "step": 5, "unit": "sec", "label": "Animation Speed", "default": 45 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author" },
        { "type": "text", "id": "product", "label": "Product/Location" }
      ]
    }
  ],
  "presets": [
    { "name": "Quiz Reviews Marquee" }
  ]
}
{% endschema %}
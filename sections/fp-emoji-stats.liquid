{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-foreground section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl font-semibold text-background md:text-4xl">{{ section.settings.heading }}</h2>
      <p class="mt-3 font-body text-base text-background/60">{{ section.settings.description }}</p>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-{{ section.blocks.size }} gap-4">
      {% for block in section.blocks %}
        <div class="rounded-xl bg-background/5 border border-background/10 p-5 text-center" {{ block.shopify_attributes }}>
          <span class="text-2xl mb-2 block">{{ block.settings.emoji }}</span>
          <p class="font-body text-sm font-semibold text-background">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FP Emoji Stats",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 80 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "5 documented effects" },
    { "type": "text", "id": "description", "label": "Description", "default": "Noticeable difference in just a few weeks" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Emoji Stat",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji (e.g. 💪)" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [
    { "name": "FP Emoji Stats" }
  ]
}
{% endschema %}
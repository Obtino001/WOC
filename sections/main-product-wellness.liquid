<product-info
  id="MainProduct-{{ section.id }}"
  class="mpw-section section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'section-main-product-wellness.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    #MainProduct-{{ section.id }} {
      --mpw-bg: {{ section.settings.background_color.red }} {{ section.settings.background_color.green }} {{ section.settings.background_color.blue }};
      --mpw-text: {{ section.settings.text_color.red }} {{ section.settings.text_color.green }} {{ section.settings.text_color.blue }};
      --mpw-gallery-bg: {{ section.settings.gallery_background.red }} {{ section.settings.gallery_background.green }} {{ section.settings.gallery_background.blue }};
      --mpw-sale-badge-bg: {{ section.settings.sale_badge_background.red }} {{ section.settings.sale_badge_background.green }} {{ section.settings.sale_badge_background.blue }};
      --mpw-sale-badge-text: {{ section.settings.sale_badge_text_color.red }} {{ section.settings.sale_badge_text_color.green }} {{ section.settings.sale_badge_text_color.blue }};
      --mpw-save-bg: {{ section.settings.save_badge_background.red }} {{ section.settings.save_badge_background.green }} {{ section.settings.save_badge_background.blue }};
      --mpw-save-text: {{ section.settings.save_badge_text_color.red }} {{ section.settings.save_badge_text_color.green }} {{ section.settings.save_badge_text_color.blue }};
      --mpw-atc-bg: {{ section.settings.atc_background.red }} {{ section.settings.atc_background.green }} {{ section.settings.atc_background.blue }};
      --mpw-atc-hover: {{ section.settings.atc_hover_background.red }} {{ section.settings.atc_hover_background.green }} {{ section.settings.atc_hover_background.blue }};
      --mpw-atc-text: {{ section.settings.atc_text_color.red }} {{ section.settings.atc_text_color.green }} {{ section.settings.atc_text_color.blue }};
      --mpw-title: {{ section.settings.title_color.red }} {{ section.settings.title_color.green }} {{ section.settings.title_color.blue }};
      --mpw-muted: {{ section.settings.muted_text_color.red }} {{ section.settings.muted_text_color.green }} {{ section.settings.muted_text_color.blue }};
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'main-product-wellness.js' | asset_url }}" defer="defer"></script>
  <main-product-wellness data-section-id="{{ section.id }}"></main-product-wellness>

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
    <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- endif -%}

  {%- liquid
    assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
    assign selected_variant = product.selected_or_first_available_variant
    assign show_sale_badge = false
    assign sale_badge_pct = 0
    assign sale_badge_display = ''

    if section.settings.show_sale_badge and selected_variant.compare_at_price > selected_variant.price
      assign show_sale_badge = true
      assign discount_amount = selected_variant.compare_at_price | minus: selected_variant.price
      assign sale_badge_pct = discount_amount | times: 100.0 | divided_by: selected_variant.compare_at_price | round

      if section.settings.sale_badge_format == 'amount'
        if settings.currency_code_enabled
          assign money_discount = discount_amount | money_with_currency
        else
          assign money_discount = discount_amount | money
        endif
        assign sale_badge_display = section.settings.sale_badge_prefix | append: ' ' | append: money_discount
      elsif section.settings.sale_badge_prefix != blank
        assign sale_badge_display = section.settings.sale_badge_prefix | append: sale_badge_pct | append: '%'
      else
        assign sale_badge_display = '-' | append: sale_badge_pct | append: '%'
      endif
    endif
  -%}

  <div class="page-width">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="mpw-breadcrumbs" role="navigation" aria-label="{{ 'general.breadcrumbs' | t | default: 'Breadcrumbs' }}">
        <ol class="flex items-center gap-2 list-none p-0 m-0">
          <li><a href="{{ routes.root_url }}">{{ section.settings.breadcrumb_home_label }}</a></li>
          <li class="mpw-breadcrumbs__sep" aria-hidden="true">/</li>
          {%- if collection -%}
            <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>
            <li class="mpw-breadcrumbs__sep" aria-hidden="true">/</li>
          {%- elsif product.collections.size > 0 -%}
            <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
            <li class="mpw-breadcrumbs__sep" aria-hidden="true">/</li>
          {%- endif -%}
          <li><span aria-current="page">{{ product.title }}</span></li>
        </ol>
      </nav>
    {%- endif -%}

    <div class="mpw-grid product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }}{% if product.media.size == 0 %} product--no-media{% endif %}">
      <div class="mpw-media product__media-wrapper">
        {%- if section.settings.show_sale_badge -%}
          <span id="SaleBadge-{{ section.id }}" class="mpw-sale-badge" data-sale-badge{% unless show_sale_badge %} style="display:none"{% endunless %}>
            {%- if show_sale_badge -%}
              {{ sale_badge_display }}
            {%- endif -%}
          </span>
        {%- endif -%}
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <div class="mpw-info product__info-wrapper{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}">
        <section id="ProductInfo-{{ section.id }}" class="product__info-container">
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}

              {%- when 'subtitle' -%}
                {%- assign subtitle_text = block.settings.text -%}
                {%- if subtitle_text == blank -%}
                  {%- assign subtitle_text = product.metafields.descriptors.subtitle.value | default: product.metafields.custom.subtitle.value -%}
                {%- endif -%}
                {%- if subtitle_text != blank -%}
                  <p class="mpw-subtitle" {{ block.shopify_attributes }}>{{ subtitle_text }}</p>
                {%- endif -%}

              {%- when 'title' -%}
                <div {{ block.shopify_attributes }}>
                  <h1 class="mpw-title">{{ product.title | escape }}</h1>
                </div>

              {%- when 'rating' -%}
                <div class="mpw-rating" {{ block.shopify_attributes }}>
                  {%- if product.metafields.reviews.rating.value != blank -%}
                    {% liquid
                      assign rating_decimal = 0
                      assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                      if decimal >= 0.3 and decimal <= 0.7
                        assign rating_decimal = 0.5
                      elsif decimal > 0.7
                        assign rating_decimal = 1
                      endif
                      assign rating_value = product.metafields.reviews.rating.value.rating
                      assign rating_count = product.metafields.reviews.rating_count
                    %}
                    <div class="rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: product.metafields.reviews.rating.value.scale_max }}">
                      <span aria-hidden="true" class="rating-star" style="--rating: {{ rating_value | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
                    </div>
                    <span class="mpw-rating__text">
                      ({{ rating_count }}
                      {%- if block.settings.reviews_label != blank -%} {{ block.settings.reviews_label }}{%- endif -%})
                    </span>
                  {%- else -%}
                    <div class="mpw-rating__stars" aria-hidden="true">
                      {%- for i in (1..5) -%}
                        <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.26l-4.94 2.45.94-5.5-4-3.9 5.53-.8L10 1.5z"/></svg>
                      {%- endfor -%}
                    </div>
                    <span class="mpw-rating__text">
                      ({{ block.settings.fallback_review_count }}
                      {%- if block.settings.reviews_label != blank -%} {{ block.settings.reviews_label }}{%- endif -%})
                    </span>
                  {%- endif -%}
                </div>

              {%- when 'status_badges' -%}
                <div class="mpw-status-badges" {{ block.shopify_attributes }}>
                  {%- if block.settings.show_warranty_badge and block.settings.warranty_text != blank -%}
                    <span class="mpw-warranty-badge">
                      {%- if block.settings.warranty_icon != 'none' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- endif -%}
                      {{ block.settings.warranty_text }}
                    </span>
                  {%- endif -%}

                  {%- if block.settings.show_stock_badge -%}
                    {%- if product.selected_or_first_available_variant.available -%}
                      <span class="mpw-stock-badge mpw-stock-badge--in" id="Inventory-{{ section.id }}" role="status">
                        <span class="mpw-stock-badge__dot" aria-hidden="true"></span>
                        {{ block.settings.in_stock_text }}
                      </span>
                    {%- else -%}
                      <span class="mpw-stock-badge mpw-stock-badge--out" id="Inventory-{{ section.id }}" role="status">
                        <span class="mpw-stock-badge__dot" aria-hidden="true"></span>
                        {{ block.settings.out_of_stock_text }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- when 'description' -%}
                {%- assign description_html = block.settings.text -%}
                {%- if description_html == blank -%}
                  {%- assign description_html = product.description -%}
                {%- endif -%}
                {%- if description_html != blank -%}
                  <div class="mpw-description rte" {{ block.shopify_attributes }}>
                    {{ description_html }}
                  </div>
                {%- endif -%}

              {%- when 'feature_list' -%}
                {%- liquid
                  assign features_str = ''
                  if product.metafields.custom.products_usps != blank
                    assign features_str = product.metafields.custom.products_usps.value | join: ','
                  elsif block.settings.features != blank
                    assign features_str = block.settings.features
                  endif
                -%}
                {%- if features_str != blank -%}
                  {%- assign features = features_str | split: ',' -%}
                  <ul class="mpw-features" {{ block.shopify_attributes }}>
                    {%- for feature in features limit: block.settings.max_items -%}
                      <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                        <span>{{ feature | strip }}</span>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'variant_picker' -%}
                {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}

              {%- when 'price' -%}
                {% render 'price-wellness', product: product, block: block, section_id: section.id %}

              {%- when 'promotion_banner' -%}
                {%- if block.settings.text != blank -%}
                  <div
                    class="mpw-promo mpw-promo--deal"
                    style="background-color: {{ block.settings.background_color }}; color: {{ block.settings.text_color }}; border: 1px solid {{ block.settings.border_color }};"
                    {{ block.shopify_attributes }}
                  >
                    <p class="mpw-promo__headline">
                      {%- if block.settings.show_icon -%}🎉 {% endif -%}{{ block.settings.text }}
                    </p>
                    {%- if block.settings.subtext != blank -%}
                      <p class="mpw-promo__subtext">{{ block.settings.subtext }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              {%- when 'inline_trust' -%}
                <ul class="mpw-inline-trust" {{ block.shopify_attributes }}>
                  {%- for i in (1..3) -%}
                    {%- liquid
                      case i
                        when 1
                          assign trust_text = block.settings.text_1
                        when 2
                          assign trust_text = block.settings.text_2
                        when 3
                          assign trust_text = block.settings.text_3
                      endcase
                    -%}
                    {%- if trust_text != blank -%}
                      <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                        <span>{{ trust_text }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>

              {%- when 'purchase_row' -%}
                {% render 'buy-buttons-wellness', block: block, product: product, product_form_id: product_form_id, section_id: section.id %}

              {%- when 'trust_footer' -%}
                <ul class="mpw-trust-footer" aria-label="{{ block.settings.aria_label }}" {{ block.shopify_attributes }}>
                  {%- for i in (1..3) -%}
                    {%- liquid
                      case i
                        when 1
                          assign item_label = block.settings.label_1
                          assign item_icon = block.settings.icon_1
                        when 2
                          assign item_label = block.settings.label_2
                          assign item_icon = block.settings.icon_2
                        when 3
                          assign item_label = block.settings.label_3
                          assign item_icon = block.settings.icon_3
                      endcase
                    -%}
                    {%- if item_label != blank -%}
                      <li class="mpw-trust-footer__item">
                        <span class="mpw-trust-footer__icon" aria-hidden="true">
                          {%- case item_icon -%}
                            {%- when 'truck' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                            {%- when 'shield' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {%- when 'return' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                          {%- endcase -%}
                        </span>
                        <span class="mpw-trust-footer__label">{{ item_label }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>

              {%- when 'trust_rail' -%}
                <ul class="mpw-trust-rail" aria-label="{{ block.settings.aria_label }}" {{ block.shopify_attributes }}>
                  {%- for i in (1..4) -%}
                    {%- liquid
                      case i
                        when 1
                          assign item_label = block.settings.label_1
                          assign item_sub = block.settings.sub_1
                          assign item_icon = block.settings.icon_1
                        when 2
                          assign item_label = block.settings.label_2
                          assign item_sub = block.settings.sub_2
                          assign item_icon = block.settings.icon_2
                        when 3
                          assign item_label = block.settings.label_3
                          assign item_sub = block.settings.sub_3
                          assign item_icon = block.settings.icon_3
                        when 4
                          assign item_label = block.settings.label_4
                          assign item_sub = block.settings.sub_4
                          assign item_icon = block.settings.icon_4
                      endcase
                    -%}
                    {%- if item_label != blank -%}
                      <li class="mpw-trust-rail__item">
                        <div class="mpw-trust-rail__icon" aria-hidden="true">
                          {%- case item_icon -%}
                            {%- when 'truck' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                            {%- when 'return' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                            {%- when 'card' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                            {%- when 'shield' -%}
                              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            {%- when 'custom' -%}
                              {{ block.settings.custom_icon_svg }}
                          {%- endcase -%}
                        </div>
                        <div>
                          <p class="mpw-trust-rail__label">{{ item_label }}</p>
                          {%- if item_sub != blank -%}
                            <p class="mpw-trust-rail__sub">{{ item_sub }}</p>
                          {%- endif -%}
                        </div>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>

              {%- when 'collapsible_tab' -%}
                <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                  <details id="Details-{{ block.id }}-{{ section.id }}"{% if block.settings.open_by_default %} open{% endif %}>
                    <summary>
                      <div class="summary__title">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                        <h2 class="h4 accordion__title inline-richtext">{{ block.settings.heading | escape }}</h2>
                      </div>
                      <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
                    </summary>
                    <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                      {%- if block.settings.content_style == 'steps' -%}
                        {%- assign steps = block.settings.steps | newline_to_br | split: '<br />' -%}
                        <ol class="mpw-accordion-steps">
                          {%- for step in steps -%}
                            {%- assign step_clean = step | strip -%}
                            {%- if step_clean != blank -%}
                              <li>
                                <span class="mpw-accordion-steps__num">{{ forloop.index }}</span>
                                <span>{{ step_clean }}</span>
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ol>
                      {%- elsif block.settings.content_style == 'checklist' -%}
                        {%- assign items = block.settings.steps | newline_to_br | split: '<br />' -%}
                        <ul class="mpw-accordion-checklist">
                          {%- for item in items -%}
                            {%- assign item_clean = item | strip -%}
                            {%- if item_clean != blank -%}
                              <li>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                                <span>{{ item_clean }}</span>
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      {%- else -%}
                        {{ block.settings.content }}
                        {{ block.settings.page.content }}
                      {%- endif -%}
                    </div>
                  </details>
                </div>

              {%- when 'info_boxes' -%}
                <div class="mpw-info-boxes" {{ block.shopify_attributes }}>
                  {%- if block.settings.box_1_title != blank -%}
                    <div class="mpw-info-box" style="background-color: {{ block.settings.box_background }}; border: 1px solid {{ block.settings.box_border }}; color: {{ block.settings.box_icon_color }};">
                      {%- case block.settings.box_1_icon -%}
                        {%- when 'truck' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'shield' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- endcase -%}
                      <div>
                        <p class="mpw-info-box__title">{{ block.settings.box_1_title }}</p>
                        {%- if block.settings.box_1_subtitle != blank -%}
                          <p class="mpw-info-box__sub">{{ block.settings.box_1_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.box_2_title != blank -%}
                    <div class="mpw-info-box" style="background-color: {{ block.settings.box_background }}; border: 1px solid {{ block.settings.box_border }}; color: {{ block.settings.box_icon_color }};">
                      {%- case block.settings.box_2_icon -%}
                        {%- when 'truck' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        {%- when 'shield' -%}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- endcase -%}
                      <div>
                        <p class="mpw-info-box__title">{{ block.settings.box_2_title }}</p>
                        {%- if block.settings.box_2_subtitle != blank -%}
                          <p class="mpw-info-box__sub">{{ block.settings.box_2_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'custom_liquid' -%}
                <div {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
            {%- endcase -%}
          {%- endfor -%}
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if first_3d_model -%}
      <script type="application/json" id="ProductJSON-{{ product.id }}">{{ product.media | where: 'media_type', 'model' | json }}</script>
      <script src="{{ 'product-model.js' | asset_url }}" defer></script>
    {%- endif -%}

    <script type="application/ld+json">{{ product | structured_data }}</script>
  </div>
</product-info>


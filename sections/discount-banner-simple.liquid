<section class="pt-16 pb-0">
  <div class="mx-auto px-4 lg:px-8 {% if section.settings.page_width == 'full' %}w-full{% elsif section.settings.page_width == 'narrow' %}max-w-5xl{% else %}container{% endif %}">
    <div class="bg-gold/10 border border-gold/20 rounded-xl p-4 mb-6">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-gold flex-shrink-0 mt-0.5"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle></svg>
        <div>
          <p class="font-body text-sm font-semibold text-foreground mb-1">{{ section.settings.title }}</p>
          <div class="flex flex-wrap gap-x-6 gap-y-1">
            <span class="font-body text-xs text-gold">{{ section.settings.condition_text }} &rarr; <strong>{{ section.settings.discount_text }}</strong></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Discount Alert Banner",
  "settings": [
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {"value": "full", "label": "Full Width"},
        {"value": "standard", "label": "Standard Width"},
        {"value": "narrow", "label": "Narrow Width"}
      ],
      "default": "narrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Adet indirimi"
    },
    {
      "type": "text",
      "id": "condition_text",
      "label": "Condition Text",
      "default": "Satın al 2+"
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Discount Amount",
      "default": "-15%"
    }
  ],
  "presets": [{"name": "Discount Alert Banner"}]
}
{% endschema %}
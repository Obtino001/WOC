
  <style>
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-marquee { display: flex; animation: marquee 25s linear infinite; }
  </style>

  <!-- Hero Section -->
  <section class="relative min-h-[80vh] grid lg:grid-cols-2">
    <div class="flex flex-col justify-center px-8 md:px-16 lg:px-20 woc-section-py bg-[#f0eae4]">
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-light text-neutral-800 leading-tight uppercase tracking-[0.05em]">
        {{ section.settings.hero_title }}
      </h1>
      <div class="flex items-center gap-3 mt-10">
        <div class="w-8 h-px bg-gold"></div>
        <p class="font-body text-[11px] uppercase tracking-[0.25em] text-neutral-500">{{ section.settings.hero_subtext }}</p>
      </div>
    </div>
    <div class="relative overflow-hidden min-h-[50vh] lg:min-h-0">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
      {% endif %}
    </div>
  </section>

  <!-- Marquee Awards -->
  <section class="py-12 bg-white overflow-hidden border-y border-neutral-100">
    <div class="animate-marquee">
      <div class="flex items-center gap-12 mx-6">
        {% for block in section.blocks %}
          {% if block.type == 'award_badge' %}
             {{ block.settings.logo | image_url: width: 200 | image_tag: class: 'h-16 md:h-20 object-contain opacity-60' }}
          {% endif %}
        {% endfor %}
      </div>
      <!-- Duplicate for infinite effect -->
      <div class="flex items-center gap-12 mx-6">
        {% for block in section.blocks %}
          {% if block.type == 'award_badge' %}
             {{ block.settings.logo | image_url: width: 200 | image_tag: class: 'h-16 md:h-20 object-contain opacity-60' }}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
  

  <!-- Yearly Awards Container -->
  {% for block in section.blocks %}
    {% if block.type == 'year_group' %}
      <section class="woc-section-py bg-white">
        <div class="container mx-auto px-4 max-w-6xl">
          <div class="mb-14">
            <h2 class="font-display text-7xl md:text-9xl font-extralight text-neutral-100 uppercase tracking-[0.1em]">{{ block.settings.year }}</h2>
            <p class="font-body text-[11px] uppercase tracking-[0.2em] text-gold mt-2">ÖDÜLLER</p>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for child in section.blocks %}
              {% if child.type == 'award_card' and child.settings.parent_year == block.settings.year %}
                <div class="bg-white border border-neutral-100 rounded-xl p-8 hover:shadow-lg transition-shadow duration-500">
                  <div class="text-4xl mb-5">{{ child.settings.emoji }}</div>
                  <p class="font-body text-[10px] uppercase tracking-[0.2em] text-neutral-400 mb-2">{{ child.settings.award_name }}</p>
                  <h3 class="font-display text-lg font-light text-neutral-800 mb-4 leading-snug">{{ child.settings.award_title }}</h3>
                  
                  {% if child.settings.link_url != blank %}
                    <a class="inline-flex items-center gap-1.5 font-body text-[11px] uppercase tracking-[0.15em] text-gold hover:text-neutral-800 transition-colors" href="{{ child.settings.link_url }}">
                      {{ child.settings.link_text }} →
                    </a>
                  {% else %}
                    <span class="font-body text-[11px] uppercase tracking-[0.15em] text-neutral-400">{{ child.settings.brand }}</span>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </section>
    {% endif %}
  {% endfor %}


{% schema %}
{
  "name": "Awards Layout",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "hero_title", "label": "Title" },
    { "type": "text", "id": "hero_subtext", "label": "Subtext" }
  ],
  "blocks": [
    { "type": "award_badge", "name": "Marquee Badge", "settings": [{ "type": "image_picker", "id": "logo", "label": "Badge Image" }] },
    { "type": "year_group", "name": "Year Heading", "settings": [{ "type": "text", "id": "year", "label": "Year (e.g. 2025)" }] },
    { "type": "award_card", "name": "Award Card", "settings": [
      { "type": "text", "id": "parent_year", "label": "Parent Year (e.g. 2025)" },
      { "type": "text", "id": "emoji", "label": "Icon/Emoji" },
      { "type": "text", "id": "award_name", "label": "Award Name" },
      { "type": "text", "id": "award_title", "label": "Award Title" },
      { "type": "text", "id": "link_text", "label": "Link Text" },
      { "type": "url", "id": "link_url", "label": "Link URL" },
      { "type": "text", "id": "brand", "label": "Brand Name (if no link)" }
    ]}
  ],
  "presets": [{ "name": "Awards Layout" }]
}
{% endschema %}
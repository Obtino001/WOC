
  <section class="relative min-h-[80vh] grid lg:grid-cols-2">
    <div class="flex flex-col justify-center px-8 md:px-16 lg:px-20 py-20 bg-[#f0eae4]">
      <div style="opacity: 1; transform: none;">
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-light text-neutral-800 leading-tight uppercase tracking-[0.05em]">
          {{ section.settings.hero_title }}
        </h1>
        <div class="flex items-center gap-3 mt-10">
          <div class="w-8 h-px bg-gold"></div>
          <p class="font-body text-[11px] uppercase tracking-[0.25em] text-neutral-500">{{ section.settings.hero_subtext }}</p>
        </div>
      </div>
    </div>
    <div class="relative overflow-hidden min-h-[50vh] lg:min-h-0">
      {% if section.settings.hero_image != blank %}
        {{ section.settings.hero_image | image_url: width: 1200 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
      {% endif %}
    </div>
  </section>

  <!-- Marquee Awards -->
  <section class="py-12 bg-white overflow-hidden border-y border-neutral-100">
    <div class="flex animate-marquee whitespace-nowrap">
      {% for i in (1..3) %}
        <div class="flex items-center gap-12 mx-6">
          {% for block in section.blocks %}
            {% if block.type == 'award_logo' %}
              {{ block.settings.logo | image_url: width: 200 | image_tag: class: 'h-16 md:h-20 object-contain opacity-60' }}
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </section>

  <!-- Intro -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-3xl text-center">
      <p class="font-body text-[10px] uppercase tracking-[0.3em] text-gold mb-6">{{ section.settings.intro_pretitle }}</p>
      <h2 class="font-display text-2xl md:text-3xl font-light text-neutral-800 leading-relaxed mb-6">{{ section.settings.intro_text }}</h2>
    </div>
  </section>

  <!-- Yearly Awards Container -->
  {% for block in section.blocks %}
    {% if block.type == 'year_group' %}
      <section class="py-20 {% cycle 'bg-[#f8f7f4]', 'bg-white' %}">
        <div class="container mx-auto px-4 max-w-6xl">
          <div class="mb-14">
            <h2 class="font-display text-5xl md:text-7xl font-extralight text-neutral-200 uppercase tracking-[0.1em]">{{ block.settings.year }}</h2>
            <p class="font-body text-[11px] uppercase tracking-[0.2em] text-gold mt-2">ÖDÜLLER</p>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% comment %} Logic to pull specific awards would go here via child blocks or nested metafields {% endcomment %}
          </div>
        </div>
      </section>
    {% endif %}
  {% endfor %}

  <!-- Final CTA -->
  <section class="py-24 bg-neutral-900">
    <div class="container mx-auto px-4 max-w-2xl text-center">
      <p class="font-body text-[10px] uppercase tracking-[0.3em] text-gold mb-6">{{ section.settings.cta_pretitle }}</p>
      <h2 class="font-display text-3xl md:text-4xl font-light text-white mb-8">{{ section.settings.cta_title }}</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a class="inline-flex items-center justify-center py-2 bg-white hover:bg-neutral-100 text-neutral-900 uppercase tracking-[0.15em] text-[11px] rounded-none px-10 h-12" href="{{ section.settings.btn_1_url }}">{{ section.settings.btn_1_text }}</a>
        <a class="inline-flex items-center justify-center py-2 bg-transparent hover:bg-white/10 text-white border border-white/30 uppercase tracking-[0.15em] text-[11px] rounded-none px-10 h-12" href="{{ section.settings.btn_2_url }}">{{ section.settings.btn_2_text }}</a>
      </div>
    </div>
  </section>

{% schema %}
{
  "name": "Awards Page",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "text", "id": "hero_title", "label": "Title", "default": "Tanındı, Kutlandı ve Ödüllendirildi" },
    { "type": "text", "id": "hero_subtext", "label": "Subtext", "default": "Mükemmellik sicilimiz" },
    { "type": "text", "id": "intro_pretitle", "label": "Intro Pretitle" },
    { "type": "textarea", "id": "intro_text", "label": "Intro Text" },
    { "type": "text", "id": "cta_pretitle", "label": "CTA Pretitle" },
    { "type": "text", "id": "cta_title", "label": "CTA Title" },
    { "type": "text", "id": "btn_1_text", "label": "Button 1 Text" },
    { "type": "url", "id": "btn_1_url", "label": "Button 1 Link" },
    { "type": "text", "id": "btn_2_text", "label": "Button 2 Text" },
    { "type": "url", "id": "btn_2_url", "label": "Button 2 Link" }
  ],
  "blocks": [
    { "type": "award_logo", "name": "Award Logo", "settings": [{ "type": "image_picker", "id": "logo", "label": "Logo" }] },
    { "type": "year_group", "name": "Year Group", "settings": [{ "type": "text", "id": "year", "label": "Year" }] }
  ],
  "presets": [{ "name": "Awards Page Section" }]
}
{% endschema %}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="bg-background border-b border-border section-{{ section.id }}-padding">
  <div class="container mx-auto px-6 lg:px-12 max-w-5xl">
    
    <div class="text-center mb-16">
      <p class="font-body text-[10px] font-medium uppercase tracking-[0.25em] text-muted-foreground mb-3">{{ section.settings.kicker }}</p>
      <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl">{{ section.settings.heading }}</h2>
    </div>

    <div class="space-y-20">
      {% for block in section.blocks %}
        <div class="max-w-3xl mx-auto" {{ block.shopify_attributes }}>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-muted px-3 py-1 font-body text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground mb-4">
            <div class="[&>svg]:w-3 [&>svg]:h-3">{{ block.settings.tag_icon }}</div>
            {{ block.settings.tag_text }}
          </span>
          <h2 class="mb-4 font-display text-2xl font-semibold text-foreground md:text-3xl">{{ block.settings.title }}</h2>
          <p class="mb-6 font-body text-base leading-relaxed text-muted-foreground">{{ block.settings.description }}</p>
          <div class="inline-flex items-baseline gap-2 rounded-xl bg-card border border-border px-5 py-3">
            <span class="font-display text-2xl font-bold text-foreground">{{ block.settings.stat_value }}</span>
            <span class="font-body text-xs text-muted-foreground">{{ block.settings.stat_label }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Treadmill Value Props",
  "settings": [
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 8, "unit": "px", "label": "Padding Bottom", "default": 96 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "HEALTH BENEFITS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Feel the difference in your body" }
  ],
  "blocks": [
    {
      "type": "value_prop",
      "name": "Value Proposition",
      "settings": [
        { "type": "html", "id": "tag_icon", "label": "Tag Icon SVG" },
        { "type": "text", "id": "tag_text", "label": "Tag Text" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "stat_value", "label": "Stat Value" },
        { "type": "text", "id": "stat_label", "label": "Stat Label" }
      ]
    }
  ],
  "presets": [
    { "name": "Treadmill Value Props" }
  ]
}
{% endschema %}
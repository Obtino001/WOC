          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Paketi Ekle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Offers (Dark)",
      "blocks": [
        {
          "type": "bundle",
          "settings": {
            "title": "Komple Rahatlama Paketi",
            "subtitle": "Masaj Koltuğu + Boyun ve Omuz Masajer – %15 indirim",
            "item_1_name": "Boyun ve Omuz Masaj Aleti",
            "discount_percentage": 15
          }
        },
        {
          "type": "bundle",
          "settings": {
            "title": "Recovery Pro Paketi",
            "subtitle": "Masaj Tabancası Elite + İyileşme Kompresyon Kiti – %10 indirim",
            "item_1_name": "Pro Masaj Tabancası Elite",
            "item_2_name": "Recovery Kompresyon Kiti",
            "discount_percentage": 10
          }
        },
        {
          "type": "bundle",
          "settings": {
            "title": "Evde Spa Paketi",
            "subtitle": "Ayak Masaj Aleti + Göz Masaj Aleti + LED Yüz Maskesi – %20 indirim",
            "item_1_name": "Ayak Masaj Aleti Pro",
            "item_2_name": "Deluxe Göz Masaj Aleti",
            "item_3_name": "LED Yüz Maskesi Pro",
            "discount_percentage": 20
          }
        }
      ]
    }
  ]
}
{% endschema %}
<section class="woc-section-py bg-[#111111] relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    
    <!-- Top Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-[#db7622]/10 border border-[#db7622]/20 px-4 py-1.5 rounded-full mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 text-[#db7622]">
          <polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line>
        </svg>
        <span class="font-body text-[10px] font-bold text-[#db7622] uppercase tracking-wider">{{ section.settings.badge_text }}</span>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-3">{{ section.settings.heading }}</h2>
      <p class="font-body text-[#999] max-w-lg mx-auto">{{ section.settings.subheading }}</p>
    </div>

    <!-- Cards Grid -->
    <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {% for block in section.blocks %}
        {% assign product_list = block.settings.product_list %}
        
        <!-- Math Calculations for Discounts -->
        {% assign total_price = 0 %}
        {% assign variant_ids = '' %}
        
        {% if product_list != blank %}
          {% for prod in product_list %}
            {% assign total_price = total_price | plus: prod.price %}
            {% assign variant_ids = variant_ids | append: prod.selected_or_first_available_variant.id | append: ',' %}
          {% endfor %}
        {% else %}
           <!-- Fallback math for visual representation in theme editor if no products are selected -->
           {% assign total_price = 224900 %} 
        {% endif %}

        {% assign discount_multiplier = 100 | minus: block.settings.discount_percentage | divided_by: 100.0 %}
        {% assign discounted_price = total_price | times: discount_multiplier %}
        {% assign savings_amount = total_price | minus: discounted_price %}

        <div class="bg-[#1a1a1a] border border-[#333] rounded-xl overflow-hidden flex flex-col" {{ block.shopify_attributes }}>
          
          <!-- Orange Top Banner -->
          <div class="bg-[#db7622] px-4 py-3 text-center">
            {% if block.settings.discount_percentage > 0 %}
              <span class="font-body text-[11px] font-bold text-white uppercase tracking-wider">
                TASARRUF %{{ block.settings.discount_percentage }} — {{ savings_amount | money_without_trailing_zeros }}
              </span>
            {% else %}
              <span class="font-body text-[11px] font-bold text-white uppercase tracking-wider">PAKET TEKLİFİ</span>
            {% endif %}
          </div>
          
          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-display text-xl text-white mb-2">{{ block.settings.title }}</h3>
            <p class="font-body text-xs text-[#888] mb-6 leading-relaxed">{{ block.settings.subtitle }}</p>
            
            <div class="space-y-3 mb-6 flex-1">
              {% if product_list != blank %}
                {% for prod in product_list %}
                  <div class="flex items-center gap-4 p-3 bg-[#222] rounded-lg border border-[#333]/50">
                    <div class="w-10 h-10 rounded-md bg-[#1a1a1a] flex-shrink-0 flex items-center justify-center overflow-hidden">
                      {% if prod.featured_image %}
                        {{ prod.featured_image | image_url: width: 80 | image_tag: class: 'w-full h-full object-contain p-1' }}
                      {% else %}
                        <svg class="w-5 h-5 text-[#555]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                      {% endif %}
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-body text-[13px] font-medium text-[#ddd] line-clamp-1">{{ prod.title }}</p>
                      <p class="font-body text-[11px] text-[#666] mt-0.5">{{ prod.price | money_without_trailing_zeros }}</p>
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <!-- Fallback manual items if no product list is selected -->
                {% for i in (1..3) %}
                  {% capture item_name_key %}item_{{ i }}_name{% endcapture %}
                  {% assign item_name = block.settings[item_name_key] %}
                  
                  {% if item_name != blank %}
                    <div class="flex items-center gap-4 p-3 bg-[#222] rounded-lg border border-[#333]/50">
                      <div class="w-10 h-10 rounded-md bg-[#1a1a1a] flex-shrink-0 flex items-center justify-center">
                        <svg class="w-5 h-5 text-[#555]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="font-body text-[13px] font-medium text-[#ddd] line-clamp-1">{{ item_name }}</p>
                        <p class="font-body text-[11px] text-[#666] mt-0.5">₺0</p>
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>

            <!-- Total Price Row -->
            <div class="flex items-baseline gap-2 mb-4 mt-auto">
              <span class="font-display text-2xl font-bold text-white">{{ discounted_price | money_without_trailing_zeros }}</span>
              {% if block.settings.discount_percentage > 0 %}
                <span class="font-body text-xs text-[#777] line-through">{{ total_price | money_without_trailing_zeros }}</span>
              {% endif %}
            </div>
            
            <!-- Button -->
            <button type="button" 
                    onclick="addBundleToCart('{{ variant_ids }}')"
                    class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm bg-[#db7622] hover:bg-[#c2681e] text-white font-body font-semibold h-11 px-4 py-2 w-full transition-all duration-300 rounded-md">
              {{ block.settings.button_text | default: 'Paketi Ekle' }} 
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
            
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  function addBundleToCart(variantIdsString) {
    const ids = variantIdsString.split(',').filter(id => id.trim() !== '');
    if (ids.length === 0) {
      alert('Lütfen bu pakete eklenecek ürünleri seçin.');
      return;
    }

    const items = ids.map(id => ({
      id: parseInt(id),
      quantity: 1
    }));

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ items: items })
    })
    .then(response => response.json())
    .then(data => {
      // Refresh or trigger mini-cart
      if (document.querySelector('cart-drawer')) {
        document.querySelector('cart-drawer').classList.remove('is-empty');
        window.location.href = window.Shopify.routes.root + 'cart';
      } else {
        window.location.href = window.Shopify.routes.root + 'cart';
      }
    })
    .catch((error) => {
      console.error('Error:', error);
      alert('Sepete eklerken bir hata oluştu.');
    });
  }
</script>

{% schema %}
{
  "name": "Bundle Offers (Dark)",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "PAKET TEKLİFLERİ"

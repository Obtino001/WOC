    "faq": {
      "type": "smart-beds-faq",
      "blocks": {
        "q1": {
          "type": "faq",
          "settings": {
            "question": "Why is the right bed so important for my health?",
            "answer": "<p>You spend about a third of your life in bed. A bed that doesn't fit your body can cause back pain, neck pain, poor sleep quality, and even affect your mood, energy levels, and immune system.</p>"
          }
        },
        "q2": {
          "type": "faq",
          "settings": {
            "question": "What is an AI mattress, and how does it work?",
            "answer": "<p>An AI mattress uses sensors and intelligent software to analyse your body and automatically adjust support. Our AI mattresses scan your body's pressure distribution and adapt the firmness in several independent zones.</p>"
          }
        }
      },

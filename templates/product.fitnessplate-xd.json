      "type": "fp-info-cards",
      "blocks": {
        "c1": {
          "type": "card",
          "settings": {
            "title": "Why do legs swell?",
            "description": "The lymphatic system has no pump of its own — it depends on muscle contractions to transport fluid. When you sit still, the system stagnates and fluid collects in your legs and feet. This causes heaviness, soreness and visible swelling.",
            "stat_val": "80%",
            "stat_label": "of swelling caused by inactivity"
          }
        },
        "c2": {
          "type": "card",
          "settings": {
            "title": "How does lymphatic training help?",
            "description": "The FitnessPlate XD creates hundreds of muscle contractions per minute via 3 XD motors. This activates lymph nodes throughout the body and pumps excess fluid back into circulation — 150% more effective than walking alone.",
            "stat_val": "150%",
            "stat_label": "increased lymph drainage"
          }
        },
        "c3": {
          "type": "card",
          "settings": {

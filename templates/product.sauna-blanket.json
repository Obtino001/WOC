    "steps": {
      "type": "woc-steps",
      "blocks": {
        "step_1": { 
          "type": "step", 
          "settings": { 
            "number": "1", 
            "title": "Gør dit saunatæppe klar", 
            "description": "Placér dit Nordic Sauna Blanket på en behagelig overflade som f.eks. din seng, en madras eller en sofa, og rul det ud. Indstil tæppet til den ønskede varme ved hjælp af controlleren." 
          } 
        },
        "step_2": { 
          "type": "step", 
          "settings": { 
            "number": "2", 
            "title": "Mærk forskellen", 
            "description": "Nyd din behandling veltilpas i 20-60 minutter. Du vil begynde at mærke varmen brede sig dybt ind i kroppen. Modtag de mange fordele og mærk forskellen." 
          } 
        },
        "step_3": { 
          "type": "step", 
          "settings": { 
            "number": "3", 
            "title": "Efter sessionen", 
            "description": "Lad saunatæppet køle ned og tør forsigtigt indersiden af med en klud. Tæppet er fuldstændig vandafvisende, hvilket gør det nemt at tørre sveden af." 
          } 
        }
      },

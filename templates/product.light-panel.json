        "block_7_tech_specs": {
          "type": "tech_specs",
          "settings": {
            "heading": "Teknik Özellikler",
            "table_html": "<div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Model</span><span class=\"font-body text-sm text-muted-foreground\">Kırmızı Işık Paneli 300 İki Dalga</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Dalga Boyları</span><span class=\"font-body text-sm text-muted-foreground\">480nm · 630nm · 660nm · 810nm · 830nm · 850nm · 1060nm</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Parlaklık</span><span class=\"font-body text-sm text-muted-foreground\">7 dalga boyu ayrı ayrı kontrol edilebilir (%0-100)</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Kısılabilir</span><span class=\"font-body text-sm text-muted-foreground\">0% – 100%</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">LED'ler</span><span class=\"font-body text-sm text-muted-foreground\">60 × 5W</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Işın Açısı</span><span class=\"font-body text-sm text-muted-foreground\">30°</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Güç Tüketimi</span><span class=\"font-body text-sm text-muted-foreground\">99W</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Titreşim</span><span class=\"font-body text-sm text-muted-foreground\">Her NIR dalga boyu için ayrı ayrı kontrol edilebilir (0-9999 Hz)</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Zamanlayıcı</span><span class=\"font-body text-sm text-muted-foreground\">1-30 dakika ayarlanabilir</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Boyutlar</span><span class=\"font-body text-sm text-muted-foreground\">26.9 × 23 × 6.6 cm</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Ağırlık</span><span class=\"font-body text-sm text-muted-foreground\">3.8 kg / 8.4 lbs</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Soğutma Fanları</span><span class=\"font-body text-sm text-muted-foreground\">1 adet</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Amper @220V</span><span class=\"font-body text-sm text-muted-foreground\">0.48A</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Amper @110V</span><span class=\"font-body text-sm text-muted-foreground\">0.95A</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">LED Ömrü</span><span class=\"font-body text-sm text-muted-foreground\">50.000 saat</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">EMF</span><span class=\"font-body text-sm text-muted-foreground\">İhmal Edilebilir</span></div><div class=\"grid grid-cols-2 px-6 py-3.5 border-b border-border\"><span class=\"font-body text-sm font-semibold text-foreground\">Maksimum Kapsama Alanı</span><span class=\"font-body tex
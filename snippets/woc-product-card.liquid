{%- comment -%}
  Accepts:
  - product: {Object} Product Liquid object
  - card_color_scheme: {String} Color scheme ID (optional)
  - badge_override: {String} Optional manual badge text to override metafields
  - status_label_override: {String} Optional manual status label text
  - tagline_override: {String} Optional short description override
  - features_override: {String} Optional comma-separated features list
{%- endcomment -%}

<div class="color-{{ card_color_scheme | default: 'scheme-2' }} group flex flex-col rounded-sm overflow-hidden hover:shadow-[0_0_20px_rgba(216,178,97,0.15)] transition-all duration-500 h-full">
  <a class="block" href="{{ product.url }}">
    <div class="relative aspect-square overflow-hidden" style="background-color: transparent;">
      {% if product.featured_image != blank %}
        {{ product.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-contain p-6 transition-transform duration-700 group-hover:scale-105', loading: 'lazy' }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-contain p-6 bg-gray-100' }}
      {% endif %}
      
      {% if badge_override != blank %}
        <span class="absolute top-4 left-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ badge_override }}</span>
      {% elsif product.metafields.custom.product_tags != blank %}
         <span class="absolute top-4 left-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">{{ product.metafields.custom.product_tags }}</span>
      {% elsif product.tags contains 'New' %}
         <span class="absolute top-4 left-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">New</span>
      {% elsif product.tags contains 'Award' %}
         <span class="absolute top-4 left-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">Award-Winning</span>
      {% elsif product.tags contains 'Flagship' %}
         <span class="absolute top-4 left-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">Flagship</span>
      {% elsif product.tags contains 'Top Seller' %}
         <span class="absolute top-4 left-4 z-10 bg-gold text-background font-body text-[10px] font-semibold px-3 py-1.5 uppercase tracking-widest rounded-sm">Top Seller</span>
      {% endif %}

      {%- if product.compare_at_price > product.price -%}
        {%- assign save_amount = product.compare_at_price | minus: product.price | money_without_trailing_zeros -%}
        <span class="absolute top-4 right-4 z-10 bg-red-600 text-white font-body text-[10px] font-bold px-2.5 py-1.5 rounded-sm">
          Spar {{ save_amount }}
        </span>
      {%- endif -%}
    </div>
  </a>

  {% if status_label_override != blank %}
     <div class="bg-red-900/20 border-t border-red-900/30 px-4 py-2 text-center">
        <span class="font-body text-[11px] font-semibold text-red-500">{{ status_label_override }}</span>
     </div>
  {% elsif product.metafields.custom.promo_banner != blank %}
     <div class="bg-sale-red/10 border-t border-sale-red/20 px-4 py-2 text-center">
        <span class="font-body text-[11px] font-semibold text-sale-red">{{ product.metafields.custom.promo_banner }}</span>
     </div>
  {% endif %}

  <div class="p-5 lg:p-6 flex flex-col flex-1">
    <div class="flex items-center gap-1 mb-2">
      {% for i in (1..5) %}
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
      {% endfor %}
      <span class="font-body text-[10px] ml-1 opacity-70">
        {% if product.metafields.custom.reviews != blank %}
          {{ product.metafields.custom.reviews }}
        {% else %}
          {{ product.metafields.reviews.rating.value | default: '4.8' }} ({{ product.metafields.reviews.rating_count.value | default: '102' }})
        {% endif %}
      </span>
    </div>
    
    <a href="{{ product.url }}">
      <h3 class="font-display text-2xl lg:text-3xl font-normal mb-2 hover:text-gold transition-colors">{{ product.title }}</h3>
    </a>
    
    <p class="font-body text-xs lg:text-sm mb-4 line-clamp-2 leading-relaxed opacity-60">
      {%- if tagline_override != blank -%}{{ tagline_override }}{%- elsif product.metafields.custom.short_description != blank -%}{{ product.metafields.custom.short_description }}{%- else -%}{{ product.description | strip_html | truncatewords: 10 }}{%- endif -%}
    </p>

    <div class="flex flex-wrap gap-1.5 mb-3">
      {% assign features = '' %}
      {% if product.metafields.custom.products_usps != blank %}
        {% assign features = product.metafields.custom.products_usps.value %}
      {% elsif features_override != blank %}
        {% assign features = features_override | split: ',' %}
      {% endif %}

      {% if features != blank and features.size > 0 %}
        {% for feature in features %}
          {% assign usp_lower = feature | downcase %}
          {% assign icon_svg = '' %}

          {% if usp_lower contains 'zero gravity' or usp_lower contains 'sıfır yer çekimi' or usp_lower contains 'sıfır yerçekimi' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gauge w-3 h-3 text-gold flex-shrink-0"><path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg>{% endcapture %}
          {% elsif usp_lower contains 'scan' or usp_lower contains 'air' or usp_lower contains 'tarama' or usp_lower contains 'hava' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-scan w-3 h-3 text-gold flex-shrink-0"><path d="M3 7V5a2 2 0 0 1 2-2h2"></path><path d="M17 3h2a2 2 0 0 1 2 2v2"></path><path d="M21 17v2a2 2 0 0 1-2 2h-2"></path><path d="M7 21H5a2 2 0 0 1-2-2v-2"></path></svg>{% endcapture %}
          {% elsif usp_lower contains 'roller' or usp_lower contains 'xd massage' or usp_lower contains '3d massage' or usp_lower contains 'sl-track' or usp_lower contains 'dual-core' or usp_lower contains 'silindir' or usp_lower contains 'xd masaj' or usp_lower contains '3d masaj' or usp_lower contains 'sl-ray' or usp_lower contains 'çift çekirdekli' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-waves w-3 h-3 text-gold flex-shrink-0"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"></path></svg>{% endcapture %}
          {% elsif usp_lower contains 'stretch' or usp_lower contains 'footrest' or usp_lower contains 'esneme' or usp_lower contains 'ayaklık' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity w-3 h-3 text-gold flex-shrink-0"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg>{% endcapture %}
          {% elsif usp_lower contains 'percussion' or usp_lower contains 'tissue' or usp_lower contains 'perküsyon' or usp_lower contains 'doku' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap w-3 h-3 text-gold flex-shrink-0"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg>{% endcapture %}
          {% elsif usp_lower contains 'heat' or usp_lower contains 'ısı' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flame w-3 h-3 text-gold flex-shrink-0"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path></svg>{% endcapture %}
          {% elsif usp_lower contains 'bluetooth' or usp_lower contains 'sound' or usp_lower contains 'ses' %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ear w-3 h-3 text-gold flex-shrink-0"><path d="M6 8.5a6.5 6.5 0 1 1 13 0c0 6-6 6-6 10a3.5 3.5 0 1 1-7 0"></path><path d="M15 8.5a2.5 2.5 0 0 0-5 0v1a2 2 0 1 1 0 4"></path></svg>{% endcapture %}
          {% else %}
            {% capture icon_svg %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-3 h-3 text-gold flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>{% endcapture %}
          {% endif %}

          <div class="flex items-center gap-1.5 bg-foreground/[0.04] rounded-sm px-2.5 py-1.5">
            {{ icon_svg }}
            <span class="font-body text-[11px] text-foreground/80 whitespace-nowrap">{{ feature | strip }}</span>
          </div>
        {% endfor %}
      {% else %}
         <!-- Fallback Features if empty -->
         <div class="flex items-center gap-1.5 bg-foreground/[0.04] rounded-sm px-2.5 py-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-3 h-3 text-gold flex-shrink-0"><path d="M20 6 9 17l-5-5"></path></svg>
            <span class="font-body text-[11px] text-foreground/80 whitespace-nowrap">XD Massage Technology</span>
         </div>
         <div class="flex items-center gap-1.5 bg-foreground/[0.04] rounded-sm px-2.5 py-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gauge w-3 h-3 text-gold flex-shrink-0"><path d="m12 14 4-4"></path><path d="M3.34 19a10 10 0 1 1 17.32 0"></path></svg>
            <span class="font-body text-[11px] text-foreground/80 whitespace-nowrap">Zero Gravity</span>
         </div>
      {% endif %}
    </div>

    <div class="flex flex-wrap gap-1.5 mb-5">
      <div class="flex items-center gap-1.5 bg-[#eaf4ec] rounded-sm px-2.5 py-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 text-[#2e7d32] flex-shrink-0"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path><path d="M15 18H9"></path><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"></path><circle cx="17" cy="18" r="2"></circle><circle cx="7" cy="18" r="2"></circle></svg>
        <span class="font-body text-[11px] text-[#2e7d32] font-semibold whitespace-nowrap">Ücretsiz kargo</span>
      </div>
      <div class="flex items-center gap-1.5 bg-gold/10 rounded-sm px-2.5 py-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 text-gold flex-shrink-0"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
        <span class="font-body text-[11px] text-gold font-semibold whitespace-nowrap">5 yıl garanti</span>
      </div>
    </div>

    <div class="mt-auto pt-4 border-t border-border/40">
      <div class="flex items-baseline gap-2 mb-1">
        <span class="font-display text-2xl lg:text-3xl font-normal">{{ product.price | money }}</span>
      </div>
      {% assign weekly_price = product.price | divided_by: 52 %}
      <p class="font-body text-[12px] text-gold font-medium mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 inline mr-1"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg>
        {{ weekly_price | money_without_trailing_zeros }} / haftadan itibaren
      </p>
      
      <div class="flex items-center gap-1.5 mb-5">
        {% if product.available %}
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#2e7d32] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#2e7d32]"></span>
          </span>
          <span class="font-body text-[11px] text-[#2e7d32] font-semibold">Stokta · 1-2 gün ücretsiz teslimat</span>
        {% else %}
           <span class="relative flex h-2 w-2 bg-amber-500 rounded-full"></span>
           <span class="font-body text-[11px] text-amber-700 font-semibold">Out of stock</span>
        {% endif %}
      </div>
      
      <div class="flex gap-2">
        <a href="{{ product.url }}" class="inline-flex items-center justify-center whitespace-nowrap bg-[#c78b30] text-white font-bold hover:bg-[#b07b2a] transition-all duration-500 tracking-widest uppercase h-11 px-4 flex-1 gap-1.5 text-xs rounded-sm">
          DAHA FAZLASINI GÖR <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a href="/pages/showrooms" class="inline-flex items-center justify-center whitespace-nowrap font-bold border h-11 px-4 gap-1.5 text-xs border-[#c78b30] text-[#c78b30] hover:bg-[#c78b30]/10 transition-all duration-500 rounded-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M16 2v4"></path><path d="M8 2v4"></path><path d="M3 10h18"></path></svg> Deneyin
        </a>
      </div>
    </div>
    
  </div>
</div>

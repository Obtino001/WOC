<div class="flex-shrink-0 w-[320px] md:w-[360px] bg-card border border-border hover:border-gold/20 transition-colors duration-500 p-6 mx-2" {{ block.shopify_attributes }}>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-5 h-5 text-gold/20 mb-3"><path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path><path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z"></path></svg>
  <div class="flex gap-0.5 mb-3">
    {% for i in (1..5) %}
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3 h-3 fill-gold text-gold"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
    {% endfor %}
  </div>
  <p class="font-body text-xs font-light text-foreground/80 leading-[1.8] mb-4 italic line-clamp-4">"{{ block.settings.quote }}"</p>
  <div>
    <p class="font-display text-xs font-medium text-foreground">{{ block.settings.author }}</p>
    <p class="font-body text-[9px] uppercase tracking-luxury text-muted-foreground">{{ block.settings.product }}</p>
  </div>
</div>
